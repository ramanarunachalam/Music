11,26,27,8,33,32,28,16,17,36,18,7,35,21,20,29,30,34,23,25,24", "odia": "3,0,4,5,6,37,19,15,22,2,1,13,14,12,9,10,31,11,26,27,8,33,32,28,16,17,36,18,7,35,21,20,29,30,34,23,25,24", "assamese": "3,0,4,5,6,37,19,15,22,2,1,13,14,12,9,10,31,11,26,27,8,33,32,28,16,17,36,18,7,29,30,35,20,21,34,23,25,24"}, "lyricstext": [{"L": "English", "text": [{"M": "pallavi", "T": "ambA nIlAyatAkshI karuNA kaTAkshi <br/> akhila lOka sAkshi kaTAksi"}, {"M": "anupallavi", "T": "bimbAdhari citpratibimbAdhari <br/> bindunAda vaSankari Sankari"}, {"M": "madhyamakAla sAhityam", "T": "ambujA ramaNa sOdari atirathi <br/> ambari kAdambari nIlAmbari"}, {"M": "caraNam", "T": "Siva rAjadhAnI kshEtra vAsini Sritajana viSvAsini <br/> Siva kAyArOhaNESOllAsini cidrUpa vilAsini <br/> navayOgini cakra vikAsini navarasa darahAsini <br/> suvarNamaya vigraha prakASini suvarNamaya hAsini"}, {"M": "madhyamakAla sAhityam", "T": "bhuvanOdaya sthitilaya vinOdini <br/> bhuvanESvari kshipra prasAdini <br/> navamANikya vallakI vAdini <br/> bhava guruguha vEdini sammOdini"}]}, {"L": "Tamil", "text": [{"M": "\u0baa\u0bb2\u0bcd\u0bb2\u0bb5\u0bbf", "T": "\u0b85\u0bae\u0bcd\u0baa\u0bbe \u0ba8\u0bc0\u0bb2\u0bbe\u0baf\u0ba4\u0bbe\u0b95\u0bcd\u0bb7\u0bc0 \u0b95\u0bb0\u0bc1\u0ba3\u0bbe \u0b95\u0b9f\u0bbe\u0b95\u0bcd\u0bb7\u0bbf <br/> \u0b85\u0b95\u0bbf\u0bb2 \u0bb2\u0bcb\u0b95 \u0b9a\u0bbe\u0b95\u0bcd\u0bb7\u0bbf \u0b95\u0b9f\u0bbe\u0b95\u0bcd\u0b9a\u0bbf"}, {"M": "\u0b85\u0ba9\u0bc1\u0baa\u0bb2\u0bcd\u0bb2\u0bb5\u0bbf", "T": "\u0baa\u0bbf\u0bae\u0bcd\u0baa\u0bbe\u0ba4\u0bb0\u0bbf \u0b9a\u0bbf\u0ba4\u0bcd\u0baa\u0bcd\u0bb0\u0ba4\u0bbf\u0baa\u0bbf\u0bae\u0bcd\u0baa\u0bbe\u0ba4\u0bb0\u0bbf <br/> \u0baa\u0bbf\u0ba8\u0bcd\u0ba4\u0bc1\u0ba9\u0bbe\u0ba4 \u0bb5\u0b9a\u0b99\u0bcd\u0b95\u0bb0\u0bbf \u0b9a\u0b99\u0bcd\u0b95\u0bb0\u0bbf"}, {"M": "\u0bae\u0ba4\u0bcd\u0baf\u0bae\u0b95\u0bbe\u0bb2 \u0b9a\u0bbe\u0bb9\u0bbf\u0ba4\u0bcd\u0baf\u0bae\u0bcd", "T": "\u0b85\u0bae\u0bcd\u0baa\u0bc1\u0b9c\u0bbe \u0bb0\u0bae\u0ba3 \u0b9a\u0bcb\u0ba4\u0bb0\u0bbf \u0b85\u0ba4\u0bbf\u0bb0\u0ba4\u0bbf <br/> \u0b85\u0bae\u0bcd\u0baa\u0bb0\u0bbf \u0b95\u0bbe\u0ba4\u0bae\u0bcd\u0baa\u0bb0\u0bbf \u0ba8\u0bc0\u0bb2\u0bbe\u0bae\u0bcd\u0baa\u0bb0\u0bbf"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd", "T": "\u0b9a\u0bbf\u0bb5 \u0bb0\u0bbe\u0b9c\u0ba4\u0bbe\u0ba9\u0bc0 \u0b95\u0bcd\u0bb7\u0bc7\u0ba4\u0bcd\u0bb0 \u0bb5\u0bbe\u0b9a\u0bbf\u0ba9\u0bbf \u0bb6\u0bcd\u0bb0\u0bbf\u0ba4\u0b9c\u0ba9 \u0bb5\u0bbf\u0bb6\u0bcd\u0bb5\u0bbe\u0b9a\u0bbf\u0ba9\u0bbf <br/> \u0b9a\u0bbf\u0bb5 \u0b95\u0bbe\u0baf\u0bbe\u0bb0\u0bcb\u0bb9\u0ba3\u0bc7\u0b9a\u0bcb\u0bb2\u0bcd\u0bb2\u0bbe\u0b9a\u0bbf\u0ba9\u0bbf \u0b9a\u0bbf\u0ba4\u0bcd\u0bb0\u0bc2\u0baa \u0bb5\u0bbf\u0bb2\u0bbe\u0b9a\u0bbf\u0ba9\u0bbf <br/> \u0ba8\u0bb5\u0baf\u0bcb\u0b95\u0bbf\u0ba9\u0bbf \u0b9a\u0b95\u0bcd\u0bb0 \u0bb5\u0bbf\u0b95\u0bbe\u0b9a\u0bbf\u0ba9\u0bbf \u0ba8\u0bb5\u0bb0\u0b9a \u0ba4\u0bb0\u0bb9\u0bbe\u0b9a\u0bbf\u0ba9\u0bbf <br/> \u0b9a\u0bc1\u0bb5\u0bb0\u0bcd\u0ba3\u0bae\u0baf \u0bb5\u0bbf\u0b95\u0bcd\u0bb0\u0bb9 \u0baa\u0bcd\u0bb0\u0b95\u0bbe\u0b9a\u0bbf\u0ba9\u0bbf \u0b9a\u0bc1\u0bb5\u0bb0\u0bcd\u0ba3\u0bae\u0baf \u0bb9\u0bbe\u0b9a\u0bbf\u0ba9\u0bbf"}, {"M": "\u0bae\u0ba4\u0bcd\u0baf\u0bae\u0b95\u0bbe\u0bb2 \u0b9a\u0bbe\u0bb9\u0bbf\u0ba4\u0bcd\u0baf\u0bae\u0bcd", "T": "\u0baa\u0bc1\u0bb5\u0ba9\u0bcb\u0ba4\u0baf \u0bb8\u0bcd\u0ba4\u0bbf\u0ba4\u0bbf\u0bb2\u0baf \u0bb5\u0bbf\u0ba9\u0bcb\u0ba4\u0bbf\u0ba9\u0bbf <br/> \u0baa\u0bc1\u0bb5\u0ba9\u0bc7\u0bb6\u0bcd\u0bb5\u0bb0\u0bbf \u0b95\u0bcd\u0bb7\u0bbf\u0baa\u0bcd\u0bb0 \u0baa\u0bcd\u0bb0\u0b9a\u0bbe\u0ba4\u0bbf\u0ba9\u0bbf <br/> \u0ba8\u0bb5\u0bae\u0bbe\u0ba3\u0bbf\u0b95\u0bcd\u0baf \u0bb5\u0bb2\u0bcd\u0bb2\u0b95\u0bc0 \u0bb5\u0bbe\u0ba4\u0bbf\u0ba9\u0bbf <br/> \u0baa\u0bb5 \u0b95\u0bc1\u0bb0\u0bc1\u0b95\u0bc1\u0bb9 \u0bb5\u0bc7\u0ba4\u0bbf\u0ba9\u0bbf \u0b9a\u0bae\u0bcd\u0bae\u0bcb\u0ba4\u0bbf\u0ba9\u0bbf"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c05\u0c2e\u0c4d\u0c2c\u0c3e \u0c28\u0c40\u0c32\u0c3e\u0c2f\u0c24\u0c3e\u0c15\u0c4d\u0c37\u0c40 \u0c15\u0c30\u0c41\u0c23\u0c3e \u0c15\u0c1f\u0c3e\u0c15\u0c4d\u0c37\u0c3f <br/> \u0c05\u0c16\u0c3f\u0c32 \u0c32\u0c4b\u0c15 \u0c38\u0c3e\u0c15\u0c4d\u0c37\u0c3f \u0c15\u0c1f\u0c3e\u0c15\u0c4d\u0c38\u0c3f"}, {"M": "\u0c05\u0c28\u0c41\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c2c\u0c3f\u0c2e\u0c4d\u0c2c\u0c3e\u0c27\u0c30\u0c3f \u0c1a\u0c3f\u0c24\u0c4d\u0c2a\u0c4d\u0c30\u0c24\u0c3f\u0c2c\u0c3f\u0c2e\u0c4d\u0c2c\u0c3e\u0c27\u0c30\u0c3f <br/> \u0c2c\u0c3f\u0c28\u0c4d\u0c26\u0c41\u0c28\u0c3e\u0c26 \u0c35\u0c36\u0c02\u0c15\u0c30\u0c3f \u0c36\u0c02\u0c15\u0c30\u0c3f"}, {"M": "\u0c2e\u0c27\u0c4d\u0c2f\u0c2e\u0c15\u0c3e\u0c32 \u0c38\u0c3e\u0c39\u0c3f\u0c24\u0c4d\u0c2f\u0c2e\u0c4d", "T": "\u0c05\u0c2e\u0c4d\u0c2c\u0c41\u0c1c\u0c3e \u0c30\u0c2e\u0c23 \u0c38\u0c4b\u0c26\u0c30\u0c3f \u0c05\u0c24\u0c3f\u0c30\u0c25\u0c3f <br/> \u0c05\u0c2e\u0c4d\u0c2c\u0c30\u0c3f \u0c15\u0c3e\u0c26\u0c2e\u0c4d\u0c2c\u0c30\u0c3f \u0c28\u0c40\u0c32\u0c3e\u0c2e\u0c4d\u0c2c\u0c30\u0c3f"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c36\u0c3f\u0c35 \u0c30\u0c3e\u0c1c\u0c27\u0c3e\u0c28\u0c40 \u0c15\u0c4d\u0c37\u0c47\u0c24\u0c4d\u0c30 \u0c35\u0c3e\u0c38\u0c3f\u0c28\u0c3f \u0c36\u0c4d\u0c30\u0c3f\u0c24\u0c1c\u0c28 \u0c35\u0c3f\u0c36\u0c4d\u0c35\u0c3e\u0c38\u0c3f\u0c28\u0c3f <br/> \u0c36\u0c3f\u0c35 \u0c15\u0c3e\u0c2f\u0c3e\u0c30\u0c4b\u0c39\u0c23\u0c47\u0c36\u0c4b\u0c32\u0c4d\u0c32\u0c3e\u0c38\u0c3f\u0c28\u0c3f \u0c1a\u0c3f\u0c26\u0c4d\u0c30\u0c42\u0c2a \u0c35\u0c3f\u0c32\u0c3e\u0c38\u0c3f\u0c28\u0c3f <br/> \u0c28\u0c35\u0c2f\u0c4b\u0c17\u0c3f\u0c28\u0c3f \u0c1a\u0c15\u0c4d\u0c30 \u0c35\u0c3f\u0c15\u0c3e\u0c38\u0c3f\u0c28\u0c3f \u0c28\u0c35\u0c30\u0c38 \u0c26\u0c30\u0c39\u0c3e\u0c38\u0c3f\u0c28\u0c3f <br/> \u0c38\u0c41\u0c35\u0c30\u0c4d\u0c23\u0c2e\u0c2f \u0c35\u0c3f\u0c17\u0c4d\u0c30\u0c39 \u0c2a\u0c4d\u0c30\u0c15\u0c3e\u0c36\u0c3f\u0c28\u0c3f \u0c38\u0c41\u0c35\u0c30\u0c4d\u0c23\u0c2e\u0c2f \u0c39\u0c3e\u0c38\u0c3f\u0c28\u0c3f"}, {"M": "\u0c2e\u0c27\u0c4d\u0c2f\u0c2e\u0c15\u0c3e\u0c32 \u0c38\u0c3e\u0c39\u0c3f\u0c24\u0c4d\u0c2f\u0c2e\u0c4d", "T": "\u0c2d\u0c41\u0c35\u0c28\u0c4b\u0c26\u0c2f \u0c38\u0c4d\u0c25\u0c3f\u0c24\u0c3f\u0c32\u0c2f \u0c35\u0c3f\u0c28\u0c4b\u0c26\u0c3f\u0c28\u0c3f <br/> \u0c2d\u0c41\u0c35\u0c28\u0c47\u0c36\u0c4d\u0c35\u0c30\u0c3f \u0c15\u0c4d\u0c37\u0c3f\u0c2a\u0c4d\u0c30 \u0c2a\u0c4d\u0c30\u0c38\u0c3e\u0c26\u0c3f\u0c28\u0c3f <br/> \u0c28\u0c35\u0c2e\u0c3e\u0c23\u0c3f\u0c15\u0c4d\u0c2f \u0c35\u0c32\u0c4d\u0c32\u0c15\u0c40 \u0c35\u0c3e\u0c26\u0c3f\u0c28\u0c3f <br/> \u0c2d\u0c35 \u0c17\u0c41\u0c30\u0c41\u0c17\u0c41\u0c39 \u0c35\u0c47\u0c26\u0c3f\u0c28\u0c3f \u0c38\u0c2e\u0c4d\u0c2e\u0c4b\u0c26\u0c3f\u0c28\u0c3f"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0c85\u0cae\u0ccd\u0cac\u0cbe \u0ca8\u0cc0\u0cb2\u0cbe\u0caf\u0ca4\u0cbe\u0c95\u0ccd\u0cb7\u0cc0 \u0c95\u0cb0\u0cc1\u0ca3\u0cbe \u0c95\u0c9f\u0cbe\u0c95\u0ccd\u0cb7\u0cbf <br/> \u0c85\u0c96\u0cbf\u0cb2 \u0cb2\u0ccb\u0c95 \u0cb8\u0cbe\u0c95\u0ccd\u0cb7\u0cbf \u0c95\u0c9f\u0cbe\u0c95\u0ccd\u0cb8\u0cbf"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cac\u0cbf\u0cae\u0ccd\u0cac\u0cbe\u0ca7\u0cb0\u0cbf \u0c9a\u0cbf\u0ca4\u0ccd\u0caa\u0ccd\u0cb0\u0ca4\u0cbf\u0cac\u0cbf\u0cae\u0ccd\u0cac\u0cbe\u0ca7\u0cb0\u0cbf <br/> \u0cac\u0cbf\u0ca8\u0ccd\u0ca6\u0cc1\u0ca8\u0cbe\u0ca6 \u0cb5\u0cb6\u0c82\u0c95\u0cb0\u0cbf \u0cb6\u0c82\u0c95\u0cb0\u0cbf"}, {"M": "\u0cae\u0ca7\u0ccd\u0caf\u0cae\u0c95\u0cbe\u0cb2 \u0cb8\u0cbe\u0cb9\u0cbf\u0ca4\u0ccd\u0caf\u0cae\u0ccd", "T": "\u0c85\u0cae\u0ccd\u0cac\u0cc1\u0c9c\u0cbe \u0cb0\u0cae\u0ca3 \u0cb8\u0ccb\u0ca6\u0cb0\u0cbf \u0c85\u0ca4\u0cbf\u0cb0\u0ca5\u0cbf <br/> \u0c85\u0cae\u0ccd\u0cac\u0cb0\u0cbf \u0c95\u0cbe\u0ca6\u0cae\u0ccd\u0cac\u0cb0\u0cbf \u0ca8\u0cc0\u0cb2\u0cbe\u0cae\u0ccd\u0cac\u0cb0\u0cbf"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0cb6\u0cbf\u0cb5 \u0cb0\u0cbe\u0c9c\u0ca7\u0cbe\u0ca8\u0cc0 \u0c95\u0ccd\u0cb7\u0cc7\u0ca4\u0ccd\u0cb0 \u0cb5\u0cbe\u0cb8\u0cbf\u0ca8\u0cbf \u0cb6\u0ccd\u0cb0\u0cbf\u0ca4\u0c9c\u0ca8 \u0cb5\u0cbf\u0cb6\u0ccd\u0cb5\u0cbe\u0cb8\u0cbf\u0ca8\u0cbf <br/> \u0cb6\u0cbf\u0cb5 \u0c95\u0cbe\u0caf\u0cbe\u0cb0\u0ccb\u0cb9\u0ca3\u0cc7\u0cb6\u0ccb\u0cb2\u0ccd\u0cb2\u0cbe\u0cb8\u0cbf\u0ca8\u0cbf \u0c9a\u0cbf\u0ca6\u0ccd\u0cb0\u0cc2\u0caa \u0cb5\u0cbf\u0cb2\u0cbe\u0cb8\u0cbf\u0ca8\u0cbf <br/> \u0ca8\u0cb5\u0caf\u0ccb\u0c97\u0cbf\u0ca8\u0cbf \u0c9a\u0c95\u0ccd\u0cb0 \u0cb5\u0cbf\u0c95\u0cbe\u0cb8\u0cbf\u0ca8\u0cbf \u0ca8\u0cb5\u0cb0\u0cb8 \u0ca6\u0cb0\u0cb9\u0cbe\u0cb8\u0cbf\u0ca8\u0cbf <br/> \u0cb8\u0cc1\u0cb5\u0cb0\u0ccd\u0ca3\u0cae\u0caf \u0cb5\u0cbf\u0c97\u0ccd\u0cb0\u0cb9 \u0caa\u0ccd\u0cb0\u0c95\u0cbe\u0cb6\u0cbf\u0ca8\u0cbf \u0cb8\u0cc1\u0cb5\u0cb0\u0ccd\u0ca3\u0cae\u0caf \u0cb9\u0cbe\u0cb8\u0cbf\u0ca8\u0cbf"}, {"M": "\u0cae\u0ca7\u0ccd\u0caf\u0cae\u0c95\u0cbe\u0cb2 \u0cb8\u0cbe\u0cb9\u0cbf\u0ca4\u0ccd\u0caf\u0cae\u0ccd", "T": "\u0cad\u0cc1\u0cb5\u0ca8\u0ccb\u0ca6\u0caf \u0cb8\u0ccd\u0ca5\u0cbf\u0ca4\u0cbf\u0cb2\u0caf \u0cb5\u0cbf\u0ca8\u0ccb\u0ca6\u0cbf\u0ca8\u0cbf <br/> \u0cad\u0cc1\u0cb5\u0ca8\u0cc7\u0cb6\u0ccd\u0cb5\u0cb0\u0cbf \u0c95\u0ccd\u0cb7\u0cbf\u0caa\u0ccd\u0cb0 \u0caa\u0ccd\u0cb0\u0cb8\u0cbe\u0ca6\u0cbf\u0ca8\u0cbf <br/> \u0ca8\u0cb5\u0cae\u0cbe\u0ca3\u0cbf\u0c95\u0ccd\u0caf \u0cb5\u0cb2\u0ccd\u0cb2\u0c95\u0cc0 \u0cb5\u0cbe\u0ca6\u0cbf\u0ca8\u0cbf <br/> \u0cad\u0cb5 \u0c97\u0cc1\u0cb0\u0cc1\u0c97\u0cc1\u0cb9 \u0cb5\u0cc7\u0ca6\u0cbf\u0ca8\u0cbf \u0cb8\u0cae\u0ccd\u0cae\u0ccb\u0ca6\u0cbf\u0ca8\u0cbf"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d05\u0d2e\u0d4d\u0d2c\u0d3e \u0d28\u0d40\u0d32\u0d3e\u0d2f\u0d24\u0d3e\u0d15\u0d4d\u0d37\u0d40 \u0d15\u0d30\u0d41\u0d23\u0d3e \u0d15\u0d1f\u0d3e\u0d15\u0d4d\u0d37\u0d3f <br/> \u0d05\u0d16\u0d3f\u0d32 \u0d32\u0d4b\u0d15 \u0d38\u0d3e\u0d15\u0d4d\u0d37\u0d3f \u0d15\u0d1f\u0d3e\u0d15\u0d4d\u0d38\u0d3f"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d2c\u0d3f\u0d2e\u0d4d\u0d2c\u0d3e\u0d27\u0d30\u0d3f \u0d1a\u0d3f\u0d24\u0d4d\u0d2a\u0d4d\u0d30\u0d24\u0d3f\u0d2c\u0d3f\u0d2e\u0d4d\u0d2c\u0d3e\u0d27\u0d30\u0d3f <br/> \u0d2c\u0d3f\u0d28\u0d4d\u0d26\u0d41\u0d28\u0d3e\u0d26 \u0d35\u0d36\u0d02\u0d15\u0d30\u0d3f \u0d36\u0d02\u0d15\u0d30\u0d3f"}, {"M": "\u0d2e\u0d27\u0d4d\u0d2f\u0d2e\u0d15\u0d3e\u0d32 \u0d38\u0d3e\u0d39\u0d3f\u0d24\u0d4d\u0d2f\u0d2e\u0d4d", "T": "\u0d05\u0d2e\u0d4d\u0d2c\u0d41\u0d1c\u0d3e \u0d30\u0d2e\u0d23 \u0d38\u0d4b\u0d26\u0d30\u0d3f \u0d05\u0d24\u0d3f\u0d30\u0d25\u0d3f <br/> \u0d05\u0d2e\u0d4d\u0d2c\u0d30\u0d3f \u0d15\u0d3e\u0d26\u0d2e\u0d4d\u0d2c\u0d30\u0d3f \u0d28\u0d40\u0d32\u0d3e\u0d2e\u0d4d\u0d2c\u0d30\u0d3f"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d36\u0d3f\u0d35 \u0d30\u0d3e\u0d1c\u0d27\u0d3e\u0d28\u0d40 \u0d15\u0d4d\u0d37\u0d47\u0d24\u0d4d\u0d30 \u0d35\u0d3e\u0d38\u0d3f\u0d28\u0d3f \u0d36\u0d4d\u0d30\u0d3f\u0d24\u0d1c\u0d28 \u0d35\u0d3f\u0d36\u0d4d\u0d35\u0d3e\u0d38\u0d3f\u0d28\u0d3f <br/> \u0d36\u0d3f\u0d35 \u0d15\u0d3e\u0d2f\u0d3e\u0d30\u0d4b\u0d39\u0d23\u0d47\u0d36\u0d4b\u0d32\u0d4d\u0d32\u0d3e\u0d38\u0d3f\u0d28\u0d3f \u0d1a\u0d3f\u0d26\u0d4d\u0d30\u0d42\u0d2a \u0d35\u0d3f\u0d32\u0d3e\u0d38\u0d3f\u0d28\u0d3f <br/> \u0d28\u0d35\u0d2f\u0d4b\u0d17\u0d3f\u0d28\u0d3f \u0d1a\u0d15\u0d4d\u0d30 \u0d35\u0d3f\u0d15\u0d3e\u0d38\u0d3f\u0d28\u0d3f \u0d28\u0d35\u0d30\u0d38 \u0d26\u0d30\u0d39\u0d3e\u0d38\u0d3f\u0d28\u0d3f <br/> \u0d38\u0d41\u0d35\u0d30\u0d4d\u0d23\u0d2e\u0d2f \u0d35\u0d3f\u0d17\u0d4d\u0d30\u0d39 \u0d2a\u0d4d\u0d30\u0d15\u0d3e\u0d36\u0d3f\u0d28\u0d3f \u0d38\u0d41\u0d35\u0d30\u0d4d\u0d23\u0d2e\u0d2f \u0d39\u0d3e\u0d38\u0d3f\u0d28\u0d3f"}, {"M": "\u0d2e\u0d27\u0d4d\u0d2f\u0d2e\u0d15\u0d3e\u0d32 \u0d38\u0d3e\u0d39\u0d3f\u0d24\u0d4d\u0d2f\u0d2e\u0d4d", "T": "\u0d2d\u0d41\u0d35\u0d28\u0d4b\u0d26\u0d2f \u0d38\u0d4d\u0d25\u0d3f\u0d24\u0d3f\u0d32\u0d2f \u0d35\u0d3f\u0d28\u0d4b\u0d26\u0d3f\u0d28\u0d3f <br/> \u0d2d\u0d41\u0d35\u0d28\u0d47\u0d36\u0d4d\u0d35\u0d30\u0d3f \u0d15\u0d4d\u0d37\u0d3f\u0d2a\u0d4d\u0d30 \u0d2a\u0d4d\u0d30\u0d38\u0d3e\u0d26\u0d3f\u0d28\u0d3f <br/> \u0d28\u0d35\u0d2e\u0d3e\u0d23\u0d3f\u0d15\u0d4d\u0d2f \u0d35\u0d32\u0d4d\u0d32\u0d15\u0d40 \u0d35\u0d3e\u0d26\u0d3f\u0d28\u0d3f <br/> \u0d2d\u0d35 \u0d17\u0d41\u0d30\u0d41\u0d17\u0d41\u0d39 \u0d35\u0d47\u0d26\u0d3f\u0d28\u0d3f \u0d38\u0d2e\u0d4d\u0d2e\u0d4b\u0d26\u0d3f\u0d28\u0d3f"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0905\u092e\u094d\u092c\u093e \u0928\u0940\u0932\u093e\u092f\u0924\u093e\u0915\u094d\u0937\u0940 \u0915\u0930\u0941\u0923\u093e \u0915\u091f\u093e\u0915\u094d\u0937\u093f <br/> \u0905\u0916\u093f\u0932 \u0932\u094b\u0915 \u0938\u093e\u0915\u094d\u0937\u093f \u0915\u091f\u093e\u0915\u094d\u0938\u093f"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u092c\u093f\u092e\u094d\u092c\u093e\u0927\u0930\u093f \u091a\u093f\u0924\u094d\u092a\u094d\u0930\u0924\u093f\u092c\u093f\u092e\u094d\u092c\u093e\u0927\u0930\u093f <br/> \u092c\u093f\u0928\u094d\u0926\u0941\u0928\u093e\u0926 \u0935\u0936\u0902\u0915\u0930\u093f \u0936\u0902\u0915\u0930\u093f"}, {"M": "\u092e\u0927\u094d\u092f\u092e\u0915\u093e\u0932 \u0938\u093e\u0939\u093f\u0924\u094d\u092f\u092e\u094d", "T": "\u0905\u092e\u094d\u092c\u0941\u091c\u093e \u0930\u092e\u0923 \u0938\u094b\u0926\u0930\u093f \u0905\u0924\u093f\u0930\u0925\u093f <br/> \u0905\u092e\u094d\u092c\u0930\u093f \u0915\u093e\u0926\u092e\u094d\u092c\u0930\u093f \u0928\u0940\u0932\u093e\u092e\u094d\u092c\u0930\u093f"}, {"M": "\u091a\u0930\u0923\u092e\u094d", "T": "\u0936\u093f\u0935 \u0930\u093e\u091c\u0927\u093e\u0928\u0940 \u0915\u094d\u0937\u0947\u0924\u094d\u0930 \u0935\u093e\u0938\u093f\u0928\u093f \u0936\u094d\u0930\u093f\u0924\u091c\u0928 \u0935\u093f\u0936\u094d\u0935\u093e\u0938\u093f\u0928\u093f <br/> \u0936\u093f\u0935 \u0915\u093e\u092f\u093e\u0930\u094b\u0939\u0923\u0947\u0936\u094b\u0932\u094d\u0932\u093e\u0938\u093f\u0928\u093f \u091a\u093f\u0926\u094d\u0930\u0942\u092a \u0935\u093f\u0932\u093e\u0938\u093f\u0928\u093f <br/> \u0928\u0935\u092f\u094b\u0917\u093f\u0928\u093f \u091a\u0915\u094d\u0930 \u0935\u093f\u0915\u093e\u0938\u093f\u0928\u093f \u0928\u0935\u0930\u0938 \u0926\u0930\u0939\u093e\u0938\u093f\u0928\u093f <br/> \u0938\u0941\u0935\u0930\u094d\u0923\u092e\u092f \u0935\u093f\u0917\u094d\u0930\u0939 \u092a\u094d\u0930\u0915\u093e\u0936\u093f\u0928\u093f \u0938\u0941\u0935\u0930\u094d\u0923\u092e\u092f \u0939\u093e\u0938\u093f\u0928\u093f"}, {"M": "\u092e\u0927\u094d\u092f\u092e\u0915\u093e\u0932 \u0938\u093e\u0939\u093f\u0924\u094d\u092f\u092e\u094d", "T": "\u092d\u0941\u0935\u0928\u094b\u0926\u092f \u0938\u094d\u0925\u093f\u0924\u093f\u0932\u092f \u0935\u093f\u0928\u094b\u0926\u093f\u0928\u093f <br/> \u092d\u0941\u0935\u0928\u0947\u0936\u094d\u0935\u0930\u093f \u0915\u094d\u0937\u093f\u092a\u094d\u0930 \u092a\u094d\u0930\u0938\u093e\u0926\u093f\u0928\u093f <br/> \u0928\u0935\u092e\u093e\u0923\u093f\u0915\u094d\u092f \u0935\u0932\u094d\u0932\u0915\u0940 \u0935\u093e\u0926\u093f\u0928\u093f <br/> \u092d\u0935 \u0917\u0941\u0930\u0941\u0917\u0941\u0939 \u0935\u0947\u0926\u093f\u0928\u093f \u0938\u092e\u094d\u092e\u094b\u0926\u093f\u0928\u093f"}]}], "L": "l", "lyricsref": [{"links": [{"N": "www.medieval.org", "L": "http://www.medieval.org/music/world/carnatic/lyrics/TKG/amba_nilayatakshi.html"}, {"N": "guru-guha.blogspot.com", "L": "http://guru-guha.blogspot.com/2007/08/dikshitar-kriti-amba-neelaayathaakshi.html"}, {"N": "www.shivkumar.org", "L": "http://www.shivkumar.org/music/ambaneelayatakshi.htm"}]}]}