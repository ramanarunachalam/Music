mAraM vAraM vAram"}, {"M": "anupallavi", "T": "shrungAraka mESa vrushcika rAshyadhipatiM <br/> raktAngaM raktAmbarAdi dharaM shakti shUla dharam <br/> mangaLaM kambu gaLaM manjuLa-tara pada yugaLaM <br/> mangaLa dAyaka mESa turangaM makarOttungam"}, {"M": "caraNam", "T": "dAnava sura sEvita manda smita vilasita vaktraM <br/> dharaNI pradaM bhrAtru kArakaM rakta nEtram <br/> dIna rakSakaM pUjita vaidya nAtha kSEtraM <br/> divyaughAdi guru guha kaTAkSAnugraha pAtram"}, {"M": "madhyamakAla sAhityam", "T": "bhAnu candra guru mitraM bhAsamAna sukaLatraM <br/> jAnustha hasta citraM caturbhujaM ati vicitram"}]}, {"L": "Tamil", "text": [{"M": "\u0baa\u0bb2\u0bcd\u0bb2\u0bb5\u0bbf", "T": "\u0b85\u0b99\u0bcd\u0b95\u0bbe\u0bb0\u0b95\u0bae\u0bcd \u0b86\u0bb7\u0bcd\u0bb0\u0baf\u0bbe\u0bae\u0bcd\u0baf\u0bb9\u0bae\u0bcd <br/> \u0bb5\u0bbf\u0ba9\u0ba4\u0bbe\u0bb7\u0bcd\u0bb0\u0bbf\u0ba4 \u0b9c\u0ba9 \u0bae\u0ba8\u0bcd\u0ba4\u0bbe\u0bb0\u0bae\u0bcd"}, {"M": "\u0bae\u0ba4\u0bcd\u0baf\u0bae\u0b95\u0bbe\u0bb2 \u0b9a\u0bbe\u0bb9\u0bbf\u0ba4\u0bcd\u0baf\u0bae\u0bcd", "T": "\u0bae\u0b99\u0bcd\u0b95\u0bb3 \u0bb5\u0bbe\u0bb0\u0bae\u0bcd \u0baa\u0bc2\u0bae\u0bbf \u0b95\u0bc1\u0bae\u0bbe\u0bb0\u0bae\u0bcd \u0bb5\u0bbe\u0bb0\u0bae\u0bcd \u0bb5\u0bbe\u0bb0\u0bae\u0bcd"}, {"M": "\u0b85\u0ba9\u0bc1\u0baa\u0bb2\u0bcd\u0bb2\u0bb5\u0bbf", "T": "\u0bb7\u0bcd\u0bb0\u0bc1\u0b99\u0bcd\u0b95\u0bbe\u0bb0\u0b95 \u0bae\u0bc7\u0b9a \u0bb5\u0bcd\u0bb0\u0bc1\u0bb7\u0bcd\u0b9a\u0bbf\u0b95 \u0bb0\u0bbe\u0bb7\u0bcd\u0baf\u0ba4\u0bbf\u0baa\u0ba4\u0bbf\u0bae\u0bcd <br/> \u0bb0\u0b95\u0bcd\u0ba4\u0bbe\u0b99\u0bcd\u0b95\u0bae\u0bcd \u0bb0\u0b95\u0bcd\u0ba4\u0bbe\u0bae\u0bcd\u0baa\u0bb0\u0bbe\u0ba4\u0bbf \u0ba4\u0bb0\u0bae\u0bcd \u0bb7\u0b95\u0bcd\u0ba4\u0bbf \u0bb7\u0bc2\u0bb2 \u0ba4\u0bb0\u0bae\u0bcd <br/> \u0bae\u0b99\u0bcd\u0b95\u0bb3\u0bae\u0bcd \u0b95\u0bae\u0bcd\u0baa\u0bc1 \u0b95\u0bb3\u0bae\u0bcd \u0bae\u0ba9\u0bcd\u0b9c\u0bc1\u0bb3-\u0ba4\u0bb0 \u0baa\u0ba4 \u0baf\u0bc1\u0b95\u0bb3\u0bae\u0bcd <br/> \u0bae\u0b99\u0bcd\u0b95\u0bb3 \u0ba4\u0bbe\u0baf\u0b95 \u0bae\u0bc7\u0b9a \u0ba4\u0bc1\u0bb0\u0b99\u0bcd\u0b95\u0bae\u0bcd \u0bae\u0b95\u0bb0\u0bcb\u0ba4\u0bcd\u0ba4\u0bc1\u0b99\u0bcd\u0b95\u0bae\u0bcd"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd", "T": "\u0ba4\u0bbe\u0ba9\u0bb5 \u0b9a\u0bc1\u0bb0 \u0b9a\u0bc7\u0bb5\u0bbf\u0ba4 \u0bae\u0ba8\u0bcd\u0ba4 \u0bb8\u0bcd\u0bae\u0bbf\u0ba4 \u0bb5\u0bbf\u0bb2\u0b9a\u0bbf\u0ba4 \u0bb5\u0b95\u0bcd\u0ba4\u0bcd\u0bb0\u0bae\u0bcd <br/> \u0ba4\u0bb0\u0ba3\u0bc0 \u0baa\u0bcd\u0bb0\u0ba4\u0bae\u0bcd \u0baa\u0bcd\u0bb0\u0bbe\u0ba4\u0bcd\u0bb0\u0bc1 \u0b95\u0bbe\u0bb0\u0b95\u0bae\u0bcd \u0bb0\u0b95\u0bcd\u0ba4 \u0ba8\u0bc7\u0ba4\u0bcd\u0bb0\u0bae\u0bcd <br/> \u0ba4\u0bc0\u0ba9 \u0bb0\u0b95\u0bcd\u0b9a\u0b95\u0bae\u0bcd \u0baa\u0bc2\u0b9c\u0bbf\u0ba4 \u0bb5\u0bc8\u0ba4\u0bcd\u0baf \u0ba8\u0bbe\u0ba4 \u0b95\u0bcd\u0b9a\u0bc7\u0ba4\u0bcd\u0bb0\u0bae\u0bcd <br/> \u0ba4\u0bbf\u0bb5\u0bcd\u0baf\u0bcc\u0b95\u0bbe\u0ba4\u0bbf \u0b95\u0bc1\u0bb0\u0bc1 \u0b95\u0bc1\u0bb9 \u0b95\u0b9f\u0bbe\u0b95\u0bcd\u0b9a\u0bbe\u0ba9\u0bc1\u0b95\u0bcd\u0bb0\u0bb9 \u0baa\u0bbe\u0ba4\u0bcd\u0bb0\u0bae\u0bcd"}, {"M": "\u0bae\u0ba4\u0bcd\u0baf\u0bae\u0b95\u0bbe\u0bb2 \u0b9a\u0bbe\u0bb9\u0bbf\u0ba4\u0bcd\u0baf\u0bae\u0bcd", "T": "\u0baa\u0bbe\u0ba9\u0bc1 \u0b9a\u0ba8\u0bcd\u0ba4\u0bcd\u0bb0 \u0b95\u0bc1\u0bb0\u0bc1 \u0bae\u0bbf\u0ba4\u0bcd\u0bb0\u0bae\u0bcd \u0baa\u0bbe\u0b9a\u0bae\u0bbe\u0ba9 \u0b9a\u0bc1\u0b95\u0bb3\u0ba4\u0bcd\u0bb0\u0bae\u0bcd <br/> \u0b9c\u0bbe\u0ba9\u0bc1\u0bb8\u0bcd\u0ba4 \u0bb9\u0bb8\u0bcd\u0ba4 \u0b9a\u0bbf\u0ba4\u0bcd\u0bb0\u0bae\u0bcd \u0b9a\u0ba4\u0bc1\u0bb0\u0bcd\u0baa\u0bc1\u0b9c\u0bae\u0bcd \u0b85\u0ba4\u0bbf \u0bb5\u0bbf\u0b9a\u0bbf\u0ba4\u0bcd\u0bb0\u0bae\u0bcd"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c05\u0c02\u0c17\u0c3e\u0c30\u0c15\u0c02 \u0c06\u0c37\u0c4d\u0c30\u0c2f\u0c3e\u0c2e\u0c4d\u0c2f\u0c39\u0c02 <br/> \u0c35\u0c3f\u0c28\u0c24\u0c3e\u0c37\u0c4d\u0c30\u0c3f\u0c24 \u0c1c\u0c28 \u0c2e\u0c28\u0c4d\u0c26\u0c3e\u0c30\u0c02"}, {"M": "\u0c2e\u0c27\u0c4d\u0c2f\u0c2e\u0c15\u0c3e\u0c32 \u0c38\u0c3e\u0c39\u0c3f\u0c24\u0c4d\u0c2f\u0c2e\u0c4d", "T": "\u0c2e\u0c02\u0c17\u0c33 \u0c35\u0c3e\u0c30\u0c02 \u0c2d\u0c42\u0c2e\u0c3f \u0c15\u0c41\u0c2e\u0c3e\u0c30\u0c02 \u0c35\u0c3e\u0c30\u0c02 \u0c35\u0c3e\u0c30\u0c2e\u0c4d"}, {"M": "\u0c05\u0c28\u0c41\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c37\u0c43\u0c02\u0c17\u0c3e\u0c30\u0c15 \u0c2e\u0c47\u0c36 \u0c35\u0c43\u0c37\u0c4d\u0c1a\u0c3f\u0c15 \u0c30\u0c3e\u0c37\u0c4d\u0c2f\u0c27\u0c3f\u0c2a\u0c24\u0c3f\u0c02 <br/> \u0c30\u0c15\u0c4d\u0c24\u0c3e\u0c02\u0c17\u0c02 \u0c30\u0c15\u0c4d\u0c24\u0c3e\u0c2e\u0c4d\u0c2c\u0c30\u0c3e\u0c26\u0c3f \u0c27\u0c30\u0c02 \u0c37\u0c15\u0c4d\u0c24\u0c3f \u0c37\u0c42\u0c32 \u0c27\u0c30\u0c2e\u0c4d <br/> \u0c2e\u0c02\u0c17\u0c33\u0c02 \u0c15\u0c2e\u0c4d\u0c2c\u0c41 \u0c17\u0c33\u0c02 \u0c2e\u0c28\u0c4d\u0c1c\u0c41\u0c33-\u0c24\u0c30 \u0c2a\u0c26 \u0c2f\u0c41\u0c17\u0c33\u0c02 <br/> \u0c2e\u0c02\u0c17\u0c33 \u0c26\u0c3e\u0c2f\u0c15 \u0c2e\u0c47\u0c36 \u0c24\u0c41\u0c30\u0c02\u0c17\u0c02 \u0c2e\u0c15\u0c30\u0c4b\u0c24\u0c4d\u0c24\u0c41\u0c02\u0c17\u0c2e\u0c4d"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c26\u0c3e\u0c28\u0c35 \u0c38\u0c41\u0c30 \u0c38\u0c47\u0c35\u0c3f\u0c24 \u0c2e\u0c28\u0c4d\u0c26 \u0c38\u0c4d\u0c2e\u0c3f\u0c24 \u0c35\u0c3f\u0c32\u0c38\u0c3f\u0c24 \u0c35\u0c15\u0c4d\u0c24\u0c4d\u0c30\u0c02 <br/> \u0c27\u0c30\u0c23\u0c40 \u0c2a\u0c4d\u0c30\u0c26\u0c02 \u0c2d\u0c4d\u0c30\u0c3e\u0c24\u0c43 \u0c15\u0c3e\u0c30\u0c15\u0c02 \u0c30\u0c15\u0c4d\u0c24 \u0c28\u0c47\u0c24\u0c4d\u0c30\u0c2e\u0c4d <br/> \u0c26\u0c40\u0c28 \u0c30\u0c15\u0c4d\u0c36\u0c15\u0c02 \u0c2a\u0c42\u0c1c\u0c3f\u0c24 \u0c35\u0c48\u0c26\u0c4d\u0c2f \u0c28\u0c3e\u0c25 \u0c15\u0c4d\u0c36\u0c47\u0c24\u0c4d\u0c30\u0c02 <br/> \u0c26\u0c3f\u0c35\u0c4d\u0c2f\u0c4c\u0c18\u0c3e\u0c26\u0c3f \u0c17\u0c41\u0c30\u0c41 \u0c17\u0c41\u0c39 \u0c15\u0c1f\u0c3e\u0c15\u0c4d\u0c36\u0c3e\u0c28\u0c41\u0c17\u0c4d\u0c30\u0c39 \u0c2a\u0c3e\u0c24\u0c4d\u0c30\u0c2e\u0c4d"}, {"M": "\u0c2e\u0c27\u0c4d\u0c2f\u0c2e\u0c15\u0c3e\u0c32 \u0c38\u0c3e\u0c39\u0c3f\u0c24\u0c4d\u0c2f\u0c2e\u0c4d", "T": "\u0c2d\u0c3e\u0c28\u0c41 \u0c1a\u0c28\u0c4d\u0c26\u0c4d\u0c30 \u0c17\u0c41\u0c30\u0c41 \u0c2e\u0c3f\u0c24\u0c4d\u0c30\u0c02 \u0c2d\u0c3e\u0c38\u0c2e\u0c3e\u0c28 \u0c38\u0c41\u0c15\u0c33\u0c24\u0c4d\u0c30\u0c02 <br/> \u0c1c\u0c3e\u0c28\u0c41\u0c38\u0c4d\u0c25 \u0c39\u0c38\u0c4d\u0c24 \u0c1a\u0c3f\u0c24\u0c4d\u0c30\u0c02 \u0c1a\u0c24\u0c41\u0c30\u0c4d\u0c2d\u0c41\u0c1c\u0c02 \u0c05\u0c24\u0c3f \u0c35\u0c3f\u0c1a\u0c3f\u0c24\u0c4d\u0c30\u0c2e\u0c4d"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0c85\u0c82\u0c97\u0cbe\u0cb0\u0c95\u0c82 \u0c86\u0cb7\u0ccd\u0cb0\u0caf\u0cbe\u0cae\u0ccd\u0caf\u0cb9\u0c82 <br/> \u0cb5\u0cbf\u0ca8\u0ca4\u0cbe\u0cb7\u0ccd\u0cb0\u0cbf\u0ca4 \u0c9c\u0ca8 \u0cae\u0ca8\u0ccd\u0ca6\u0cbe\u0cb0\u0c82"}, {"M": "\u0cae\u0ca7\u0ccd\u0caf\u0cae\u0c95\u0cbe\u0cb2 \u0cb8\u0cbe\u0cb9\u0cbf\u0ca4\u0ccd\u0caf\u0cae\u0ccd", "T": "\u0cae\u0c82\u0c97\u0cb3 \u0cb5\u0cbe\u0cb0\u0c82 \u0cad\u0cc2\u0cae\u0cbf \u0c95\u0cc1\u0cae\u0cbe\u0cb0\u0c82 \u0cb5\u0cbe\u0cb0\u0c82 \u0cb5\u0cbe\u0cb0\u0cae\u0ccd"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cb7\u0cc3\u0c82\u0c97\u0cbe\u0cb0\u0c95 \u0cae\u0cc7\u0cb6 \u0cb5\u0cc3\u0cb7\u0ccd\u0c9a\u0cbf\u0c95 \u0cb0\u0cbe\u0cb7\u0ccd\u0caf\u0ca7\u0cbf\u0caa\u0ca4\u0cbf\u0c82 <br/> \u0cb0\u0c95\u0ccd\u0ca4\u0cbe\u0c82\u0c97\u0c82 \u0cb0\u0c95\u0ccd\u0ca4\u0cbe\u0cae\u0ccd\u0cac\u0cb0\u0cbe\u0ca6\u0cbf \u0ca7\u0cb0\u0c82 \u0cb7\u0c95\u0ccd\u0ca4\u0cbf \u0cb7\u0cc2\u0cb2 \u0ca7\u0cb0\u0cae\u0ccd <br/> \u0cae\u0c82\u0c97\u0cb3\u0c82 \u0c95\u0cae\u0ccd\u0cac\u0cc1 \u0c97\u0cb3\u0c82 \u0cae\u0ca8\u0ccd\u0c9c\u0cc1\u0cb3-\u0ca4\u0cb0 \u0caa\u0ca6 \u0caf\u0cc1\u0c97\u0cb3\u0c82 <br/> \u0cae\u0c82\u0c97\u0cb3 \u0ca6\u0cbe\u0caf\u0c95 \u0cae\u0cc7\u0cb6 \u0ca4\u0cc1\u0cb0\u0c82\u0c97\u0c82 \u0cae\u0c95\u0cb0\u0ccb\u0ca4\u0ccd\u0ca4\u0cc1\u0c82\u0c97\u0cae\u0ccd"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0ca6\u0cbe\u0ca8\u0cb5 \u0cb8\u0cc1\u0cb0 \u0cb8\u0cc7\u0cb5\u0cbf\u0ca4 \u0cae\u0ca8\u0ccd\u0ca6 \u0cb8\u0ccd\u0cae\u0cbf\u0ca4 \u0cb5\u0cbf\u0cb2\u0cb8\u0cbf\u0ca4 \u0cb5\u0c95\u0ccd\u0ca4\u0ccd\u0cb0\u0c82 <br/> \u0ca7\u0cb0\u0ca3\u0cc0 \u0caa\u0ccd\u0cb0\u0ca6\u0c82 \u0cad\u0ccd\u0cb0\u0cbe\u0ca4\u0cc3 \u0c95\u0cbe\u0cb0\u0c95\u0c82 \u0cb0\u0c95\u0ccd\u0ca4 \u0ca8\u0cc7\u0ca4\u0ccd\u0cb0\u0cae\u0ccd <br/> \u0ca6\u0cc0\u0ca8 \u0cb0\u0c95\u0ccd\u0cb6\u0c95\u0c82 \u0caa\u0cc2\u0c9c\u0cbf\u0ca4 \u0cb5\u0cc8\u0ca6\u0ccd\u0caf \u0ca8\u0cbe\u0ca5 \u0c95\u0ccd\u0cb6\u0cc7\u0ca4\u0ccd\u0cb0\u0c82 <br/> \u0ca6\u0cbf\u0cb5\u0ccd\u0caf\u0ccc\u0c98\u0cbe\u0ca6\u0cbf \u0c97\u0cc1\u0cb0\u0cc1 \u0c97\u0cc1\u0cb9 \u0c95\u0c9f\u0cbe\u0c95\u0ccd\u0cb6\u0cbe\u0ca8\u0cc1\u0c97\u0ccd\u0cb0\u0cb9 \u0caa\u0cbe\u0ca4\u0ccd\u0cb0\u0cae\u0ccd"}, {"M": "\u0cae\u0ca7\u0ccd\u0caf\u0cae\u0c95\u0cbe\u0cb2 \u0cb8\u0cbe\u0cb9\u0cbf\u0ca4\u0ccd\u0caf\u0cae\u0ccd", "T": "\u0cad\u0cbe\u0ca8\u0cc1 \u0c9a\u0ca8\u0ccd\u0ca6\u0ccd\u0cb0 \u0c97\u0cc1\u0cb0\u0cc1 \u0cae\u0cbf\u0ca4\u0ccd\u0cb0\u0c82 \u0cad\u0cbe\u0cb8\u0cae\u0cbe\u0ca8 \u0cb8\u0cc1\u0c95\u0cb3\u0ca4\u0ccd\u0cb0\u0c82 <br/> \u0c9c\u0cbe\u0ca8\u0cc1\u0cb8\u0ccd\u0ca5 \u0cb9\u0cb8\u0ccd\u0ca4 \u0c9a\u0cbf\u0ca4\u0ccd\u0cb0\u0c82 \u0c9a\u0ca4\u0cc1\u0cb0\u0ccd\u0cad\u0cc1\u0c9c\u0c82 \u0c85\u0ca4\u0cbf \u0cb5\u0cbf\u0c9a\u0cbf\u0ca4\u0ccd\u0cb0\u0cae\u0ccd"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d05\u0d02\u0d17\u0d3e\u0d30\u0d15\u0d02 \u0d06\u0d37\u0d4d\u0d30\u0d2f\u0d3e\u0d2e\u0d4d\u0d2f\u0d39\u0d02 <br/> \u0d35\u0d3f\u0d28\u0d24\u0d3e\u0d37\u0d4d\u0d30\u0d3f\u0d24 \u0d1c\u0d28 \u0d2e\u0d28\u0d4d\u0d26\u0d3e\u0d30\u0d02"}, {"M": "\u0d2e\u0d27\u0d4d\u0d2f\u0d2e\u0d15\u0d3e\u0d32 \u0d38\u0d3e\u0d39\u0d3f\u0d24\u0d4d\u0d2f\u0d2e\u0d4d", "T": "\u0d2e\u0d02\u0d17\u0d33 \u0d35\u0d3e\u0d30\u0d02 \u0d2d\u0d42\u0d2e\u0d3f \u0d15\u0d41\u0d2e\u0d3e\u0d30\u0d02 \u0d35\u0d3e\u0d30\u0d02 \u0d35\u0d3e\u0d30\u0d2e\u0d4d"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d37\u0d43\u0d02\u0d17\u0d3e\u0d30\u0d15 \u0d2e\u0d47\u0d36 \u0d35\u0d43\u0d37\u0d4d\u0d1a\u0d3f\u0d15 \u0d30\u0d3e\u0d37\u0d4d\u0d2f\u0d27\u0d3f\u0d2a\u0d24\u0d3f\u0d02 <br/> \u0d30\u0d15\u0d4d\u0d24\u0d3e\u0d02\u0d17\u0d02 \u0d30\u0d15\u0d4d\u0d24\u0d3e\u0d2e\u0d4d\u0d2c\u0d30\u0d3e\u0d26\u0d3f \u0d27\u0d30\u0d02 \u0d37\u0d15\u0d4d\u0d24\u0d3f \u0d37\u0d42\u0d32 \u0d27\u0d30\u0d2e\u0d4d <br/> \u0d2e\u0d02\u0d17\u0d33\u0d02 \u0d15\u0d2e\u0d4d\u0d2c\u0d41 \u0d17\u0d33\u0d02 \u0d2e\u0d28\u0d4d\u0d1c\u0d41\u0d33-\u0d24\u0d30 \u0d2a\u0d26 \u0d2f\u0d41\u0d17\u0d33\u0d02 <br/> \u0d2e\u0d02\u0d17\u0d33 \u0d26\u0d3e\u0d2f\u0d15 \u0d2e\u0d47\u0d36 \u0d24\u0d41\u0d30\u0d02\u0d17\u0d02 \u0d2e\u0d15\u0d30\u0d4b\u0d24\u0d4d\u0d24\u0d41\u0d02\u0d17\u0d2e\u0d4d"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d26\u0d3e\u0d28\u0d35 \u0d38\u0d41\u0d30 \u0d38\u0d47\u0d35\u0d3f\u0d24 \u0d2e\u0d28\u0d4d\u0d26 \u0d38\u0d4d\u0d2e\u0d3f\u0d24 \u0d35\u0d3f\u0d32\u0d38\u0d3f\u0d24 \u0d35\u0d15\u0d4d\u0d24\u0d4d\u0d30\u0d02 <br/> \u0d27\u0d30\u0d23\u0d40 \u0d2a\u0d4d\u0d30\u0d26\u0d02 \u0d2d\u0d4d\u0d30\u0d3e\u0d24\u0d43 \u0d15\u0d3e\u0d30\u0d15\u0d02 \u0d30\u0d15\u0d4d\u0d24 \u0d28\u0d47\u0d24\u0d4d\u0d30\u0d2e\u0d4d <br/> \u0d26\u0d40\u0d28 \u0d30\u0d15\u0d4d\u0d36\u0d15\u0d02 \u0d2a\u0d42\u0d1c\u0d3f\u0d24 \u0d35\u0d48\u0d26\u0d4d\u0d2f \u0d28\u0d3e\u0d25 \u0d15\u0d4d\u0d36\u0d47\u0d24\u0d4d\u0d30\u0d02 <br/> \u0d26\u0d3f\u0d35\u0d4d\u0d2f\u0d4c\u0d18\u0d3e\u0d26\u0d3f \u0d17\u0d41\u0d30\u0d41 \u0d17\u0d41\u0d39 \u0d15\u0d1f\u0d3e\u0d15\u0d4d\u0d36\u0d3e\u0d28\u0d41\u0d17\u0d4d\u0d30\u0d39 \u0d2a\u0d3e\u0d24\u0d4d\u0d30\u0d2e\u0d4d"}, {"M": "\u0d2e\u0d27\u0d4d\u0d2f\u0d2e\u0d15\u0d3e\u0d32 \u0d38\u0d3e\u0d39\u0d3f\u0d24\u0d4d\u0d2f\u0d2e\u0d4d", "T": "\u0d2d\u0d3e\u0d28\u0d41 \u0d1a\u0d28\u0d4d\u0d26\u0d4d\u0d30 \u0d17\u0d41\u0d30\u0d41 \u0d2e\u0d3f\u0d24\u0d4d\u0d30\u0d02 \u0d2d\u0d3e\u0d38\u0d2e\u0d3e\u0d28 \u0d38\u0d41\u0d15\u0d33\u0d24\u0d4d\u0d30\u0d02 <br/> \u0d1c\u0d3e\u0d28\u0d41\u0d38\u0d4d\u0d25 \u0d39\u0d38\u0d4d\u0d24 \u0d1a\u0d3f\u0d24\u0d4d\u0d30\u0d02 \u0d1a\u0d24\u0d41\u0d30\u0d4d\u0d2d\u0d41\u0d1c\u0d02 \u0d05\u0d24\u0d3f \u0d35\u0d3f\u0d1a\u0d3f\u0d24\u0d4d\u0d30\u0d2e\u0d4d"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0905\u0902\u0917\u093e\u0930\u0915\u0902 \u0906\u0937\u094d\u0930\u092f\u093e\u092e\u094d\u092f\u0939\u0902 <br/> \u0935\u093f\u0928\u0924\u093e\u0937\u094d\u0930\u093f\u0924 \u091c\u0928 \u092e\u0928\u094d\u0926\u093e\u0930\u0902"}, {"M": "\u092e\u0927\u094d\u092f\u092e\u0915\u093e\u0932 \u0938\u093e\u0939\u093f\u0924\u094d\u092f\u092e\u094d", "T": "\u092e\u0902\u0917\u0932 \u0935\u093e\u0930\u0902 \u092d\u0942\u092e\u093f \u0915\u0941\u092e\u093e\u0930\u0902 \u0935\u093e\u0930\u0902 \u0935\u093e\u0930\u092e\u094d"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0937\u0943\u0902\u0917\u093e\u0930\u0915 \u092e\u0947\u0936 \u0935\u0943\u0937\u094d\u091a\u093f\u0915 \u0930\u093e\u0937\u094d\u092f\u0927\u093f\u092a\u0924\u093f\u0902 <br/> \u0930\u0915\u094d\u0924\u093e\u0902\u0917\u0902 \u0930\u0915\u094d\u0924\u093e\u092e\u094d\u092c\u0930\u093e\u0926\u093f \u0927\u0930\u0902 \u0937\u0915\u094d\u0924\u093f \u0937\u0942\u0932 \u0927\u0930\u092e\u094d <br/> \u092e\u0902\u0917\u0932\u0902 \u0915\u092e\u094d\u092c\u0941 \u0917\u0932\u0902 \u092e\u0928\u094d\u091c\u0941\u0932-\u0924\u0930 \u092a\u0926 \u092f\u0941\u0917\u0932\u0902 <br/> \u092e\u0902\u0917\u0932 \u0926\u093e\u092f\u0915 \u092e\u0947\u0936 \u0924\u0941\u0930\u0902\u0917\u0902 \u092e\u0915\u0930\u094b\u0924\u094d\u0924\u0941\u0902\u0917\u092e\u094d"}, {"M": "\u091a\u0930\u0923\u092e\u094d", "T": "\u0926\u093e\u0928\u0935 \u0938\u0941\u0930 \u0938\u0947\u0935\u093f\u0924 \u092e\u0928\u094d\u0926 \u0938\u094d\u092e\u093f\u0924 \u0935\u093f\u0932\u0938\u093f\u0924 \u0935\u0915\u094d\u0924\u094d\u0930\u0902 <br/> \u0927\u0930\u0923\u0940 \u092a\u094d\u0930\u0926\u0902 \u092d\u094d\u0930\u093e\u0924\u0943 \u0915\u093e\u0930\u0915\u0902 \u0930\u0915\u094d\u0924 \u0928\u0947\u0924\u094d\u0930\u092e\u094d <br/> \u0926\u0940\u0928 \u0930\u0915\u094d\u0936\u0915\u0902 \u092a\u0942\u091c\u093f\u0924 \u0935\u0948\u0926\u094d\u092f \u0928\u093e\u0925 \u0915\u094d\u0936\u0947\u0924\u094d\u0930\u0902 <br/> \u0926\u093f\u0935\u094d\u092f\u094c\u0918\u093e\u0926\u093f \u0917\u0941\u0930\u0941 \u0917\u0941\u0939 \u0915\u091f\u093e\u0915\u094d\u0936\u093e\u0928\u0941\u0917\u094d\u0930\u0939 \u092a\u093e\u0924\u094d\u0930\u092e\u094d"}, {"M": "\u092e\u0927\u094d\u092f\u092e\u0915\u093e\u0932 \u0938\u093e\u0939\u093f\u0924\u094d\u092f\u092e\u094d", "T": "\u092d\u093e\u0928\u0941 \u091a\u0928\u094d\u0926\u094d\u0930 \u0917\u0941\u0930\u0941 \u092e\u093f\u0924\u094d\u0930\u0902 \u092d\u093e\u0938\u092e\u093e\u0928 \u0938\u0941\u0915\u0932\u0924\u094d\u0930\u0902 <br/> \u091c\u093e\u0928\u0941\u0938\u094d\u0925 \u0939\u0938\u094d\u0924 \u091a\u093f\u0924\u094d\u0930\u0902 \u091a\u0924\u0941\u0930\u094d\u092d\u0941\u091c\u0902 \u0905\u0924\u093f \u0935\u093f\u091a\u093f\u0924\u094d\u0930\u092e\u094d"}]}], "L": "l", "lyricsref": [{"links": [{"N": "www.medieval.org", "L": "http://www.medieval.org/music/world/carnatic/lyrics/navagraha.html#angaraka"}, {"N": "guru-guha.blogspot.com", "L": "http://guru-guha.blogspot.com/2007/07/dikshitar-kriti-angaarakamaasrayaamyaha.html"}, {"N": "www.shivkumar.org", "L": "http://www.shivkumar.org/music/angaraka.htm"}]}]}