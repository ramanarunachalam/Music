be\u0ba4\u0bb5\u0bc8 \u0b9c\u0ba9\u0b95\u0b9c\u0bbe \u0bae\u0bbe\u0ba4\u0bb5\u0bc8 <br/> \u0b9c\u0ba9\u0b95 \u0b9c\u0bbe\u0bb2\u0bae\u0bc1 \u0b9a\u0bbe\u0bb2\u0bc1 \u0b9a\u0bbe\u0bb2\u0bc1\u0ba9\u0bc1 \u0bb9\u0bb0\u0bbf"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd 2", "T": "\u0b95\u0ba9\u0b95 \u0baa\u0b9f \u0ba4\u0bb0 \u0ba8\u0ba9\u0bcd\u0ba9\u0bc1 \u0b95\u0ba9 \u0b95\u0baa\u0b9f\u0bae\u0bc7\u0bb2 \u0ba4\u0ba9\u0bc1 <br/> \u0b95\u0ba9\u0b95 \u0baa\u0b9f\u0ba9\u0bae\u0bc1 \u0b9a\u0bc7\u0ba4\u0bc1 \u0b95\u0bbe\u0ba9\u0bbf \u0baa\u0bc2\u0ba9\u0bbf"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd 3", "T": "\u0b95\u0bb2\u0bb2\u0bcb\u0ba9 \u0ba8\u0bc0\u0bb5\u0bc7 \u0b9a\u0b95\u0bb2 \u0bb2\u0bcb\u0b95 \u0ba8\u0bbe\u0ba4 <br/> \u0b95\u0bcb\u0b95\u0bb2\u0bc1 \u0bb2\u0bcb\u0b95\u0bc1\u0bb5 \u0b95\u0ba9\u0bbf\u0b9a\u0bcd\u0b9a\u0bbf \u0b95\u0bbe\u0b9a\u0bbf\u0ba9\u0ba4\u0bbf \u0bb5\u0bbf\u0ba9\u0bbf"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd 4", "T": "\u0bb0\u0bbe\u0b9c \u0b95\u0bc1\u0bb2 \u0b95\u0bb2\u0b9a\u0bbe\u0baa\u0bcd\u0ba4\u0bbf \u0bb0\u0bbe\u0b9c \u0b9a\u0bc1\u0bb0 \u0baa\u0bbe\u0bb2 \u0b95\u0b9c <br/> \u0bb0\u0bbe\u0b9c \u0bb0\u0b95\u0bcd\u0bb7\u0b95 \u0ba4\u0bcd\u0baf\u0bbe\u0b95\u0bb0\u0bbe\u0b9c \u0bb5\u0bbf\u0ba9\u0bc1\u0ba4"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c05\u0c28\u0c41\u0c2a\u0c2e \u0c17\u0c41\u0c23\u0c3e\u0c2e\u0c4d\u0c2c\u0c41\u0c27\u0c3f\u0c2f\u0c28\u0c3f \u0c28\u0c3f\u0c28\u0c4d\u0c28\u0c41 \u0c28\u0c46\u0c30 \u0c28\u0c2e\u0c4d\u0c2e\u0c3f- <br/> \u0c2f\u0c28\u0c41\u0c38\u0c30\u0c3f\u0c28\u0c4d\u0c1a\u0c3f\u0c28 \u0c35\u0c3e\u0c21\u0c28\u0c48\u0c24\u0c3f"}, {"M": "\u0c05\u0c28\u0c41\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c2e\u0c28\u0c41\u0c2a\u0c15\u0c2f\u0c47\u0c2f\u0c41\u0c28\u0c4d\u0c28\u0c3e\u0c35\u0c41 \u0c2e\u0c28\u0c41 \u0c2a\u0c24\u0c40 \u0c35\u0c4d\u0c30\u0c3e\u0c38\u0c3f <br/> \u0c2e\u0c47\u0c2e\u0c28\u0c41\u0c2a \u0c2e\u0c3e\u0c15\u0c46\u0c35\u0c30\u0c41 \u0c35\u0c3f\u0c28\u0c41\u0c2e\u0c3e \u0c26\u0c2f \u0c30\u0c3e\u0c28\u0c3f"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d 1", "T": "\u0c1c\u0c28\u0c15 \u0c1c\u0c3e\u0c2e\u0c3e\u0c24\u0c35\u0c48 \u0c1c\u0c28\u0c15\u0c1c\u0c3e \u0c2e\u0c3e\u0c24\u0c35\u0c48 <br/> \u0c1c\u0c28\u0c15 \u0c1c\u0c3e\u0c32\u0c2e\u0c41 \u0c1a\u0c3e\u0c32\u0c41 \u0c1a\u0c3e\u0c32\u0c41\u0c28\u0c41 \u0c39\u0c30\u0c3f"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d 2", "T": "\u0c15\u0c28\u0c15 \u0c2a\u0c1f \u0c27\u0c30 \u0c28\u0c28\u0c4d\u0c28\u0c41 \u0c15\u0c28 \u0c15\u0c2a\u0c1f\u0c2e\u0c47\u0c32 \u0c24\u0c28\u0c41 <br/> \u0c15\u0c28\u0c15 \u0c2a\u0c20\u0c28\u0c2e\u0c41 \u0c38\u0c47\u0c24\u0c41 \u0c15\u0c3e\u0c28\u0c3f \u0c2a\u0c42\u0c28\u0c3f"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d 3", "T": "\u0c15\u0c32\u0c32\u0c4b\u0c28 \u0c28\u0c40\u0c35\u0c47 \u0c38\u0c15\u0c32 \u0c32\u0c4b\u0c15 \u0c28\u0c3e\u0c25 <br/> \u0c15\u0c4b\u0c15\u0c32\u0c41 \u0c32\u0c4b\u0c15\u0c41\u0c35 \u0c15\u0c28\u0c3f\u0c1a\u0c4d\u0c1a\u0c3f \u0c15\u0c3e\u0c1a\u0c3f\u0c28\u0c26\u0c3f \u0c35\u0c3f\u0c28\u0c3f"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d 4", "T": "\u0c30\u0c3e\u0c1c \u0c15\u0c41\u0c32 \u0c15\u0c32\u0c36\u0c3e\u0c2c\u0c4d\u0c27\u0c3f \u0c30\u0c3e\u0c1c \u0c38\u0c41\u0c30 \u0c2a\u0c3e\u0c32 \u0c17\u0c1c <br/> \u0c30\u0c3e\u0c1c \u0c30\u0c15\u0c4d\u0c37\u0c15 \u0c24\u0c4d\u0c2f\u0c3e\u0c17\u0c30\u0c3e\u0c1c \u0c35\u0c3f\u0c28\u0c41\u0c24"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0c85\u0ca8\u0cc1\u0caa\u0cae \u0c97\u0cc1\u0ca3\u0cbe\u0cae\u0ccd\u0cac\u0cc1\u0ca7\u0cbf\u0caf\u0ca8\u0cbf \u0ca8\u0cbf\u0ca8\u0ccd\u0ca8\u0cc1 \u0ca8\u0cc6\u0cb0 \u0ca8\u0cae\u0ccd\u0cae\u0cbf- <br/> \u0caf\u0ca8\u0cc1\u0cb8\u0cb0\u0cbf\u0ca8\u0ccd\u0c9a\u0cbf\u0ca8 \u0cb5\u0cbe\u0ca1\u0ca8\u0cc8\u0ca4\u0cbf"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cae\u0ca8\u0cc1\u0caa\u0c95\u0caf\u0cc7\u0caf\u0cc1\u0ca8\u0ccd\u0ca8\u0cbe\u0cb5\u0cc1 \u0cae\u0ca8\u0cc1 \u0caa\u0ca4\u0cc0 \u0cb5\u0ccd\u0cb0\u0cbe\u0cb8\u0cbf <br/> \u0cae\u0cc7\u0cae\u0ca8\u0cc1\u0caa \u0cae\u0cbe\u0c95\u0cc6\u0cb5\u0cb0\u0cc1 \u0cb5\u0cbf\u0ca8\u0cc1\u0cae\u0cbe \u0ca6\u0caf \u0cb0\u0cbe\u0ca8\u0cbf"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd 1", "T": "\u0c9c\u0ca8\u0c95 \u0c9c\u0cbe\u0cae\u0cbe\u0ca4\u0cb5\u0cc8 \u0c9c\u0ca8\u0c95\u0c9c\u0cbe \u0cae\u0cbe\u0ca4\u0cb5\u0cc8 <br/> \u0c9c\u0ca8\u0c95 \u0c9c\u0cbe\u0cb2\u0cae\u0cc1 \u0c9a\u0cbe\u0cb2\u0cc1 \u0c9a\u0cbe\u0cb2\u0cc1\u0ca8\u0cc1 \u0cb9\u0cb0\u0cbf"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd 2", "T": "\u0c95\u0ca8\u0c95 \u0caa\u0c9f \u0ca7\u0cb0 \u0ca8\u0ca8\u0ccd\u0ca8\u0cc1 \u0c95\u0ca8 \u0c95\u0caa\u0c9f\u0cae\u0cc7\u0cb2 \u0ca4\u0ca8\u0cc1 <br/> \u0c95\u0ca8\u0c95 \u0caa\u0ca0\u0ca8\u0cae\u0cc1 \u0cb8\u0cc7\u0ca4\u0cc1 \u0c95\u0cbe\u0ca8\u0cbf \u0caa\u0cc2\u0ca8\u0cbf"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd 3", "T": "\u0c95\u0cb2\u0cb2\u0ccb\u0ca8 \u0ca8\u0cc0\u0cb5\u0cc7 \u0cb8\u0c95\u0cb2 \u0cb2\u0ccb\u0c95 \u0ca8\u0cbe\u0ca5 <br/> \u0c95\u0ccb\u0c95\u0cb2\u0cc1 \u0cb2\u0ccb\u0c95\u0cc1\u0cb5 \u0c95\u0ca8\u0cbf\u0c9a\u0ccd\u0c9a\u0cbf \u0c95\u0cbe\u0c9a\u0cbf\u0ca8\u0ca6\u0cbf \u0cb5\u0cbf\u0ca8\u0cbf"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd 4", "T": "\u0cb0\u0cbe\u0c9c \u0c95\u0cc1\u0cb2 \u0c95\u0cb2\u0cb6\u0cbe\u0cac\u0ccd\u0ca7\u0cbf \u0cb0\u0cbe\u0c9c \u0cb8\u0cc1\u0cb0 \u0caa\u0cbe\u0cb2 \u0c97\u0c9c <br/> \u0cb0\u0cbe\u0c9c \u0cb0\u0c95\u0ccd\u0cb7\u0c95 \u0ca4\u0ccd\u0caf\u0cbe\u0c97\u0cb0\u0cbe\u0c9c \u0cb5\u0cbf\u0ca8\u0cc1\u0ca4"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d05\u0d28\u0d41\u0d2a\u0d2e \u0d17\u0d41\u0d23\u0d3e\u0d2e\u0d4d\u0d2c\u0d41\u0d27\u0d3f\u0d2f\u0d28\u0d3f \u0d28\u0d3f\u0d28\u0d4d\u0d28\u0d41 \u0d28\u0d46\u0d30 \u0d28\u0d2e\u0d4d\u0d2e\u0d3f- <br/> \u0d2f\u0d28\u0d41\u0d38\u0d30\u0d3f\u0d28\u0d4d\u0d1a\u0d3f\u0d28 \u0d35\u0d3e\u0d21\u0d28\u0d48\u0d24\u0d3f"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d2e\u0d28\u0d41\u0d2a\u0d15\u0d2f\u0d47\u0d2f\u0d41\u0d28\u0d4d\u0d28\u0d3e\u0d35\u0d41 \u0d2e\u0d28\u0d41 \u0d2a\u0d24\u0d40 \u0d35\u0d4d\u0d30\u0d3e\u0d38\u0d3f <br/> \u0d2e\u0d47\u0d2e\u0d28\u0d41\u0d2a \u0d2e\u0d3e\u0d15\u0d46\u0d35\u0d30\u0d41 \u0d35\u0d3f\u0d28\u0d41\u0d2e\u0d3e \u0d26\u0d2f \u0d30\u0d3e\u0d28\u0d3f"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 1", "T": "\u0d1c\u0d28\u0d15 \u0d1c\u0d3e\u0d2e\u0d3e\u0d24\u0d35\u0d48 \u0d1c\u0d28\u0d15\u0d1c\u0d3e \u0d2e\u0d3e\u0d24\u0d35\u0d48 <br/> \u0d1c\u0d28\u0d15 \u0d1c\u0d3e\u0d32\u0d2e\u0d41 \u0d1a\u0d3e\u0d32\u0d41 \u0d1a\u0d3e\u0d32\u0d41\u0d28\u0d41 \u0d39\u0d30\u0d3f"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 2", "T": "\u0d15\u0d28\u0d15 \u0d2a\u0d1f \u0d27\u0d30 \u0d28\u0d28\u0d4d\u0d28\u0d41 \u0d15\u0d28 \u0d15\u0d2a\u0d1f\u0d2e\u0d47\u0d32 \u0d24\u0d28\u0d41 <br/> \u0d15\u0d28\u0d15 \u0d2a\u0d20\u0d28\u0d2e\u0d41 \u0d38\u0d47\u0d24\u0d41 \u0d15\u0d3e\u0d28\u0d3f \u0d2a\u0d42\u0d28\u0d3f"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 3", "T": "\u0d15\u0d32\u0d32\u0d4b\u0d28 \u0d28\u0d40\u0d35\u0d47 \u0d38\u0d15\u0d32 \u0d32\u0d4b\u0d15 \u0d28\u0d3e\u0d25 <br/> \u0d15\u0d4b\u0d15\u0d32\u0d41 \u0d32\u0d4b\u0d15\u0d41\u0d35 \u0d15\u0d28\u0d3f\u0d1a\u0d4d\u0d1a\u0d3f \u0d15\u0d3e\u0d1a\u0d3f\u0d28\u0d26\u0d3f \u0d35\u0d3f\u0d28\u0d3f"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 4", "T": "\u0d30\u0d3e\u0d1c \u0d15\u0d41\u0d32 \u0d15\u0d32\u0d36\u0d3e\u0d2c\u0d4d\u0d27\u0d3f \u0d30\u0d3e\u0d1c \u0d38\u0d41\u0d30 \u0d2a\u0d3e\u0d32 \u0d17\u0d1c <br/> \u0d30\u0d3e\u0d1c \u0d30\u0d15\u0d4d\u0d37\u0d15 \u0d24\u0d4d\u0d2f\u0d3e\u0d17\u0d30\u0d3e\u0d1c \u0d35\u0d3f\u0d28\u0d41\u0d24"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0905\u0928\u0941\u092a\u092e \u0917\u0941\u0923\u093e\u092e\u094d\u092c\u0941\u0927\u093f\u092f\u0928\u093f \u0928\u093f\u0928\u094d\u0928\u0941 \u0928\u0947\u0930 \u0928\u092e\u094d\u092e\u093f- <br/> \u092f\u0928\u0941\u0938\u0930\u093f\u0928\u094d\u091a\u093f\u0928 \u0935\u093e\u0921\u0928\u0948\u0924\u093f"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u092e\u0928\u0941\u092a\u0915\u092f\u0947\u092f\u0941\u0928\u094d\u0928\u093e\u0935\u0941 \u092e\u0928\u0941 \u092a\u0924\u0940 \u0935\u094d\u0930\u093e\u0938\u093f <br/> \u092e\u0947\u092e\u0928\u0941\u092a \u092e\u093e\u0915\u0947\u0935\u0930\u0941 \u0935\u093f\u0928\u0941\u092e\u093e \u0926\u092f \u0930\u093e\u0928\u093f"}, {"M": "\u091a\u0930\u0923\u092e\u094d 1", "T": "\u091c\u0928\u0915 \u091c\u093e\u092e\u093e\u0924\u0935\u0948 \u091c\u0928\u0915\u091c\u093e \u092e\u093e\u0924\u0935\u0948 <br/> \u091c\u0928\u0915 \u091c\u093e\u0932\u092e\u0941 \u091a\u093e\u0932\u0941 \u091a\u093e\u0932\u0941\u0928\u0941 \u0939\u0930\u093f"}, {"M": "\u091a\u0930\u0923\u092e\u094d 2", "T": "\u0915\u0928\u0915 \u092a\u091f \u0927\u0930 \u0928\u0928\u094d\u0928\u0941 \u0915\u0928 \u0915\u092a\u091f\u092e\u0947\u0932 \u0924\u0928\u0941 <br/> \u0915\u0928\u0915 \u092a\u0920\u0928\u092e\u0941 \u0938\u0947\u0924\u0941 \u0915\u093e\u0928\u093f \u092a\u0942\u0928\u093f"}, {"M": "\u091a\u0930\u0923\u092e\u094d 3", "T": "\u0915\u0932\u0932\u094b\u0928 \u0928\u0940\u0935\u0947 \u0938\u0915\u0932 \u0932\u094b\u0915 \u0928\u093e\u0925 <br/> \u0915\u094b\u0915\u0932\u0941 \u0932\u094b\u0915\u0941\u0935 \u0915\u0928\u093f\u091a\u094d\u091a\u093f \u0915\u093e\u091a\u093f\u0928\u0926\u093f \u0935\u093f\u0928\u093f"}, {"M": "\u091a\u0930\u0923\u092e\u094d 4", "T": "\u0930\u093e\u091c \u0915\u0941\u0932 \u0915\u0932\u0936\u093e\u092c\u094d\u0927\u093f \u0930\u093e\u091c \u0938\u0941\u0930 \u092a\u093e\u0932 \u0917\u091c <br/> \u0930\u093e\u091c \u0930\u0915\u094d\u0937\u0915 \u0924\u094d\u092f\u093e\u0917\u0930\u093e\u091c \u0935\u093f\u0928\u0941\u0924"}]}], "L": "l", "lyricsref": [{"links": [{"N": "thyagaraja-vaibhavam.blogspot.com", "L": "http://thyagaraja-vaibhavam.blogspot.com/2008/04/thyagaraja-kriti-anupama-guna-raga.html"}, {"N": "www.karnatik.com", "L": "http://www.karnatik.com/c1385.shtml"}, {"N": "www.shivkumar.org", "L": "http://www.shivkumar.org/music/anupamagunambudhi.htm"}, {"N": "www.sangeetasudha.org", "L": "http://www.sangeetasudha.org/thyagaraja/a.html#MARK_ANUPAMA"}]}]}