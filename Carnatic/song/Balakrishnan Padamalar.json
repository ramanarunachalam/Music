0b9a\u0bbe\u0bb9\u0bbf\u0ba4\u0bcd\u0baf\u0bae\u0bcd", "T": "\u0bae\u0bb4\u0bc8 \u0ba4\u0b9f\u0bc1\u0b95\u0bcd\u0b95 \u0b95\u0bcb\u0bb5\u0bb0\u0bcd\u0ba4\u0ba9 \u0bae\u0bb2\u0bc8 \u0b8e\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4 \u0ba4\u0bbf\u0ba3\u0bcd\u0ba4\u0bcb\u0bb3\u0ba9\u0bcd <br/> \u0baa\u0bbf\u0bb4\u0bc8 \u0baa\u0bca\u0bb0\u0bc1\u0ba4\u0bcd\u0ba4\u0bb0\u0bc1\u0bb3\u0bcd \u0ba4\u0baf\u0bbe\u0bb3\u0ba9\u0bcd \u0baa\u0bbf\u0bb0\u0bae\u0ba9\u0bcd \u0baa\u0ba3\u0bbf \u0bae\u0bb2\u0bb0\u0bcd \u0ba4\u0bbe\u0bb3\u0ba9\u0bcd"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c2c\u0c3e\u0c32\u0c15\u0c3f\u0c30\u0c41\u0c37\u0c4d\u0c23\u0c28\u0c4d \u0c2a\u0c3e\u0c26\u0c2e\u0c32\u0c30\u0c4d \u0c2a\u0c23\u0c3f\u0c35\u0c4b\u0c30\u0c4d\u0c15\u0c4d\u0c15\u0c3f\u0c21\u0c30\u0c3f\u0c32\u0c48 \u0c35\u0c30 \u0c17\u0c41\u0c23"}, {"M": "\u0c05\u0c28\u0c41\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c28\u0c40\u0c32 \u0c2e\u0c41\u0c15\u0c3f\u0c32\u0c4d \u0c2a\u0c4b\u0c32\u0c4d \u0c05\u0c34\u0c15\u0c28\u0c4d"}, {"M": "\u0c2e\u0c27\u0c4d\u0c2f\u0c2e\u0c15\u0c3e\u0c32 \u0c38\u0c3e\u0c39\u0c3f\u0c24\u0c4d\u0c2f\u0c2e\u0c4d", "T": "\u0c28\u0c3f\u0c31\u0c48\u0c2e\u0c24\u0c3f \u0c35\u0c24\u0c28\u0c2e\u0c4d \u0c05\u0c24\u0c28\u0c3f\u0c32\u0c4d \u0c07\u0c33 \u0c28\u0c15\u0c48 \u0c28\u0c3f\u0c32\u0c35 \u0c05\u0c30\u0c41\u0c33\u0c4a\u0c33\u0c3f \u0c24\u0c35\u0c34\u0c41\u0c2e\u0c4d"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c15\u0c4b\u0c15\u0c41\u0c32\u0c2e\u0c4d \u0c2a\u0c4d\u0c30\u0c41\u0c28\u0c4d\u0c24\u0c3e\u0c35\u0c28\u0c2e\u0c4d \u0c2f\u0c2e\u0c41\u0c28\u0c3e \u0c35\u0c3f\u0c39\u0c3e\u0c30\u0c40 \u0c15\u0c4b\u0c2a\u0c3e\u0c32\u0c28\u0c4d <br/> \u0c15\u0c4b\u0c2a\u0c40 \u0c1c\u0c28 \u0c2e\u0c28 \u0c2e\u0c4b\u0c39\u0c28 \u0c2e\u0c41\u0c30\u0c33\u0c40 \u0c15\u0c3e\u0c28 \u0c35\u0c3f\u0c32\u0c4b\u0c32\u0c28\u0c4d\u0c35\u0c4d\u0c2f\u0c3e\u0c15\u0c41\u0c32\u0c2e\u0c4d <br/> \u0c24\u0c35\u0c3f\u0c30\u0c4d\u0c24\u0c4d\u0c24\u0c28\u0c4d\u0c2a\u0c30\u0c4d \u0c2e\u0c28\u0c24\u0c3f\u0c32\u0c4d \u0c35\u0c3e\u0c34\u0c4d \u0c15\u0c30\u0c41\u0c23\u0c3e\u0c32 \u0c35\u0c3e\u0c32\u0c28\u0c4d"}, {"M": "\u0c2e\u0c27\u0c4d\u0c2f\u0c2e\u0c15\u0c3e\u0c32 \u0c38\u0c3e\u0c39\u0c3f\u0c24\u0c4d\u0c2f\u0c2e\u0c4d", "T": "\u0c2e\u0c34\u0c48 \u0c24\u0c1f\u0c41\u0c15\u0c4d\u0c15 \u0c15\u0c4b\u0c35\u0c30\u0c4d\u0c24\u0c28 \u0c2e\u0c32\u0c48 \u0c0e\u0c1f\u0c41\u0c24\u0c4d\u0c24 \u0c24\u0c3f\u0c23\u0c4d\u0c24\u0c4b\u0c33\u0c28\u0c4d <br/> \u0c2a\u0c3f\u0c34\u0c48 \u0c2a\u0c4a\u0c30\u0c41\u0c24\u0c4d\u0c24\u0c30\u0c41\u0c33\u0c4d \u0c24\u0c2f\u0c3e\u0c33\u0c28\u0c4d \u0c2a\u0c3f\u0c30\u0c2e\u0c28\u0c4d \u0c2a\u0c23\u0c3f \u0c2e\u0c32\u0c30\u0c4d \u0c24\u0c3e\u0c33\u0c28\u0c4d"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cac\u0cbe\u0cb2\u0c95\u0cbf\u0cb0\u0cc1\u0cb7\u0ccd\u0ca3\u0ca8\u0ccd \u0caa\u0cbe\u0ca6\u0cae\u0cb2\u0cb0\u0ccd \u0caa\u0ca3\u0cbf\u0cb5\u0ccb\u0cb0\u0ccd\u0c95\u0ccd\u0c95\u0cbf\u0ca1\u0cb0\u0cbf\u0cb2\u0cc8 \u0cb5\u0cb0 \u0c97\u0cc1\u0ca3"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0ca8\u0cc0\u0cb2 \u0cae\u0cc1\u0c95\u0cbf\u0cb2\u0ccd \u0caa\u0ccb\u0cb2\u0ccd \u0c85\u0cb3\u0c95\u0ca8\u0ccd"}, {"M": "\u0cae\u0ca7\u0ccd\u0caf\u0cae\u0c95\u0cbe\u0cb2 \u0cb8\u0cbe\u0cb9\u0cbf\u0ca4\u0ccd\u0caf\u0cae\u0ccd", "T": "\u0ca8\u0cbf\u0cb1\u0cc8\u0cae\u0ca4\u0cbf \u0cb5\u0ca4\u0ca8\u0cae\u0ccd \u0c85\u0ca4\u0ca8\u0cbf\u0cb2\u0ccd \u0c87\u0cb3 \u0ca8\u0c95\u0cc8 \u0ca8\u0cbf\u0cb2\u0cb5 \u0c85\u0cb0\u0cc1\u0cb3\u0cca\u0cb3\u0cbf \u0ca4\u0cb5\u0cb3\u0cc1\u0cae\u0ccd"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0c95\u0ccb\u0c95\u0cc1\u0cb2\u0cae\u0ccd \u0caa\u0ccd\u0cb0\u0cc1\u0ca8\u0ccd\u0ca4\u0cbe\u0cb5\u0ca8\u0cae\u0ccd \u0caf\u0cae\u0cc1\u0ca8\u0cbe \u0cb5\u0cbf\u0cb9\u0cbe\u0cb0\u0cc0 \u0c95\u0ccb\u0caa\u0cbe\u0cb2\u0ca8\u0ccd <br/> \u0c95\u0ccb\u0caa\u0cc0 \u0c9c\u0ca8 \u0cae\u0ca8 \u0cae\u0ccb\u0cb9\u0ca8 \u0cae\u0cc1\u0cb0\u0cb3\u0cc0 \u0c95\u0cbe\u0ca8 \u0cb5\u0cbf\u0cb2\u0ccb\u0cb2\u0ca8\u0ccd\u0cb5\u0ccd\u0caf\u0cbe\u0c95\u0cc1\u0cb2\u0cae\u0ccd <br/> \u0ca4\u0cb5\u0cbf\u0cb0\u0ccd\u0ca4\u0ccd\u0ca4\u0ca8\u0ccd\u0caa\u0cb0\u0ccd \u0cae\u0ca8\u0ca4\u0cbf\u0cb2\u0ccd \u0cb5\u0cbe\u0cb3\u0ccd \u0c95\u0cb0\u0cc1\u0ca3\u0cbe\u0cb2 \u0cb5\u0cbe\u0cb2\u0ca8\u0ccd"}, {"M": "\u0cae\u0ca7\u0ccd\u0caf\u0cae\u0c95\u0cbe\u0cb2 \u0cb8\u0cbe\u0cb9\u0cbf\u0ca4\u0ccd\u0caf\u0cae\u0ccd", "T": "\u0cae\u0cb3\u0cc8 \u0ca4\u0c9f\u0cc1\u0c95\u0ccd\u0c95 \u0c95\u0ccb\u0cb5\u0cb0\u0ccd\u0ca4\u0ca8 \u0cae\u0cb2\u0cc8 \u0c8e\u0c9f\u0cc1\u0ca4\u0ccd\u0ca4 \u0ca4\u0cbf\u0ca3\u0ccd\u0ca4\u0ccb\u0cb3\u0ca8\u0ccd <br/> \u0caa\u0cbf\u0cb3\u0cc8 \u0caa\u0cca\u0cb0\u0cc1\u0ca4\u0ccd\u0ca4\u0cb0\u0cc1\u0cb3\u0ccd \u0ca4\u0caf\u0cbe\u0cb3\u0ca8\u0ccd \u0caa\u0cbf\u0cb0\u0cae\u0ca8\u0ccd \u0caa\u0ca3\u0cbf \u0cae\u0cb2\u0cb0\u0ccd \u0ca4\u0cbe\u0cb3\u0ca8\u0ccd"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d2c\u0d3e\u0d32\u0d15\u0d3f\u0d30\u0d41\u0d37\u0d4d\u0d23\u0d28\u0d4d \u0d2a\u0d3e\u0d26\u0d2e\u0d32\u0d30\u0d4d \u0d2a\u0d23\u0d3f\u0d35\u0d4b\u0d30\u0d4d\u0d15\u0d4d\u0d15\u0d3f\u0d21\u0d30\u0d3f\u0d32\u0d48 \u0d35\u0d30 \u0d17\u0d41\u0d23"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d28\u0d40\u0d32 \u0d2e\u0d41\u0d15\u0d3f\u0d32\u0d4d \u0d2a\u0d4b\u0d32\u0d4d \u0d05\u0d34\u0d15\u0d28\u0d4d"}, {"M": "\u0d2e\u0d27\u0d4d\u0d2f\u0d2e\u0d15\u0d3e\u0d32 \u0d38\u0d3e\u0d39\u0d3f\u0d24\u0d4d\u0d2f\u0d2e\u0d4d", "T": "\u0d28\u0d3f\u0d31\u0d48\u0d2e\u0d24\u0d3f \u0d35\u0d24\u0d28\u0d2e\u0d4d \u0d05\u0d24\u0d28\u0d3f\u0d32\u0d4d \u0d07\u0d33 \u0d28\u0d15\u0d48 \u0d28\u0d3f\u0d32\u0d35 \u0d05\u0d30\u0d41\u0d33\u0d4a\u0d33\u0d3f \u0d24\u0d35\u0d34\u0d41\u0d2e\u0d4d"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d15\u0d4b\u0d15\u0d41\u0d32\u0d2e\u0d4d \u0d2a\u0d4d\u0d30\u0d41\u0d28\u0d4d\u0d24\u0d3e\u0d35\u0d28\u0d2e\u0d4d \u0d2f\u0d2e\u0d41\u0d28\u0d3e \u0d35\u0d3f\u0d39\u0d3e\u0d30\u0d40 \u0d15\u0d4b\u0d2a\u0d3e\u0d32\u0d28\u0d4d <br/> \u0d15\u0d4b\u0d2a\u0d40 \u0d1c\u0d28 \u0d2e\u0d28 \u0d2e\u0d4b\u0d39\u0d28 \u0d2e\u0d41\u0d30\u0d33\u0d40 \u0d15\u0d3e\u0d28 \u0d35\u0d3f\u0d32\u0d4b\u0d32\u0d28\u0d4d\u0d35\u0d4d\u0d2f\u0d3e\u0d15\u0d41\u0d32\u0d2e\u0d4d <br/> \u0d24\u0d35\u0d3f\u0d30\u0d4d\u0d24\u0d4d\u0d24\u0d28\u0d4d\u0d2a\u0d30\u0d4d \u0d2e\u0d28\u0d24\u0d3f\u0d32\u0d4d \u0d35\u0d3e\u0d34\u0d4d \u0d15\u0d30\u0d41\u0d23\u0d3e\u0d32 \u0d35\u0d3e\u0d32\u0d28\u0d4d"}, {"M": "\u0d2e\u0d27\u0d4d\u0d2f\u0d2e\u0d15\u0d3e\u0d32 \u0d38\u0d3e\u0d39\u0d3f\u0d24\u0d4d\u0d2f\u0d2e\u0d4d", "T": "\u0d2e\u0d34\u0d48 \u0d24\u0d1f\u0d41\u0d15\u0d4d\u0d15 \u0d15\u0d4b\u0d35\u0d30\u0d4d\u0d24\u0d28 \u0d2e\u0d32\u0d48 \u0d0e\u0d1f\u0d41\u0d24\u0d4d\u0d24 \u0d24\u0d3f\u0d23\u0d4d\u0d24\u0d4b\u0d33\u0d28\u0d4d <br/> \u0d2a\u0d3f\u0d34\u0d48 \u0d2a\u0d4a\u0d30\u0d41\u0d24\u0d4d\u0d24\u0d30\u0d41\u0d33\u0d4d \u0d24\u0d2f\u0d3e\u0d33\u0d28\u0d4d \u0d2a\u0d3f\u0d30\u0d2e\u0d28\u0d4d \u0d2a\u0d23\u0d3f \u0d2e\u0d32\u0d30\u0d4d \u0d24\u0d3e\u0d33\u0d28\u0d4d"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u092c\u093e\u0932\u0915\u093f\u0930\u0941\u0937\u094d\u0923\u0928\u094d \u092a\u093e\u0926\u092e\u0932\u0930\u094d \u092a\u0923\u093f\u0935\u094b\u0930\u094d\u0915\u094d\u0915\u093f\u0921\u0930\u093f\u0932\u0948 \u0935\u0930 \u0917\u0941\u0923"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0928\u0940\u0932 \u092e\u0941\u0915\u093f\u0932\u094d \u092a\u094b\u0932\u094d \u0905\u0932\u0915\u0928\u094d"}, {"M": "\u092e\u0927\u094d\u092f\u092e\u0915\u093e\u0932 \u0938\u093e\u0939\u093f\u0924\u094d\u092f\u092e\u094d", "T": "\u0928\u093f\u0930\u0948\u092e\u0924\u093f \u0935\u0924\u0928\u092e\u094d \u0905\u0924\u0928\u093f\u0932\u094d \u0907\u0932 \u0928\u0915\u0948 \u0928\u093f\u0932\u0935 \u0905\u0930\u0941\u0932\u094b\u0932\u093f \u0924\u0935\u0932\u0941\u092e\u094d"}, {"M": "\u091a\u0930\u0923\u092e\u094d", "T": "\u0915\u094b\u0915\u0941\u0932\u092e\u094d \u092a\u094d\u0930\u0941\u0928\u094d\u0924\u093e\u0935\u0928\u092e\u094d \u092f\u092e\u0941\u0928\u093e \u0935\u093f\u0939\u093e\u0930\u0940 \u0915\u094b\u092a\u093e\u0932\u0928\u094d <br/> \u0915\u094b\u092a\u0940 \u091c\u0928 \u092e\u0928 \u092e\u094b\u0939\u0928 \u092e\u0941\u0930\u0932\u0940 \u0915\u093e\u0928 \u0935\u093f\u0932\u094b\u0932\u0928\u094d\u0935\u094d\u092f\u093e\u0915\u0941\u0932\u092e\u094d <br/> \u0924\u0935\u093f\u0930\u094d\u0924\u094d\u0924\u0928\u094d\u092a\u0930\u094d \u092e\u0928\u0924\u093f\u0932\u094d \u0935\u093e\u0932\u094d \u0915\u0930\u0941\u0923\u093e\u0932 \u0935\u093e\u0932\u0928\u094d"}, {"M": "\u092e\u0927\u094d\u092f\u092e\u0915\u093e\u0932 \u0938\u093e\u0939\u093f\u0924\u094d\u092f\u092e\u094d", "T": "\u092e\u0932\u0948 \u0924\u091f\u0941\u0915\u094d\u0915 \u0915\u094b\u0935\u0930\u094d\u0924\u0928 \u092e\u0932\u0948 \u090f\u091f\u0941\u0924\u094d\u0924 \u0924\u093f\u0923\u094d\u0924\u094b\u0932\u0928\u094d <br/> \u092a\u093f\u0932\u0948 \u092a\u094b\u0930\u0941\u0924\u094d\u0924\u0930\u0941\u0932\u094d \u0924\u092f\u093e\u0932\u0928\u094d \u092a\u093f\u0930\u092e\u0928\u094d \u092a\u0923\u093f \u092e\u0932\u0930\u094d \u0924\u093e\u0932\u0928\u094d"}]}], "L": "l", "lyricsref": [{"links": [{"N": "periscope-narada.blogspot.com", "L": "http://periscope-narada.blogspot.com/2018/04/balakrishnan-pada-malar.html"}]}]}