\u0c28\u0c38\u0c3e"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d 1", "T": "\u0c39\u0c30\u0c3f \u0c05\u0c35\u0c24\u0c3e\u0c30\u0c2e\u0c41\u0c32\u0c47 \u0c05\u0c16\u0c3f\u0c32 \u0c26\u0c47\u0c35\u0c24\u0c32\u0c41 \u0c39\u0c30\u0c3f \u0c32\u0c4b\u0c28\u0c3f \u0c35\u0c47 \u0c2c\u0c4d\u0c30\u0c39\u0c4d\u0c2e\u0c3e\u0c23\u0c4d\u0c21\u0c2e\u0c4d\u0c2c\u0c41\u0c32\u0c41 <br/> \u0c39\u0c30\u0c3f \u0c28\u0c3e\u0c2e\u0c2e\u0c41\u0c32\u0c47 \u0c05\u0c28\u0c4d\u0c28\u0c3f \u0c2e\u0c28\u0c4d\u0c24\u0c4d\u0c30\u0c2e\u0c41\u0c32\u0c41 \u0c39\u0c30\u0c3f \u0c39\u0c30\u0c3f \u0c39\u0c30\u0c3f \u0c39\u0c30\u0c3f \u0c05\u0c28\u0c35\u0c4b \u0c2e\u0c28\u0c38\u0c3e"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d 2", "T": "\u0c35\u0c3f\u0c37\u0c4d\u0c23\u0c41\u0c28\u0c3f \u0c2e\u0c39\u0c3f\u0c2e\u0c32\u0c47 \u0c35\u0c3f\u0c39\u0c3f\u0c24 \u0c15\u0c30\u0c4d\u0c2e\u0c2e\u0c41\u0c32\u0c41 \u0c35\u0c3f\u0c37\u0c4d\u0c23\u0c41\u0c28\u0c3f \u0c2a\u0c4a\u0c17\u0c21\u0c46\u0c21\u0c3f \u0c35\u0c47\u0c26\u0c2e\u0c4d\u0c2c\u0c41\u0c32\u0c41 <br/> \u0c35\u0c3f\u0c37\u0c4d\u0c23\u0c41\u0c26\u0c4a\u0c15\u0c4d\u0c15\u0c26\u0c47 \u0c35\u0c3f\u0c36\u0c4d\u0c35\u0c3e\u0c28\u0c4d\u0c24\u0c30\u0c3e\u0c26\u0c2e\u0c41\u0c21\u0c41 \u0c35\u0c3f\u0c37\u0c4d\u0c23\u0c41\u0c35\u0c41 \u0c35\u0c3f\u0c37\u0c4d\u0c23\u0c41\u0c35\u0c28\u0c3f \u0c35\u0c46\u0c26\u0c15\u0c35\u0c4b \u0c2e\u0c28\u0c38\u0c3e"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d 3", "T": "\u0c05\u0c1a\u0c4d\u0c2f\u0c41\u0c24\u0c41\u0c21\u0c3f\u0c24\u0c26\u0c47 \u0c06\u0c26\u0c3f\u0c2f\u0c41 \u0c05\u0c28\u0c4d\u0c24\u0c4d\u0c2f\u0c2e\u0c41 \u0c05\u0c1a\u0c4d\u0c2f\u0c41\u0c24\u0c41\u0c26\u0c47 \u0c05\u0c38\u0c41\u0c30\u0c3e\u0c28\u0c4d\u0c24\u0c15\u0c41\u0c21\u0c41 <br/> \u0c05\u0c1a\u0c4d\u0c2f\u0c41\u0c24\u0c41\u0c21\u0c41 \u0c36\u0c4d\u0c30\u0c40 \u0c35\u0c46\u0c02\u0c15\u0c24\u0c3e\u0c26\u0c4d\u0c30\u0c3f \u0c2e\u0c40\u0c26\u0c28\u0c3f\u0c24\u0c47 \u0c05\u0c1a\u0c4d\u0c2f\u0c41\u0c24\u0c3e \u0c05\u0c1a\u0c4d\u0c2f\u0c41\u0c24\u0c3e \u0c36\u0c30\u0c23\u0c35\u0c4b \u0