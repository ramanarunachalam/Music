cc1\u0ca6\u0cc7 \u0c85\u0cb8\u0cc1\u0cb0\u0cbe\u0ca8\u0ccd\u0ca4\u0c95\u0cc1\u0ca1\u0cc1 <br/> \u0c85\u0c9a\u0ccd\u0caf\u0cc1\u0ca4\u0cc1\u0ca1\u0cc1 \u0cb6\u0ccd\u0cb0\u0cc0 \u0cb5\u0cc6\u0c82\u0c95\u0ca4\u0cbe\u0ca6\u0ccd\u0cb0\u0cbf \u0cae\u0cc0\u0ca6\u0ca8\u0cbf\u0ca4\u0cc7 \u0c85\u0c9a\u0ccd\u0caf\u0cc1\u0ca4\u0cbe \u0c85\u0c9a\u0ccd\u0caf\u0cc1\u0ca4\u0cbe \u0cb6\u0cb0\u0ca3\u0cb5\u0ccb \u0cae\u0ca8\u0cb8\u0cbe"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d2d\u0d3e\u0d35\u0d2e\u0d41\u0d32\u0d4b\u0d28 \u0d2c\u0d3e\u0d39\u0d2f\u0d2e\u0d41\u0d32\u0d28\u0d4d\u0d26\u0d41\u0d28\u0d41 \u0d17\u0d4b\u0d35\u0d3f\u0d28\u0d4d\u0d26\u0d3e \u0d17\u0d4b\u0d35\u0d3f\u0d28\u0d4d\u0d26\u0d3e \u0d05\u0d28\u0d3f \u0d15\u0d4a\u0d32\u0d41\u0d35\u0d35\u0d4b \u0d2e\u0d28\u0d38\u0d3e"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 1", "T": "\u0d39\u0d30\u0d3f \u0d05\u0d35\u0d24\u0d3e\u0d30\u0d2e\u0d41\u0d32\u0d47 \u0d05\u0d16\u0d3f\u0d32 \u0d26\u0d47\u0d35\u0d24\u0d32\u0d41 \u0d39\u0d30\u0d3f \u0d32\u0d4b\u0d28\u0d3f \u0d35\u0d47 \u0d2c\u0d4d\u0d30\u0d39\u0d4d\u0d2e\u0d3e\u0d23\u0d4d\u0d21\u0d2e\u0d4d\u0d2c\u0d41\u0d32\u0d41 <br/> \u0d39\u0d30\u0d3f \u0d28\u0d3e\u0d2e\u0d2e\u0d41\u0d32\u0d47 \u0d05\u0d28\u0d4d\u0d28\u0d3f \u0d2e\u0d28\u0d4d\u0d24\u0d4d\u0d30\u0d2e\u0d41\u0d32\u0d41 \u0d39\u0d30\u0d3f \u0d39\u0d30\u0d3f \u0d39\u0d30\u0d3f \u0d39\u0d30\u0d3f \u0d05\u0d28\u0d35\u0d4b \u0d2e\u0d28\u0d38\u0d3e"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 2", "T": "\u0d35\u0d3f\u0d37\u0d4d\u0d23\u0d41\u0d28\u0d3f \u0d2e\u0d39\u0d3f\u0d2e\u0d32\u0d47 \u0d35\u0d3f\u0d39\u0d3f\u0d24 \u0d15\u0d30\u0d4d\u0d2e\u0d2e\u0d41\u0d32\u0d41 \u0d35\u0d3f\u0d37\u0d4d\u0d23\u0d41\u0d28\u0d3f \u0d2a\u0d4a\u0d17\u0d21\u0d46\u0d21\u0d3f \u0d35\u0d47\u0d26\u0d2e\u0d4d\u0d2c\u0d41\u0d32\u0d41 <br/> \u0d35\u0d3f\u0d37\u0d4d\u0d23\u0d41\u0d26\u0d4a\u0d15\u0d4d\u0d15\u0d26\u0d47 \u0d35\u0d3f\u0d36\u0d4d\u0d35\u0d3e\u0d28\u0d4d\u0d24\u0d30\u0d3e\u0d26\u0d2e\u0d41\u0d21\u0d41 \u0d35\u0d3f\u0d37\u0d4d\u0d23\u0d41\u0d35\u0d41 \u0d35\u0d3f\u0d37\u0d4d\u0d23\u0d41\u0d35\u0d28\u0d3f \u0d35\u0d46\u0d26\u0d15\u0d35\u0d4b \u0d2e\u0d28\u0d38\u0d3e"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 3", "T": "\u0d05\u0d1a\u0d4d\u0d2f\u0d41\u0d24\u0d41\u0d21\u0d3f\u0d24\u0d26\u0d47 \u0d06\u0d26\u0d3f\u0d2f\u0d41 \u0d05\u0d28\u0d4d\u0d24\u0d4d\u0d2f\u0d2e\u0d41 \u0d05\u0d1a\u0d4d\u0d2f\u0d41\u0d24\u0d41\u0d26\u0d47 \u0d05\u0d38\u0d41\u0d30\u0d3e\u0d28\u0d4d\u0d24\u0d15\u0d41\u0d21\u0d41 <br/> \u0d05\u0d1a\u0d4d\u0d2f\u0d41\u0d24\u0d41\u0d21\u0d41 \u0d36\u0d4d\u0d30\u0d40 \u0d35\u0d46\u0d02\u0d15\u0d24\u0d3e\u0d26\u0d4d\u0d30\u0d3f \u0d2e\u0d40\u0d26\u0d28\u0d3f\u0d24\u0d47 \u0d05\u0d1a\u0d4d\u0d2f\u0d41\u0d24\u0d3e \u0d05\u0d1a\u0d4d\u0d2f\u0d41\u0d24\u0d3e \u0d36\u0d30\u0d23\u0d35\u0d4b \u0d2e\u0d28\u0d38\u0d3e"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u092d\u093e\u0935\u092e\u0941\u0932\u094b\u0928 \u092c\u093e\u0939\u092f\u092e\u0941\u0932\u0928\u094d\u0926\u0941\u0928\u0941 \u0917\u094b\u0935\u093f\u0928\u094d\u0926\u093e \u0917\u094b\u0935\u093f\u0928\u094d\u0926\u093e \u0905\u0928\u093f \u0915\u094b\u0932\u0941\u0935\u0935\u094b \u092e\u0928\u0938\u093e"}, {"M": "\u091a\u0930\u0923\u092e\u094d 1", "T": "\u0939\u0930\u093f \u0905\u0935\u0924\u093e\u0930\u092e\u0941\u0932\u0947 \u0905\u0916\u093f\u0932 \u0926\u0947\u0935\u0924\u0932\u0941 \u0939\u0930\u093f \u0932\u094b\u0928\u093f \u0935\u0947 \u092c\u094d\u0930\u0939\u094d\u092e\u093e\u0923\u094d\u0921\u092e\u094d\u092c\u0941\u0932\u0941 <br/> \u0939\u0930\u093f \u0928\u093e\u092e\u092e\u0941\u0932\u0947 \u0905\u0928\u094d\u0928\u093f \u092e\u0928\u094d\u0924\u094d\u0930\u092e\u0941\u0932\u0941 \u0939\u0930\u093f \u0939\u0930\u093f \u0939\u0930\u093f \u0939\u0930\u093f \u0905\u0928\u0935\u094b \u092e\u0928\u0938\u093e"}, {"M": "\u091a\u0930\u0923\u092e\u094d 2", "T": "\u0935\u093f\u0937\u094d\u0923\u0941\u0928\u093f \u092e\u0939\u093f\u092e\u0932\u0947 \u0935\u093f\u0939\u093f\u0924 \u0915\u0930\u094d\u092e\u092e\u0941\u0932\u0941 \u0935\u093f\u0937\u094d\u0923\u0941\u0928\u093f \u092a\u094b\u0917\u0921\u0947\u0921\u093f \u0935\u0947\u0926\u092e\u094d\u092c\u0941\u0932\u0941 <br/> \u0935\u093f\u0937\u094d\u0923\u0941\u0926\u094b\u0915\u094d\u0915\u0926\u0947 \u0935\u093f\u0936\u094d\u0935\u093e\u0928\u094d\u0924\u0930\u093e\u0926\u092e\u0941\u0921\u0941 \u0935\u093f\u0937\u094d\u0923\u0941\u0935\u0941 \u0935\u093f\u0937\u094d\u0923\u0941\u0935\u0928\u093f \u0935\u0947\u0926\u0915\u0935\u094b \u092e\u0928\u0938\u093e"}, {"M": "\u091a\u0930\u0923\u092e\u094d 3", "T": "\u0905\u091a\u094d\u092f\u0941\u0924\u0941\u0921\u093f\u0924\u0926\u0947 \u0906\u0926\u093f\u092f\u0941 \u0905\u0928\u094d\u0924\u094d\u092f\u092e\u0941 \u0905\u091a\u094d\u092f\u0941\u0924\u0941\u0926\u0947 \u0905\u0938\u0941\u0930\u093e\u0928\u094d\u0924\u0915\u0941\u0921\u0941 <br/> \u0905\u091a\u094d\u092f\u0941\u0924\u0941\u0921\u0941 \u0936\u094d\u0930\u0940 \u0935\u0947\u0902\u0915\u0924\u093e\u0926\u094d\u0930\u093f \u092e\u0940\u0926\u0928\u093f\u0924\u0947 \u0905\u091a\u094d\u092f\u0941\u0924\u093e \u0905\u091a\u094d\u092f\u0941\u0924\u093e \u0936\u0930\u0923\u0935\u094b \u092e\u0928\u0938\u093e"}]}], "L": "l", "lyricsref": [{"links": [{"N": "www.karnatik.com", "L": "http://www.karnatik.com/c1444.shtml"}]}]}