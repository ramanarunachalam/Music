0ccd\u0caf\u0cbe\u0cae\u0cb3\u0cbe\u0cae\u0ccd\u0cac\u0cbe \u0c8f\u0c95\u0cbe\u0cae\u0ccd\u0cb0\u0cc7\u0cb7\u0ccd\u0cb5\u0cb0 \u0caa\u0ccd\u0cb0\u0cbf\u0caf\u0cbe <br/> \u0ca4\u0cbe\u0cae\u0cb8\u0cae\u0cc1 \u0cb8\u0cc7\u0caf\u0c95\u0ca8\u0cc7 \u0c95\u0cbe\u0cae\u0cbe\u0c95\u0ccd\u0cb6\u0cae\u0ccd\u0cae\u0cbe \u0cae\u0cbe\u0caf\u0cae\u0ccd\u0cae\u0cbe <br/> \u0ca8\u0cbe \u0caa\u0cb0\u0cbf\u0ca4\u0cbe\u0caa\u0cae\u0cc1\u0cb2\u0ca8\u0cc1 \u0caa\u0cb0\u0cbf\u0cb9\u0cb0\u0cbf\u0ca8\u0ccd\u0c9a\u0cbf \u0ca8\u0ca8\u0cc1"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d2c\u0d4d\u0d30\u0d4b\u0d35\u0d35\u0d2e\u0d4d\u0d2e\u0d3e \u0d2c\u0d02\u0d17\u0d3e\u0d30\u0d41 \u0d2c\u0d4a\u0d2e\u0d4d\u0d2e\u0d3e \u0d2e\u0d3e\u0d2f\u0d2e\u0d4d\u0d2e\u0d3e \u0d28\u0d28\u0d41 \u0d2c\u0d4d\u0d30\u0d4b\u0d35"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d2c\u0d4d\u0d30\u0d4b\u0d35\u0d35\u0d2e\u0d4d\u0d2e\u0d3e \u0d28\u0d3e\u0d24\u0d4b \u0d2e\u0d3e\u0d1f\u0d4d\u0d32\u0d3e\u0d21\u0d35\u0d2e\u0d4d\u0d2e\u0d3e <br/> \u0d38\u0d3e\u0d30\u0d4d\u0d35\u0d2d\u0d4c\u0d2e \u0d2c\u0d4a\u0d2e\u0d4d\u0d2e\u0d3e \u0d15\u0d3e\u0d2e\u0d3e\u0d15\u0d4d\u0d36\u0d2e\u0d4d\u0d2e\u0d3e \u0d28\u0d28\u0d41"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d37\u0d4d\u0d2f\u0d3e\u0d2e \u0d15\u0d43\u0d36\u0d4d\u0d23 \u0d2a\u0d42\u0d1c\u0d3f\u0d24\u0d3e \u0d38\u0d41\u0d32\u0d32\u0d3f\u0d24\u0d3e <br/> \u0d37\u0d4d\u0d2f\u0d3e\u0d2e\u0d33\u0d3e\u0d2e\u0d4d\u0d2c\u0d3e \u0d0f\u0d15\u0d3e\u0d2e\u0d4d\u0d30\u0d47\u0d37\u0d4d\u0d35\u0d30 \u0d2a\u0d4d\u0d30\u0d3f\u0d2f\u0d3e <br/> \u0d24\u0d3e\u0d2e\u0d38\u0d2e\u0d41 \u0d38\u0d47\u0d2f\u0d15\u0d28\u0d47 \u0d15\u0d3e\u0d2e\u0d3e\u0d15\u0d4d\u0d36\u0d2e\u0d4d\u0d2e\u0d3e \u0d2e\u0d3e\u0d2f\u0d2e\u0d4d\u0d2e\u0d3e <br/> \u0d28\u0d3e \u0d2a\u0d30\u0d3f\u0d24\u0d3e\u0d2a\u0d2e\u0d41\u0d32\u0d28\u0d41 \u0d2a\u0d30\u0d3f\u0d39\u0d30\u0d3f\u0d28\u0d4d\u0d1a\u0d3f \u0d28\u0d28\u0d41"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u092c\u094d\u0930\u094b\u0935\u0935\u092e\u094d\u092e\u093e \u092c\u0902\u0917\u093e\u0930\u0941 \u092c\u094b\u092e\u094d\u092e\u093e \u092e\u093e\u092f\u092e\u094d\u092e\u093e \u0928\u0928\u0941 \u092c\u094d\u0930\u094b\u0935"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u092c\u094d\u0930\u094b\u0935\u0935\u092e\u094d\u092e\u093e \u0928\u093e\u0924\u094b \u092e\u093e\u091f\u094d\u0932\u093e\u0921\u0935\u092e\u094d\u092e\u093e <br/> \u0938\u093e\u0930\u094d\u0935\u092d\u094c\u092e \u092c\u094b\u092e\u094d\u092e\u093e \u0915\u093e\u092e\u093e\u0915\u094d\u0936\u092e\u094d\u092e\u093e \u0928\u0928\u0941"}, {"M": "\u091a\u0930\u0923\u092e\u094d", "T": "\u0937\u094d\u092f\u093e\u092e \u0915\u0943\u0936\u094d\u0923 \u092a\u0942\u091c\u093f\u0924\u093e \u0938\u0941\u0932\u0932\u093f\u0924\u093e <br/> \u0937\u094d\u092f\u093e\u092e\u0932\u093e\u092e\u094d\u092c\u093e \u090f\u0915\u093e\u092e\u094d\u0930\u0947\u0937\u094d\u0935\u0930 \u092a\u094d\u0930\u093f\u092f\u093e <br/> \u0924\u093e\u092e\u0938\u092e\u0941 \u0938\u0947\u092f\u0915\u0928\u0947 \u0915\u093e\u092e\u093e\u0915\u094d\u0936\u092e\u094d\u092e\u093e \u092e\u093e\u092f\u092e\u094d\u092e\u093e <br/> \u0928\u093e \u092a\u0930\u093f\u0924\u093e\u092a\u092e\u0941\u0932\u0928\u0941 \u092a\u0930\u093f\u0939\u0930\u093f\u0928\u094d\u091a\u093f \u0928\u0928\u0941"}]}], "L": "l", "lyricsref": [{"links": [{"N": "www.medieval.org", "L": "http://www.medieval.org/music/world/carnatic/lyrics/TKG/brova_vamma_bangaru.html"}, {"N": "syamakrishnavaibhavam.blogspot.com", "L": "http://syamakrishnavaibhavam.blogspot.com/2011/06/syama-sastry-kriti-brovavamma-raga.html"}, {"N": "www.sangeetasudha.org", "L": "http://www.sangeetasudha.org/othercomposers/syamasastry2.html#MARK_BROVAVAMMA"}]}]}