l", "text": [{"M": "\u0baa\u0bb2\u0bcd\u0bb2\u0bb5\u0bbf", "T": "\u0ba4\u0bc1\u0bb0\u0bcd\u0bae\u0bbe\u0bb0\u0bcd\u0b95 \u0b9a\u0bb0\u0bbe\u0ba4\u0bae\u0bc1\u0bb2\u0ba9\u0bc1 <br/> \u0ba4\u0bca\u0bb0 \u0ba8\u0bc0\u0bb5\u0ba9 \u0b9c\u0bbe\u0bb2\u0bb0"}, {"M": "\u0b85\u0ba9\u0bc1\u0baa\u0bb2\u0bcd\u0bb2\u0bb5\u0bbf", "T": "\u0ba4\u0bb0\u0bcd\u0bae\u0bbe\u0ba4\u0bcd\u0bae\u0b95 \u0ba4\u0ba9 \u0ba4\u0bbe\u0ba9\u0bcd\u0baf <br/> \u0ba4\u0bc8\u0bb5\u0bae\u0bc1 \u0ba8\u0bc0\u0bb5\u0bc8\u0baf\u0bc1\u0ba3\u0bcd\u0b9f\u0b95"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd", "T": "\u0baa\u0bb2\u0bc1\u0b95\u0bc1 \u0baa\u0bcb\u0b9f\u0bbf\u0ba9\u0bbf \u0b9a\u0baa\u0bb2\u0bcb\u0ba9 <br/> \u0baa\u0ba4\u0bbf\u0ba4 \u0bae\u0bbe\u0ba9\u0bb5\u0bc1\u0bb2\u0b95\u0bca\u0b9a\u0b95\u0bc1 <br/> \u0b95\u0bb2\u0bc1\u0bb2\u0ba9\u0bc6\u0b9a\u0bcd\u0b9a\u0b9f \u0baa\u0bca\u0b95\u0b9f\u0ba9\u0bbf \u0bb6\u0bcd\u0bb0\u0bc0- <br/> \u0b95\u0bb0 \u0ba4\u0bcd\u0baf\u0bbe\u0b95\u0bb0\u0bbe\u0b9c \u0bb5\u0bbf\u0ba9\u0bc1\u0ba4"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c26\u0c41\u0c30\u0c4d\u0c2e\u0c3e\u0c30\u0c4d\u0c17 \u0c1a\u0c30\u0c3e\u0c27\u0c2e\u0c41\u0c32\u0c28\u0c41 <br/> \u0c26\u0c4a\u0c30 \u0c28\u0c40\u0c35\u0c28 \u0c1c\u0c3e\u0c32\u0c30"}, {"M": "\u0c05\u0c28\u0c41\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c27\u0c30\u0c4d\u0c2e\u0c3e\u0c24\u0c4d\u0c2e\u0c15 \u0c27\u0c28 \u0c27\u0c3e\u0c28\u0c4d\u0c2f <br/> \u0c26\u0c48\u0c35\u0c2e\u0c41 \u0c28\u0c40\u0c35\u0c48\u0c2f\u0c41\u0c23\u0c4d\u0c21\u0c17"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c2a\u0c32\u0c41\u0c15\u0c41 \u0c2c\u0c4b\u0c1f\u0c3f\u0c28\u0c3f \u0c38\u0c2d\u0c32\u0c4b\u0c28 <br/> \u0c2a\u0c24\u0c3f\u0c24 \u0c2e\u0c3e\u0c28\u0c35\u0c41\u0c32\u0c15\u0c4a\u0c38\u0c17\u0c41 <br/> \u0c16\u0c32\u0c41\u0c32\u0c28\u0c46\u0c1a\u0c4d\u0c1a\u0c1f \u0c2a\u0c4a\u0c17\u0c21\u0c28\u0c3f \u0c36\u0c4d\u0c30\u0c40- <br/> \u0c15\u0c30 \u0c24\u0c4d\u0c2f\u0c3e\u0c17\u0c30\u0c3e\u0c1c \u0c35\u0c3f\u0c28\u0c41\u0c24"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0ca6\u0cc1\u0cb0\u0ccd\u0cae\u0cbe\u0cb0\u0ccd\u0c97 \u0c9a\u0cb0\u0cbe\u0ca7\u0cae\u0cc1\u0cb2\u0ca8\u0cc1 <br/> \u0ca6\u0cca\u0cb0 \u0ca8\u0cc0\u0cb5\u0ca8 \u0c9c\u0cbe\u0cb2\u0cb0"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0ca7\u0cb0\u0ccd\u0cae\u0cbe\u0ca4\u0ccd\u0cae\u0c95 \u0ca7\u0ca8 \u0ca7\u0cbe\u0ca8\u0ccd\u0caf <br/> \u0ca6\u0cc8\u0cb5\u0cae\u0cc1 \u0ca8\u0cc0\u0cb5\u0cc8\u0caf\u0cc1\u0ca3\u0ccd\u0ca1\u0c97"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0caa\u0cb2\u0cc1\u0c95\u0cc1 \u0cac\u0ccb\u0c9f\u0cbf\u0ca8\u0cbf \u0cb8\u0cad\u0cb2\u0ccb\u0ca8 <br/> \u0caa\u0ca4\u0cbf\u0ca4 \u0cae\u0cbe\u0ca8\u0cb5\u0cc1\u0cb2\u0c95\u0cca\u0cb8\u0c97\u0cc1 <br/> \u0c96\u0cb2\u0cc1\u0cb2\u0ca8\u0cc6\u0c9a\u0ccd\u0c9a\u0c9f \u0caa\u0cca\u0c97\u0ca1\u0ca8\u0cbf \u0cb6\u0ccd\u0cb0\u0cc0- <br/> \u0c95\u0cb0 \u0ca4\u0ccd\u0caf\u0cbe\u0c97\u0cb0\u0cbe\u0c9c \u0cb5\u0cbf\u0ca8\u0cc1\u0ca4"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d26\u0d41\u0d30\u0d4d\u0d2e\u0d3e\u0d30\u0d4d\u0d17 \u0d1a\u0d30\u0d3e\u0d27\u0d2e\u0d41\u0d32\u0d28\u0d41 <br/> \u0d26\u0d4a\u0d30 \u0d28\u0d40\u0d35\u0d28 \u0d1c\u0d3e\u0d32\u0d30"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d27\u0d30\u0d4d\u0d2e\u0d3e\u0d24\u0d4d\u0d2e\u0d15 \u0d27\u0d28 \u0d27\u0d3e\u0d28\u0d4d\u0d2f <br/> \u0d26\u0d48\u0d35\u0d2e\u0d41 \u0d28\u0d40\u0d35\u0d48\u0d2f\u0d41\u0d23\u0d4d\u0d21\u0d17"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d2a\u0d32\u0d41\u0d15\u0d41 \u0d2c\u0d4b\u0d1f\u0d3f\u0d28\u0d3f \u0d38\u0d2d\u0d32\u0d4b\u0d28 <br/> \u0d2a\u0d24\u0d3f\u0d24 \u0d2e\u0d3e\u0d28\u0d35\u0d41\u0d32\u0d15\u0d4a\u0d38\u0d17\u0d41 <br/> \u0d16\u0d32\u0d41\u0d32\u0d28\u0d46\u0d1a\u0d4d\u0d1a\u0d1f \u0d2a\u0d4a\u0d17\u0d21\u0d28\u0d3f \u0d36\u0d4d\u0d30\u0d40- <br/> \u0d15\u0d30 \u0d24\u0d4d\u0d2f\u0d3e\u0d17\u0d30\u0d3e\u0d1c \u0d35\u0d3f\u0d28\u0d41\u0d24"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0926\u0941\u0930\u094d\u092e\u093e\u0930\u094d\u0917 \u091a\u0930\u093e\u0927\u092e\u0941\u0932\u0928\u0941 <br/> \u0926\u094b\u0930 \u0928\u0940\u0935\u0928 \u091c\u093e\u0932\u0930"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0927\u0930\u094d\u092e\u093e\u0924\u094d\u092e\u0915 \u0927\u0928 \u0927\u093e\u0928\u094d\u092f <br/> \u0926\u0948\u0935\u092e\u0941 \u0928\u0940\u0935\u0948\u092f\u0941\u0923\u094d\u0921\u0917"}, {"M": "\u091a\u0930\u0923\u092e\u094d", "T": "\u092a\u0932\u0941\u0915\u0941 \u092c\u094b\u091f\u093f\u0928\u093f \u0938\u092d\u0932\u094b\u0928 <br/> \u092a\u0924\u093f\u0924 \u092e\u093e\u0928\u0935\u0941\u0932\u0915\u094b\u0938\u0917\u0941 <br/> \u0916\u0932\u0941\u0932\u0928\u0947\u091a\u094d\u091a\u091f \u092a\u094b\u0917\u0921\u0928\u093f \u0936\u094d\u0930\u0940- <br/> \u0915\u0930 \u0924\u094d\u092f\u093e\u0917\u0930\u093e\u091c \u0935\u093f\u0928\u0941\u0924"}]}], "L": "l", "lyricsref": [{"links": [{"N": "thyagaraja-vaibhavam.blogspot.com", "L": "http://thyagaraja-vaibhavam.blogspot.com/2008/09/thyagaraja-kriti-durmarga-chara-raga.html"}, {"N": "www.karnatik.com", "L": "http://www.karnatik.com/c1186.shtml"}, {"N": "www.shivkumar.org", "L": "http://www.shivkumar.org/music/durmargachara-new.htm"}, {"N": "sangeetasudha.org", "L": "http://sangeetasudha.org/thyagaraja/d.html#MARK_DURMARGA"}]}]}