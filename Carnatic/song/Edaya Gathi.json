0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0c8f\u0ca6\u0caf\u0ccd\u0caf\u0cbe \u0c97\u0ca4\u0cbf \u0c8e\u0ca8\u0c95\u0ccd\u0c95\u0cc1"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cae\u0cbe \u0ca6\u0caf\u0cbe.\u0ca3\u0cbf\u0ca7\u0cbf \u0c89\u0cae\u0cbe\u0caa\u0ca4\u0cbf \u0cb8\u0cc1\u0c95\u0cc1\u0cae\u0cbe\u0cb0 \u0cb5\u0cb0\u0c97\u0cc1\u0ca3 \u0ca8\u0cbf\u0ca7\u0cbf \u0ca8\u0cc0 \u0ca4\u0cbe\u0ca8\u0ccd \u0c85\u0cb2\u0ca6\u0cc1\u0cb5\u0cc7"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0caa\u0cc7\u0ca6\u0cc8 \u0c8f\u0cb0\u0ccd\u0c95\u0ccd\u0c95\u0cc1\u0ca8\u0ccd\u0ca8\u0cb0\u0cc1\u0cb3\u0ccd \u0c95\u0cbe\u0c9f\u0ccd\u0c9f\u0cbe\u0ca6\u0cc1 \u0c8e\u0ca8\u0ccd\u0ca8\u0ccb\u0ca1\u0cc7\u0ca6\u0caf\u0ccd\u0caf\u0cbe \u0cb5\u0cbf\u0cb2\u0cc8\u0caf\u0cbe\u0c9f\u0ccd\u0c9f <br/> \u0cad\u0cc2\u0ca4\u0cb2\u0cbe \u0c9a\u0cb2\u0ca8\u0cbe\u0c9f\u0ccd\u0c9f \u0ca8\u0cbf\u0ca8\u0ccd \u0ca4\u0cbe\u0cb3\u0ccd \u0ca4\u0cbe\u0ca8\u0ccd \u0c97\u0ca4\u0cbf \u0caa\u0cc1\u0c97\u0cb3\u0ccd \u0c95\u0cb5\u0cbf \u0c95\u0cc1\u0c9e\u0ccd\u0c9c\u0cb0\u0ca6\u0cbe\u0cb8\u0ca8\u0cc1\u0c95\u0ccd\u0c95\u0cc1"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d0f\u0d26\u0d2f\u0d4d\u0d2f\u0d3e \u0d17\u0d24\u0d3f \u0d0e\u0d28\u0d15\u0d4d\u0d15\u0d41"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d2e\u0d3e \u0d26\u0d2f\u0d3e.\u0d23\u0d3f\u0d27\u0d3f \u0d09\u0d2e\u0d3e\u0d2a\u0d24\u0d3f \u0d38\u0d41\u0d15\u0d41\u0d2e\u0d3e\u0d30 \u0d35\u0d30\u0d17\u0d41\u0d23 \u0d28\u0d3f\u0d27\u0d3f \u0d28\u0d40 \u0d24\u0d3e\u0d28\u0d4d \u0d05\u0d32\u0d26\u0d41\u0d35\u0d47"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d2a\u0d47\u0d26\u0d48 \u0d0f\u0d30\u0d4d\u0d15\u0d4d\u0d15\u0d41\u0d28\u0d4d\u0d28\u0d30\u0d41\u0d33\u0d4d \u0d15\u0d3e\u0d1f\u0d4d\u0d1f\u0d3e\u0d26\u0d41 \u0d0e\u0d28\u0d4d\u0d28\u0d4b\u0d21\u0d47\u0d26\u0d2f\u0d4d\u0d2f\u0d3e \u0d35\u0d3f\u0d32\u0d48\u0d2f\u0d3e\u0d1f\u0d4d\u0d1f <br/> \u0d2d\u0d42\u0d24\u0d3