c1\u0b9a\u0bc1\u0ba9\u0bc1\u0baa\u0bcd\u0baa\u0bca\u0b99\u0bcd\u0b95\u0bc1\u0b9a\u0bc1\u0ba9\u0bc1 <br/> \u0b9a\u0ba4\u0bcd\u0ba4 \u0bae\u0bbe\u0ba4\u0bcd\u0bb0\u0bae\u0bbe \u0b9a\u0bbe\u0bb2 \u0ba8\u0bae\u0bcd\u0bae\u0bbf\u0ba4\u0bbf\u0ba9\u0bbf <br/> \u0b9a\u0bbe\u0bb0\u0bcd\u0bb5\u0baa\u0bcc\u0bae \u0bb6\u0bcd\u0bb0\u0bc0 \u0ba4\u0bcd\u0baf\u0bbe\u0b95\u0bb0\u0bbe\u0b9c \u0ba8\u0bc1\u0ba4"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c0e\u0c28\u0c4d\u0c24 \u0c35\u0c47\u0c21\u0c41\u0c15\u0c4a\u0c28\u0c4d\u0c26\u0c41 \u0c30\u0c3e\u0c18\u0c35 <br/> \u0c2a\u0c28\u0c4d\u0c24\u0c2e\u0c47\u0c32\u0c30\u0c3e \u0c13 \u0c30\u0c3e\u0c18\u0c35"}, {"M": "\u0c05\u0c28\u0c41\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c1a\u0c3f\u0c28\u0c4d\u0c24 \u0c24\u0c40\u0c30\u0c4d\u0c1a\u0c41\u0c1f\u0c15\u0c46\u0c28\u0c4d\u0c24 \u0c2e\u0c4b\u0c21\u0c3f\u0c30\u0c3e <br/> \u0c05\u0c28\u0c4d\u0c24\u0c30\u0c3e\u0c24\u0c4d\u0c2e \u0c28\u0c3e \u0c1a\u0c46\u0c28\u0c4d\u0c24 \u0c30\u0c3e\u0c28\u0c41 \u0c28\u0c47\u0c28\u0c46\u0c28\u0c4d\u0c24"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c1a\u0c3f\u0c24\u0c4d\u0c24\u0c2e\u0c28\u0c4d\u0c26\u0c41 \u0c28\u0c3f\u0c28\u0c4d\u0c28\u0c41 \u0c1c\u0c42\u0c1a\u0c41 \u0c38\u0c4c\u0c16\u0c4d\u0c2f\u0c2e\u0c47 <br/> \u0c09\u0c24\u0c4d\u0c24\u0c2e\u0c2e\u0c4d\u0c2c\u0c28\u0c41\u0c1a\u0c41\u0c28\u0c41\u0c2a\u0c4d\u0c2a\u0c4a\u0c02\u0c17\u0c41\u0c1a\u0c41\u0c28\u0c41 <br/> \u0c38\u0c24\u0c4d\u0c24 \u0c2e\u0c3e\u0c24\u0c4d\u0c30\u0c2e\u0c3e \u0c1a\u0c3e\u0c32 \u0c28\u0c2e\u0c4d\u0c2e\u0c3f\u0c24\u0c3f\u0c28\u0c3f <br/> \u0c38\u0c3e\u0c30\u0c4d\u0c35\u0c2d\u0c4c\u0c2e \u0c36\u0c4d\u0c30\u0c40 \u0c24\u0c4d\u0c2f\u0c3e\u0c17\u0c30\u0c3e\u0c1c \u0c28\u0c41\u0c24"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0c8e\u0ca8\u0ccd\u0ca4 \u0cb5\u0cc7\u0ca1\u0cc1\u0c95\u0cca\u0ca8\u0ccd\u0ca6\u0cc1 \u0cb0\u0cbe\u0c98\u0cb5 <br/> \u0caa\u0ca8\u0ccd\u0ca4\u0cae\u0cc7\u0cb2\u0cb0\u0cbe \u0c93 \u0cb0\u0cbe\u0c98\u0cb5"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0c9a\u0cbf\u0ca8\u0ccd\u0ca4 \u0ca4\u0cc0\u0cb0\u0ccd\u0c9a\u0cc1\u0c9f\u0c95\u0cc6\u0ca8\u0ccd\u0ca4 \u0cae\u0ccb\u0ca1\u0cbf\u0cb0\u0cbe <br/> \u0c85\u0ca8\u0ccd\u0ca4\u0cb0\u0cbe\u0ca4\u0ccd\u0cae \u0ca8\u0cbe \u0c9a\u0cc6\u0ca8\u0ccd\u0ca4 \u0cb0\u0cbe\u0ca8\u0cc1 \u0ca8\u0cc7\u0ca8\u0cc6\u0ca8\u0ccd\u0ca4"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0c9a\u0cbf\u0ca4\u0ccd\u0ca4\u0cae\u0ca8\u0ccd\u0ca6\u0cc1 \u0ca8\u0cbf\u0ca8\u0ccd\u0ca8\u0cc1 \u0c9c\u0cc2\u0c9a\u0cc1 \u0cb8\u0ccc\u0c96\u0ccd\u0caf\u0cae\u0cc7 <br/> \u0c89\u0ca4\u0ccd\u0ca4\u0cae\u0cae\u0ccd\u0cac\u0ca8\u0cc1\u0c9a\u0cc1\u0ca8\u0cc1\u0caa\u0ccd\u0caa\u0cca\u0c82\u0c97\u0cc1\u0c9a\u0cc1\u0ca8\u0cc1 <br/> \u0cb8\u0ca4\u0ccd\u0ca4 \u0cae\u0cbe\u0ca4\u0ccd\u0cb0\u0cae\u0cbe \u0c9a\u0cbe\u0cb2 \u0ca8\u0cae\u0ccd\u0cae\u0cbf\u0ca4\u0cbf\u0ca8\u0cbf <br/> \u0cb8\u0cbe\u0cb0\u0ccd\u0cb5\u0cad\u0ccc\u0cae \u0cb6\u0ccd\u0cb0\u0cc0 \u0ca4\u0ccd\u0caf\u0cbe\u0c97\u0cb0\u0cbe\u0c9c \u0ca8\u0cc1\u0ca4"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d0e\u0d28\u0d4d\u0d24 \u0d35\u0d47\u0d21\u0d41\u0d15\u0d4a\u0d28\u0d4d\u0d26\u0d41 \u0d30\u0d3e\u0d18\u0d35 <br/> \u0d2a\u0d28\u0d4d\u0d24\u0d2e\u0d47\u0d32\u0d30\u0d3e \u0d13 \u0d30\u0d3e\u0d18\u0d35"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d1a\u0d3f\u0d28\u0d4d\u0d24 \u0d24\u0d40\u0d30\u0d4d\u0d1a\u0d41\u0d1f\u0d15\u0d46\u0d28\u0d4d\u0d24 \u0d2e\u0d4b\u0d21\u0d3f\u0d30\u0d3e <br/> \u0d05\u0d28\u0d4d\u0d24\u0d30\u0d3e\u0d24\u0d4d\u0d2e \u0d28\u0d3e \u0d1a\u0d46\u0d28\u0d4d\u0d24 \u0d30\u0d3e\u0d28\u0d41 \u0d28\u0d47\u0d28\u0d46\u0d28\u0d4d\u0d24"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d1a\u0d3f\u0d24\u0d4d\u0d24\u0d2e\u0d28\u0d4d\u0d26\u0d41 \u0d28\u0d3f\u0d28\u0d4d\u0d28\u0d41 \u0d1c\u0d42\u0d1a\u0d41 \u0d38\u0d4c\u0d16\u0d4d\u0d2f\u0d2e\u0d47 <br/> \u0d09\u0d24\u0d4d\u0d24\u0d2e\u0d2e\u0d4d\u0d2c\u0d28\u0d41\u0d1a\u0d41\u0d28\u0d41\u0d2a\u0d4d\u0d2a\u0d4a\u0d02\u0d17\u0d41\u0d1a\u0d41\u0d28\u0d41 <br/> \u0d38\u0d24\u0d4d\u0d24 \u0d2e\u0d3e\u0d24\u0d4d\u0d30\u0d2e\u0d3e \u0d1a\u0d3e\u0d32 \u0d28\u0d2e\u0d4d\u0d2e\u0d3f\u0d24\u0d3f\u0d28\u0d3f <br/> \u0d38\u0d3e\u0d30\u0d4d\u0d35\u0d2d\u0d4c\u0d2e \u0d36\u0d4d\u0d30\u0d40 \u0d24\u0d4d\u0d2f\u0d3e\u0d17\u0d30\u0d3e\u0d1c \u0d28\u0d41\u0d24"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u090f\u0928\u094d\u0924 \u0935\u0947\u0921\u0941\u0915\u094b\u0928\u094d\u0926\u0941 \u0930\u093e\u0918\u0935 <br/> \u092a\u0928\u094d\u0924\u092e\u0947\u0932\u0930\u093e \u0913 \u0930\u093e\u0918\u0935"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u091a\u093f\u0928\u094d\u0924 \u0924\u0940\u0930\u094d\u091a\u0941\u091f\u0915\u0947\u0928\u094d\u0924 \u092e\u094b\u0921\u093f\u0930\u093e <br/> \u0905\u0928\u094d\u0924\u0930\u093e\u0924\u094d\u092e \u0928\u093e \u091a\u0947\u0928\u094d\u0924 \u0930\u093e\u0928\u0941 \u0928\u0947\u0928\u0947\u0928\u094d\u0924"}, {"M": "\u091a\u0930\u0923\u092e\u094d", "T": "\u091a\u093f\u0924\u094d\u0924\u092e\u0928\u094d\u0926\u0941 \u0928\u093f\u0928\u094d\u0928\u0941 \u091c\u0942\u091a\u0941 \u0938\u094c\u0916\u094d\u092f\u092e\u0947 <br/> \u0909\u0924\u094d\u0924\u092e\u092e\u094d\u092c\u0928\u0941\u091a\u0941\u0928\u0941\u092a\u094d\u092a\u094b\u0902\u0917\u0941\u091a\u0941\u0928\u0941 <br/> \u0938\u0924\u094d\u0924 \u092e\u093e\u0924\u094d\u0930\u092e\u093e \u091a\u093e\u0932 \u0928\u092e\u094d\u092e\u093f\u0924\u093f\u0928\u093f <br/> \u0938\u093e\u0930\u094d\u0935\u092d\u094c\u092e \u0936\u094d\u0930\u0940 \u0924\u094d\u092f\u093e\u0917\u0930\u093e\u091c \u0928\u0941\u0924"}]}], "L": "l", "lyricsref": [{"links": [{"N": "thyagaraja-vaibhavam.blogspot.com", "L": "http://thyagaraja-vaibhavam.blogspot.com/2008/02/thyagaraja-kriti-entha-vedukondu-raga.html"}, {"N": "www.karnatik.com", "L": "http://www.karnatik.com/c2309.shtml"}, {"N": "www.sangeetasudha.org", "L": "http://www.sangeetasudha.org/thyagaraja/vol2/e.html#MARK_ENTAVEDU"}]}]}