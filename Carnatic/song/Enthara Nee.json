0cb0 \u0cb5\u0cb0 \u0ca8\u0cc0\u0c95\u0cc8 \u0cb8\u0cc1\u0cb0 \u0c97\u0ca3\u0cae\u0cc1\u0cb2\u0cc1 <br/> \u0cb5\u0cbe\u0ca8\u0cb0\u0cc1\u0cb2\u0cc8 \u0c95\u0cca\u0cb2\u0cc1\u0cb5\u0c97 \u0cb2\u0cc7\u0ca6\u0cbe"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd 4", "T": "\u0c86\u0c97\u0cae\u0ccb\u0c95\u0ccd\u0ca4\u0cae\u0c97\u0cc1 \u0ca8\u0cc0 \u0c97\u0cc1\u0ca3\u0cae\u0cc1\u0cb2\u0cc1 \u0cb6\u0ccd\u0cb0\u0cc0 <br/> \u0ca4\u0ccd\u0caf\u0cbe\u0c97\u0cb0\u0cbe\u0c9c\u0cc1 \u0caa\u0cbe\u0ca1\u0c97 \u0cb2\u0cc7\u0ca6\u0cbe"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d0e\u0d28\u0d4d\u0d24 \u0d30\u0d3e\u0d28\u0d3f \u0d24\u0d28\u0d15\u0d46\u0d28\u0d4d\u0d24 \u0d2a\u0d4b\u0d28\u0d3f \u0d28\u0d40 <br/> \u0d1a\u0d46\u0d28\u0d4d\u0d24 \u0d35\u0d3f\u0d21\u0d41\u0d35 \u0d1c\u0d3e\u0d32 \u0d36\u0d4d\u0d30\u0d40 \u0d30\u0d3e\u0d2e"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d05\u0d28\u0d4d\u0d24\u0d15\u0d3e\u0d30\u0d3f \u0d28\u0d40 \u0d1a\u0d46\u0d28\u0d4d\u0d24 \u0d1c\u0d47\u0d30\u0d3f <br/> \u0d39\u0d28\u0d41\u0d2e\u0d28\u0d4d\u0d24\u0d41\u0d21\u0d48 \u0d15\u0d4a\u0d32\u0d41\u0d35 \u0d32\u0d47\u0d26\u0d3e"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 1", "T": "\u0d36\u0d47\u0d37\u0d41\u0d21\u0d41 \u0d36\u0d3f\u0d35\u0d41\u0d28\u0d3f\u0d15\u0d3f \u0d2d\u0d42\u0d37\u0d41\u0d21\u0d41 \u0d32\u0d15\u0d4d\u0d37\u0d4d\u0d2e\u0d23 <br/> \u0d35\u0d47\u0d37\u0d3f\u0d2f\u0d48 \u0d15\u0d4a\u0d32\u0d41\u0d35 \u0d32\u0d47\u0d26\u0d3e"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 2", "T": "\u0d36\u0d3f\u0d37\u0d4d\u0d1f\u0d41\u0d21\u0d41 \u0d2e\u0d4c\u0d28\u0d3f \u0d35\u0d30\u0d3f\u0d37\u0d4d\u0d20\u0d41\u0d21\u0d41 \u0d17\u0d4a\u0d2a\u0d4d\u0d2a <br/> \u0d35\u0d38\u0d3f\u0d37\u0d4d\u0d20\u0d41\u0d21\u0d41 \u0d39\u0d3f\u0d24\u0d41\u0d21\u0d41\u0d17\u0d3e \u0d32\u0d47\u0d26\u0d3e"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 3", "T": "\u0d28\u0d30 \u0d35\u0d30 \u0d28\u0d40\u0d15\u0d48 \u0d38\u0d41\u0d30 \u0d17\u0d23\u0d2e\u0d41\u0d32\u0d41 <br/> \u0d35\u0d3e\u0d28\u0d30\u0d41\u0d32\u0d48 \u0d15\u0d4a\u0d32\u0d41\u0d35\u0d17 \u0d32\u0d47\u0d26\u0d3e"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 4", "T": "\u0d06\u0d17\u0d2e\u0d4b\u0d15\u0d4d\u0d24\u0d2e\u0d17\u0d41 \u0d28\u0d40 \u0d17\u0d41\u0d23\u0d2e\u0d41\u0d32\u0d41 \u0d36\u0d4d\u0d30\u0d40 <br/> \u0d24\u0d4d\u0d2f\u0d3e\u0d17\u0d30\u0d3e\u0d1c\u0d41 \u0d2a\u0d3e\u0d21\u0d17 \u0d32\u0d47\u0d26\u0d3e"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u090f\u0928\u094d\u0924 \u0930\u093e\u0928\u093f \u0924\u0928\u0915\u0947\u0928\u094d\u0924 \u092a\u094b\u0928\u093f \u0928\u0940 <br/> \u091a\u0947\u0928\u094d\u0924 \u0935\u093f\u0921\u0941\u0935 \u091c\u093e\u0932 \u0936\u094d\u0930\u0940 \u0930\u093e\u092e"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0905\u0928\u094d\u0924\u0915\u093e\u0930\u093f \u0928\u0940 \u091a\u0947\u0928\u094d\u0924 \u091c\u0947\u0930\u093f <br/> \u0939\u0928\u0941\u092e\u0928\u094d\u0924\u0941\u0921\u0948 \u0915\u094b\u0932\u0941\u0935 \u0932\u0947\u0926\u093e"}, {"M": "\u091a\u0930\u0923\u092e\u094d 1", "T": "\u0936\u0947\u0937\u0941\u0921\u0941 \u0936\u093f\u0935\u0941\u0928\u093f\u0915\u093f \u092d\u0942\u0937\u0941\u0921\u0941 \u0932\u0915\u094d\u0937\u094d\u092e\u0923 <br/> \u0935\u0947\u0937\u093f\u092f\u0948 \u0915\u094b\u0932\u0941\u0935 \u0932\u0947\u0926\u093e"}, {"M": "\u091a\u0930\u0923\u092e\u094d 2", "T": "\u0936\u093f\u0937\u094d\u091f\u0941\u0921\u0941 \u092e\u094c\u0928\u093f \u0935\u0930\u093f\u0937\u094d\u0920\u0941\u0921\u0941 \u0917\u094b\u092a\u094d\u092a <br/> \u0935\u0938\u093f\u0937\u094d\u0920\u0941\u0921\u0941 \u0939\u093f\u0924\u0941\u0921\u0941\u0917\u093e \u0932\u0947\u0926\u093e"}, {"M": "\u091a\u0930\u0923\u092e\u094d 3", "T": "\u0928\u0930 \u0935\u0930 \u0928\u0940\u0915\u0948 \u0938\u0941\u0930 \u0917\u0923\u092e\u0941\u0932\u0941 <br/> \u0935\u093e\u0928\u0930\u0941\u0932\u0948 \u0915\u094b\u0932\u0941\u0935\u0917 \u0932\u0947\u0926\u093e