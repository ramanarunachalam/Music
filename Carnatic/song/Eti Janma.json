ba8\u0bcd\u0ba4\u0ba9\u0bbf \u0b9a\u0bc8\u0bb0\u0bbf\u0ba8\u0bcd\u0ba4\u0bc1 \u0bb9\u0bbe \u0b93 \u0bb0\u0bbe\u0bae"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd 1", "T": "\u0b9a\u0bbe\u0ba4\u0bbf \u0bb2\u0bc7\u0ba9\u0bbf \u0bae\u0bbe\u0bb0 \u0b95\u0bcb\u0b9f\u0bbf \u0bb2\u0bbe\u0bb5\u0ba3\u0bcd\u0baf\u0bc1\u0ba9\u0bbf <br/> \u0bae\u0bbe\u0b9f\u0bbf \u0bae\u0bbe\u0b9f\u0bbf\u0b95\u0bbf \u0b9c\u0bc2\u0b9a\u0bbf \u0bae\u0bbe\u0b9f\u0bb2\u0bbe\u0b9f\u0ba9\u0bbf \u0ba4\u0ba9\u0b95\u0bcd"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd 2", "T": "\u0b9a\u0bbe\u0bb0\u0bc6\u0b95\u0bc1 \u0bae\u0bc1\u0ba4\u0bcd\u0baf\u0bbe\u0bb2 \u0bb9\u0bbe\u0bb0\u0baf\u0bc1\u0bb0\u0bae\u0bc1 \u0baa\u0bbe\u0bb2\u0bc1 <br/> \u0b95\u0bbe\u0bb0\u0bc1 \u0bae\u0bcb\u0bae\u0bc1\u0ba9\u0bc1 \u0b95\u0ba9\u0bcd\u0ba9\u0bc1\u0bb2\u0bbe\u0bb0 \u0b9c\u0bc2\u0b9f\u0ba9\u0bbf \u0ba4\u0ba9\u0b95\u0bcd"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd 3", "T": "\u0b87\u0b99\u0bcd\u0b95\u0bbf\u0ba4\u0bae\u0bc6\u0bb0\u0bbf\u0b95\u0bbf\u0ba9 \u0b9a\u0b99\u0bcd\u0b95\u0bc0\u0ba4 \u0bb2\u0bcb\u0bb2\u0bc1\u0ba9\u0bbf <br/> \u0baa\u0bca\u0b99\u0bcd\u0b95\u0bc1\u0b9a\u0bc1 \u0ba4\u0ba9\u0bbf\u0bb5\u0bbe\u0bb0 \u0b95\u0bcc\u0b95\u0bbf\u0bb2\u0bbf\u0b9e\u0bcd\u0b9a\u0ba9\u0bbf \u0ba4\u0ba9\u0b95\u0bcd"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd 4", "T": "\u0b9a\u0bbe\u0b95\u0bb0 \u0bb7\u0baf\u0ba9\u0bc1\u0ba9\u0bbf \u0ba4\u0bcd\u0baf\u0bbe\u0b95\u0bb0\u0bbe\u0b9c \u0ba8\u0bc1\u0ba4\u0bc1\u0ba9\u0bbf <br/> \u0bb5\u0bc7\u0b95\u0bae\u0bc7 \u0b9c\u0bc2\u0b9f\u0b95 \u0bb5\u0bc7\u0b95\u0bc6\u0ba9\u0bc1 \u0bb9\u0bcd\u0bb0\u0bcd\u0ba4\u0baf\u0bae\u0bc1"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c0f\u0c1f\u0c3f \u0c1c\u0c28\u0c4d\u0c2e\u0c2e\u0c3f\u0c26\u0c3f \u0c39\u0c3e \u0c13 \u0c30\u0c3e\u0c2e"}, {"M": "\u0c05\u0c28\u0c41\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c0f\u0c1f\u0c3f \u0c1c\u0c28\u0c4d\u0c2e\u0c2e\u0c3f\u0c26\u0c3f \u0c0e\u0c28\u0c4d\u0c26\u0c41\u0c15\u0c41 \u0c15\u0c32\u0c3f\u0c17\u0c46\u0c28\u0c41 <br/> \u0c0e\u0c28\u0c4d\u0c24\u0c28\u0c3f \u0c38\u0c48\u0c30\u0c3f\u0c28\u0c4d\u0c24\u0c41 \u0c39\u0c3e \u0c13 \u0c30\u0c3e\u0c2e"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d 1", "T": "\u0c38\u0c3e\u0c24\u0c3f \u0c32\u0c47\u0c28\u0c3f \u0c2e\u0c3e\u0c30 \u0c15\u0c4b\u0c1f\u0c3f \u0c32\u0c3e\u0c35\u0c23\u0c4d\u0c2f\u0c41\u0c28\u0c3f <br/> \u0c2e\u0c3e\u0c1f\u0c3f \u0c2e\u0c3e\u0c1f\u0c3f\u0c15\u0c3f \u0c1c\u0c42\u0c1a\u0c3f \u0c2e\u0c3e\u0c1f\u0c32\u0c3e\u0c21\u0c28\u0c3f \u0c24\u0c28\u0c15\u0c4d"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d 2", "T": "\u0c38\u0c3e\u0c30\u0c46\u0c15\u0c41 \u0c2e\u0c41\u0c24\u0c4d\u0c2f\u0c3e\u0c32 \u0c39\u0c3e\u0c30\u0c2f\u0c41\u0c30\u0c2e\u0c41 \u0c2a\u0c3e\u0c32\u0c41 <br/> \u0c15\u0c3e\u0c30\u0c41 \u0c2e\u0c4b\u0c2e\u0c41\u0c28\u0c41 \u0c15\u0c28\u0c4d\u0c28\u0c41\u0c32\u0c3e\u0c30 \u0c1c\u0c42\u0c21\u0c28\u0c3f \u0c24\u0c28\u0c15\u0c4d"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d 3", "T": "\u0c07\u0c02\u0c17\u0c3f\u0c24\u0c2e\u0c46\u0c30\u0c3f\u0c17\u0c3f\u0c28 \u0c38\u0c02\u0c17\u0c40\u0c24 \u0c32\u0c4b\u0c32\u0c41\u0c28\u0c3f <br/> \u0c2a\u0c4a\u0c02\u0c17\u0c41\u0c1a\u0c41 \u0c24\u0c28\u0c3f\u0c35\u0c3e\u0c30 \u0c15\u0c4c\u0c17\u0c3f\u0c32\u0c3f\u0c02\u0c1a\u0c28\u0c3f \u0c24\u0c28\u0c15\u0c4d"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d 4", "T": "\u0c38\u0c3e\u0c17\u0c30 \u0c37\u0c2f\u0c28\u0c41\u0c28\u0c3f \u0c24\u0c4d\u0c2f\u0c3e\u0c17\u0c30\u0c3e\u0c1c \u0c28\u0c41\u0c24\u0c41\u0c28\u0c3f <br/> \u0c35\u0c47\u0c17\u0c2e\u0c47 \u0c1c\u0c42\u0c21\u0c15 \u0c35\u0c47\u0c17\u0c46\u0c28\u0c41 \u0c39\u0c4d\u0c30\u0c4d\u0c26\u0c2f\u0c2e\u0c41"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0c8f\u0c9f\u0cbf \u0c9c\u0ca8\u0ccd\u0cae\u0cae\u0cbf\u0ca6\u0cbf \u0cb9\u0cbe \u0c93 \u0cb0\u0cbe\u0cae"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0c8f\u0c9f\u0cbf \u0c9c\u0ca8\u0ccd\u0cae\u0cae\u0cbf\u0ca6\u0cbf \u0c8e\u0ca8\u0ccd\u0ca6\u0cc1\u0c95\u0cc1 \u0c95\u0cb2\u0cbf\u0c97\u0cc6\u0ca8\u0cc1 <br/> \u0c8e\u0ca8\u0ccd\u0ca4\u0ca8\u0cbf \u0cb8\u0cc8\u0cb0\u0cbf\u0ca8\u0ccd\u0ca4\u0cc1 \u0cb9\u0cbe \u0c93 \u0cb0\u0cbe\u0cae"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd 1", "T": "\u0cb8\u0cbe\u0ca4\u0cbf \u0cb2\u0cc7\u0ca8\u0cbf \u0cae\u0cbe\u0cb0 \u0c95\u0ccb\u0c9f\u0cbf \u0cb2\u0cbe\u0cb5\u0ca3\u0ccd\u0caf\u0cc1\u0ca8\u0cbf <br/> \u0cae\u0cbe\u0c9f\u0cbf \u0cae\u0cbe\u0c9f\u0cbf\u0c95\u0cbf \u0c9c\u0cc2\u0c9a\u0cbf \u0cae\u0cbe\u0c9f\u0cb2\u0cbe\u0ca1\u0ca8\u0cbf \u0ca4\u0ca8\u0c95\u0ccd"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd 2", "T": "\u0cb8\u0cbe\u0cb0\u0cc6\u0c95\u0cc1 \u0cae\u0cc1\u0ca4\u0ccd\u0caf\u0cbe\u0cb2 \u0cb9\u0cbe\u0cb0\u0caf\u0cc1\u0cb0\u0cae\u0cc1 \u0caa\u0cbe\u0cb2\u0cc1 <br/> \u0c95\u0cbe\u0cb0\u0cc1 \u0cae\u0ccb\u0cae\u0cc1\u0ca8\u0cc1 \u0c95\u0ca8\u0ccd\u0ca8\u0cc1\u0cb2\u0cbe\u0cb0 \u0c9c\u0cc2\u0ca1\u0ca8\u0cbf \u0ca4\u0ca8\u0c95\u0ccd"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd 3", "T": "\u0c87\u0c82\u0c97\u0cbf\u0ca4\u0cae\u0cc6\u0cb0\u0cbf\u0c97\u0cbf\u0ca8 \u0cb8\u0c82\u0c97\u0cc0\u0ca4 \u0cb2\u0ccb\u0cb2\u0cc1\u0ca8\u0cbf <br/> \u0caa\u0cca\u0c82\u0c97\u0cc1\u0c9a\u0cc1 \u0ca4\u0ca8\u0cbf\u0cb5\u0cbe\u0cb0 \u0c95\u0ccc\u0c97\u0cbf\u0cb2\u0cbf\u0c82\u0c9a\u0ca8\u0cbf \u0ca4\u0ca8\u0c95\u0ccd"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd 4", "T": "\u0cb8\u0cbe\u0c97\u0cb0 \u0cb7\u0caf\u0ca8\u0cc1\u0ca8\u0cbf \u0ca4\u0ccd\u0caf\u0cbe\u0c97\u0cb0\u0cbe\u0c9c \u0ca8\u0cc1\u0ca4\u0cc1\u0ca8\u0cbf <br/> \u0cb5\u0cc7\u0c97\u0cae\u0cc7 \u0c9c\u0cc2\u0ca1\u0c95 \u0cb5\u0cc7\u0c97\u0cc6\u0ca8\u0cc1 \u0cb9\u0ccd\u0cb0\u0ccd\u0ca6\u0caf\u0cae\u0cc1"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d0f\u0d1f\u0d3f \u0d1c\u0d28\u0d4d\u0d2e\u0d2e\u0d3f\u0d26\u0d3f \u0d39\u0d3e \u0d13 \u0d30\u0d3e\u0d2e"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d0f\u0d1f\u0d3f \u0d1c\u0d28\u0d4d\u0d2e\u0d2e\u0d3f\u0d26\u0d3f \u0d0e\u0d28\u0d4d\u0d26\u0d41\u0d15\u0d41 \u0d15\u0d32\u0d3f\u0d17\u0d46\u0d28\u0d41 <br/> \u0d0e\u0d28\u0d4d\u0d24\u0d28\u0d3f \u0d38\u0d48\u0d30\u0d3f\u0d28\u0d4d\u0d24\u0d41 \u0d39\u0d3e \u0d13 \u0d30\u0d3e\u0d2e"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 1", "T": "\u0d38\u0d3e\u0d24\u0d3f \u0d32\u0d47\u0d28\u0d3f \u0d2e\u0d3e\u0d30 \u0d15\u0d4b\u0d1f\u0d3f \u0d32\u0d3e\u0d35\u0d23\u0d4d\u0d2f\u0d41\u0d28\u0d3f <br/> \u0d2e\u0d3e\u0d1f\u0d3f \u0d2e\u0d3e\u0d1f\u0d3f\u0d15\u0d3f \u0d1c\u0d42\u0d1a\u0d3f \u0d2e\u0d3e\u0d1f\u0d32\u0d3e\u0d21\u0d28\u0d3f \u0d24\u0d28\u0d15\u0d4d"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 2", "T": "\u0d38\u0d3e\u0d30\u0d46\u0d15\u0d41 \u0d2e\u0d41\u0d24\u0d4d\u0d2f\u0d3e\u0d32 \u0d39\u0d3e\u0d30\u0d2f\u0d41\u0d30\u0d2e\u0d41 \u0d2a\u0d3e\u0d32\u0d41 <br/> \u0d15\u0d3e\u0d30\u0d41 \u0d2e\u0d4b\u0d2e\u0d41\u0d28\u0d41 \u0d15\u0d28\u0d4d\u0d28\u0d41\u0d32\u0d3e\u0d30 \u0d1c\u0d42\u0d21\u0d28\u0d3f \u0d24\u0d28\u0d15\u0d4d"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 3", "T": "\u0d07\u0d02\u0d17\u0d3f\u0d24\u0d2e\u0d46\u0d30\u0d3f\u0d17\u0d3f\u0d28 \u0d38\u0d02\u0d17\u0d40\u0d24 \u0d32\u0d4b\u0d32\u0d41\u0d28\u0d3f <br/> \u0d2a\u0d4a\u0d02\u0d17\u0d41\u0d1a\u0d41 \u0d24\u0d28\u0d3f\u0d35\u0d3e\u0d30 \u0d15\u0d4c\u0d17\u0d3f\u0d32\u0d3f\u0d02\u0d1a\u0d28\u0d3f \u0d24\u0d28\u0d15\u0d4d"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 4", "T": "\u0d38\u0d3e\u0d17\u0d30 \u0d37\u0d2f\u0d28\u0d41\u0d28\u0d3f \u0d24\u0d4d\u0d2f\u0d3e\u0d17\u0d30\u0d3e\u0d1c \u0d28\u0d41\u0d24\u0d41\u0d28\u0d3f <br/> \u0d35\u0d47\u0d17\u0d2e\u0d47 \u0d1c\u0d42\u0d21\u0d15 \u0d35\u0d47\u0d17\u0d46\u0d28\u0d41 \u0d39\u0d4d\u0d30\u0d4d\u0d26\u0d2f\u0d2e\u0d41"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u090f\u091f\u093f \u091c\u0928\u094d\u092e\u092e\u093f\u0926\u093f \u0939\u093e \u0913 \u0930\u093e\u092e"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u090f\u091f\u093f \u091c\u0928\u094d\u092e\u092e\u093f\u0926\u093f \u090f\u0928\u094d\u0926\u0941\u0915\u0941 \u0915\u0932\u093f\u0917\u0947\u0928\u0941 <br/> \u090f\u0928\u094d\u0924\u0928\u093f \u0938\u0948\u0930\u093f\u0928\u094d\u0924\u0941 \u0939\u093e \u0913 \u0930\u093e\u092e"}, {"M": "\u091a\u0930\u0923\u092e\u094d 1", "T": "\u0938\u093e\u0924\u093f \u0932\u0947\u0928\u093f \u092e\u093e\u0930 \u0915\u094b\u091f\u093f \u0932\u093e\u0935\u0923\u094d\u092f\u0941\u0928\u093f <br/> \u092e\u093e\u091f\u093f \u092e\u093e\u091f\u093f\u0915\u093f \u091c\u0942\u091a\u093f \u092e\u093e\u091f\u0932\u093e\u0921\u0928\u093f \u0924\u0928\u0915\u094d"}, {"M": "\u091a\u0930\u0923\u092e\u094d 2", "T": "\u0938\u093e\u0930\u0947\u0915\u0941 \u092e\u0941\u0924\u094d\u092f\u093e\u0932 \u0939\u093e\u0930\u092f\u0941\u0930\u092e\u0941 \u092a\u093e\u0932\u0941 <br/> \u0915\u093e\u0930\u0941 \u092e\u094b\u092e\u0941\u0928\u0941 \u0915\u0928\u094d\u0928\u0941\u0932\u093e\u0930 \u091c\u0942\u0921\u0928\u093f \u0924\u0928\u0915\u094d"}, {"M": "\u091a\u0930\u0923\u092e\u094d 3", "T": "\u0907\u0902\u0917\u093f\u0924\u092e\u0947\u0930\u093f\u0917\u093f\u0928 \u0938\u0902\u0917\u0940\u0924 \u0932\u094b\u0932\u0941\u0928\u093f <br/> \u092a\u094b\u0902\u0917\u0941\u091a\u0941 \u0924\u0928\u093f\u0935\u093e\u0930 \u0915\u094c\u0917\u093f\u0932\u093f\u0902\u091a\u0928\u093f \u0924\u0928\u0915\u094d"}, {"M": "\u091a\u0930\u0923\u092e\u094d 4", "T": "\u0938\u093e\u0917\u0930 \u0937\u092f\u0928\u0941\u0928\u093f \u0924\u094d\u092f\u093e\u0917\u0930\u093e\u091c \u0928\u0941\u0924\u0941\u0928\u093f <br/> \u0935\u0947\u0917\u092e\u0947 \u091c\u0942\u0921\u0915 \u0935\u0947\u0917\u0947\u0928\u0941 \u0939\u094d\u0930\u094d\u0926\u092f\u092e\u0941"}]}], "L": "l", "lyricsref": [{"links": [{"N": "thyagaraja-vaibhavam.blogspot.com", "L": "http://thyagaraja-vaibhavam.blogspot.com/2008/07/thyagaraja-kriti-eti-janmamidi-raga.html"}, {"N": "www.shivkumar.org", "L": "http://www.shivkumar.org/music/etijanmamidi.htm"}, {"N": "www.karnatik.com", "L": "http://www.karnatik.com/c2314.shtml"}, {"N": "sangeetasudha.org", "L": "http://sangeeta