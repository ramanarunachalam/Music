b0\u0bbe\u0bae <br/> \u0ba8\u0bbe \u0bb2\u0bcb\u0ba9\u0bbf \u0b9c\u0bbe\u0bb2\u0bbf\u0ba9\u0bbf"}, {"M": "\u0b85\u0ba9\u0bc1\u0baa\u0bb2\u0bcd\u0bb2\u0bb5\u0bbf", "T": "\u0b95\u0bb5\u0b95\u0bca\u0ba9\u0bbf \u0b9a\u0ba4\u0bbe \u0baa\u0b9c\u0ba9 \u0b9a\u0bc7\u0baf <br/> \u0b95\u0bbe\u0bb0\u0bcd\u0baf\u0bae\u0bc1\u0bb2\u0ba9\u0bcd\u0ba9\u0bbf \u0bb5\u0bc7\u0bb0\u0bbe\u0baf\u0bc6"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd", "T": "\u0b95\u0ba3 \u0ba8\u0bbe\u0ba4\u0bc1 \u0b9a\u0bc7\u0baf \u0b95\u0bcb\u0bb0\u0b95 \u0b95\u0b9f\u0bc1 <br/> \u0bb5\u0bbe\u0ba9\u0bb0\u0bc1\u0b9f\u0bc8 \u0ba4\u0bc0\u0bb0\u0bc6\u0b95\u0bbe <br/> \u0b95\u0bc1\u0ba3 \u0bae\u0baf \u0bae\u0bbe\u0baf\u0bbe\u0bae\u0bcd\u0baa\u0bc1\u0ba4 \u0b9a\u0bae\u0bc0\u0bb0 <br/> \u0b95\u0bcb\u0baa\u0bbe\u0bb2 \u0ba4\u0bcd\u0baf\u0bbe\u0b95\u0bb0\u0bbe\u0b9c \u0ba8\u0bc1\u0ba4"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c0e\u0c35\u0c30\u0c3f\u0c24\u0c4b \u0c28\u0c47 \u0c24\u0c46\u0c32\u0c4d\u0c2a\u0c41\u0c26\u0c41 \u0c30\u0c3e\u0c2e <br/> \u0c28\u0c3e \u0c32\u0c4b\u0c28\u0c3f \u0c1c\u0c3e\u0c32\u0c3f\u0c28\u0c3f"}, {"M": "\u0c05\u0c28\u0c41\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c15\u0c35\u0c17\u0c4a\u0c28\u0c3f \u0c38\u0c26\u0c3e \u0c2d\u0c1c\u0c28 \u0c38\u0c47\u0c2f <br/> \u0c15\u0c3e\u0c30\u0c4d\u0c2f\u0c2e\u0c41\u0c32\u0c28\u0c4d\u0c28\u0c3f \u0c35\u0c47\u0c30\u0c3e\u0c2f\u0c46"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c17\u0c23 \u0c28\u0c3e\u0c25\u0c41 \u0c38\u0c47\u0c2f \u0c15\u0c4b\u0c30\u0c17 \u0c15\u0c21\u0c41 <br/> \u0c35\u0c3e\u0c28\u0c30\u0c41\u0c21\u0c48 \u0c24\u0c40\u0c30\u0c46\u0c17\u0c3e <br/> \u0c17\u0c41\u0c23 \u0c2e\u0c2f \u0c2e\u0c3e\u0c2f\u0c3e\u0c2e\u0c4d\u0c2c\u0c41\u0c26 \u0c38\u0c2e\u0c40\u0c30 <br/> \u0c17\u0c4b\u0c2a\u0c3e\u0c32 \u0c24\u0c4d\u0c2f\u0c3e\u0c17\u0c30\u0c3e\u0c1c \u0c28\u0c41\u0c24"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0c8e\u0cb5\u0cb0\u0cbf\u0ca4\u0ccb \u0ca8\u0cc7 \u0ca4\u0cc6\u0cb2\u0ccd\u0caa\u0cc1\u0ca6\u0cc1 \u0cb0\u0cbe\u0cae <br/> \u0ca8\u0cbe \u0cb2\u0ccb\u0ca8\u0cbf \u0c9c\u0cbe\u0cb2\u0cbf\u0ca8\u0cbf"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0c95\u0cb5\u0c97\u0cca\u0ca8\u0cbf \u0cb8\u0ca6\u0cbe \u0cad\u0c9c\u0ca8 \u0cb8\u0cc7\u0caf <br/> \u0c95\u0cbe\u0cb0\u0ccd\u0caf\u0cae\u0cc1\u0cb2\u0ca8\u0ccd\u0ca8\u0cbf \u0cb5\u0cc7\u0cb0\u0cbe\u0caf\u0cc6"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0c97\u0ca3 \u0ca8\u0cbe\u0ca5\u0cc1 \u0cb8\u0cc7\u0caf \u0c95\u0ccb\u0cb0\u0c97 \u0c95\u0ca1\u0cc1 <br/> \u0cb5\u0cbe\u0ca8\u0cb0\u0cc1\u0ca1\u0cc8 \u0ca4\u0cc0\u0cb0\u0cc6\u0c97\u0cbe <br/> \u0c97\u0cc1\u0ca3 \u0cae\u0caf \u0cae\u0cbe\u0caf\u0cbe\u0cae\u0ccd\u0cac\u0cc1\u0ca6 \u0cb8\u0cae\u0cc0\u0cb0 <br/> \u0c97\u0ccb\u0caa\u0cbe\u0cb2 \u0ca4\u0ccd\u0caf\u0cbe\u0c97\u0cb0\u0cbe\u0c9c \u0ca8\u0cc1\u0ca4"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d0e\u0d35\u0d30\u0d3f\u0d24\u0d4b \u0d28\u0d47 \u0d24\u0d46\u0d32\u0d4d\u0d2a\u0d41\u0d26\u0d41 \u0d30\u0d3e\u0d2e <br/> \u0d28\u0d3e \u0d32\u0d4b\u0d28\u0d3f \u0d1c\u0d3e\u0d32\u0d3f\u0d28\u0d3f"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d15\u0d35\u0d17\u0d4a\u0d28\u0d3f \u0d38\u0d26\u0d3e \u0d2d\u0d1c\u0d28 \u0d38\u0d47\u0d2f <br/> \u0d15\u0d3e\u0d30\u0d4d\u0d2f\u0d2e\u0d41\u0d32\u0d28\u0d4d\u0d28\u0d3f \u0d35\u0d47\u0d30\u0d3e\u0d2f\u0d46"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d17\u0d23 \u0d28\u0d3e\u0d25\u0d41 \u0d38\u0d47\u0d2f \u0d15\u0d4b\u0d30\u0d17 \u0d15\u0d21\u0d41 <br/> \u0d35\u0d3e\u0d28\u0d30\u0d41\u0d21\u0d48 \u0d24\u0d40\u0d30\u0d46\u0d17\u0d3e <br/> \u0d17\u0d41\u0d23 \u0d2e\u0d2f \u0d2e\u0d3e\u0d2f\u0d3e\u0d2e\u0d4d\u0d2c\u0d41\u0d26 \u0d38\u0d2e\u0d40\u0d30 <br/> \u0d17\u0d4b\u0d2a\u0d3e\u0d32 \u0d24\u0d4d\u0d2f\u0d3e\u0d17\u0d30\u0d3e\u0d1c \u0d28\u0d41\u0d24"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u090f\u0935\u0930\u093f\u0924\u094b \u0928\u0947 \u0924\u0947\u0932\u094d\u092a\u0941\u0926\u0941 \u0930\u093e\u092e <br/> \u0928\u093e \u0932\u094b\u0928\u093f \u091c\u093e\u0932\u093f\u0928\u093f"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0915\u0935\u0917\u094b\u0928\u093f \u0938\u0926\u093e \u092d\u091c\u0928 \u0938\u0947\u092f <br/> \u0915\u093e\u0930\u094d\u092f\u092e\u0941\u0932\u0928\u094d\u0928\u093f \u0935\u0947\u0930\u093e\u092f\u0947"}, {"M": "\u091a\u0930\u0923\u092e\u094d", "T": "\u0917\u0923 \u0928\u093e\u0925\u0941 \u0938\u0947\u092f \u0915\u094b\u0930\u0917 \u0915\u0921\u0941 <br/> \u0935\u093e\u0928\u0930\u0941\u0921\u0948 \u0924\u0940\u0930\u0947\u0917\u093e <br/> \u0917\u0941\u0923 \u092e\u092f \u092e\u093e\u092f\u093e\u092e\u094d\u092c\u0941\u0926 \u0938\u092e\u0940\u0930 <br/> \u0917\u094b\u092a\u093e\u0932 \u0924\u094d\u092f\u093e\u0917\u0930\u093e\u091c \u0928\u0941\u0924"}]}], "L": "l", "lyricsref": [{"links": [{"N": "thyagaraja-vaibhavam.blogspot.com", "L": "http://thyagaraja-vaibhavam.blogspot.com/2008/10/thyagaraja-kriti-evarito-ne-telpudu.html"}, {"N": "www.sangeetasudha.org", "L": "http://www.sangeetasudha.org/thyagaraja/vol4/Ty1.html#MARK_EVARITO"}, {"N": "www.karnatik.com", "L": "http://www.karnatik.com/c2325.shtml"}]}]}