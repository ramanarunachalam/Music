\u0ba9\u0bc6\u0bb0\u0bbf\u0b95\u0bbf \u0bb2\u0b99\u0bcd\u0b95\u0bbe \u0baa\u0b9f\u0bcd\u0b9f\u0bae\u0bca\u0b9a\u0b95\u0b95\u0bbe <br/> \u0ba8\u0b95 \u0ba4\u0bb0 \u0b9a\u0bc1\u0bb0 \u0baa\u0bc2-\u0b9a\u0bc1\u0bb0 \u0baa\u0bc2\u0b9c\u0bbf\u0ba4 \u0bb5\u0bb0 <br/> \u0ba8\u0bbe\u0b95 \u0b9a\u0baf\u0ba9 \u0ba4\u0bcd\u0baf\u0bbe\u0b95\u0bb0\u0bbe\u0b9c \u0bb5\u0bbf\u0ba9\u0bc1\u0ba4 \u0b9a\u0bb0\u0bbf\u0baf\u0bcd"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c0e\u0c35\u0c4d\u0c35\u0c30\u0c47 \u0c30\u0c3e\u0c2e\u0c2f\u0c4d\u0c2f \u0c28\u0c40 \u0c38\u0c30\u0c3f"}, {"M": "\u0c05\u0c28\u0c41\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c30\u0c35\u0c4d\u0c35\u0c15\u0c41 \u0c24\u0c3e\u0c35\u0c41 \u0c32\u0c47\u0c15 \u0c38\u0c41\u0c1c\u0c28\u0c41\u0c32\u0c28\u0c41 <br/> \u0c30\u0c3e\u0c1c\u0c3f\u0c17 \u0c30\u0c15\u0c4d\u0c37\u0c3f\u0c28\u0c4d\u0c1a\u0c41 \u0c35\u0c3e\u0c30\u0c4d"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c2a\u0c17\u0c35\u0c3e\u0c28\u0c3f\u0c15\u0c3f \u0c38\u0c4b\u0c26\u0c30\u0c41\u0c21\u0c28\u0c3f\u0c2f\u0c46\u0c28\u0c4d\u0c1a\u0c15 <br/> \u0c2d\u0c15\u0c4d\u0c24\u0c3f\u0c28\u0c46\u0c30\u0c3f\u0c17\u0c3f \u0c32\u0c02\u0c15\u0c3e \u0c2a\u0c1f\u0c4d\u0c1f\u0c2e\u0c4a\u0c38\u0c17\u0c17\u0c3e <br/> \u0c28\u0c17 \u0c27\u0c30 \u0c38\u0c41\u0c30 \u0c2d\u0c42-\u0c38\u0c41\u0c30 \u0c2a\u0c42\u0c1c\u0c3f\u0c24 \u0c35\u0c30 <br/> \u0c28\u0c3e\u0c17 \u0c36\u0c2f\u0c28 \u0c24\u0c4d\u0c2f\u0c3e\u0c17\u0c30\u0c3e\u0c1c \u0c35\u0c3f\u0c28\u0c41\u0c24 \u0c38\u0c30\u0c3f\u0c2f\u0c4d"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0c8e\u0cb5\u0ccd\u0cb5\u0cb0\u0cc7 \u0cb0\u0cbe\u0cae\u0caf\u0ccd\u0caf \u0ca8\u0cc0 \u0cb8\u0cb0\u0cbf"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cb0\u0cb5\u0ccd\u0cb5\u0c95\u0cc1 \u0ca4\u0cbe\u0cb5\u0cc1 \u0cb2\u0cc7\u0c95 \u0cb8\u0cc1\u0c9c\u0ca8\u0cc1\u0cb2\u0ca8\u0cc1 <br/> \u0cb0\u0cbe\u0c9c\u0cbf\u0c97 \u0cb0\u0c95\u0ccd\u0cb7\u0cbf\u0ca8\u0ccd\u0c9a\u0cc1 \u0cb5\u0cbe\u0cb0\u0ccd"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0caa\u0c97\u0cb5\u0cbe\u0ca8\u0cbf\u0c95\u0cbf \u0cb8\u0ccb\u0ca6\u0cb0\u0cc1\u0ca1\u0ca8\u0cbf\u0caf\u0cc6\u0ca8\u0ccd\u0c9a\u0c95 <br/> \u0cad\u0c95\u0ccd\u0ca4\u0cbf\u0ca8\u0cc6\u0cb0\u0cbf\u0c97\u0cbf \u0cb2\u0c82\u0c95\u0cbe \u0caa\u0c9f\u0ccd\u0c9f\u0cae\u0cca\u0cb8\u0c97\u0c97\u0cbe <br/> \u0ca8\u0c97 \u0ca7\u0cb0 \u0cb8\u0cc1\u0cb0 \u0cad\u0cc2-\u0cb8\u0cc1\u0cb0 \u0caa\u0cc2\u0c9c\u0cbf\u0ca4 \u0cb5\u0cb0 <br/> \u0ca8\u0cbe\u0c97 \u0cb6\u0caf\u0ca8 \u0ca4\u0ccd\u0caf\u0cbe\u0c97\u0cb0\u0cbe\u0c9c \u0cb5\u0cbf\u0ca8\u0cc1\u0ca4 \u0cb8\u0cb0\u0cbf\u0caf\u0ccd"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d0e\u0d35\u0d4d\u0d35\u0d30\u0d47 \u0d30\u0d3e\u0d2e\u0d2f\u0d4d\u0d2f \u0d28\u0d40 \u0d38\u0d30\u0d3f"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d30\u0d35\u0d4d\u0d35\u0d15\u0d41 \u0d24\u0d3e\u0d35\u0d41 \u0d32\u0d47\u0d15 \u0d38\u0d41\u0d1c\u0d28\u0d41\u0d32\u0d28\u0d41 <br/> \u0d30\u0d3e\u0d1c\u0d3f\u0d17 \u0d30\u0d15\u0d4d\u0d37\u0d3f\u0d28\u0d4d\u0d1a\u0d41 \u0d35\u0d3e\u0d30\u0d4d"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d2a\u0d17\u0d35\u0d3e\u0d28\u0d3f\u0d15\u0d3f \u0d38\u0d4b\u0d26\u0d30\u0d41\u0d21\u0d28\u0d3f\u0d2f\u0d46\u0d28\u0d4d\u0d1a\u0d15 <br/> \u0d2d\u0d15\u0d4d\u0d24\u0d3f\u0d28\u0d46\u0d30\u0d3f\u0d17\u0d3f \u0d32\u0d02\u0d15\u0d3e \u0d2a\u0d1f\u0d4d\u0d1f\u0d2e\u0d4a\u0d38\u0d17\u0d17\u0d3e <br/> \u0d28\u0d17 \u0d27\u0d30 \u0d38\u0d41\u0d30 \u0d2d\u0d42-\u0d38\u0d41\u0d30 \u0d2a\u0d42\u0d1c\u0d3f\u0d24 \u0d35\u0d30 <br/> \u0d28\u0d3e\u0d17 \u0d36\u0d2f\u0d28 \u0d24\u0d4d\u0d2f\u0d3e\u0d17\u0d30\u0d3e\u0d1c \u0d35\u0d3f\u0d28\u0d41\u0d24 \u0d38\u0d30\u0d3f\u0d2f\u0d4d"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u090f\u0935\u094d\u0935\u0930\u0947 \u0930\u093e\u092e\u092f\u094d\u092f \u0928\u0940 \u0938\u0930\u093f"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0930\u0935\u094d\u0935\u0915\u0941 \u0924\u093e\u0935\u0941 \u0932\u0947\u0915 \u0938\u0941\u091c\u0928\u0941\u0932\u0928\u0941 <br/> \u0930\u093e\u091c\u093f\u0917 \u0930\u0915\u094d\u0937\u093f\u0928\u094d\u091a\u0941 \u0935\u093e\u0930\u094d"}, {"M": "\u091a\u0930\u0923\u092e\u094d", "T": "\u092a\u0917\u0935\u093e\u0928\u093f\u0915\u093f \u0938\u094b\u0926\u0930\u0941\u0921\u0928\u093f\u092f\u0947\u0928\u094d\u091a\u0915 <br/> \u092d\u0915\u094d\u0924\u093f\u0928\u0947\u0930\u093f\u0917\u093f \u0932\u0902\u0915\u093e \u092a\u091f\u094d\u091f\u092e\u094b\u0938\u0917\u0917\u093e <br/> \u0928\u0917 \u0927\u0930 \u0938\u0941\u0930 \u092d\u0942-\u0938\u0941\u0930 \u092a\u0942\u091c\u093f\u0924 \u0935\u0930 <br/> \u0928\u093e\u0917 \u0936\u092f\u0928 \u0924\u094d\u092f\u093e\u0917\u0930\u093e\u091c \u0935\u093f\u0928\u0941\u0924 \u0938\u0930\u093f\u092f\u094d"}]}], "L": "l", "lyricsref": [{"links": [{"N": "thyagaraja-vaibhavam.blogspot.com", "L": "http://thyagaraja-vaibhavam.blogspot.com/2008/07/thyagaraja-kriti-evvare-ramayya-raga.html"}, {"N": "www.karnatik.com", "L": "http://www.karnatik.com/c2332.shtml"}, {"N": "www.shivkumar.org", "L": "http://www.shivkumar.org/music/evvareramaiah.htm"}]}]}