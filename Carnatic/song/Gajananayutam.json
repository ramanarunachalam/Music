0c3f \u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c05\u0c1c\u0c47\u0c28\u0c4d\u0c26\u0c4d\u0c30 \u0c2a\u0c42\u0c1c\u0c3f\u0c24 \u0c35\u0c3f\u0c18\u0c4d\u0c28\u0c47\u0c36\u0c4d\u0c35\u0c30\u0c2e\u0c4d <br/> \u0c17\u0c23\u0c3e\u0c26\u0c3f \u0c38\u0c28\u0c4d\u0c28\u0c41\u0c24 \u0c2a\u0c26 \u0c2a\u0c26\u0c4d\u0c2e\u0c15\u0c30\u0c2e\u0c4d"}, {"M": "\u0c2e\u0c27\u0c4d\u0c2f\u0c2e\u0c15\u0c3e\u0c32 \u0c38\u0c3e\u0c39\u0c3f\u0c24\u0c4d\u0c2f\u0c2e\u0c4d", "T": "\u0c15\u0c41\u0c02\u0c1c\u0c30 \u0c2d\u0c02\u0c1c\u0c28 \u0c1a\u0c24\u0c41\u0c30\u0c24\u0c30\u0c15\u0c30\u0c2e\u0c4d <br/> \u0c17\u0c41\u0c30\u0c41\u0c17\u0c41\u0c39\u0c3e\u0c17\u0c4d\u0c30\u0c1c\u0c2e\u0c4d \u0c2a\u0c4d\u0c30\u0c23\u0c35\u0c3e\u0c15\u0c3e\u0c30\u0c2e\u0c4d"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0c97\u0c9c\u0cbe\u0ca8\u0ca8\u0caf\u0cc1\u0ca4\u0cae\u0ccd \u0c97\u0ca3\u0cc7\u0cb6\u0ccd\u0cb5\u0cb0\u0cae\u0ccd <br/> \u0cad\u0c9c\u0cbe\u0cae\u0cbf \u0cb8\u0ca4\u0ca4\u0cae\u0ccd \u0cb8\u0cc1\u0cb0\u0cc7\u0cb6\u0ccd\u0cb5\u0cb0\u0cae\u0ccd"}, {"M": "\u0cb8\u0cae\u0cb8\u0ccd\u0ca4\u0cbf \u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0c85\u0c9c\u0cc7\u0ca8\u0ccd\u0ca6\u0ccd\u0cb0 \u0caa\u0cc2\u0c9c\u0cbf\u0ca4 \u0cb5\u0cbf\u0c98\u0ccd\u0ca8\u0cc7\u0cb6\u0ccd\u0cb5\u0cb0\u0cae\u0ccd <br/> \u0c97\u0ca3\u0cbe\u0ca6\u0cbf \u0cb8\u0ca8\u0ccd\u0ca8\u0cc1\u0ca4 \u0caa\u0ca6 \u0caa\u0ca6\u0ccd\u0cae\u0c95\u0cb0\u0cae\u0ccd"}, {"M": "\u0cae\u0ca7\u0ccd\u0caf\u0cae\u0c95\u0cbe\u0cb2 \u0cb8\u0cbe\u0cb9\u0cbf\u0ca4\u0ccd\u0caf\u0cae\u0ccd", "T": "\u0c95\u0cc1\u0c82\u0c9c\u0cb0 \u0cad\u0c82\u0c9c\u0ca8 \u0c9a\u0ca4\u0cc1\u0cb0\u0ca4\u0cb0\u0c95\u0cb0\u0cae\u0ccd <br/> \u0c97\u0cc1\u0cb0\u0cc1\u0c97\u0cc1\u0cb9\u0cbe\u0c97\u0ccd\u0cb0\u0c9c\u0cae\u0ccd \u0caa\u0ccd\u0cb0\u0ca3\u0cb5\u0cbe\u0c95\u0cbe\u0cb0\u0cae\u0ccd"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d17\u0d1c\u0d3e\u0d28\u0d28\u0d2f\u0d41\u0d24\u0d2e\u0d4d \u0d17\u0d23\u0d47\u0d36\u0d4d\u0d35\u0d30\u0d2e\u0d4d <br/> \u0d2d\u0d1c\u0d3e\u0d2e\u0d3f \u0d38\u0d24\u0d24\u0d2e\u0d4d \u0d38\u0d41\u0d30\u0d47\u0d36\u0d4d\u0d35\u0d30\u0d2e\u0d4d"}, {"M": "\u0d38\u0d2e\u0d38\u0d4d\u0d24\u0d3f \u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d05\u0d1c\u0d47\u0d28\u0d4d\u0d26\u0d4d\u0d30 \u0d2a\u0d42\u0d1c\u0d3f\u0d24 \u0d35\u0d3f\u0d18\u0d4d\u0d28\u0d47\u0d36\u0d4d\u0d35\u0d30\u0d2e\u0d4d <br/> \u0d17\u0d23\u0d3e\u0d26\u0d3f \u0d38\u0d28\u0d4d\u0d28\u0d41\u0d24 \u0d2a\u0d26 \u0d2a\u0d26\u0d4d\u0d2e\u0d15\u0d30\u0d2e\u0d4d"}, {"M": "\u0d2e\u0d27\u0d4d\u0d2f\u0d2e\u0d15\u0d3e\u0d32 \u0d38\u0d3e\u0d39\u0d3f\u0d24\u0d4d\u0d2f\u0d2e\u0d4d", "T": "\u0d15\u0d41\u0d02\u0d1c\u0d30 \u0d2d\u0d02\u0d1c\u0d28 \u0d1a\u0d24\u0d41\u0d30\u0d24\u0d30\u0d15\u0d30\u0d2e\u0d4d <br/> \u0d17\u0d41\u0d30\u0d41\u0d17\u0d41\u0d39\u0d3e\u0d17\u0d4d\u0d30\u0d1c\u0d2e\u0d4d \u0d2a\u0d4d\u0d30\u0d23\u0d35\u0d3e\u0d15\u0d3e\u0d30\u0d2e\u0d4d"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0917\u091c\u093e\u0928\u0928\u092f\u0941\u0924\u092e\u094d \u0917\u0923\u0947\u0936\u094d\u0935\u0930\u092e\u094d <br/> \u092d\u091c\u093e\u092e\u093f \u0938\u0924\u0924\u092e\u094d \u0938\u0941\u0930\u0947\u0936\u094d\u0935\u0930\u092e\u094d"}, {"M": "\u0938\u092e\u0938\u094d\u0924\u093f \u091a\u0930\u0923\u092e\u094d", "T": "\u0905\u091c\u0947\u0928\u094d\u0926\u094d\u0930 \u092a\u0942\u091c\u093f\u0924 \u0935\u093f\u0918\u094d\u0928\u0947\u0936\u094d\u0935\u0930\u092e\u094d <br/> \u0917\u0923\u093e\u0926\u093f \u0938\u0928\u094d\u0928\u0941\u0924 \u092a\u0926 \u092a\u0926\u094d\u092e\u0915\u0930\u092e\u094d"}, {"M": "\u092e\u0927\u094d\u092f\u092e\u0915\u093e\u0932 \u0938\u093e\u0939\u093f\u0924\u094d\u092f\u092e\u094d", "T": "\u0915\u0941\u0902\u091c\u0930 \u092d\u0902\u091c\u0928 \u091a\u0924\u0941\u0930\u0924\u0930\u0915\u0930\u092e\u094d <br/> \u0917\u0941\u0930\u0941\u0917\u0941\u0939\u093e\u0917\u094d\u0930\u091c\u092e\u094d \u092a\u094d\u0930\u0923\u0935\u093e\u0915\u093e\u0930\u092e\u094d"}]}], "L": "l", "lyricsref": [{"links": [{"N": "www.medieval.org", "L": "http://www.medieval.org/music/world/carnatic/lyrics/TKG/gajananayutam.html"}, {"N": "guru-guha.blogspot.com", "L": "http://guru-guha.blogspot.com/2007/10/dikshitar-kriti-gajaanana-yutham-raga.html"}, {"N": "www.karnatik.com", "L": "http://www.karnatik.com/c1723.shtml"}, {"N": "www.sangeetasudha.org", "L": "http://www.sangeetasudha.org/dikshitar/vol2/d26.html#MARK_GAJANANA"}, {"N": "www.shivkumar.org", "L": "http://www.shivkumar.org/music/gajananayutham.htm"}]}]}