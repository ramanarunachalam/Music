c3e\u0c02\u0c15\u0c41\u0c36\u0c27\u0c30 \u0c2a\u0c30\u0c2e \u0c2a\u0c35\u0c3f\u0c24\u0c4d\u0c30 <br/> \u0c2e\u0c42\u0c36\u0c3f\u0c15\u0c35\u0c3e\u0c39\u0c28 \u0c2e\u0c41\u0c28\u0c3f\u0c1c\u0c28\u0c2a\u0c4d\u0c30\u0c47\u0c2e\u0c3e"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c2e\u0c4b\u0c26\u0c26\u0c3f \u0c28\u0c3f\u0c28\u0c4d\u0c28\u0c2f \u0c2a\u0c3e\u0c26\u0c35 \u0c24\u0c4b\u0c30\u0c4b <br/> \u0c38\u0c3e\u0c27\u0c41 \u0c35\u0c28\u0c4d\u0c26\u0c3f\u0c24\u0c28\u0c46 \u0c06\u0c26\u0c30\u0c26\u0c3f\u0c28\u0c4d\u0c26\u0c32\u0c3f <br/> \u0c38\u0c30\u0c4d\u0c38\u0c3f\u0c1c\u0c28\u0c3e\u0c2d \u0c36\u0c4d\u0c30\u0c40 \u0c2a\u0c41\u0c30\u0c28\u0c4d\u0c26\u0c30 \u0c35\u0c3f\u0c25\u0c32\u0c28 <br/> \u0c28\u0c3f\u0c30\u0c41\u0c24 \u0c28\u0c46\u0c28\u0c46\u0c2f\u0c41\u0c35\u0c28\u0c4d\u0c24\u0c46 \u0c26\u0c2f \u0c2e\u0c3e\u0c21\u0c4b"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0c97\u0c9c\u0cb5\u0ca7\u0ca8\u0cbe \u0cac\u0cc7\u0ca6\u0cc1\u0cb5\u0cc7 \u0c97\u0ccc\u0cb0\u0cbf \u0ca5\u0ca8\u0caf <br/> \u0ca4\u0ccd\u0cb0\u0cbf\u0c9c\u0c97 \u0cb5\u0ca8\u0ccd\u0ca6\u0cbf\u0ca4\u0ca8\u0cc7 \u0cb8\u0cc1\u0c9c\u0ca8\u0cb0 \u0caa\u0cca\u0cb0\u0cc6\u0cb5\u0ca8\u0cc7"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0caa\u0cbe\u0cb6\u0cbe\u0c82\u0c95\u0cc1\u0cb6\u0ca7\u0cb0 \u0caa\u0cb0\u0cae \u0caa\u0cb5\u0cbf\u0ca4\u0ccd\u0cb0 <br/> \u0cae\u0cc2\u0cb6\u0cbf\u0c95\u0cb5\u0cbe\u0cb9\u0ca8 \u0cae\u0cc1\u0ca8\u0cbf\u0c9c\u0ca8\u0caa\u0ccd\u0cb0\u0cc7\u0cae\u0cbe"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0cae\u0ccb\u0ca6\u0ca6\u0cbf \u0ca8\u0cbf\u0ca8\u0ccd\u0ca8\u0caf \u0caa\u0cbe\u0ca6\u0cb5 \u0ca4\u0ccb\u0cb0\u0ccb <br/> \u0cb8\u0cbe\u0ca7\u0cc1 \u0cb5\u0ca8\u0ccd\u0ca6\u0cbf\u0ca4\u0ca8\u0cc6 \u0c86\u0ca6\u0cb0\u0ca6\u0cbf\u0ca8\u0ccd\u0ca6\u0cb2\u0cbf <br/> \u0cb8\u0cb0\u0ccd\u0cb8\u0cbf\u0c9c\u0ca8\u0cbe\u0cad \u0cb6\u0ccd\u0cb0\u0cc0 \u0caa\u0cc1\u0cb0\u0ca8\u0ccd\u0ca6\u0cb0 \u0cb5\u0cbf\u0ca5\u0cb2\u0ca8 <br/> \u0ca8\u0cbf\u0cb0\u0cc1\u0ca4 \u0ca8\u0cc6\u0ca8\u0cc6\u0caf\u0cc1\u0cb5\u0ca8\u0ccd\u0ca4\u0cc6 \u0ca6\u0caf \u0cae\u0cbe\u0ca1\u0ccb"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d17\u0d1c\u0d35\u0d27\u0d28\u0d3e \u0d2c\u0d47\u0d26\u0d41\u0d35\u0d47 \u0d17\u0d4c\u0d30\u0d3f \u0d25\u0d28\u0d2f <br/> \u0d24\u0d4d\u0d30\u0d3f\u0d1c\u0d17 \u0d35\u0d28\u0d4d\u0d26\u0d3f\u0d24\u0d28\u0d47 \u0d38\u0d41\u0d1c\u0d28\u0d30 \u0d2a\u0d4a\u0d30\u0d46\u0d35\u0d28\u0d47"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d2a\u0d3e\u0d36\u0d3e\u0d02\u0d15\u0d41\u0d36\u0d27\u0d30 \u0d2a\u0d30\u0d2e \u0d2a\u0d35\u0d3f\u0d24\u0d4d\u0d30 <br/> \u0d2e\u0d42\u0d36\u0d3f\u0d15\u0d35\u0d3e\u0d39\u0d28 \u0d2e\u0d41\u0d28\u0d3f\u0d1c\u0d28\u0d2a\u0d4d\u0d30\u0d47\u0d2e\u0d3e"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d2e\u0d4b\u0d26\u0d26\u0d3f \u0d28\u0d3f\u0d28\u0d4d\u0d28\u0d2f \u0d2a\u0d3e\u0d26\u0d35 \u0d24\u0d4b\u0d30\u0d4b <br/> \u0d38\u0d3e\u0d27\u0d41 \u0d35\u0d28\u0d4d\u0d26\u0d3f\u0d24\u0d28\u0d46 \u0d06\u0d26\u0d30\u0d26\u0d3f\u0d28\u0d4d\u0d26\u0d32\u0d3f <br/> \u0d38\u0d30\u0d4d\u0d38\u0d3f\u0d1c\u0d28\u0d3e\u0d2d \u0d36\u0d4d\u0d30\u0d40 \u0d2a\u0d41\u0d30\u0d28\u0d4d\u0d26\u0d30 \u0d35\u0d3f\u0d25\u0d32\u0d28 <br/> \u0d28\u0d3f\u0d30\u0d41\u0d24 \u0d28\u0d46\u0d28\u0d46\u0d2f\u0d41\u0d35\u0d28\u0d4d\u0d24\u0d46 \u0d26\u0d2f \u0d2e\u0d3e\u0d21\u0d4b"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0917\u091c\u0935\u0927\u0928\u093e \u092c\u0947\u0926\u0941\u0935\u0947 \u0917\u094c\u0930\u093f \u0925\u0928\u092f <br/> \u0924\u094d\u0930\u093f\u091c\u0917 \u0935\u0928\u094d\u0926\u093f\u0924\u0928\u0947 \u0938\u0941\u091c\u0928\u0930 \u092a\u094b\u0930\u0947\u0935\u0928\u0947"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u092a\u093e\u0936\u093e\u0902\u0915\u0941\u0936\u0927\u0930 \u092a\u0930\u092e \u092a\u0935\u093f\u0924\u094d\u0930 <br/> \u092e\u0942\u0936\u093f\u0915\u0935\u093e\u0939\u0928 \u092e\u0941\u0928\u093f\u091c\u0928\u092a\u094d\u0930\u0947\u092e\u093e"}, {"M": "\u091a\u0930\u0923\u092e\u094d", "T": "\u092e\u094b\u0926\u0926\u093f \u0928\u093f\u0928\u094d\u0928\u092f \u092a\u093e\u0926\u0935 \u0924\u094b\u0930\u094b <br/> \u0938\u093e\u0927\u0941 \u0935\u0928\u094d\u0926\u093f\u0924\u0928\u0947 \u0906\u0926\u0930\u0926\u093f\u0928\u094d\u0926\u0932\u093f <br/> \u0938\u0930\u094d\u0938\u093f\u091c\u0928\u093e\u092d \u0936\u094d\u0930\u0940 \u092a\u0941\u0930\u0928\u094d\u0926\u0930 \u0935\u093f\u0925\u0932\u0928 <br/> \u0928\u093f\u0930\u0941\u0924 \u0928\u0947\u0928\u0947\u092f\u0941\u0935\u0928\u094d\u0924\u0947 \u0926\u092f \u092e\u093e\u0921\u094b"}]}], "L": "l", "lyricsref": [{"links": [{"N": "www.karnatik.com", "L": "http://www.karnatik.com/c1117.shtml"}]}]}