baa\u0bb5 \u0bb6\u0bcd\u0bb0\u0bc0 \u0ba4\u0bcd\u0baf\u0bbe\u0b95\u0bb0\u0bbe\u0b9c \u0ba8\u0bc1\u0ba4"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c17\u0c3f\u0c30\u0c3f \u0c30\u0c3e\u0c1c \u0c38\u0c41\u0c24\u0c3e \u0c24\u0c28\u0c2f \u0c38\u0c26\u0c2f"}, {"M": "\u0c05\u0c28\u0c41\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c38\u0c41\u0c30 \u0c28\u0c3e\u0c25 \u0c2e\u0c41\u0c16\u0c3e\u0c30\u0c4d\u0c1a\u0c3f\u0c24 \u0c2a\u0c3e\u0c26 \u0c2f\u0c41\u0c17 <br/> \u0c2a\u0c30\u0c3f\u0c2a\u0c3e\u0c32\u0c2f \u0c2e\u0c3e\u0c2e\u0c4d \u0c07\u0c2d \u0c30\u0c3e\u0c1c \u0c2e\u0c41\u0c16"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c17\u0c23 \u0c28\u0c3e\u0c25 \u0c2a\u0c30\u0c3e\u0c24\u0c4d\u0c2a\u0c30 \u0c36\u0c02\u0c15\u0c30\u0c3e\u0c17\u0c2e <br/> \u0c35\u0c3e\u0c30\u0c3f \u0c28\u0c3f\u0c27\u0c3f \u0c30\u0c1c\u0c28\u0c40-\u0c15\u0c30 <br/> \u0c2b\u0c23\u0c3f \u0c30\u0c3e\u0c1c \u0c15\u0c02\u0c15\u0c23 \u0c35\u0c3f\u0c18\u0c4d\u0c28 <br/> \u0c28\u0c3f\u0c35\u0c3e\u0c30\u0c23 \u0c36\u0c3e\u0c2e\u0c4d\u0c2d\u0c35 \u0c36\u0c4d\u0c30\u0c40 \u0c24\u0c4d\u0c2f\u0c3e\u0c17\u0c30\u0c3e\u0c1c \u0c28\u0c41\u0c24"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0c97\u0cbf\u0cb0\u0cbf \u0cb0\u0cbe\u0c9c \u0cb8\u0cc1\u0ca4\u0cbe \u0ca4\u0ca8\u0caf \u0cb8\u0ca6\u0caf"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cb8\u0cc1\u0cb0 \u0ca8\u0cbe\u0ca5 \u0cae\u0cc1\u0c96\u0cbe\u0cb0\u0ccd\u0c9a\u0cbf\u0ca4 \u0caa\u0cbe\u0ca6 \u0caf\u0cc1\u0c97 <br/> \u0caa\u0cb0\u0cbf\u0caa\u0cbe\u0cb2\u0caf \u0cae\u0cbe\u0cae\u0ccd \u0c87\u0cad \u0cb0\u0cbe\u0c9c \u0cae\u0cc1\u0c96"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0c97\u0ca3 \u0ca8\u0cbe\u0ca5 \u0caa\u0cb0\u0cbe\u0ca4\u0ccd\u0caa\u0cb0 \u0cb6\u0c82\u0c95\u0cb0\u0cbe\u0c97\u0cae <br/> \u0cb5\u0cbe\u0cb0\u0cbf \u0ca8\u0cbf\u0ca7\u0cbf \u0cb0\u0c9c\u0ca8\u0cc0-\u0c95\u0cb0 <br/> \u0cab\u0ca3\u0cbf \u0cb0\u0cbe\u0c9c \u0c95\u0c82\u0c95\u0ca3 \u0cb5\u0cbf\u0c98\u0ccd\u0ca8 <br/> \u0ca8\u0cbf\u0cb5\u0cbe\u0cb0\u0ca3 \u0cb6\u0cbe\u0cae\u0ccd\u0cad\u0cb5 \u0cb6\u0ccd\u0cb0\u0cc0 \u0ca4\u0ccd\u0caf\u0cbe\u0c97\u0cb0\u0cbe\u0c9c \u0ca8\u0cc1\u0ca4"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d17\u0d3f\u0d30\u0d3f \u0d30\u0d3e\u0d1c \u0d38\u0d41\u0d24\u0d3e \u0d24\u0d28\u0d2f \u0d38\u0d26\u0d2f"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d38\u0d41\u0d30 \u0d28\u0d3e\u0d25 \u0d2e\u0d41\u0d16\u0d3e\u0d30\u0d4d\u0d1a\u0d3f\u0d24 \u0d2a\u0d3e\u0d26 \u0d2f\u0d41\u0d17 <br/> \u0d2a\u0d30\u0d3f\u0d2a\u0d3e\u0d32\u0d2f \u0d2e\u0d3e\u0d2e\u0d4d \u0d07\u0d2d \u0d30\u0d3e\u0d1c \u0d2e\u0d41\u0d16"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d17\u0d23 \u0d28\u0d3e\u0d25 \u0d2a\u0d30\u0d3e\u0d24\u0d4d\u0d2a\u0d30 \u0d36\u0d02\u0d15\u0d30\u0d3e\u0d17\u0d2e <br/> \u0d35\u0d3e\u0d30\u0d3f \u0d28\u0d3f\u0d27\u0d3f \u0d30\u0d1c\u0d28\u0d40-\u0d15\u0d30 <br/> \u0d2b\u0d23\u0d3f \u0d30\u0d3e\u0d1c \u0d15\u0d02\u0d15\u0d23 \u0d35\u0d3f\u0d18\u0d4d\u0d28 <br/> \u0d28\u0d3f\u0d35\u0d3e\u0d30\u0d23 \u0d36\u0d3e\u0d2e\u0d4d\u0d2d\u0d35 \u0d36\u0d4d\u0d30\u0d40 \u0d24\u0d4d\u0d2f\u0d3e\u0d17\u0d30\u0d3e\u0d1c \u0d28\u0d41\u0d24"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0917\u093f\u0930\u093f \u0930\u093e\u091c \u0938\u0941\u0924\u093e \u0924\u0928\u092f \u0938\u0926\u092f"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0938\u0941\u0930 \u0928\u093e\u0925 \u092e\u0941\u0916\u093e\u0930\u094d\u091a\u093f\u0924 \u092a\u093e\u0926 \u092f\u0941\u0917 <br/> \u092a\u0930\u093f\u092a\u093e\u0932\u092f \u092e\u093e\u092e\u094d \u0907\u092d \u0930\u093e\u091c \u092e\u0941\u0916"}, {"M": "\u091a\u0930\u0923\u092e\u094d", "T": "\u0917\u0923 \u0928\u093e\u0925 \u092a\u0930\u093e\u0924\u094d\u092a\u0930 \u0936\u0902\u0915\u0930\u093e\u0917\u092e <br/> \u0935\u093e\u0930\u093f \u0928\u093f\u0927\u093f \u0930\u091c\u0928\u0940-\u0915\u0930 <br/> \u092b\u0923\u093f \u0930\u093e\u091c \u0915\u0902\u0915\u0923 \u0935\u093f\u0918\u094d\u0928 <br/> \u0928\u093f\u0935\u093e\u0930\u0923 \u0936\u093e\u092e\u094d\u092d\u0935 \u0936\u094d\u0930\u0940 \u0924\u094d\u092f\u093e\u0917\u0930\u093e\u091c \u0928\u0941\u0924"}]}], "L": "l", "lyricsref": [{"links": [{"N": "thyagaraja-vaibhavam.blogspot.com", "L": "http://thyagaraja-vaibhavam.blogspot.com/2008/06/thyagaraja-kriti-giri-raja-suta-raga.html"}, {"N": "www.sangeetasudha.org", "L": "http://www.sangeetasudha.org/thyagaraja/g.html#MARK_GIRIRAJASUTA"}, {"N": "www.karnatik.com", "L": "http://www.karnatik.com/c2340.shtml"}]}]}