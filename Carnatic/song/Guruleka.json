inci cedaru jAlini karuNatO <br/> manasunaNTaka sEyu mandanucu tatva <br/> bOdhana jEsi kApADu tyAgarAjAptuDagu"}]}, {"L": "Tamil", "text": [{"M": "\u0baa\u0bb2\u0bcd\u0bb2\u0bb5\u0bbf", "T": "\u0b95\u0bc1\u0bb0\u0bc1 \u0bb2\u0bc7\u0b95\u0baf\u0bc6\u0b9f\u0bc1\u0bb5\u0ba3\u0bcd\u0b9f\u0bbf \u0b95\u0bc1\u0ba3\u0bbf\u0b95\u0bbf \u0ba4\u0bc6\u0bb2\u0bbf\u0baf\u0b95 \u0baa\u0bcb\u0ba4\u0bc1"}, {"M": "\u0b85\u0ba9\u0bc1\u0baa\u0bb2\u0bcd\u0bb2\u0bb5\u0bbf", "T": "\u0b95\u0bb0\u0bc1\u0b95\u0bc8\u0ba9 \u0bb9\u0bcd\u0bb0\u0bc1\u0ba4\u0bcd-\u0bb0\u0bcb\u0b95 \u0b95\u0bb9\u0ba9\u0bae\u0bc1\u0ba9\u0bc1 \u0b95\u0bca\u0b9f\u0bcd\u0b9f\u0ba9\u0bc1 \u0b9a\u0ba4\u0bcd-"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd", "T": "\u0ba4\u0ba9\u0bc1\u0bb5\u0bc1 \u0b9a\u0bc1\u0ba4 \u0ba4\u0ba9 \u0ba4\u0bbe\u0bb0 \u0ba4\u0bbe\u0baf\u0bbe\u0ba4\u0bbf \u0baa\u0bbe\u0ba8\u0bcd\u0ba4\u0bb5\u0bc1\u0bb2\u0bc1 <br/> \u0b9c\u0ba9\u0bbf\u0baf\u0bbf\u0ba9\u0bcd\u0b9a\u0bbf \u0b9a\u0bc6\u0ba4\u0bb0\u0bc1 \u0b9c\u0bbe\u0bb2\u0bbf\u0ba9\u0bbf \u0b95\u0bb0\u0bc1\u0ba3\u0ba4\u0bcb <br/> \u0bae\u0ba9\u0b9a\u0bc1\u0ba9\u0ba3\u0bcd\u0b9f\u0b95 \u0b9a\u0bc7\u0baf\u0bc1 \u0bae\u0ba8\u0bcd\u0ba4\u0ba9\u0bc1\u0b9a\u0bc1 \u0ba4\u0ba4\u0bcd\u0bb5 <br/> \u0baa\u0bcb\u0ba4\u0ba9 \u0b9c\u0bc7\u0b9a\u0bbf \u0b95\u0bbe\u0baa\u0bbe\u0b9f\u0bc1 \u0ba4\u0bcd\u0baf\u0bbe\u0b95\u0bb0\u0bbe\u0b9c\u0bbe\u0baa\u0bcd\u0ba4\u0bc1\u0b9f\u0b95\u0bc1"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c17\u0c41\u0c30\u0c41 \u0c32\u0c47\u0c15\u0c2f\u0c46\u0c1f\u0c41\u0c35\u0c23\u0c4d\u0c1f\u0c3f \u0c17\u0c41\u0c23\u0c3f\u0c15\u0c3f \u0c24\u0c46\u0c32\u0c3f\u0c2f\u0c17 \u0c2a\u0c4b\u0c26\u0c41"}, {"M": "\u0c05\u0c28\u0c41\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c15\u0c30\u0c41\u0c15\u0c48\u0c28 \u0c39\u0c43\u0c26\u0c4d-\u0c30\u0c4b\u0c17 \u0c17\u0c39\u0c28\u0c2e\u0c41\u0c28\u0c41 \u0c15\u0c4a\u0c1f\u0c4d\u0c1f\u0c28\u0c41 \u0c38\u0c26\u0c4d-"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c24\u0c28\u0c41\u0c35\u0c41 \u0c38\u0c41\u0c24 \u0c27\u0c28 \u0c26\u0c3e\u0c30 \u0c26\u0c3e\u0c2f\u0c3e\u0c26\u0c3f \u0c2c\u0c3e\u0c28\u0c4d\u0c27\u0c35\u0c41\u0c32\u0c41 <br/> \u0c1c\u0c28\u0c3f\u0c2f\u0c3f\u0c28\u0c4d\u0c1a\u0c3f \u0c1a\u0c46\u0c26\u0c30\u0c41 \u0c1c\u0c3e\u0c32\u0c3f\u0c28\u0c3f \u0c15\u0c30\u0c41\u0c23\u0c24\u0c4b <br/> \u0c2e\u0c28\u0c38\u0c41\u0c28\u0c23\u0c4d\u0c1f\u0c15 \u0c38\u0c47\u0c2f\u0c41 \u0c2e\u0c28\u0c4d\u0c26\u0c28\u0c41\u0c1a\u0c41 \u0c24\u0c24\u0c4d\u0c35 <br/> \u0c2c\u0c4b\u0c27\u0c28 \u0c1c\u0c47\u0c38\u0c3f \u0c15\u0c3e\u0c2a\u0c3e\u0c21\u0c41 \u0c24\u0c4d\u0c2f\u0c3e\u0c17\u0c30\u0c3e\u0c1c\u0c3e\u0c2a\u0c4d\u0c24\u0c41\u0c21\u0c17\u0c41"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0c97\u0cc1\u0cb0\u0cc1 \u0cb2\u0cc7\u0c95\u0caf\u0cc6\u0c9f\u0cc1\u0cb5\u0ca3\u0ccd\u0c9f\u0cbf \u0c97\u0cc1\u0ca3\u0cbf\u0c95\u0cbf \u0ca4\u0cc6\u0cb2\u0cbf\u0caf\u0c97 \u0caa\u0ccb\u0ca6\u0cc1"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0c95\u0cb0\u0cc1\u0c95\u0cc8\u0ca8 \u0cb9\u0cc3\u0ca6\u0ccd-\u0cb0\u0ccb\u0c97 \u0c97\u0cb9\u0ca8\u0cae\u0cc1\u0ca8\u0cc1 \u0c95\u0cca\u0c9f\u0ccd\u0c9f\u0ca8\u0cc1 \u0cb8\u0ca6\u0ccd-"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0ca4\u0ca8\u0cc1\u0cb5\u0cc1 \u0cb8\u0cc1\u0ca4 \u0ca7\u0ca8 \u0ca6\u0cbe\u0cb0 \u0ca6\u0cbe\u0caf\u0cbe\u0ca6\u0cbf \u0cac\u0cbe\u0ca8\u0ccd\u0ca7\u0cb5\u0cc1\u0cb2\u0cc1 <br/> \u0c9c\u0ca8\u0cbf\u0caf\u0cbf\u0ca8\u0ccd\u0c9a\u0cbf \u0c9a\u0cc6\u0ca6\u0cb0\u0cc1 \u0c9c\u0cbe\u0cb2\u0cbf\u0ca8\u0cbf \u0c95\u0cb0\u0cc1\u0ca3\u0ca4\u0ccb <br/> \u0cae\u0ca8\u0cb8\u0cc1\u0ca8\u0ca3\u0ccd\u0c9f\u0c95 \u0cb8\u0cc7\u0caf\u0cc1 \u0cae\u0ca8\u0ccd\u0ca6\u0ca8\u0cc1\u0c9a\u0cc1 \u0ca4\u0ca4\u0ccd\u0cb5 <br/> \u0cac\u0ccb\u0ca7\u0ca8 \u0c9c\u0cc7\u0cb8\u0cbf \u0c95\u0cbe\u0caa\u0cbe\u0ca1\u0cc1 \u0ca4\u0ccd\u0caf\u0cbe\u0c97\u0cb0\u0cbe\u0c9c\u0cbe\u0caa\u0ccd\u0ca4\u0cc1\u0ca1\u0c97\u0cc1"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d17\u0d41\u0d30\u0d41 \u0d32\u0d47\u0d15\u0d2f\u0d46\u0d1f\u0d41\u0d35\u0d23\u0d4d\u0d1f\u0d3f \u0d17\u0d41\u0d23\u0d3f\u0d15\u0d3f \u0d24\u0d46\u0d32\u0d3f\u0d2f\u0d17 \u0d2a\u0d4b\u0d26\u0d41"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d15\u0d30\u0d41\u0d15\u0d48\u0d28 \u0d39\u0d43\u0d26\u0d4d-\u0d30\u0d4b\u0d17 \u0d17\u0d39\u0d28\u0d2e\u0d41\u0d28\u0d41 \u0d15\u0d4a\u0d1f\u0d4d\u0d1f\u0d28\u0d41 \u0d38\u0d26\u0d4d-"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d24\u0d28\u0d41\u0d35\u0d41 \u0d38\u0d41\u0d24 \u0d27\u0d28 \u0d26\u0d3e\u0d30 \u0d26\u0d3e\u0d2f\u0d3e\u0d26\u0d3f \u0d2c\u0d3e\u0d28\u0d4d\u0d27\u0d35\u0d41\u0d32\u0d41 <br/> \u0d1c\u0d28\u0d3f\u0d2f\u0d3f\u0d28\u0d4d\u0d1a\u0d3f \u0d1a\u0d46\u0d26\u0d30\u0d41 \u0d1c\u0d3e\u0d32\u0d3f\u0d28\u0d3f \u0d15\u0d30\u0d41\u0d23\u0d24\u0d4b <br/> \u0d2e\u0d28\u0d38\u0d41\u0d28\u0d23\u0d4d\u0d1f\u0d15 \u0d38\u0d47\u0d2f\u0d41 \u0d2e\u0d28\u0d4d\u0d26\u0d28\u0d41\u0d1a\u0d41 \u0d24\u0d24\u0d4d\u0d35 <br/> \u0d2c\u0d4b\u0d27\u0d28 \u0d1c\u0d47\u0d38\u0d3f \u0d15\u0d3e\u0d2a\u0d3e\u0d21\u0d41 \u0d24\u0d4d\u0d2f\u0d3e\u0d17\u0d30\u0d3e\u0d1c\u0d3e\u0d2a\u0d4d\u0d24\u0d41\u0d21\u0d17\u0d41"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0917\u0941\u0930\u0941 \u0932\u0947\u0915\u092f\u0947\u091f\u0941\u0935\u0923\u094d\u091f\u093f \u0917\u0941\u0923\u093f\u0915\u093f \u0924\u0947\u0932\u093f\u092f\u0917 \u092a\u094b\u0926\u0941"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0915\u0930\u0941\u0915\u0948\u0928 \u0939\u0943\u0926\u094d-\u0930\u094b\u0917 \u0917\u0939\u0928\u092e\u0941\u0928\u0941 \u0915\u094b\u091f\u094d\u091f\u0928\u0941 \u0938\u0926\u094d-"}, {"M": "\u091a\u0930\u0923\u092e\u094d", "T": "\u0924\u0928\u0941\u0935\u0941 \u0938\u0941\u0924 \u0927\u0928 \u0926\u093e\u0930 \u0926\u093e\u092f\u093e\u0926\u093f \u092c\u093e\u0928\u094d\u0927\u0935\u0941\u0932\u0941 <br/> \u091c\u0928\u093f\u092f\u093f\u0928\u094d\u091a\u093f \u091a\u0947\u0926\u0930\u0941 \u091c\u093e\u0932\u093f\u0928\u093f \u0915\u0930\u0941\u0923\u0924\u094b <br/> \u092e\u0928\u0938\u0941\u0928\u0923\u094d\u091f\u0915 \u0938\u0947\u092f\u0941 \u092e\u0928\u094d\u0926\u0928\u0941\u091a\u0941 \u0924\u0924\u094d\u0935 <br/> \u092c\u094b\u0927\u0928 \u091c\u0947\u0938\u093f \u0915\u093e\u092a\u093e\u0921\u0941 \u0924\u094d\u092f\u093e\u0917\u0930\u093e\u091c\u093e\u092a\u094d\u0924\u0941\u0921\u0917\u0941"}]}], "L": "l", "lyricsref": [{"links": [{"N": "thyagaraja-vaibhavam.blogspot.com", "L": "http://thyagaraja-vaibhavam.blogspot.com/2007/11/thyagaraja-kriti-guru-leka-raga-gauri.html"}, {"N": "www.karnatik.com", "L": "http://www.karnatik.com/c2343.shtml"}, {"N": "www.sangeetasudha.org", "L": "http://www.sangeetasudha.org/thyagaraja/g.html#MARK_GURULEKA"}, {"N": "www.shivkumar.org", "L": "http://www.shivkumar.org/music/guruleka.htm"}]}]}