rvatajA prArthitAblinga vibhO <br/> panca bhUta-maya prapanca prabhO <br/> sarva jIva dayA-kara shambhO <br/> sAmajATavI nilaya svayambhO <br/> sharva karuNA sudhA sindhO <br/> sharaNAgata vatsalArta bandhO <br/> anirvacanIya nAda bindO <br/> nitya mauLi vidhruta gangEndO"}, {"M": "madhyamakAla sAhityam", "T": "nirvikalpaka samAdhi niSTha shiva kalpaka tarO <br/> nirvishESa caitanya niranjana guru guha gurO"}]}, {"L": "Tamil", "text": [{"M": "\u0baa\u0bb2\u0bcd\u0bb2\u0bb5\u0bbf", "T": "\u0b9c\u0bae\u0bcd\u0baa\u0bc2 \u0baa\u0ba4\u0bc7 \u0bae\u0bbe\u0bae\u0bcd \u0baa\u0bbe\u0bb9\u0bbf \u0ba8\u0bbf\u0b9c\u0bbe\u0ba9\u0ba8\u0bcd\u0ba4\u0bbe\u0bae\u0bcd\u0bb0\u0bc1\u0ba4 \u0baa\u0bcb\u0ba4\u0bae\u0bcd \u0ba4\u0bc7\u0bb9\u0bbf"}, {"M": "\u0b85\u0ba9\u0bc1\u0baa\u0bb2\u0bcd\u0bb2\u0bb5\u0bbf", "T": "\u0b85\u0bae\u0bcd\u0baa\u0bc1\u0b9c\u0bbe\u0b9a\u0ba9\u0bbe\u0ba4\u0bbf \u0b9a\u0b95\u0bb2 \u0ba4\u0bc7\u0bb5 \u0ba8\u0bae\u0ba9 <br/> \u0ba4\u0bc1\u0bae\u0bcd\u0baa\u0bc1\u0bb0\u0bc1 \u0ba8\u0bc1\u0ba4 \u0bb9\u0bcd\u0bb0\u0bc1\u0ba4\u0baf \u0ba4\u0bbe\u0baa\u0bcb\u0baa\u0bb7\u0bae\u0ba9 <br/> \u0b85\u0bae\u0bcd\u0baa\u0bc1\u0ba4\u0bbf \u0b95\u0b99\u0bcd\u0b95\u0bbe \u0b95\u0bbe\u0bb5\u0bc7\u0bb0\u0bc0 \u0baf\u0bae\u0bc1\u0ba9\u0bbe <br/> \u0b95\u0bae\u0bcd\u0baa\u0bc1 \u0b95\u0ba3\u0bcd\u0b9f\u0bcd\u0baf\u0b95\u0bbf\u0bb2\u0bbe\u0ba3\u0bcd\u0b9f\u0bc7\u0bb7\u0bcd\u0bb5\u0bb0\u0bc0 \u0bb0\u0bae\u0ba3"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd", "T": "\u0baa\u0bb0\u0bcd\u0bb5\u0ba4\u0b9c\u0bbe \u0baa\u0bcd\u0bb0\u0bbe\u0bb0\u0bcd\u0ba4\u0bbf\u0ba4\u0bbe\u0baa\u0bcd\u0bb2\u0bbf\u0b99\u0bcd\u0b95 \u0bb5\u0bbf\u0baa\u0bcb <br/> \u0baa\u0ba9\u0bcd\u0b9a \u0baa\u0bc2\u0ba4-\u0bae\u0baf \u0baa\u0bcd\u0bb0\u0baa\u0ba9\u0bcd\u0b9a \u0baa\u0bcd\u0bb0\u0baa\u0bcb <br/> \u0b9a\u0bb0\u0bcd\u0bb5 \u0b9c\u0bc0\u0bb5 \u0ba4\u0baf\u0bbe-\u0b95\u0bb0 \u0bb7\u0bae\u0bcd\u0baa\u0bcb <br/> \u0b9a\u0bbe\u0bae\u0b9c\u0bbe\u0b9f\u0bb5\u0bc0 \u0ba8\u0bbf\u0bb2\u0baf \u0bb8\u0bcd\u0bb5\u0baf\u0bae\u0bcd\u0baa\u0bcb <br/> \u0bb7\u0bb0\u0bcd\u0bb5 \u0b95\u0bb0\u0bc1\u0ba3\u0bbe \u0b9a\u0bc1\u0ba4\u0bbe \u0b9a\u0bbf\u0ba8\u0bcd\u0ba4\u0bcb <br/> \u0bb7\u0bb0\u0ba3\u0bbe\u0b95\u0ba4 \u0bb5\u0ba4\u0bcd\u0b9a\u0bb2\u0bbe\u0bb0\u0bcd\u0ba4 \u0baa\u0ba8\u0bcd\u0ba4\u0bcb <br/> \u0b85\u0ba9\u0bbf\u0bb0\u0bcd\u0bb5\u0b9a\u0ba9\u0bc0\u0baf \u0ba8\u0bbe\u0ba4 \u0baa\u0bbf\u0ba8\u0bcd\u0ba4\u0bcb <br/> \u0ba8\u0bbf\u0ba4\u0bcd\u0baf \u0bae\u0bcc\u0bb3\u0bbf \u0bb5\u0bbf\u0ba4\u0bcd\u0bb0\u0bc1\u0ba4 \u0b95\u0b99\u0bcd\u0b95\u0bc7\u0ba8\u0bcd\u0ba4\u0bcb"}, {"M": "\u0bae\u0ba4\u0bcd\u0baf\u0bae\u0b95\u0bbe\u0bb2 \u0b9a\u0bbe\u0bb9\u0bbf\u0ba4\u0bcd\u0baf\u0bae\u0bcd", "T": "\u0ba8\u0bbf\u0bb0\u0bcd\u0bb5\u0bbf\u0b95\u0bb2\u0bcd\u0baa\u0b95 \u0b9a\u0bae\u0bbe\u0ba4\u0bbf \u0ba8\u0bbf\u0bb6\u0bcd\u0b9f \u0bb7\u0bbf\u0bb5 \u0b95\u0bb2\u0bcd\u0baa\u0b95 \u0ba4\u0bb0\u0bcb <br/> \u0ba8\u0bbf\u0bb0\u0bcd\u0bb5\u0bbf\u0bb7\u0bc7\u0b9a \u0b9a\u0bc8\u0ba4\u0ba9\u0bcd\u0baf \u0ba8\u0bbf\u0bb0\u0ba9\u0bcd\u0b9c\u0ba9 \u0b95\u0bc1\u0bb0\u0bc1 \u0b95\u0bc1\u0bb9 \u0b95\u0bc1\u0bb0\u0bcb"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c1c\u0c2e\u0c4d\u0c2c\u0c42 \u0c2a\u0c24\u0c47 \u0c2e\u0c3e\u0c02 \u0c2a\u0c3e\u0c39\u0c3f \u0c28\u0c3f\u0c1c\u0c3e\u0c28\u0c28\u0c4d\u0c26\u0c3e\u0c2e\u0c43\u0c24 \u0c2c\u0c4b\u0c27\u0c02 \u0c26\u0c47\u0c39\u0c3f"}, {"M": "\u0c05\u0c28\u0c41\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c05\u0c2e\u0c4d\u0c2c\u0c41\u0c1c\u0c3e\u0c38\u0c28\u0c3e\u0c26\u0c3f \u0c38\u0c15\u0c32 \u0c26\u0c47\u0c35 \u0c28\u0c2e\u0c28 <br/> \u0c24\u0c41\u0c2e\u0c4d\u0c2c\u0c41\u0c30\u0c41 \u0c28\u0c41\u0c24 \u0c39\u0c43\u0c26\u0c2f \u0c24\u0c3e\u0c2a\u0c4b\u0c2a\u0c37\u0c2e\u0c28 <br/> \u0c05\u0c2e\u0c4d\u0c2c\u0c41\u0c27\u0c3f \u0c17\u0c02\u0c17\u0c3e \u0c15\u0c3e\u0c35\u0c47\u0c30\u0c40 \u0c2f\u0c2e\u0c41\u0c28\u0c3e <br/> \u0c15\u0c2e\u0c4d\u0c2c\u0c41 \u0c15\u0c23\u0c4d\u0c20\u0c4d\u0c2f\u0c16\u0c3f\u0c32\u0c3e\u0c23\u0c4d\u0c21\u0c47\u0c37\u0c4d\u0c35\u0c30\u0c40 \u0c30\u0c2e\u0c23"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c2a\u0c30\u0c4d\u0c35\u0c24\u0c1c\u0c3e \u0c2a\u0c4d\u0c30\u0c3e\u0c30\u0c4d\u0c25\u0c3f\u0c24\u0c3e\u0c2c\u0c4d\u0c32\u0c3f\u0c02\u0c17 \u0c35\u0c3f\u0c2d\u0c4b <br/> \u0c2a\u0c28\u0c4d\u0c1a \u0c2d\u0c42\u0c24-\u0c2e\u0c2f \u0c2a\u0c4d\u0c30\u0c2a\u0c28\u0c4d\u0c1a \u0c2a\u0c4d\u0c30\u0c2d\u0c4b <br/> \u0c38\u0c30\u0c4d\u0c35 \u0c1c\u0c40\u0c35 \u0c26\u0c2f\u0c3e-\u0c15\u0c30 \u0c37\u0c2e\u0c4d\u0c2d\u0c4b <br/> \u0c38\u0c3e\u0c2e\u0c1c\u0c3e\u0c1f\u0c35\u0c40 \u0c28\u0c3f\u0c32\u0c2f \u0c38\u0c4d\u0c35\u0c2f\u0c2e\u0c4d\u0c2d\u0c4b <br/> \u0c37\u0c30\u0c4d\u0c35 \u0c15\u0c30\u0c41\u0c23\u0c3e \u0c38\u0c41\u0c27\u0c3e \u0c38\u0c3f\u0c28\u0c4d\u0c27\u0c4b <br/> \u0c37\u0c30\u0c23\u0c3e\u0c17\u0c24 \u0c35\u0c24\u0c4d\u0c38\u0c32\u0c3e\u0c30\u0c4d\u0c24 \u0c2c\u0c28\u0c4d\u0c27\u0c4b <br/> \u0c05\u0c28\u0c3f\u0c30\u0c4d\u0c35\u0c1a\u0c28\u0c40\u0c2f \u0c28\u0c3e\u0c26 \u0c2c\u0c3f\u0c28\u0c4d\u0c26\u0c4b <br/> \u0c28\u0c3f\u0c24\u0c4d\u0c2f \u0c2e\u0c4c\u0c33\u0c3f \u0c35\u0c3f\u0c27\u0c43\u0c24 \u0c17\u0c02\u0c17\u0c47\u0c28\u0c4d\u0c26\u0c4b"}, {"M": "\u0c2e\u0c27\u0c4d\u0c2f\u0c2e\u0c15\u0c3e\u0c32 \u0c38\u0c3e\u0c39\u0c3f\u0c24\u0c4d\u0c2f\u0c2e\u0c4d", "T": "\u0c28\u0c3f\u0c30\u0c4d\u0c35\u0c3f\u0c15\u0c32\u0c4d\u0c2a\u0c15 \u0c38\u0c2e\u0c3e\u0c27\u0c3f \u0c28\u0c3f\u0c36\u0c4d\u0c20 \u0c37\u0c3f\u0c35 \u0c15\u0c32\u0c4d\u0c2a\u0c15 \u0c24\u0c30\u0c4b <br/> \u0c28\u0c3f\u0c30\u0c4d\u0c35\u0c3f\u0c37\u0c47\u0c36 \u0c1a\u0c48\u0c24\u0c28\u0c4d\u0c2f \u0c28\u0c3f\u0c30\u0c28\u0c4d\u0c1c\u0c28 \u0c17\u0c41\u0c30\u0c41 \u0c17\u0c41\u0c39 \u0c17\u0c41\u0c30\u0c4b"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0c9c\u0cae\u0ccd\u0cac\u0cc2 \u0caa\u0ca4\u0cc7 \u0cae\u0cbe\u0c82 \u0caa\u0cbe\u0cb9\u0cbf \u0ca8\u0cbf\u0c9c\u0cbe\u0ca8\u0ca8\u0ccd\u0ca6\u0cbe\u0cae\u0cc3\u0ca4 \u0cac\u0ccb\u0ca7\u0c82 \u0ca6\u0cc7\u0cb9\u0cbf"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0c85\u0cae\u0ccd\u0cac\u0cc1\u0c9c\u0cbe\u0cb8\u0ca8\u0cbe\u0ca6\u0cbf \u0cb8\u0c95\u0cb2 \u0ca6\u0cc7\u0cb5 \u0ca8\u0cae\u0ca8 <br/> \u0ca4\u0cc1\u0cae\u0ccd\u0cac\u0cc1\u0cb0\u0cc1 \u0ca8\u0cc1\u0ca4 \u0cb9\u0cc3\u0ca6\u0caf \u0ca4\u0cbe\u0caa\u0ccb\u0caa\u0cb7\u0cae\u0ca8 <br/> \u0c85\u0cae\u0ccd\u0cac\u0cc1\u0ca7\u0cbf \u0c97\u0c82\u0c97\u0cbe \u0c95\u0cbe\u0cb5\u0cc7\u0cb0\u0cc0 \u0caf\u0cae\u0cc1\u0ca8\u0cbe <br/> \u0c95\u0cae\u0ccd\u0cac\u0cc1 \u0c95\u0ca3\u0ccd\u0ca0\u0ccd\u0caf\u0c96\u0cbf\u0cb2\u0cbe\u0ca3\u0ccd\u0ca1\u0cc7\u0cb7\u0ccd\u0cb5\u0cb0\u0cc0 \u0cb0\u0cae\u0ca3"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0caa\u0cb0\u0ccd\u0cb5\u0ca4\u0c9c\u0cbe \u0caa\u0ccd\u0cb0\u0cbe\u0cb0\u0ccd\u0ca5\u0cbf\u0ca4\u0cbe\u0cac\u0ccd\u0cb2\u0cbf\u0c82\u0c97 \u0cb5\u0cbf\u0cad\u0ccb <br/> \u0caa\u0ca8\u0ccd\u0c9a \u0cad\u0cc2\u0ca4-\u0cae\u0caf \u0caa\u0ccd\u0cb0\u0caa\u0ca8\u0ccd\u0c9a \u0caa\u0ccd\u0cb0\u0cad\u0ccb <br/> \u0cb8\u0cb0\u0ccd\u0cb5 \u0c9c\u0cc0\u0cb5 \u0ca6\u0caf\u0cbe-\u0c95\u0cb0 \u0cb7\u0cae\u0ccd\u0cad\u0ccb <br/> \u0cb8\u0cbe\u0cae\u0c9c\u0cbe\u0c9f\u0cb5\u0cc0 \u0ca8\u0cbf\u0cb2\u0caf \u0cb8\u0ccd\u0cb5\u0caf\u0cae\u0ccd\u0cad\u0ccb <br/> \u0cb7\u0cb0\u0ccd\u0cb5 \u0c95\u0cb0\u0cc1\u0ca3\u0cbe \u0cb8\u0cc1\u0ca7\u0cbe \u0cb8\u0cbf\u0ca8\u0ccd\u0ca7\u0ccb <br/> \u0cb7\u0cb0\u0ca3\u0cbe\u0c97\u0ca4 \u0cb5\u0ca4\u0ccd\u0cb8\u0cb2\u0cbe\u0cb0\u0ccd\u0ca4 \u0cac\u0ca8\u0ccd\u0ca7\u0ccb <br/> \u0c85\u0ca8\u0cbf\u0cb0\u0ccd\u0cb5\u0c9a\u0ca8\u0cc0\u0caf \u0ca8\u0cbe\u0ca6 \u0cac\u0cbf\u0ca8\u0ccd\u0ca6\u0ccb <br/> \u0ca8\u0cbf\u0ca4\u0ccd\u0caf \u0cae\u0ccc\u0cb3\u0cbf \u0cb5\u0cbf\u0ca7\u0cc3\u0ca4 \u0c97\u0c82\u0c97\u0cc7\u0ca8\u0ccd\u0ca6\u0ccb"}, {"M": "\u0cae\u0ca7\u0ccd\u0caf\u0cae\u0c95\u0cbe\u0cb2 \u0cb8\u0cbe\u0cb9\u0cbf\u0ca4\u0ccd\u0caf\u0cae\u0ccd", "T": "\u0ca8\u0cbf\u0cb0\u0ccd\u0cb5\u0cbf\u0c95\u0cb2\u0ccd\u0caa\u0c95 \u0cb8\u0cae\u0cbe\u0ca7\u0cbf \u0ca8\u0cbf\u0cb6\u0ccd\u0ca0 \u0cb7\u0cbf\u0cb5 \u0c95\u0cb2\u0ccd\u0caa\u0c95 \u0ca4\u0cb0\u0ccb <br/> \u0ca8\u0cbf\u0cb0\u0ccd\u0cb5\u0cbf\u0cb7\u0cc7\u0cb6 \u0c9a\u0cc8\u0ca4\u0ca8\u0ccd\u0caf \u0ca8\u0cbf\u0cb0\u0ca8\u0ccd\u0c9c\u0ca8 \u0c97\u0cc1\u0cb0\u0cc1 \u0c97\u0cc1\u0cb9 \u0c97\u0cc1\u0cb0\u0ccb"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d1c\u0d2e\u0d4d\u0d2c\u0d42 \u0d2a\u0d24\u0d47 \u0d2e\u0d3e\u0d02 \u0d2a\u0d3e\u0d39\u0d3f \u0d28\u0d3f\u0d1c\u0d3e\u0d28\u0d28\u0d4d\u0d26\u0d3e\u0d2e\u0d43\u0d24 \u0d2c\u0d4b\u0d27\u0d02 \u0d26\u0d47\u0d39\u0d3f"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d05\u0d2e\u0d4d\u0d2c\u0d41\u0d1c\u0d3e\u0d38\u0d28\u0d3e\u0d26\u0d3f \u0d38\u0d15\u0d32 \u0d26\u0d47\u0d35 \u0d28\u0d2e\u0d28 <br/> \u0d24\u0d41\u0d2e\u0d4d\u0d2c\u0d41\u0d30\u0d41 \u0d28\u0d41\u0d24 \u0d39\u0d43\u0d26\u0d2f \u0d24\u0d3e\u0d2a\u0d4b\u0d2a\u0d37\u0d2e\u0d28 <br/> \u0d05\u0d2e\u0d4d\u0d2c\u0d41\u0d27\u0d3f \u0d17\u0d02\u0d17\u0d3e \u0d15\u0d3e\u0d35\u0d47\u0d30\u0d40 \u0d2f\u0d2e\u0d41\u0d28\u0d3e <br/> \u0d15\u0d2e\u0d4d\u0d2c\u0d41 \u0d15\u0d23\u0d4d\u0d20\u0d4d\u0d2f\u0d16\u0d3f\u0d32\u0d3e\u0d23\u0d4d\u0d21\u0d47\u0d37\u0d4d\u0d35\u0d30\u0d40 \u0d30\u0d2e\u0d23"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d2a\u0d30\u0d4d\u0d35\u0d24\u0d1c\u0d3e \u0d2a\u0d4d\u0d30\u0d3e\u0d30\u0d4d\u0d25\u0d3f\u0d24\u0d3e\u0d2c\u0d4d\u0d32\u0d3f\u0d02\u0d17 \u0d35\u0d3f\u0d2d\u0d4b <br/> \u0d2a\u0d28\u0d4d\u0d1a \u0d2d\u0d42\u0d24-\u0d2e\u0d2f \u0d2a\u0d4d\u0d30\u0d2a\u0d28\u0d4d\u0d1a \u0d2a\u0d4d\u0d30\u0d2d\u0d4b <br/> \u0d38\u0d30\u0d4d\u0d35 \u0d1c\u0d40\u0d35 \u0d26\u0d2f\u0d3e-\u0d15\u0d30 \u0d37\u0d2e\u0d4d\u0d2d\u0d4b <br/> \u0d38\u0d3e\u0d2e\u0d1c\u0d3e\u0d1f\u0d35\u0d40 \u0d28\u0d3f\u0d32\u0d2f \u0d38\u0d4d\u0d35\u0d2f\u0d2e\u0d4d\u0d2d\u0d4b <br/> \u0d37\u0d30\u0d4d\u0d35 \u0d15\u0d30\u0d41\u0d23\u0d3e \u0d38\u0d41\u0d27\u0d3e \u0d38\u0d3f\u0d28\u0d4d\u0d27\u0d4b <br/> \u0d37\u0d30\u0d23\u0d3e\u0d17\u0d24 \u0d35\u0d24\u0d4d\u0d38\u0d32\u0d3e\u0d30\u0d4d\u0d24 \u0d2c\u0d28\u0d4d\u0d27\u0d4b <br/> \u0d05\u0d28\u0d3f\u0d30\u0d4d\u0d35\u0d1a\u0d28\u0d40\u0d2f \u0d28\u0d3e\u0d26 \u0d2c\u0d3f\u0d28\u0d4d\u0d26\u0d4b <br/> \u0d28\u0d3f\u0d24\u0d4d\u0d2f \u0d2e\u0d4c\u0d33\u0d3f \u0d35\u0d3f\u0d27\u0d43\u0d24 \u0d17\u0d02\u0d17\u0d47\u0d28\u0d4d\u0d26\u0d4b"}, {"M": "\u0d2e\u0d27\u0d4d\u0d2f\u0d2e\u0d15\u0d3e\u0d32 \u0d38\u0d3e\u0d39\u0d3f\u0d24\u0d4d\u0d2f\u0d2e\u0d4d", "T": "\u0d28\u0d3f\u0d30\u0d4d\u0d35\u0d3f\u0d15\u0d32\u0d4d\u0d2a\u0d15 \u0d38\u0d2e\u0d3e\u0d27\u0d3f \u0d28\u0d3f\u0d36\u0d4d\u0d20 \u0d37\u0d3f\u0d35 \u0d15\u0d32\u0d4d\u0d2a\u0d15 \u0d24\u0d30\u0d4b <br/> \u0d28\u0d3f\u0d30\u0d4d\u0d35\u0d3f\u0d37\u0d47\u0d36 \u0d1a\u0d48\u0d24\u0d28\u0d4d\u0d2f \u0d28\u0d3f\u0d30\u0d28\u0d4d\u0d1c\u0d28 \u0d17\u0d41\u0d30\u0d41 \u0d17\u0d41\u0d39 \u0d17\u0d41\u0d30\u0d4b"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u091c\u092e\u094d\u092c\u0942 \u092a\u0924\u0947 \u092e\u093e\u0902 \u092a\u093e\u0939\u093f \u0928\u093f\u091c\u093e\u0928\u0928\u094d\u0926\u093e\u092e\u0943\u0924 \u092c\u094b\u0927\u0902 \u0926\u0947\u0939\u093f"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0905\u092e\u094d\u092c\u0941\u091c\u093e\u0938\u0928\u093e\u0926\u093f \u0938\u0915\u0932 \u0926\u0947\u0935 \u0928\u092e\u0928 <br/> \u0924\u0941\u092e\u094d\u092c\u0941\u0930\u0941 \u0928\u0941\u0924 \u0939\u0943\u0926\u092f \u0924\u093e\u092a\u094b\u092a\u0937\u092e\u0928 <br/> \u0905\u092e\u094d\u092c\u0941\u0927\u093f \u0917\u0902\u0917\u093e \u0915\u093e\u0935\u0947\u0930\u0940 \u092f\u092e\u0941\u0928\u093e <br/> \u0915\u092e\u094d\u092c\u0941 \u0915\u0923\u094d\u0920\u094d\u092f\u0916\u093f\u0932\u093e\u0923\u094d\u0921\u0947\u0937\u094d\u0935\u0930\u0940 \u0930\u092e\u0923"}, {"M": "\u091a\u0930\u0923\u092e\u094d", "T": "\u092a\u0930\u094d\u0935\u0924\u091c\u093e \u092a\u094d\u0930\u093e\u0930\u094d\u0925\u093f\u0924\u093e\u092c\u094d\u0932\u093f\u0902\u0917 \u0935\u093f\u092d\u094b <br/> \u092a\u0928\u094d\u091a \u092d\u0942\u0924-\u092e\u092f \u092a\u094d\u0930\u092a\u0928\u094d\u091a \u092a\u094d\u0930\u092d\u094b <br/> \u0938\u0930\u094d\u0935 \u091c\u0940\u0935 \u0926\u092f\u093e-\u0915\u0930 \u0937\u092e\u094d\u092d\u094b <br/> \u0938\u093e\u092e\u091c\u093e\u091f\u0935\u0940 \u0928\u093f\u0932\u092f \u0938\u094d\u0935\u092f\u092e\u094d\u092d\u094b <br/> \u0937\u0930\u094d\u0935 \u0915\u0930\u0941\u0923\u093e \u0938\u0941\u0927\u093e \u0938\u093f\u0928\u094d\u0927\u094b <br/> \u0937\u0930\u0923\u093e\u0917\u0924 \u0935\u0924\u094d\u0938\u0932\u093e\u0930\u094d\u0924 \u092c\u0928\u094d\u0927\u094b <br/> \u0905\u0928\u093f\u0930\u094d\u0935\u091a\u0928\u0940\u092f \u0928\u093e\u0926 \u092c\u093f\u0928\u094d\u0926\u094b <br/> \u0928\u093f\u0924\u094d\u092f \u092e\u094c\u0932\u093f \u0935\u093f\u0927\u0943\u0924 \u0917\u0902\u0917\u0947\u0928\u094d\u0926\u094b"}, {"M": "\u092e\u0927\u094d\u092f\u092e\u0915\u093e\u0932 \u0938\u093e\u0939\u093f\u0924\u094d\u092f\u092e\u094d", "T": "\u0928\u093f\u0930\u094d\u0935\u093f\u0915\u0932\u094d\u092a\u0915 \u0938\u092e\u093e\u0927\u093f \u0928\u093f\u0936\u094d\u0920 \u0937\u093f\u0935 \u0915\u0932\u094d\u092a\u0915 \u0924\u0930\u094b <br/> \u0928\u093f\u0930\u094d\u0935\u093f\u0937\u0947\u0936 \u091a\u0948\u0924\u0928\u094d\u092f \u0928\u093f\u0930\u0928\u094d\u091c\u0928 \u0917\u0941\u0930\u0941 \u0917\u0941\u0939 \u0917\u0941\u0930\u094b"}]}], "L": "l", "lyricsref": [{"links": [{"N": "www.medieval.org", "L": "http://www.medieval.org/music/world/carnatic/lyrics/TKG/jambupate.html"}, {"N": "www.sangeetasudha.org", "L": "http://www.sangeetasudha.org/dikshitar/vol2/d38.html#MARK_JAMBUPATE"}, {"N": "guru-guha.blogspot.com", "L": "http://guru-guha.blogspot.com/2007/11/dikshitar-kriti-jamboo-pathae-raga.html"}]}]}