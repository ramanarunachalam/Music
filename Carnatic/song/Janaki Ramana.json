\u0bbf\u0ba9 \u0ba4\u0bb3 \u0ba8\u0baf\u0ba9 \u0ba8\u0bcd\u0bb0\u0bc1\u0baa\u0bbe\u0bb2 <br/> \u0bb0\u0bae\u0ba3\u0bc0\u0baf\u0bbe\u0ba9\u0ba9 \u0bae\u0bc1\u0b95\u0bc1\u0bb0 \u0b95\u0baa\u0bcb\u0bb2 <br/> \u0baa\u0b95\u0bcd\u0ba4\u0bbf \u0bb9\u0bc0\u0ba9 \u0b9c\u0ba9 \u0bae\u0ba4 \u0b95\u0b9c \u0b9c\u0bbe\u0bb2 <br/> \u0baa\u0ba9\u0bcd\u0b9a \u0bb5\u0ba4\u0ba9 \u0ba4\u0bcd\u0baf\u0bbe\u0b95\u0bb0\u0bbe\u0b9c \u0baa\u0bbe\u0bb2"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c1c\u0c3e\u0c28\u0c15\u0c40 \u0c30\u0c2e\u0c23 \u0c2d\u0c15\u0c4d\u0c24 \u0c2a\u0c3e\u0c30\u0c3f\u0c1c\u0c3e\u0c24 <br/> \u0c2a\u0c3e\u0c39\u0c3f \u0c38\u0c15\u0c32 \u0c32\u0c4b\u0c15 \u0c36\u0c30\u0c23"}, {"M": "\u0c05\u0c28\u0c41\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c17\u0c3e\u0c28 \u0c32\u0c4b\u0c32 \u0c18\u0c28 \u0c24\u0c2e\u0c3e\u0c32 \u0c28\u0c40\u0c32 <br/> \u0c15\u0c30\u0c41\u0c23\u0c3e\u0c32\u0c35\u0c3e\u0c32 \u0c38\u0c41\u0c17\u0c41\u0c23 \u0c36\u0c40\u0c32"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c30\u0c15\u0c4d\u0c24 \u0c28\u0c33\u0c3f\u0c28 \u0c26\u0c33 \u0c28\u0c2f\u0c28 \u0c28\u0c43\u0c2a\u0c3e\u0c32 <br/> \u0c30\u0c2e\u0c23\u0c40\u0c2f\u0c3e\u0c28\u0c28 \u0c2e\u0c41\u0c15\u0c41\u0c30 \u0c15\u0c2a\u0c4b\u0c32 <br/> \u0c2d\u0c15\u0c4d\u0c24\u0c3f \u0c39\u0c40\u0c28 \u0c1c\u0c28 \u0c2e\u0c26 \u0c17\u0c1c \u0c1c\u0c3e\u0c32 <br/> \u0c2a\u0c28\u0c4d\u0c1a \u0c35\u0c26\u0c28 \u0c24\u0c4d\u0c2f\u0c3e\u0c17\u0c30\u0c3e\u0c1c \u0c2a\u0c3e\u0c32"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0c9c\u0cbe\u0ca8\u0c95\u0cc0 \u0cb0\u0cae\u0ca3 \u0cad\u0c95\u0ccd\u0ca4 \u0caa\u0cbe\u0cb0\u0cbf\u0c9c\u0cbe\u0ca4 <br/> \u0caa\u0cbe\u0cb9\u0cbf \u0cb8\u0c95\u0cb2 \u0cb2\u0ccb\u0c95 \u0cb6\u0cb0\u0ca3"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0c97\u0cbe\u0ca8 \u0cb2\u0ccb\u0cb2 \u0c98\u0ca8 \u0ca4\u0cae\u0cbe\u0cb2 \u0ca8\u0cc0\u0cb2 <br/> \u0c95\u0cb0\u0cc1\u0ca3\u0cbe\u0cb2\u0cb5\u0cbe\u0cb2 \u0cb8\u0cc1\u0c97\u0cc1\u0ca3 \u0cb6\u0cc0\u0cb2"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0cb0\u0c95\u0ccd\u0ca4 \u0ca8\u0cb3\u0cbf\u0ca8 \u0ca6\u0cb3 \u0ca8\u0caf\u0ca8 \u0ca8\u0cc3\u0caa\u0cbe\u0cb2 <br/> \u0cb0\u0cae\u0ca3\u0cc0\u0caf\u0cbe\u0ca8\u0ca8 \u0cae\u0cc1\u0c95\u0cc1\u0cb0 \u0c95\u0caa\u0ccb\u0cb2 <br/> \u0cad\u0c95\u0ccd\u0ca4\u0cbf \u0cb9\u0cc0\u0ca8 \u0c9c\u0ca8 \u0cae\u0ca6 \u0c97\u0c9c \u0c9c\u0cbe\u0cb2 <br/> \u0caa\u0ca8\u0ccd\u0c9a \u0cb5\u0ca6\u0ca8 \u0ca4\u0ccd\u0caf\u0cbe\u0c97\u0cb0\u0cbe\u0c9c \u0caa\u0cbe\u0cb2"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d1c\u0d3e\u0d28\u0d15\u0d40 \u0d30\u0d2e\u0d23 \u0d2d\u0d15\u0d4d\u0d24 \u0d2a\u0d3e\u0d30\u0d3f\u0d1c\u0d3e\u0d24 <br/> \u0d2a\u0d3e\u0d39\u0d3f \u0d38\u0d15\u0d32 \u0d32\u0d4b\u0d15 \u0d36\u0d30\u0d23"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d17\u0d3e\u0d28 \u0d32\u0d4b\u0d32 \u0d18\u0d28 \u0d24\u0d2e\u0d3e\u0d32 \u0d28\u0d40\u0d32 <br/> \u0d15\u0d30\u0d41\u0d23\u0d3e\u0d32\u0d35\u0d3e\u0d32 \u0d38\u0d41\u0d17\u0d41\u0d23 \u0d36\u0d40\u0d32"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d30\u0d15\u0d4d\u0d24 \u0d28\u0d33\u0d3f\u0d28 \u0d26\u0d33 \u0d28\u0d2f\u0d28 \u0d28\u0d43\u0d2a\u0d3e\u0d32 <br/> \u0d30\u0d2e\u0d23\u0d40\u0d2f\u0d3e\u0d28\u0d28 \u0d2e\u0d41\u0d15\u0d41\u0d30 \u0d15\u0d2a\u0d4b\u0d32 <br/> \u0d2d\u0d15\u0d4d\u0d24\u0d3f \u0d39\u0d40\u0d28 \u0d1c\u0d28 \u0d2e\u0d26 \u0d17\u0d1c \u0d1c\u0d3e\u0d32 <br/> \u0d2a\u0d28\u0d4d\u0d1a \u0d35\u0d26\u0d28 \u0d24\u0d4d\u0d2f\u0d3e\u0d17\u0d30\u0d3e\u0d1c \u0d2a\u0d3e\u0d32"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u091c\u093e\u0928\u0915\u0940 \u0930\u092e\u0923 \u092d\u0915\u094d\u0924 \u092a\u093e\u0930\u093f\u091c\u093e\u0924 <br/> \u092a\u093e\u0939\u093f \u0938\u0915\u0932 \u0932\u094b\u0915 \u0936\u0930\u0923"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0917\u093e\u0928 \u0932\u094b\u0932 \u0918\u0928 \u0924\u092e\u093e\u0932 \u0928\u0940\u0932 <br/> \u0915\u0930\u0941\u0923\u093e\u0932\u0935\u093e\u0932 \u0938\u0941\u0917\u0941\u0923 \u0936\u0940\u0932"}, {"M": "\u091a\u0930\u0923\u092e\u094d", "T": "\u0930\u0915\u094d\u0924 \u0928\u0932\u093f\u0928 \u0926\u0932 \u0928\u092f\u0928 \u0928\u0943\u092a\u093e\u0932 <br/> \u0930\u092e\u0923\u0940\u092f\u093e\u0928\u0928 \u092e\u0941\u0915\u0941\u0930 \u0915\u092a\u094b\u0932 <br/> \u092d\u0915\u094d\u0924\u093f \u0939\u0940\u0928 \u091c\u0928 \u092e\u0926 \u0917\u091c \u091c\u093e\u0932 <br/> \u092a\u0928\u094d\u091a \u0935\u0926\u0928 \u0924\u094d\u092f\u093e\u0917\u0930\u093e\u091c \u092a\u093e\u0932"}]}], "L": "l", "lyricsref": [{"links": [{"N": "thyagaraja-vaibhavam.blogspot.com", "L": "http://thyagaraja-vaibhavam.blogspot.com/2009/01/tyagaraja-kriti-janaki-ramana-raga.html"}, {"N": "www.karnatik.com", "L": "http://www.karnatik.com/c1404.shtml"}, {"N": "www.sangeetasudha.org", "L": "http://www.sangeetasudha.org/thyagaraja/vol2/j.html#MARK_JANAKIRAMANA"}, {"N": "www.shivkumar.org", "L": "http://www.shivkumar.org/music/janakiramana.htm"}]}]}