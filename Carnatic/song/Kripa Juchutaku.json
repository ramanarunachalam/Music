\u0bae\u0bc6\u0bb0\u0bc1\u0b95\u0bb0\u0bc1 <br/> \u0baa\u0bcd\u0bb0\u0baa\u0bc1\u0bb5\u0bc1\u0bb2\u0bc6\u0bb2\u0bcd\u0bb2 \u0ba8\u0bc0\u0b9a \u0b9a\u0bc7\u0bb5\u0b95\u0bc1\u0bb2\u0bc1\u0bb0\u0bbe <br/> \u0baa\u0bb0 \u0bb2\u0bcb\u0b95 \u0baa\u0baf\u0bae\u0bc6\u0ba8\u0bcd\u0ba4 \u0b95\u0bbe\u0ba9\u0bb0\u0bc1 <br/> \u0bb5\u0bb0 \u0ba4\u0bcd\u0baf\u0bbe\u0b95\u0bb0\u0bbe\u0b9c \u0bb9\u0bcd\u0bb0\u0bcd\u0ba4\u0bcd-\u0b9a\u0ba4\u0ba9"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c15\u0c43\u0c2a \u0c1c\u0c42\u0c1a\u0c41\u0c1f\u0c15\u0c41 \u0c35\u0c47\u0c33\u0c30\u0c3e \u0c30\u0c3e\u0c2e"}, {"M": "\u0c05\u0c28\u0c41\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c05\u0c2a\u0c30\u0c3e\u0c27\u0c2e\u0c41\u0c32\u0c28\u0c4b\u0c30\u0c4d\u0c35 \u0c35\u0c37\u0c2e\u0c3e- <br/> \u0c2f\u0c28 \u0c2a\u0c4b\u0c15\u0c35\u0c47 \u0c38\u0c30\u0c3f\u0c35\u0c3e\u0c30\u0c32\u0c32\u0c4b \u0c15\u0c4d\u0c30\u0c4d\u0c2a"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c2a\u0c30\u0c2e\u0c3e\u0c30\u0c4d\u0c25\u0c2e\u0c4c \u0c2e\u0c3e\u0c30\u0c4d\u0c17\u0c2e\u0c46\u0c30\u0c41\u0c17\u0c30\u0c41 <br/> \u0c2a\u0c4d\u0c30\u0c2d\u0c41\u0c35\u0c41\u0c32\u0c46\u0c32\u0c4d\u0c32 \u0c28\u0c40\u0c1a \u0c38\u0c47\u0c35\u0c15\u0c41\u0c32\u0c41\u0c30\u0c3e <br/> \u0c2a\u0c30 \u0c32\u0c4b\u0c15 \u0c2d\u0c2f\u0c2e\u0c46\u0c28\u0c4d\u0c24 \u0c15\u0c3e\u0c28\u0c30\u0c41 <br/> \u0c35\u0c30 \u0c24\u0c4d\u0c2f\u0c3e\u0c17\u0c30\u0c3e\u0c1c \u0c39\u0c4d\u0c30\u0c4d\u0c24\u0c4d-\u0c38\u0c26\u0c28"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0c95\u0cc3\u0caa \u0c9c\u0cc2\u0c9a\u0cc1\u0c9f\u0c95\u0cc1 \u0cb5\u0cc7\u0cb3\u0cb0\u0cbe \u0cb0\u0cbe\u0cae"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0c85\u0caa\u0cb0\u0cbe\u0ca7\u0cae\u0cc1\u0cb2\u0ca8\u0ccb\u0cb0\u0ccd\u0cb5 \u0cb5\u0cb7\u0cae\u0cbe- <br/> \u0caf\u0ca8 \u0caa\u0ccb\u0c95\u0cb5\u0cc7 \u0cb8\u0cb0\u0cbf\u0cb5\u0cbe\u0cb0\u0cb2\u0cb2\u0ccb \u0c95\u0ccd\u0cb0\u0ccd\u0caa"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0caa\u0cb0\u0cae\u0cbe\u0cb0\u0ccd\u0ca5\u0cae\u0ccc \u0cae\u0cbe\u0cb0\u0ccd\u0c97\u0cae\u0cc6\u0cb0\u0cc1\u0c97\u0cb0\u0cc1 <br/> \u0caa\u0ccd\u0cb0\u0cad\u0cc1\u0cb5\u0cc1\u0cb2\u0cc6\u0cb2\u0ccd\u0cb2 \u0ca8\u0cc0\u0c9a \u0cb8\u0cc7\u0cb5\u0c95\u0cc1\u0cb2\u0cc1\u0cb0\u0cbe <br/> \u0caa\u0cb0 \u0cb2\u0ccb\u0c95 \u0cad\u0caf\u0cae\u0cc6\u0ca8\u0ccd\u0ca4 \u0c95\u0cbe\u0ca8\u0cb0\u0cc1 <br/> \u0cb5\u0cb0 \u0ca4\u0ccd\u0caf\u0cbe\u0c97\u0cb0\u0cbe\u0c9c \u0cb9\u0ccd\u0cb0\u0ccd\u0ca4\u0ccd-\u0cb8\u0ca6\u0ca8"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d15\u0d43\u0d2a \u0d1c\u0d42\u0d1a\u0d41\u0d1f\u0d15\u0d41 \u0d35\u0d47\u0d33\u0d30\u0d3e \u0d30\u0d3e\u0d2e"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d05\u0d2a\u0d30\u0d3e\u0d27\u0d2e\u0d41\u0d32\u0d28\u0d4b\u0d30\u0d4d\u0d35 \u0d35\u0d37\u0d2e\u0d3e- <br/> \u0d2f\u0d28 \u0d2a\u0d4b\u0d15\u0d35\u0d47 \u0d38\u0d30\u0d3f\u0d35\u0d3e\u0d30\u0d32\u0d32\u0d4b \u0d15\u0d4d\u0d30\u0d4d\u0d2a"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d2a\u0d30\u0d2e\u0d3e\u0d30\u0d4d\u0d25\u0d2e\u0d4c \u0d2e\u0d3e\u0d30\u0d4d\u0d17\u0d2e\u0d46\u0d30\u0d41\u0d17\u0d30\u0d41 <br/> \u0d2a\u0d4d\u0d30\u0d2d\u0d41\u0d35\u0d41\u0d32\u0d46\u0d32\u0d4d\u0d32 \u0d28\u0d40\u0d1a \u0d38\u0d47\u0d35\u0d15\u0d41\u0d32\u0d41\u0d30\u0d3e <br/> \u0d2a\u0d30 \u0d32\u0d4b\u0d15 \u0d2d\u0d2f\u0d2e\u0d46\u0d28\u0d4d\u0d24 \u0d15\u0d3e\u0d28\u0d30\u0d41 <br/> \u0d35\u0d30 \u0d24\u0d4d\u0d2f\u0d3e\u0d17\u0d30\u0d3e\u0d1c \u0d39\u0d4d\u0d30\u0d4d\u0d24\u0d4d-\u0d38\u0d26\u0d28"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0915\u0943\u092a \u091c\u0942\u091a\u0941\u091f\u0915\u0941 \u0935\u0947\u0932\u0930\u093e \u0930\u093e\u092e"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0905\u092a\u0930\u093e\u0927\u092e\u0941\u0932\u0928\u094b\u0930\u094d\u0935 \u0935\u0937\u092e\u093e- <br/> \u092f\u0928 \u092a\u094b\u0915\u0935\u0947 \u0938\u0930\u093f\u0935\u093e\u0930\u0932\u0932\u094b \u0915\u094d\u0930\u094d\u092a"}, {"M": "\u091a\u0930\u0923\u092e\u094d", "T": "\u092a\u0930\u092e\u093e\u0930\u094d\u0925\u092e\u094c \u092e\u093e\u0930\u094d\u0917\u092e\u0947\u0930\u0941\u0917\u0930\u0941 <br/> \u092a\u094d\u0930\u092d\u0941\u0935\u0941\u0932\u0947\u0932\u094d\u0932 \u0928\u0940\u091a \u0938\u0947\u0935\u0915\u0941\u0932\u0941\u0930\u093e <br/> \u092a\u0930 \u0932\u094b\u0915 \u092d\u092f\u092e\u0947\u0928\u094d\u0924 \u0915\u093e\u0928\u0930\u0941 <br/> \u0935\u0930 \u0924\u094d\u092f\u093e\u0917\u0930\u093e\u091c \u0939\u094d\u0930\u094d\u0924\u094d-\u0938\u0926\u0928"}]}], "L": "l", "lyricsref": [{"links": [{"N": "thyagaraja-vaibhavam.blogspot.in", "L": "http://thyagaraja-vaibhavam.blogspot.in/2008/01/thyagaraja-kriti-krpa-joochutaku-raga.html"}, {"N": "www.sangeetasudha.org", "L": "http://www.sangeetasudha.org/thyagaraja/vol2/k.html#MARK_KRUPAJOOCHUTAKU"}, {"N": "karnatik.com", "L": "http://karnatik.com/c2409.shtml"}]}]}