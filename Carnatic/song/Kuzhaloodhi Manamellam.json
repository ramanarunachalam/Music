c6\u0bb2\u0bcd\u0bb2\u0bbe\u0bae\u0bcd \u0b95\u0bca\u0bb3\u0bcd\u0bb3\u0bc8 \u0b95\u0bca\u0ba3\u0bcd\u0b9f \u0baa\u0bbf\u0ba9\u0bcd\u0ba9\u0bc1\u0bae\u0bcd \u0b95\u0bc1\u0bb1\u0bc8 \u0b8f\u0ba4\u0bc1 \u0b8e\u0ba9\u0b95\u0bcd\u0b95\u0bc7\u0ba4\u0b9f\u0bc0 \u0ba4\u0bcb\u0bb4\u0bbf \u0b95\u0bc1\u0bb4\u0bb2\u0bcd"}, {"M": "\u0b85\u0ba9\u0bc1\u0baa\u0bb2\u0bcd\u0bb2\u0bb5\u0bbf", "T": "\u0b85\u0bb4\u0b95\u0bbe\u0ba9 \u0bae\u0baf\u0bbf\u0bb2\u0bcd \u0b86\u0b9f\u0bb5\u0bc1\u0bae\u0bcd \u0bae\u0bbf\u0b95 <br/> \u0b95\u0bbe\u0bb1\u0bcd\u0bb1\u0bbf\u0bb2\u0bcd \u0b85\u0b9a\u0bc8\u0ba8\u0bcd\u0ba4\u0bbe\u0b9f\u0bc1\u0bae\u0bcd \u0b95\u0bca\u0b9f\u0bbf \u0baa\u0bcb\u0bb2\u0bb5\u0bc1\u0bae\u0bcd"}, {"M": "\u0bae\u0ba4\u0bcd\u0baf\u0bae\u0b95\u0bbe\u0bb2 \u0b9a\u0bbe\u0bb9\u0bbf\u0ba4\u0bcd\u0baf\u0bae\u0bcd", "T": "\u0b85\u0b95\u0bae\u0b95\u0bbf\u0bb4\u0bbf\u0ba8\u0bcd\u0ba4\u0bbf\u0bb2\u0b95\u0bc1\u0bae\u0bcd \u0ba8\u0bbf\u0bb2\u0bb5\u0bca\u0bb3\u0bbf \u0ba4\u0ba9\u0bbf\u0bb2\u0bc7 \u0ba4\u0ba9\u0bc8 \u0bae\u0bb1\u0ba8\u0bcd\u0ba4\u0bc1 \u0baa\u0bc1\u0bb3\u0bcd\u0bb3\u0bbf\u0ba9\u0bae\u0bcd \u0b95\u0bc2\u0bb5 <br/> \u0b85\u0b9a\u0bc8\u0ba8\u0bcd\u0ba4\u0bbe\u0b9f\u0bbf \u0bae\u0bbf\u0b95 \u0b87\u0b9a\u0bc8\u0ba8\u0bcd\u0ba4\u0bcb\u0b9f\u0bbf \u0bb5\u0bb0\u0bc1\u0bae\u0bcd \u0ba8\u0bb2\u0bae\u0bcd \u0b95\u0bbe\u0ba3 \u0b92\u0bb0\u0bc1 \u0bae\u0ba9\u0bae\u0bcd \u0ba8\u0bbe\u0b9f <br/> \u0ba4\u0b95\u0bc1\u0bae\u0bc0\u0ba4\u0bc1 \u0b8e\u0ba9 \u0b92\u0bb0\u0bc1 \u0baa\u0ba4\u0bae\u0bcd \u0baa\u0bbe\u0b9f \u0ba4\u0b95\u0bbf\u0b9f \u0ba4\u0ba4\u0bbf\u0bae\u0bbf \u0b8e\u0ba9 \u0ba8\u0b9f\u0bae\u0bcd \u0ba8\u0bbe\u0b9f <br/> \u0b95\u0ba9\u0bcd\u0bb1\u0bc1 \u0baa\u0b9a\u0bc1\u0bb5\u0bbf\u0ba9\u0bb5\u0bc1\u0bae\u0bcd \u0ba8\u0bbf\u0ba9\u0bcd\u0bb1\u0bc1 \u0baa\u0bc1\u0b9f\u0bc8 \u0b9a\u0bc2\u0bb4 \u0b8e\u0ba9\u0bcd\u0bb1\u0bc1 \u0bae\u0bb2\u0bb0\u0bc1\u0bae\u0bc1\u0b95 \u0b87\u0bb1\u0bc8\u0bb5\u0ba9\u0bcd \u0b95\u0ba9\u0bbf\u0bb5\u0bcb\u0b9f\u0bc1"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd", "T": "\u0bae\u0b95\u0bb0 \u0b95\u0bc1\u0ba3\u0bcd\u0b9f\u0bb2\u0bae\u0bcd \u0b86\u0b9f\u0bb5\u0bc1\u0bae\u0bcd \u0b85\u0ba4\u0bb1\u0bcd\u0b95\u0bc7\u0bb1\u0bcd\u0baa\u0bcd\u0baa \u0bae\u0b95\u0bc1\u0b9f\u0bae\u0bcd \u0b92\u0bb3\u0bbf \u0bb5\u0bc0\u0b9a\u0bb5\u0bc1\u0bae\u0bcd"}, {"M": "\u0bae\u0ba4\u0bcd\u0baf\u0bae\u0b95\u0bbe\u0bb2 \u0b9a\u0bbe\u0bb9\u0bbf\u0ba4\u0bcd\u0baf\u0bae\u0bcd", "T": "\u0bae\u0bbf\u0b95\u0bb5\u0bc1\u0bae\u0bcd \u0b8e\u0bb4\u0bbf\u0bb2\u0bbe\u0b95\u0bb5\u0bc1\u0bae\u0bcd \u0b95\u0bbe\u0bb1\u0bcd\u0bb1\u0bbf\u0bb2\u0bcd \u0bae\u0bbf\u0bb3\u0bbf\u0bb0\u0bc1\u0bae\u0bcd \u0ba4\u0bc1\u0b95\u0bbf\u0bb2\u0bcd \u0b86\u0b9f\u0bb5\u0bc1\u0bae\u0bcd <br/> \u0b85\u0b95\u0bae\u0b95\u0bbf\u0bb4\u0bcd\u0ba8\u0bcd\u0ba4\u0bc1 \u0b87\u0bb1\u0bc8\u0bb5\u0ba9\u0bcd \u0b95\u0ba9\u0bbf\u0bb5\u0bca\u0b9f\u0bc1"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c15\u0c41\u0c34\u0c32\u0c42\u0c26\u0c3f \u0c2e\u0c28\u0c2e\u0c46\u0c32\u0c4d\u0c32\u0c3e\u0c2e\u0c4d \u0c15\u0c4a\u0c33\u0c4d\u0c33\u0c48 \u0c15\u0c4a\u0c23\u0c4d\u0c21 \u0c2a\u0c3f\u0c28\u0c4d\u0c28\u0c41\u0c2e\u0c4d \u0c15\u0c41\u0c31\u0c48 \u0c0f\u0c26\u0c41 \u0c0e\u0c28\u0c15\u0c4d\u0c15\u0c47\u0c26\u0c21\u0c40 \u0c24\u0c4b\u0c34\u0c3f \u0c15\u0c41\u0c34\u0c32\u0c4d"}, {"M": "\u0c05\u0c28\u0c41\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c05\u0c34\u0c17\u0c3e\u0c28 \u0c2e\u0c2f\u0c3f\u0c32\u0c4d \u0c06\u0c21\u0c35\u0c41\u0c2e\u0c4d \u0c2e\u0c3f\u0c17 <br/> \u0c15\u0c3e\u0c1f\u0c4d\u0c31\u0c3f\u0c32\u0c4d \u0c05\u0c38\u0c48\u0c28\u0c4d\u0c26\u0c3e\u0c21\u0c41\u0c2e\u0c4d \u0c15\u0c4a\u0c21\u0c3f \u0c2a\u0c4b\u0c32\u0c35\u0c41\u0c2e\u0c4d"}, {"M": "\u0c2e\u0c27\u0c4d\u0c2f\u0c2e\u0c15\u0c3e\u0c32 \u0c38\u0c3e\u0c39\u0c3f\u0c24\u0c4d\u0c2f\u0c2e\u0c4d", "T": "\u0c05\u0c17\u0c2e\u0c17\u0c3f\u0c34\u0c3f\u0c28\u0c4d\u0c26\u0c3f\u0c32\u0c17\u0c41\u0c2e\u0c4d \u0c28\u0c3f\u0c32\u0c35\u0c4a\u0c33\u0c3f \u0c24\u0c28\u0c3f\u0c32\u0c47 \u0c24\u0c28\u0c48 \u0c2e\u0c31\u0c28\u0c4d\u0c26\u0c41 \u0c2a\u0c41\u0c33\u0c4d\u0c33\u0c3f\u0c28\u0c2e\u0c4d \u0c15\u0c42\u0c35 <br/> \u0c05\u0c38\u0c48\u0c28\u0c4d\u0c26\u0c3e\u0c21\u0c3f \u0c2e\u0c3f\u0c17 \u0c07\u0c38\u0c48\u0c28\u0c4d\u0c26\u0c4b\u0c21\u0c3f \u0c35\u0c30\u0c41\u0c2e\u0c4d \u0c28\u0c32\u0c2e\u0c4d \u0c15\u0c3e\u0c23 \u0c12\u0c30\u0c41 \u0c2e\u0c28\u0c2e\u0c4d \u0c28\u0c3e\u0c21 <br/> \u0c24\u0c15\u0c41\u0c2e\u0c40\u0c26\u0c41 \u0c0e\u0c28 \u0c12\u0c30\u0c41 \u0c2a\u0c26\u0c2e\u0c4d \u0c2a\u0c3e\u0c21 \u0c24\u0c15\u0c3f\u0c1f \u0c24\u0c27\u0c3f\u0c2e\u0c3f \u0c0e\u0c28 \u0c28\u0c1f\u0c2e\u0c4d \u0c28\u0c3e\u0c21 <br/> \u0c15\u0c28\u0c4d\u0c31\u0c41 \u0c2a\u0c38\u0c41\u0c35\u0c3f\u0c28\u0c35\u0c41\u0c2e\u0c4d \u0c28\u0c3f\u0c28\u0c4d\u0c31\u0c41 \u0c2a\u0c41\u0c21\u0c48 \u0c38\u0c42\u0c34 \u0c0e\u0c28\u0c4d\u0c31\u0c41 \u0c2e\u0c32\u0c30\u0c41\u0c2e\u0c41\u0c16 \u0c07\u0c31\u0c48\u0c35\u0c28\u0c4d \u0c15\u0c28\u0c3f\u0c35\u0c4b\u0c21\u0c41"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c2e\u0c15\u0c30 \u0c15\u0c41\u0c23\u0c4d\u0c21\u0c32\u0c2e\u0c4d \u0c06\u0c21\u0c35\u0c41\u0c2e\u0c4d \u0c05\u0c26\u0c31\u0c4d\u0c15\u0c47\u0c31\u0c4d\u0c2a\u0c4d\u0c2a \u0c2e\u0c15\u0c41\u0c1f\u0c2e\u0c4d \u0c12\u0c33\u0c3f \u0c35\u0c40\u0c38\u0c35\u0c41\u0c2e\u0c4d"}, {"M": "\u0c2e\u0c27\u0c4d\u0c2f\u0c2e\u0c15\u0c3e\u0c32 \u0c38\u0c3e\u0c39\u0c3f\u0c24\u0c4d\u0c2f\u0c2e\u0c4d", "T": "\u0c2e\u0c3f\u0c17\u0c35\u0c41\u0c2e\u0c4d \u0c0e\u0c34\u0c3f\u0c32\u0c3e\u0c17\u0c35\u0c41\u0c2e\u0c4d \u0c15\u0c3e\u0c1f\u0c4d\u0c31\u0c3f\u0c32\u0c4d \u0c2e\u0c3f\u0c33\u0c3f\u0c30\u0c41\u0c2e\u0c4d \u0c24\u0c41\u0c17\u0c3f\u0c32\u0c4d \u0c06\u0c21\u0c35\u0c41\u0c2e\u0c4d <br/> \u0c05\u0c15\u0c2e\u0c17\u0c3f\u0c34\u0c4d\u0c28\u0c4d\u0c26\u0c41 \u0c07\u0c31\u0c48\u0c35\u0c28\u0c4d \u0c15\u0c28\u0c3f\u0c35\u0c4a\u0c21\u0c41"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0c95\u0cc1\u0cb3\u0cb2\u0cc2\u0ca6\u0cbf \u0cae\u0ca8\u0cae\u0cc6\u0cb2\u0ccd\u0cb2\u0cbe\u0cae\u0ccd \u0c95\u0cca\u0cb3\u0ccd\u0cb3\u0cc8 \u0c95\u0cca\u0ca3\u0ccd\u0ca1 \u0caa\u0cbf\u0ca8\u0ccd\u0ca8\u0cc1\u0cae\u0ccd \u0c95\u0cc1\u0cb1\u0cc8 \u0c8f\u0ca6\u0cc1 \u0c8e\u0ca8\u0c95\u0ccd\u0c95\u0cc7\u0ca6\u0ca1\u0cc0 \u0ca4\u0ccb\u0cb3\u0cbf \u0c95\u0cc1\u0cb3\u0cb2\u0ccd"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0c85\u0cb3\u0c97\u0cbe\u0ca8 \u0cae\u0caf\u0cbf\u0cb2\u0ccd \u0c86\u0ca1\u0cb5\u0cc1\u0cae\u0ccd \u0cae\u0cbf\u0c97 <br/> \u0c95\u0cbe\u0c9f\u0ccd\u0cb1\u0cbf\u0cb2\u0ccd \u0c85\u0cb8\u0cc8\u0ca8\u0ccd\u0ca6\u0cbe\u0ca1\u0cc1\u0cae\u0ccd \u0c95\u0cca\u0ca1\u0cbf \u0caa\u0ccb\u0cb2\u0cb5\u0cc1\u0cae\u0ccd"}, {"M": "\u0cae\u0ca7\u0ccd\u0caf\u0cae\u0c95\u0cbe\u0cb2 \u0cb8\u0cbe\u0cb9\u0cbf\u0ca4\u0ccd\u0caf\u0cae\u0ccd", "T": "\u0c85\u0c97\u0cae\u0c97\u0cbf\u0cb3\u0cbf\u0ca8\u0ccd\u0ca6\u0cbf\u0cb2\u0c97\u0cc1\u0cae\u0ccd \u0ca8\u0cbf\u0cb2\u0cb5\u0cca\u0cb3\u0cbf \u0ca4\u0ca8\u0cbf\u0cb2\u0cc7 \u0ca4\u0ca8\u0cc8 \u0cae\u0cb1\u0ca8\u0ccd\u0ca6\u0cc1 \u0caa\u0cc1\u0cb3\u0ccd\u0cb3\u0cbf\u0ca8\u0cae\u0ccd \u0c95\u0cc2\u0cb5 <br/> \u0c85\u0cb8\u0cc8\u0ca8\u0ccd\u0ca6\u0cbe\u0ca1\u0cbf \u0cae\u0cbf\u0c97 \u0c87\u0cb8\u0cc8\u0ca8\u0ccd\u0ca6\u0ccb\u0ca1\u0cbf \u0cb5\u0cb0\u0cc1\u0cae\u0ccd \u0ca8\u0cb2\u0cae\u0ccd \u0c95\u0cbe\u0ca3 \u0c92\u0cb0\u0cc1 \u0cae\u0ca8\u0cae\u0ccd \u0ca8\u0cbe\u0ca1 <br/> \u0ca4\u0c95\u0cc1\u0cae\u0cc0\u0ca6\u0cc1 \u0c8e\u0ca8 \u0c92\u0cb0\u0cc1 \u0caa\u0ca6\u0cae\u0ccd \u0caa\u0cbe\u0ca1 \u0ca4\u0c95\u0cbf\u0c9f \u0ca4\u0ca7\u0cbf\u0cae\u0cbf \u0c8e\u0ca8 \u0ca8\u0c9f\u0cae\u0ccd \u0ca8\u0cbe\u0ca1 <br/> \u0c95\u0ca8\u0ccd\u0cb1\u0cc1 \u0caa\u0cb8\u0cc1\u0cb5\u0cbf\u0ca8\u0cb5\u0cc1\u0cae\u0ccd \u0ca8\u0cbf\u0ca8\u0ccd\u0cb1\u0cc1 \u0caa\u0cc1\u0ca1\u0cc8 \u0cb8\u0cc2\u0cb3 \u0c8e\u0ca8\u0ccd\u0cb1\u0cc1 \u0cae\u0cb2\u0cb0\u0cc1\u0cae\u0cc1\u0c96 \u0c87\u0cb1\u0cc8\u0cb5\u0ca8\u0ccd \u0c95\u0ca8\u0cbf\u0cb5\u0ccb\u0ca1\u0cc1"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0cae\u0c95\u0cb0 \u0c95\u0cc1\u0ca3\u0ccd\u0ca1\u0cb2\u0cae\u0ccd \u0c86\u0ca1\u0cb5\u0cc1\u0cae\u0ccd \u0c85\u0ca6\u0cb1\u0ccd\u0c95\u0cc7\u0cb1\u0ccd\u0caa\u0ccd\u0caa \u0cae\u0c95\u0cc1\u0c9f\u0cae\u0ccd \u0c92\u0cb3\u0cbf \u0cb5\u0cc0\u0cb8\u0cb5\u0cc1\u0cae\u0ccd"}, {"M": "\u0cae\u0ca7\u0ccd\u0caf\u0cae\u0c95\u0cbe\u0cb2 \u0cb8\u0cbe\u0cb9\u0cbf\u0ca4\u0ccd\u0caf\u0cae\u0ccd", "T": "\u0cae\u0cbf\u0c97\u0cb5\u0cc1\u0cae\u0ccd \u0c8e\u0cb3\u0cbf\u0cb2\u0cbe\u0c97\u0cb5\u0cc1\u0cae\u0ccd \u0c95\u0cbe\u0c9f\u0ccd\u0cb1\u0cbf\u0cb2\u0ccd \u0cae\u0cbf\u0cb3\u0cbf\u0cb0\u0cc1\u0cae\u0ccd \u0ca4\u0cc1\u0c97\u0cbf\u0cb2\u0ccd \u0c86\u0ca1\u0cb5\u0cc1\u0cae\u0ccd <br/> \u0c85\u0c95\u0cae\u0c97\u0cbf\u0cb3\u0ccd\u0ca8\u0ccd\u0ca6\u0cc1 \u0c87\u0cb1\u0cc8\u0cb5\u0ca8\u0ccd \u0c95\u0ca8\u0cbf\u0cb5\u0cca\u0ca1\u0cc1"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d15\u0d41\u0d34\u0d32\u0d42\u0d26\u0d3f \u0d2e\u0d28\u0d2e\u0d46\u0d32\u0d4d\u0d32\u0d3e\u0d2e\u0d4d \u0d15\u0d4a\u0d33\u0d4d\u0d33\u0d48 \u0d15\u0d4a\u0d23\u0d4d\u0d21 \u0d2a\u0d3f\u0d28\u0d4d\u0d28\u0d41\u0d2e\u0d4d \u0d15\u0d41\u0d31\u0d48 \u0d0f\u0d26\u0d41 \u0d0e\u0d28\u0d15\u0d4d\u0d15\u0d47\u0d26\u0d21\u0d40 \u0d24\u0d4b\u0d34\u0d3f \u0d15\u0d41\u0d34\u0d32\u0d4d"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d05\u0d34\u0d17\u0d3e\u0d28 \u0d2e\u0d2f\u0d3f\u0d32\u0d4d \u0d06\u0d21\u0d35\u0d41\u0d2e\u0d4d \u0d2e\u0d3f\u0d17 <br/> \u0d15\u0d3e\u0d1f\u0d4d\u0d31\u0d3f\u0d32\u0d4d \u0d05\u0d38\u0d48\u0d28\u0d4d\u0d26\u0d3e\u0d21\u0d41\u0d2e\u0d4d \u0d15\u0d4a\u0d21\u0d3f \u0d2a\u0d4b\u0d32\u0d35\u0d41\u0d2e\u0d4d"}, {"M": "\u0d2e\u0d27\u0d4d\u0d2f\u0d2e\u0d15\u0d3e\u0d32 \u0d38\u0d3e\u0d39\u0d3f\u0d24\u0d4d\u0d2f\u0d2e\u0d4d", "T": "\u0d05\u0d17\u0d2e\u0d17\u0d3f\u0d34\u0d3f\u0d28\u0d4d\u0d26\u0d3f\u0d32\u0d17\u0d41\u0d2e\u0d4d \u0d28\u0d3f\u0d32\u0d35\u0d4a\u0d33\u0d3f \u0d24\u0d28\u0d3f\u0d32\u0d47 \u0d24\u0d28\u0d48 \u0d2e\u0d31\u0d28\u0d4d\u0d26\u0d41 \u0d2a\u0d41\u0d33\u0d4d\u0d33\u0d3f\u0d28\u0d2e\u0d4d \u0d15\u0d42\u0d35 <br/> \u0d05\u0d38\u0d48\u0d28\u0d4d\u0d26\u0d3e\u0d21\u0d3f \u0d2e\u0d3f\u0d17 \u0d07\u0d38\u0d48\u0d28\u0d4d\u0d26\u0d4b\u0d21\u0d3f \u0d35\u0d30\u0d41\u0d2e\u0d4d \u0d28\u0d32\u0d2e\u0d4d \u0d15\u0d3e\u0d23 \u0d12\u0d30\u0d41 \u0d2e\u0d28\u0d2e\u0d4d \u0d28\u0d3e\u0d21 <br/> \u0d24\u0d15\u0d41\u0d2e\u0d40\u0d26\u0d41 \u0d0e\u0d28 \u0d12\u0d30\u0d41 \u0d2a\u0d26\u0d2e\u0d4d \u0d2a\u0d3e\u0d21 \u0d24\u0d15\u0d3f\u0d1f \u0d24\u0d27\u0d3f\u0d2e\u0d3f \u0d0e\u0d28 \u0d28\u0d1f\u0d2e\u0d4d \u0d28\u0d3e\u0d21 <br/> \u0d15\u0d28\u0d4d\u0d31\u0d41 \u0d2a\u0d38\u0d41\u0d35\u0d3f\u0d28\u0d35\u0d41\u0d2e\u0d4d \u0d28\u0d3f\u0d28\u0d4d\u0d31\u0d41 \u0d2a\u0d41\u0d21\u0d48 \u0d38\u0d42\u0d34 \u0d0e\u0d28\u0d4d\u0d31\u0d41 \u0d2e\u0d32\u0d30\u0d41\u0d2e\u0d41\u0d16 \u0d07\u0d31\u0d48\u0d35\u0d28\u0d4d \u0d15\u0d28\u0d3f\u0d35\u0d4b\u0d21\u0d41"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d2e\u0d15\u0d30 \u0d15\u0d41\u0d23\u0d4d\u0d21\u0d32\u0d2e\u0d4d \u0d06\u0d21\u0d35\u0d41\u0d2e\u0d4d \u0d05\u0d26\u0d31\u0d4d\u0d15\u0d47\u0d31\u0d4d\u0d2a\u0d4d\u0d2a \u0d2e\u0d15\u0d41\u0d1f\u0d2e\u0d4d \u0d12\u0d33\u0d3f \u0d35\u0d40\u0d38\u0d35\u0d41\u0d2e\u0d4d"}, {"M": "\u0d2e\u0d27\u0d4d\u0d2f\u0d2e\u0d15\u0d3e\u0d32 \u0d38\u0d3e\u0d39\u0d3f\u0d24\u0d4d\u0d2f\u0d2e\u0d4d", "T": "\u0d2e\u0d3f\u0d17\u0d35\u0d41\u0d2e\u0d4d \u0d0e\u0d34\u0d3f\u0d32\u0d3e\u0d17\u0d35\u0d41\u0d2e\u0d4d \u0d15\u0d3e\u0d1f\u0d4d\u0d31\u0d3f\u0d32\u0d4d \u0d2e\u0d3f\u0d33\u0d3f\u0d30\u0d41\u0d2e\u0d4d \u0d24\u0d41\u0d17\u0d3f\u0d32\u0d4d \u0d06\u0d21\u0d35\u0d41\u0d2e\u0d4d <br/> \u0d05\u0d15\u0d2e\u0d17\u0d3f\u0d34\u0d4d\u0d28\u0d4d\u0d26\u0d41 \u0d07\u0d31\u0d48\u0d35\u0d28\u0d4d \u0d15\u0d28\u0d3f\u0d35\u0d4a\u0d21\u0d41"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0915\u0941\u0932\u0932\u0942\u0926\u093f \u092e\u0928\u092e\u0947\u0932\u094d\u0932\u093e\u092e\u094d \u0915\u094b\u0932\u094d\u0932\u0948 \u0915\u094b\u0923\u094d\u0921 \u092a\u093f\u0928\u094d\u0928\u0941\u092e\u094d \u0915\u0941\u0930\u0948 \u090f\u0926\u0941 \u090f\u0928\u0915\u094d\u0915\u0947\u0926\u0921\u0940 \u0924\u094b\u0932\u093f \u0915\u0941\u0932\u0932\u094d"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0905\u0932\u0917\u093e\u0928 \u092e\u092f\u093f\u0932\u094d \u0906\u0921\u0935\u0941\u092e\u094d \u092e\u093f\u0917 <br/> \u0915\u093e\u091f\u094d\u0930\u093f\u0932\u094d \u0905\u0938\u0948\u0928\u094d\u0926\u093e\u0921\u0941\u092e\u094d \u0915\u094b\u0921\u093f \u092a\u094b\u0932\u0935\u0941\u092e\u094d"}, {"M": "\u092e\u0927\u094d\u092f\u092e\u0915\u093e\u0932 \u0938\u093e\u0939\u093f\u0924\u094d\u092f\u092e\u094d", "T": "\u0905\u0917\u092e\u0917\u093f\u0932\u093f\u0928\u094d\u0926\u093f\u0932\u0917\u0941\u092e\u094d \u0928\u093f\u0932\u0935\u094b\u0932\u093f \u0924\u0928\u093f\u0932\u0947 \u0924\u0928\u0948 \u092e\u0930\u0928\u094d\u0926\u0941 \u092a\u0941\u0932\u094d\u0932\u093f\u0928\u092e\u094d \u0915\u0942\u0935 <br/> \u0905\u0938\u0948\u0928\u094d\u0926\u093e\u0921\u093f \u092e\u093f\u0917 \u0907\u0938\u0948\u0928\u094d\u0926\u094b\u0921\u093f \u0935\u0930\u0941\u092e\u094d \u0928\u0932\u092e\u094d \u0915\u093e\u0923 \u0913\u0930\u0941 \u092e\u0928\u092e\u094d \u0928\u093e\u0921 <br/> \u0924\u0915\u0941\u092e\u0940\u0926\u0941 \u090f\u0928 \u0913\u0930\u0941 \u092a\u0926\u092e\u094d \u092a\u093e\u0921 \u0924\u0915\u093f\u091f \u0924\u0927\u093f\u092e\u093f \u090f\u0928 \u0928\u091f\u092e\u094d \u0928\u093e\u0921 <br/> \u0915\u0928\u094d\u0930\u0941 \u092a\u0938\u0941\u0935\u093f\u0928\u0935\u0941\u092e\u094d \u0928\u093f\u0928\u094d\u0930\u0941 \u092a\u0941\u0921\u0948 \u0938\u0942\u0932 \u090f\u0928\u094d\u0930\u0941 \u092e\u0932\u0930\u0941\u092e\u0941\u0916 \u0907\u0930\u0948\u0935\u0928\u094d \u0915\u0928\u093f\u0935\u094b\u0921\u0941"}, {"M": "\u091a\u0930\u0923\u092e\u094d", "T": "\u092e\u0915\u0930 \u0915\u0941\u0923\u094d\u0921\u0932\u092e\u094d \u0906\u0921\u0935\u0941\u092e\u094d \u0905\u0926\u0930\u094d\u0915\u0947\u0930\u094d\u092a\u094d\u092a \u092e\u0915\u0941\u091f\u092e\u094d \u0913\u0932\u093f \u0935\u0940\u0938\u0935\u0941\u092e\u094d"}, {"M": "\u092e\u0927\u094d\u092f\u092e\u0915\u093e\u0932 \u0938\u093e\u0939\u093f\u0924\u094d\u092f\u092e\u094d", "T": "\u092e\u093f\u0917\u0935\u0941\u092e\u094d \u090f\u0932\u093f\u0932\u093e\u0917\u0935\u0941\u092e\u094d \u0915\u093e\u091f\u094d\u0930\u093f\u0932\u094d \u092e\u093f\u0932\u093f\u0930\u0941\u092e\u094d \u0924\u0941\u0917\u093f\u0932\u094d \u0906\u0921\u0935\u0941\u092e\u094d <br/> \u0905\u0915\u092e\u0917\u093f\u0932\u094d\u0928\u094d\u0926\u0941 \u0907\u0930\u0948\u0935\u0928\u094d \u0915\u0928\u093f\u0935\u094b\u0921\u0941"}]}], "L": "l", "lyricsref": [{"links": [{"N": "www.venkatakavi.org", "L": "http://www.venkatakavi.org/ovk/compositions.html?id=278"}]}]}