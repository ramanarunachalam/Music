 \u0ba8\u0bc1\u0ba4 \u0ba4\u0bbf\u0bb5\u0bcd\u0baf"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c32\u0c3e\u0c35\u0c23\u0c4d\u0c2f \u0c30\u0c3e\u0c2e \u0c15\u0c28\u0c41\u0c32\u0c3e\u0c30 \u0c1c\u0c42\u0c21\u0c35\u0c47 \u0c05\u0c24\u0c3f"}, {"M": "\u0c05\u0c28\u0c41\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c36\u0c4d\u0c30\u0c40 \u0c35\u0c28\u0c3f\u0c24\u0c3e \u0c1a\u0c3f\u0c24\u0c4d\u0c24 \u0c15\u0c41\u0c2e\u0c41\u0c26 <br/> \u0c36\u0c40\u0c24 \u0c15\u0c30 \u0c36\u0c24\u0c3e\u0c28\u0c28\u0c4d\u0c2f\u0c1c"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c28\u0c40 \u0c2e\u0c28\u0c38\u0c41 \u0c28\u0c40 \u0c38\u0c4a\u0c17\u0c38\u0c41 <br/> \u0c28\u0c40 \u0c26\u0c3f\u0c28\u0c41\u0c38\u0c41 \u0c35\u0c47\u0c30\u0c47 <br/> \u0c24\u0c3e\u0c2e\u0c38 \u0c2e\u0c24 \u0c26\u0c48\u0c35\u0c2e\u0c47\u0c32 <br/> \u0c24\u0c4d\u0c2f\u0c3e\u0c17\u0c30\u0c3e\u0c1c \u0c28\u0c41\u0c24 \u0c26\u0c3f\u0c35\u0c4d\u0c2f"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cb2\u0cbe\u0cb5\u0ca3\u0ccd\u0caf \u0cb0\u0cbe\u0cae \u0c95\u0ca8\u0cc1\u0cb2\u0cbe\u0cb0 \u0c9c\u0cc2\u0ca1\u0cb5\u0cc7 \u0c85\u0ca4\u0cbf"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cb6\u0ccd\u0cb0\u0cc0 \u0cb5\u0ca8\u0cbf\u0ca4\u0cbe \u0c9a\u0cbf\u0ca4\u0ccd\u0ca4 \u0c95\u0cc1\u0cae\u0cc1\u0ca6 <br/> \u0cb6\u0cc0\u0ca4 \u0c95\u0cb0 \u0cb6\u0ca4\u0cbe\u0ca8\u0ca8\u0ccd\u0caf\u0c9c"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0ca8\u0cc0 \u0cae\u0ca8\u0cb8\u0cc1 \u0ca8\u0cc0 \u0cb8\u0cca\u0c97\u0cb8\u0cc1 <br/> \u0ca8\u0cc0 \u0ca6\u0cbf\u0ca8\u0cc1\u0cb8\u0cc1 \u0cb5\u0cc7\u0cb0\u0cc7 <br/> \u0ca4\u0cbe\u0cae\u0cb8 \u0cae\u0ca4 \u0ca6\u0cc8\u0cb5\u0cae\u0cc7\u0cb2 <br/> \u0ca4\u0ccd\u0caf\u0cbe\u0c97\u0cb0\u0cbe\u0c9c \u0ca8\u0cc1\u0ca4 \u0ca6\u0cbf\u0cb5\u0ccd\u0caf"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d32\u0d3e\u0d35\u0d23\u0d4d\u0d2f \u0d30\u0d3e\u0d2e \u0d15\u0d28\u0d41\u0d32\u0d3e\u0d30 \u0d1c\u0d42\u0d21\u0d35\u0d47 \u0d05\u0d24\u0d3f"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d36\u0d4d\u0d30\u0d40 \u0d35\u0d28\u0d3f\u0d24\u0d3e \u0d1a\u0d3f\u0d24\u0d4d\u0d24 \u0d15\u0d41\u0d2e\u0d41\u0d26 <br/> \u0d36\u0d40\u0d24 \u0d15\u0d30 \u0d36\u0d24\u0d3e\u0d28\u0d28\u0d4d\u0d2f\u0d1c"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d28\u0d40 \u0d2e\u0d28\u0d38\u0d41 \u0d28\u0d40 \u0d38\u0d4a\u0d17\u0d38\u0d41 <br/> \u0d28\u0d40 \u0d26\u0d3f\u0d28\u0d41\u0d38\u0d41 \u0d35\u0d47\u0d30\u0d47 <br/> \u0d24\u0d3e\u0d2e\u0d38 \u0d2e\u0d24 \u0d26\u0d48\u0d35\u0d2e\u0d47\u0d32 <br/> \u0d24\u0d4d\u0d2f\u0d3e\u0d17\u0d30\u0d3e\u0d1c \u0d28\u0d41\u0d24 \u0d26\u0d3f\u0d35\u0d4d\u0d2f"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0932\u093e\u0935\u0923\u094d\u092f \u0930\u093e\u092e \u0915\u0928\u0941\u0932\u093e\u0930 \u091c\u0942\u0921\u0935\u0947 \u0905\u0924\u093f"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0936\u094d\u0930\u0940 \u0935\u0928\u093f\u0924\u093e \u091a\u093f\u0924\u094d\u0924 \u0915\u0941\u092e\u0941\u0926 <br/> \u0936\u0940\u0924 \u0915\u0930 \u0936\u0924\u093e\u0928\u0928\u094d\u092f\u091c"}, {"M": "\u091a\u0930\u0923\u092e\u094d", "T": "\u0928\u0940 \u092e\u0928\u0938\u0941 \u0928\u0940 \u0938\u094b\u0917\u0938\u0941 <br/> \u0928\u0940 \u0926\u093f\u0928\u0941\u0938\u0941 \u0935\u0947\u0930\u0947 <br/> \u0924\u093e\u092e\u0938 \u092e\u0924 \u0926\u0948\u0935\u092e\u0947\u0932 <br/> \u0924\u094d\u092f\u093e\u0917\u0930\u093e\u091c \u0928\u0941\u0924 \u0926\u093f\u0935\u094d\u092f"}]}], "L": "l", "lyricsref": [{"links": [{"N": "thyagaraja-vaibhavam.blogspot.com", "L": "http://thyagaraja-vaibhavam.blogspot.com/2007/09/thyagaraja-kriti-laavanya-rama-raga.html"}, {"N": "www.sangeetasudha.org", "L": "http://www.sangeetasudha.org/thyagaraja/vol2/l.html#MARK_LAVANYARAMA"}, {"N": "www.karnatik.com", "L": "http://www.karn