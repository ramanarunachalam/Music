f \u0cad\u0cbe\u0c97\u0ccd\u0caf \u0caa\u0ca4\u0cc7 <br/> \u0cb6\u0c82\u0c96 \u0c97\u0ca6\u0cbe \u0cb5\u0ca8\u0cae\u0cbe\u0cb2 \u0cb8\u0cc1\u0ca6\u0cb0\u0ccd\u0cb6\u0ca8 \u0ca7\u0cbe\u0cb0\u0ca3 \u0ca4\u0cb0\u0cc1\u0ca3 \u0c95\u0cb0 \u0c9c\u0ccd\u0cb5\u0cb2\u0cb8\u0cc7 <br/> \u0c9a\u0cb2 \u0c9a\u0cb2 \u0ca8\u0caf\u0ca8 \u0cb8\u0cc1\u0ca7\u0cbe\u0c95\u0cb0 \u0cad\u0cbe\u0cb6\u0ca3 \u0ca4\u0ca8\u0ccd\u0ca4\u0ccd\u0cb0 \u0cb8\u0ccd\u0cb5\u0ca4\u0ca8\u0ccd\u0ca4\u0ccd\u0cb0 \u0cb8\u0ccd\u0cb5\u0cb0\u0cc2\u0caa \u0ca8\u0cbf\u0ca7\u0cc7 <br/> \u0c85\u0cae\u0cb0 \u0c97\u0ca3\u0cc8\u0cb0\u0caa\u0cbf \u0cb5\u0cbe\u0ca8\u0ccd\u0c9b\u0ccd\u0cb9\u0cbf\u0ca4 \u0caa\u0ca6\u0caf\u0cc1\u0c97 \u0cb5\u0cbf\u0cae\u0cb2 \u0c95\u0cae\u0cb2\u0ca6\u0cb3 \u0cb8\u0cca\u0cb5\u0ccd\u0cae\u0ccd\u0caf \u0ca8\u0cbf\u0ca7\u0cc7 <br/> \u0cb9\u0cb0\u0cbf \u0cb9\u0cb0\u0cbf \u0cae\u0cbe\u0ca7\u0cb5 \u0cae\u0ca7\u0cc1\u0cb8\u0cc2\u0ca6\u0ca8 \u0c9c\u0caf \u0c86\u0ca8\u0c95 \u0ca6\u0cc1\u0ca8\u0ccd\u0ca6\u0cc1\u0cad\u0cbf \u0cad\u0cbe\u0c97\u0ccd\u0caf \u0caa\u0ca4\u0cc7 <br/> \u0cad\u0ca6\u0ccd\u0cb0 \u0cb5\u0cbf\u0c9a\u0cbf\u0ca4\u0ccd\u0cb0 \u0c9a\u0cb0\u0cbf\u0ca4\u0ccd\u0cb0 \u0caa\u0cb5\u0cbf\u0ca4\u0ccd\u0cb0 \u0cb8\u0cc1\u0cae\u0cbf\u0ca4\u0ccd\u0cb0 \u0cb8\u0cc1\u0cae\u0cbf\u0ca4\u0ccd\u0cb0 \u0cb8\u0cc1\u0cae\u0cbf\u0ca4\u0ccd\u0cb0 \u0caa\u0ca4\u0cc7 <br/> \u0cad\u0cbe\u0cb5\u0cbf\u0ca4 \u0cb2\u0ccb\u0c95 \u0c9a\u0cb0\u0cbe\u0c9a\u0cb0 \u0caa\u0cbe\u0cb2\u0ca8 \u0caa\u0cbe\u0ca6 \u0caf\u0cc1\u0c97\u0cb3 \u0c95\u0cb0\u0cc1\u0ca3\u0cbe \u0c9c\u0cb2\u0ca7\u0cc7 <br/> \u0c85\u0c97\u0ca3\u0cbf\u0ca4 \u0cae\u0cc1\u0ca8\u0cbf \u0c98\u0ccb\u0cb7\u0ca3 \u0c98\u0ccb\u0cb7\u0cbf\u0ca4 \u0cb9\u0cb0\u0cbf \u0cb9\u0cb0\u0cbf \u0ca8\u0cbe\u0cae \u0cb8\u0cc1\u0ca6\u0cbe\u0cb8\u0caf\u0cc1\u0ca4\u0cc7 <br/> \u0cb9\u0cb0\u0cbf \u0cb9\u0cb0\u0cbf \u0cae\u0cbe\u0ca7\u0cb5 \u0cae\u0ca7\u0cc1\u0cb8\u0cc2\u0ca6\u0ca8 \u0c9c\u0caf \u0c86\u0ca8\u0c95 \u0ca6\u0cc1\u0ca8\u0ccd\u0ca6\u0cc1\u0cad\u0cbf \u0cad\u0cbe\u0c97\u0ccd\u0caf \u0caa\u0ca4\u0cc7 <br/> \u0cb2\u0cb2\u0ca8\u0cbe \u0cb2\u0cbe\u0cb2\u0cbf\u0ca4 \u0cb2\u0cb2\u0cbf\u0ca4 \u0cb5\u0cbf\u0cb2\u0cc1\u0cb2\u0cbf\u0ca4 \u0cb2\u0cb2\u0cbe\u0c9f \u0cb2\u0cb2\u0cbe\u0cae\u0c95 \u0cb2\u0cb8\u0cbf\u0ca4 \u0caa\u0ca4\u0cc7 <br/> \u0ca8\u0cb5 \u0ca8\u0cb5 \u0cad\u0cbe\u0cb5 \u0cae\u0ca8\u0ccb\u0cb9\u0cb0 \u0c96\u0cc7\u0ca6 \u0ca8\u0cbf\u0c95\u0cc3\u0ca8\u0ccd\u0ca4\u0ca8 \u0cb9\u0cc7\u0ca4\u0cc1 \u0cb5\u0cbf\u0ca8\u0ccb\u0ca6 \u0c97\u0ca4\u0cc7 <br/> \u0c86\u0ca8\u0ca8 \u0cb5\u0cbf\u0c95\u0cb8\u0cbf\u0ca4 \u0cb9\u0cb8\u0ca8 \u0cae\u0ca8\u0ccd\u0ca6 \u0cb9\u0cb8\u0ca8 \u0cad\u0cb0 \u0c85\u0c95\u0cb2\u0cc1\u0cb6 \u0cb8\u0cc1\u0ca8\u0ccd\u0ca6\u0cb0 \u0cb0\u0cc2\u0caa \u0ca8\u0cbf\u0ca7\u0cc7 <br/> \u0cb9\u0cb0\u0cbf \u0cb9\u0cb0\u0cbf \u0cae\u0cbe\u0ca7\u0cb5 \u0cae\u0ca7\u0cc1\u0cb8\u0cc2\u0ca6\u0ca8 \u0c9c\u0caf \u0c86\u0ca8\u0c95 \u0ca6\u0cc1\u0ca8\u0ccd\u0ca6\u0cc1\u0cad\u0cbf \u0cad\u0cbe\u0c97\u0ccd\u0caf \u0caa\u0ca4\u0cc7 <br/> \u0cb0\u0cae\u0ccd\u0caf \u0cb8\u0cc1\u0c97\u0ca8\u0ccd\u0ca7 \u0cae\u0ca7\u0cc1\u0c95\u0cb0 \u0cae\u0ca7\u0cc1\u0c95 \u0cae\u0ca4 \u0cb0\u0cbe\u0c97 \u0cae\u0caa\u0cbe\u0ca6 \u0cae \u0caa\u0cbe \u0ca6 \u0caa \u0cae\u0cbe <br/> \u0ca8\u0cbe\u0ca6 \u0c97\u0cc0\u0ca4 \u0caa\u0cb0 \u0c95\u0ca8\u0ccd\u0c9c\u0cb0 \u0caf\u0cc1\u0ca4\u0cb5\u0ca8 \u0ca8\u0cbe\u0ca8\u0cbe\u0cb5\u0cbf\u0ca7 \u0ca6\u0cb3 \u0cb9\u0cbe\u0cb0 \u0caa\u0ca4\u0cc7 <br/> \u0c85\u0cae\u0cbf\u0ca4 \u0cb0\u0cae\u0cbf\u0ca4 \u0c98\u0ca8 \u0c95\u0ccb\u0cb2\u0cbe\u0cb9\u0cb2 \u0cb6\u0cbf\u0c96\u0cbf\u0ca8\u0cbe\u0cb0\u0ccd\u0caa\u0cbf\u0ca4 \u0caa\u0cbf\u0ca8\u0ccd\u0c9b\u0c95 \u0c9a\u0cbf\u0c95\u0cc1\u0cb0 \u0caa\u0ca4\u0cc7 <br/> \u0cb9\u0cb0\u0cbf \u0cb9\u0cb0\u0cbf \u0cae\u0cbe\u0ca7\u0cb5 \u0cae\u0ca7\u0cc1\u0cb8\u0cc2\u0ca6\u0ca8 \u0c9c\u0caf \u0c86\u0ca8\u0c95 \u0ca6\u0cc1\u0ca8\u0ccd\u0ca6\u0cc1\u0cad\u0cbf \u0cad\u0cbe\u0c97\u0ccd\u0caf \u0caa\u0ca4\u0cc7"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d2e\u0d02\u0d17\u0d33 \u0d24\u0d41\u0d02\u0d17 \u0d28\u0d3f\u0d30\u0d28\u0d4d\u0d24\u0d30 \u0d1a\u0d28\u0d4d\u0d26\u0d4d\u0d30 \u0d27\u0d41\u0d30\u0d28\u0d4d\u0d27\u0d30 \u0d2c\u0d4d\u0d30\u0d4d\u0d28\u0d4d\u0d26 \u0d27\u0d30\u0d3e\u0d27\u0d3f\u0d2a\u0d24\u0d47 <br/> \u0d2e\u0d3e\u0d27\u0d35 \u0d17\u0d4a\u0d35\u0d4d\u0d30 \u0d35\u0d38\u0d28 \u0d2e\u0d23\u0d40 \u0d28\u0d42\u0d2a\u0d41\u0d30 \u0d2e\u0d30\u0d15\u0d24 \u0d39\u0d3e\u0d30 \u0d38\u0d41\u0d30\u0d3e\u0d27\u0d3f\u0d2a\u0d24\u0d47 <br/> \u0d05\u0d02\u0d15\u0d3f\u0d24 \u0d1a\u0d28\u0d4d\u0d26\u0d28 \u0d05\u0d28\u0d41\u0d2a\u0d2e \u0d38\u0d2e\u0d4d \u0d17\u0d41\u0d23 \u0d05\u0d28\u0d4d\u0d1c\u0d28 \u0d30\u0d42\u0d36\u0d3f\u0d24 \u0d28\u0d2f\u0d28\u0d2a\u0d24\u0d47 <br/> \u0d39\u0d30\u0d3f \u0d39\u0d30\u0d3f \u0d2e\u0d3e\u0d27\u0d35 \u0d2e\u0d27\u0d41\u0d38\u0d42\u0d26\u0d28 \u0d1c\u0d2f \u0d06\u0d28\u0d15 \u0d26\u0d41\u0d28\u0d4d\u0d26\u0d41\u0d2d\u0d3f \u0d2d\u0d3e\u0d17\u0d4d\u0d2f \u0d2a\u0d24\u0d47 <br/> \u0d36\u0d02\u0d16 \u0d17\u0d26\u0d3e \u0d35\u0d28\u0d2e\u0d3e\u0d32 \u0d38\u0d41\u0d26\u0d30\u0d4d\u0d36\u0d28 \u0d27\u0d3e\u0d30\u0d23 \u0d24\u0d30\u0d41\u0d23 \u0d15\u0d30 \u0d1c\u0d4d\u0d35\u0d32\u0d38\u0d47 <br/> \u0d1a\u0d32 \u0d1a\u0d32 \u0d28\u0d2f\u0d28 \u0d38\u0d41\u0d27\u0d3e\u0d15\u0d30 \u0d2d\u0d3e\u0d36\u0d23 \u0d24\u0d28\u0d4d\u0d24\u0d4d\u0d30 \u0d38\u0d4d\u0d35\u0d24\u0d28\u0d4d\u0d24\u0d4d\u0d30 \u0d38\u0d4d\u0d35\u0d30\u0d42\u0d2a \u0d28\u0d3f\u0d27\u0d47 <br/> \u0d05\u0d2e\u0d30 \u0d17\u0d23\u0d48\u0d30\u0d2a\u0d3f \u0d35\u0d3e\u0d28\u0d4d\u0d1b\u0d4d\u0d39\u0d3f\u0d24 \u0d2a\u0d26\u0d2f\u0d41\u0d17 \u0d35\u0d3f\u0d2e\u0d32 \u0d15\u0d2e\u0d32\u0d26\u0d33 \u0d38\u0d4a\u0d35\u0d4d\u0d2e\u0d4d\u0d2f \u0d28\u0d3f\u0d27\u0d47 <br/> \u0d39\u0d30\u0d3f \u0d39\u0d30\u0d3f \u0d2e\u0d3e\u0d27\u0d35 \u0d2e\u0d27\u0d41\u0d38\u0d42\u0d26\u0d28 \u0d1c\u0d2f \u0d06\u0d28\u0d15 \u0d26\u0d41\u0d28\u0d4d\u0d26\u0d41\u0d2d\u0d3f \u0d2d\u0d3e\u0d17\u0d4d\u0d2f \u0d2a\u0d24\u0d47 <br/> \u0d2d\u0d26\u0d4d\u0d30 \u0d35\u0d3f\u0d1a\u0d3f\u0d24\u0d4d\u0d30 \u0d1a\u0d30\u0d3f\u0d24\u0d4d\u0d30 \u0d2a\u0d35\u0d3f\u0d24\u0d4d\u0d30 \u0d38\u0d41\u0d2e\u0d3f\u0d24\u0d4d\u0d30 \u0d38\u0d41\u0d2e\u0d3f\u0d24\u0d4d\u0d30 \u0d38\u0d41\u0d2e\u0d3f\u0d24\u0d4d\u0d30 \u0d2a\u0d24\u0d47 <br/> \u0d2d\u0d3e\u0d35\u0d3f\u0d24 \u0d32\u0d4b\u0d15 \u0d1a\u0d30\u0d3e\u0d1a\u0d30 \u0d2a\u0d3e\u0d32\u0d28 \u0d2a\u0d3e\u0d26 \u0d2f\u0d41\u0d17\u0d33 \u0d15\u0d30\u0d41\u0d23\u0d3e \u0d1c\u0d32\u0d27\u0d47 <br/> \u0d05\u0d17\u0d23\u0d3f\u0d24 \u0d2e\u0d41\u0d28\u0d3f \u0d18\u0d4b\u0d37\u0d23 \u0d18\u0d4b\u0d37\u0d3f\u0d24 \u0d39\u0d30\u0d3f \u0d39\u0d30\u0d3f \u0d28\u0d3e\u0d2e \u0d38\u0d41\u0d26\u0d3e\u0d38\u0d2f\u0d41\u0d24\u0d47 <br/> \u0d39\u0d30\u0d3f \u0d39\u0d30\u0d3f \u0d2e\u0d3e\u0d27\u0d35 \u0d2e\u0d27\u0d41\u0d38\u0d42\u0d26\u0d28 \u0d1c\u0d2f \u0d06\u0d28\u0d15 \u0d26\u0d41\u0d28\u0d4d\u0d26\u0d41\u0d2d\u0d3f \u0d2d\u0d3e\u0d17\u0d4d\u0d2f \u0d2a\u0d24\u0d47 <br/> \u0d32\u0d32\u0d28\u0d3e \u0d32\u0d3e\u0d32\u0d3f\u0d24 \u0d32\u0d32\u0d3f\u0d24 \u0d35\u0d3f\u0d32\u0d41\u0d32\u0d3f\u0d24 \u0d32\u0d32\u0d3e\u0d1f \u0d32\u0d32\u0d3e\u0d2e\u0d15 \u0d32\u0d38\u0d3f\u0d24 \u0d2a\u0d24\u0d47 <br/> \u0d28\u0d35 \u0d28\u0d35 \u0d2d\u0d3e\u0d35 \u0d2e\u0d28\u0d4b\u0d39\u0d30 \u0d16\u0d47\u0d26 \u0d28\u0d3f\u0d15\u0d43\u0d28\u0d4d\u0d24\u0d28 \u0d39\u0d47\u0d24\u0d41 \u0d35\u0d3f\u0d28\u0d4b\u0d26 \u0d17\u0d24\u0d47 <br/> \u0d06\u0d28\u0d28 \u0d35\u0d3f\u0d15\u0d38\u0d3f\u0d24 \u0d39\u0d38\u0d28 \u0d2e\u0d28\u0d4d\u0d26 \u0d39\u0d38\u0d28 \u0d2d\u0d30 \u0d05\u0d15\u0d32\u0d41\u0d36 \u0d38\u0d41\u0d28\u0d4d\u0d26\u0d30 \u0d30\u0d42\u0d2a \u0d28\u0d3f\u0d27\u0d47 <br/> \u0d39\u0d30\u0d3f \u0d39\u0d30\u0d3f \u0d2e\u0d3e\u0d27\u0d35 \u0d2e\u0d27\u0d41\u0d38\u0d42\u0d26\u0d28 \u0d1c\u0d2f \u0d06\u0d28\u0d15 \u0d26\u0d41\u0d28\u0d4d\u0d26\u0d41\u0d2d\u0d3f \u0d2d\u0d3e\u0d17\u0d4d\u0d2f \u0d2a\u0d24\u0d47 <br/> \u0d30\u0d2e\u0d4d\u0d2f \u0d38\u0d41\u0d17\u0d28\u0d4d\u0d27 \u0d2e\u0d27\u0d41\u0d15\u0d30 \u0d2e\u0d27\u0d41\u0d15 \u0d2e\u0d24 \u0d30\u0d3e\u0d17 \u0d2e\u0d2a\u0d3e\u0d26 \u0d2e \u0d2a\u0d3e \u0d26 \u0d2a \u0d2e\u0d3e <br/> \u0d28\u0d3e\u0d26 \u0d17\u0d40\u0d24 \u0d2a\u0d30 \u0d15\u0d28\u0d4d\u0d1c\u0d30 \u0d2f\u0d41\u0d24\u0d35\u0d28 \u0d28\u0d3e\u0d28\u0d3e\u0d35\u0d3f\u0d27 \u0d26\u0d33 \u0d39\u0d3e\u0d30 \u0d2a\u0d24\u0d47 <br/> \u0d05\u0d2e\u0d3f\u0d24 \u0d30\u0d2e\u0d3f\u0d24 \u0d18\u0d28 \u0d15\u0d4b\u0d32\u0d3e\u0d39\u0d32 \u0d36\u0d3f\u0d16\u0d3f\u0d28\u0d3e\u0d30\u0d4d\u0d2a\u0d3f\u0d24 \u0d2a\u0d3f\u0d28\u0d4d\u0d1b\u0d15 \u0d1a\u0d3f\u0d15\u0d41\u0d30 \u0d2a\u0d24\u0d47 <br/> \u0d39\u0d30\u0d3f \u0d39\u0d30\u0d3f \u0d2e\u0d3e\u0d27\u0d35 \u0d2e\u0d27\u0d41\u0d38\u0d42\u0d26\u0d28 \u0d1c\u0d2f \u0d06\u0d28\u0d15 \u0d26\u0d41\u0d28\u0d4d\u0d26\u0d41\u0d2d\u0d3f \u0d2d\u0d3e\u0d17\u0d4d\u0d2f \u0d2a\u0d24\u0d47"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u092e\u0902\u0917\u0932 \u0924\u0941\u0902\u0917 \u0928\u093f\u0930\u0928\u094d\u0924\u0930 \u091a\u0928\u094d\u0926\u094d\u0930 \u0927\u0941\u0930\u0928\u094d\u0927\u0930 \u092c\u094d\u0930\u094d\u0928\u094d\u0926 \u0927\u0930\u093e\u0927\u093f\u092a\u0924\u0947 <br/> \u092e\u093e\u0927\u0935 \u0917\u094b\u0935\u094d\u0930 \u0935\u0938\u0928 \u092e\u0923\u0940 \u0928\u0942\u092a\u0941\u0930 \u092e\u0930\u0915\u0924 \u0939\u093e\u0930 \u0938\u0941\u0930\u093e\u0927\u093f\u092a\u0924\u0947 <br/> \u0905\u0902\u0915\u093f\u0924 \u091a\u0928\u094d\u0926\u0928 \u0905\u0928\u0941\u092a\u092e \u0938\u092e\u094d \u0917\u0941\u0923 \u0905\u0928\u094d\u091c\u0928 \u0930\u0942\u0936\u093f\u0924 \u0928\u092f\u0928\u092a\u0924\u0947 <br/> \u0939\u0930\u093f \u0939\u0930\u093f \u092e\u093e\u0927\u0935 \u092e\u0927\u0941\u0938\u0942\u0926\u0928 \u091c\u092f \u0906\u0928\u0915 \u0926\u0941\u0928\u094d\u0926\u0941\u092d\u093f \u092d\u093e\u0917\u094d\u092f \u092a\u0924\u0947 <br/> \u0936\u0902\u0916 \u0917\u0926\u093e \u0935\u0928\u092e\u093e\u0932 \u0938\u09