bbe\u0bae\u0bcd <br/> \u0bae\u0bbe\u0baf\u0bbe-\u0bae\u0baf \u0bb5\u0bb2\u0bcd\u0bb2\u0baa\u0bbe \u0baa\u0ba4\u0bc7 \u0bb6\u0bcd\u0bb0\u0bc0"}, {"M": "\u0b9a\u0bae\u0bb8\u0bcd\u0ba4\u0bbf \u0b9a\u0bb0\u0ba3\u0bae\u0bcd", "T": "\u0bae\u0bb9\u0bbe \u0ba8\u0b9f \u0ba8\u0bbe\u0bb0\u0bbe\u0baf\u0ba3\u0bc0 \u0ba8\u0ba8\u0bcd\u0ba4\u0ba9 <br/> \u0bae\u0bbe\u0ba9\u0bbf\u0ba4 \u0ba4\u0bc7\u0bb5 \u0ba4\u0bc7\u0bb5\u0b95\u0bc0 \u0ba8\u0ba8\u0bcd\u0ba4\u0ba9"}, {"M": "\u0bae\u0ba4\u0bcd\u0baf\u0bae\u0b95\u0bbe\u0bb2 \u0b9a\u0bbe\u0bb9\u0bbf\u0ba4\u0bcd\u0baf\u0bae\u0bcd", "T": "\u0bae\u0bb9\u0bc7\u0bb6\u0bcd\u0bb5\u0bb0 \u0b95\u0bc1\u0bb0\u0bc1 \u0b95\u0bc1\u0bb9 \u0baa\u0b95\u0bcd\u0ba4 \u0b9a\u0ba8\u0bcd\u0ba4\u0ba9 <br/> \u0bae\u0bbe\u0ba4\u0b99\u0bcd\u0b95 \u0bb5\u0ba4\u0ba9\u0bc7\u0ba8\u0bcd\u0ba4\u0bcd\u0bb0\u0bbe\u0ba4\u0bbf \u0bb5\u0ba8\u0bcd\u0ba4\u0ba9"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c2e\u0c39\u0c3e \u0c17\u0c23 \u0c2a\u0c24\u0c47 \u0c2a\u0c3e\u0c32\u0c2f\u0c3e\u0c36\u0c41 \u0c2e\u0c3e\u0c02 <br/> \u0c2e\u0c3e\u0c2f\u0c3e-\u0c2e\u0c2f \u0c35\u0c32\u0c4d\u0c32\u0c2d\u0c3e \u0c2a\u0c24\u0c47 \u0c36\u0c4d\u0c30\u0c40"}, {"M": "\u0c38\u0c2e\u0c38\u0c4d\u0c24\u0c3f \u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c2e\u0c39\u0c3e \u0c28\u0c1f \u0c28\u0c3e\u0c30\u0c3e\u0c2f\u0c23\u0c40 \u0c28\u0c28\u0c4d\u0c26\u0c28 <br/> \u0c2e\u0c3e\u0c28\u0c3f\u0c24 \u0c26\u0c47\u0c35 \u0c26\u0c47\u0c35\u0c15\u0c40 \u0c28\u0c28\u0c4d\u0c26\u0c28"}, {"M": "\u0c2e\u0c27\u0c4d\u0c2f\u0c2e\u0c15\u0c3e\u0c32 \u0c38\u0c3e\u0c39\u0c3f\u0c24\u0c4d\u0c2f\u0c2e\u0c4d", "T": "\u0c2e\u0c39\u0c47\u0c36\u0c4d\u0c35\u0c30 \u0c17\u0c41\u0c30\u0c41 \u0c17\u0c41\u0c39 \u0c2d\u0c15\u0c4d\u0c24 \u0c1a\u0c28\u0c4d\u0c26\u0c28 <br/> \u0c2e\u0c3e\u0c24\u0c02\u0c17 \u0c35\u0c26\u0c28\u0c47\u0c28\u0c4d\u0c26\u0c4d\u0c30\u0c3e\u0c26\u0c3f \u0c35\u0c28\u0c4d\u0c26\u0c28"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cae\u0cb9\u0cbe \u0c97\u0ca3 \u0caa\u0ca4\u0cc7 \u0caa\u0cbe\u0cb2\u0caf\u0cbe\u0cb6\u0cc1 \u0cae\u0cbe\u0c82 <br/> \u0cae\u0cbe\u0caf\u0cbe-\u0cae\u0caf \u0cb5\u0cb2\u0ccd\u0cb2\u0cad\u0cbe \u0caa\u0ca4\u0cc7 \u0cb6\u0ccd\u0cb0\u0cc0"}, {"M": "\u0cb8\u0cae\u0cb8\u0ccd\u0ca4\u0cbf \u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0cae\u0cb9\u0cbe \u0ca8\u0c9f \u0ca8\u0cbe\u0cb0\u0cbe\u0caf\u0ca3\u0cc0 \u0ca8\u0ca8\u0ccd\u0ca6\u0ca8 <br/> \u0cae\u0cbe\u0ca8\u0cbf\u0ca4 \u0ca6\u0cc7\u0cb5 \u0ca6\u0cc7\u0cb5\u0c95\u0cc0 \u0ca8\u0ca8\u0ccd\u0ca6\u0ca8"}, {"M": "\u0cae\u0ca7\u0ccd\u0caf\u0cae\u0c95\u0cbe\u0cb2 \u0cb8\u0cbe\u0cb9\u0cbf\u0ca4\u0ccd\u0caf\u0cae\u0ccd", "T": "\u0cae\u0cb9\u0cc7\u0cb6\u0ccd\u0cb5\u0cb0 \u0c97\u0cc1\u0cb0\u0cc1 \u0c97\u0cc1\u0cb9 \u0cad\u0c95\u0ccd\u0ca4 \u0c9a\u0ca8\u0ccd\u0ca6\u0ca8 <br/> \u0cae\u0cbe\u0ca4\u0c82\u0c97 \u0cb5\u0ca6\u0ca8\u0cc7\u0ca8\u0ccd\u0ca6\u0ccd\u0cb0\u0cbe\u0ca6\u0cbf \u0cb5\u0ca8\u0ccd\u0ca6\u0ca8"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d2e\u0d39\u0d3e \u0d17\u0d23 \u0d2a\u0d24\u0d47 \u0d2a\u0d3e\u0d32\u0d2f\u0d3e\u0d36\u0d41 \u0d2e\u0d3e\u0d02 <br/> \u0d2e\u0d3e\u0d2f\u0d3e-\u0d2e\u0d2f \u0d35\u0d32\u0d4d\u0d32\u0d2d\u0d3e \u0d2a\u0d24\u0d47 \u0d36\u0d4d\u0d30\u0d40"}, {"M": "\u0d38\u0d2e\u0d38\u0d4d\u0d24\u0d3f \u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d2e\u0d39\u0d3e \u0d28\u0d1f \u0d28\u0d3e\u0d30\u0d3e\u0d2f\u0d23\u0d40 \u0d28\u0d28\u0d4d\u0d26\u0d28 <br/> \u0d2e\u0d3e\u0d28\u0d3f\u0d24 \u0d26\u0d47\u0d35 \u0d26\u0d47\u0d35\u0d15\u0d40 \u0d28\u0d28\u0d4d\u0d26\u0d28"}, {"M": "\u0d2e\u0d27\u0d4d\u0d2f\u0d2e\u0d15\u0d3e\u0d32 \u0d38\u0d3e\u0d39\u0d3f\u0d24\u0d4d\u0d2f\u0d2e\u0d4d", "T": "\u0d2e\u0d39\u0d47\u0d36\u0d4d\u0d35\u0d30 \u0d17\u0d41\u0d30\u0d41 \u0d17\u0d41\u0d39 \u0d2d\u0d15\u0d4d\u0d24 \u0d1a\u0d28\u0d4d\u0d26\u0d28 <br/> \u0d2e\u0d3e\u0d24\u0d02\u0d17 \u0d35\u0d26\u0d28\u0d47\u0d28\u0d4d\u0d26\u0d4d\u0d30\u0d3e\u0d26\u0d3f \u0d35\u0d28\u0d4d\u0d26\u0d28"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u092e\u0939\u093e \u0917\u0923 \u092a\u0924\u0947 \u092a\u093e\u0932\u092f\u093e\u0936\u0941 \u092e\u093e\u0902 <br/> \u092e\u093e\u092f\u093e-\u092e\u092f \u0935\u0932\u094d\u0932\u092d\u093e \u092a\u0924\u0947 \u0936\u094d\u0930\u0940"}, {"M": "\u0938\u092e\u0938\u094d\u0924\u093f \u091a\u0930\u0923\u092e\u094d", "T": "\u092e\u0939\u093e \u0928\u091f \u0928\u093e\u0930\u093e\u092f\u0923\u0940 \u0928\u0928\u094d\u0926\u0928 <br/> \u092e\u093e\u0928\u093f\u0924 \u0926\u0947\u0935 \u0926\u0947\u0935\u0915\u0940 \u0928\u0928\u094d\u0926\u0928"}, {"M": "\u092e\u0927\u094d\u092f\u092e\u0915\u093e\u0932 \u0938\u093e\u0939\u093f\u0924\u094d\u092f\u092e\u094d", "T": "\u092e\u0939\u0947\u0936\u094d\u0935\u0930 \u0917\u0941\u0930\u0941 \u0917\u0941\u0939 \u092d\u0915\u094d\u0924 \u091a\u0928\u094d\u0926\u0928 <br/> \u092e\u093e\u0924\u0902\u0917 \u0935\u0926\u0928\u0947\u0928\u094d\u0926\u094d\u0930\u093e\u0926\u093f \u0935\u0928\u094d\u0926\u0928"}]}], "L": "l", "lyricsref": [{"links": [{"N": "guru-guha.blogspot.com", "L": "http://guru-guha.blogspot.com/2008/04/dikshitar-kriti-maha-ganapate-raga-nata.html"}, {"N": "www.medieval.org", "L": "http://www.medieval.org/music/world/carnatic/lyrics/TKG/mahaganapate_palayashu.html"}]}]}