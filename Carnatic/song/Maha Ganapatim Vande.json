5,1,0,2,13,7,5,6,9,3,12,11,10", "odia": "8,4,14,15,1,0,2,13,7,5,6,9,3,12,11,10", "assamese": "8,4,14,15,1,0,2,13,7,5,6,9,3,12,11,10"}, "lyricstext": [{"L": "English", "text": [{"M": "pallavi", "T": "mahA gaNa patiM vandE <br/> mAdhavAdyamara brundam"}, {"M": "anupallavi", "T": "ahantAdi rahitaM Sakti sahitaM <br/> AnandadaM tamEka dantam"}, {"M": "caraNam", "T": "tripura vadhArthaM SivEna - <br/> tryambakEnArcitaM <br/> upanishat pratipAditaM <br/> umA mahESvara sutam <br/> kapila vasishThAdi nataM <br/> kanjajAdibhirIDitaM <br/> kapilaM krushNa pUjitaM <br/> kari vadana su-SObhitam"}, {"M": "madhyamakAla sAhityam", "T": "suparNa vAha sEvitaM <br/> sura guru guha bhAvitaM <br/> kapitthAmra panasa jambU - <br/> kadalI phala bhakshitam"}]}, {"L": "Tamil", "text": [{"M": "\u0baa\u0bb2\u0bcd\u0bb2\u0bb5\u0bbf", "T": "\u0bae\u0bb9\u0bbe \u0b95\u0ba3 \u0baa\u0ba4\u0bbf\u0bae\u0bcd \u0bb5\u0ba8\u0bcd\u0ba4\u0bc7 <br/> \u0bae\u0bbe\u0ba4\u0bb5\u0bbe\u0ba4\u0bcd\u0baf\u0bae\u0bb0 \u0baa\u0bcd\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0bae\u0bcd"}, {"M": "\u0b85\u0ba9\u0bc1\u0baa\u0bb2\u0bcd\u0bb2\u0bb5\u0bbf", "T": "\u0b85\u0bb9\u0ba8\u0bcd\u0ba4\u0bbe\u0ba4\u0bbf \u0bb0\u0bb9\u0bbf\u0ba4\u0bae\u0bcd \u0b9a\u0b95\u0bcd\u0ba4\u0bbf \u0b9a\u0bb9\u0bbf\u0ba4\u0bae\u0bcd <br/> \u0b86\u0ba9\u0ba8\u0bcd\u0ba4\u0ba4\u0bae\u0bcd \u0ba4\u0bae\u0bc7\u0b95 \u0ba4\u0ba8\u0bcd\u0ba4\u0bae\u0bcd"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd", "T": "\u0ba4\u0bcd\u0bb0\u0bbf\u0baa\u0bc1\u0bb0 \u0bb5\u0ba4\u0bbe\u0bb0\u0bcd\u0ba4\u0bae\u0bcd \u0b9a\u0bbf\u0bb5\u0bc7\u0ba9 - <br/> \u0ba4\u0bcd\u0bb0\u0bcd\u0baf\u0bae\u0bcd\u0baa\u0b95\u0bc7\u0ba9\u0bbe\u0bb0\u0bcd\u0b9a\u0bbf\u0ba4\u0bae\u0bcd <br/> \u0b89\u0baa\u0ba9\u0bbf\u0bb7\u0ba4\u0bcd \u0baa\u0bcd\u0bb0\u0ba4\u0bbf\u0baa\u0bbe\u0ba4\u0bbf\u0ba4\u0bae\u0bcd <br/> \u0b89\u0bae\u0bbe \u0bae\u0bb9\u0bc7\u0bb6\u0bcd\u0bb5\u0bb0 \u0b9a\u0bc1\u0ba4\u0bae\u0bcd <br/> \u0b95\u0baa\u0bbf\u0bb2 \u0bb5\u0b9a\u0bbf\u0bb7\u0bcd\u0b9f\u0bbe\u0ba4\u0bbf \u0ba8\u0ba4\u0bae\u0bcd <br/> \u0b95\u0ba9\u0bcd\u0b9c\u0b9c\u0bbe\u0ba4\u0bbf\u0baa\u0bbf\u0bb0\u0bc0\u0b9f\u0bbf\u0ba4\u0bae\u0bcd <br/> \u0b95\u0baa\u0bbf\u0bb2\u0bae\u0bcd \u0b95\u0bcd\u0bb0\u0bc1\u0bb7\u0bcd\u0ba3 \u0baa\u0bc2\u0b9c\u0bbf\u0ba4\u0bae\u0bcd <br/> \u0b95\u0bb0\u0bbf \u0bb5\u0ba4\u0ba9 \u0b9a\u0bc1-\u0b9a\u0bcb\u0baa\u0bbf\u0ba4\u0bae\u0bcd"}, {"M": "\u0bae\u0ba4\u0bcd\u0baf\u0bae\u0b95\u0bbe\u0bb2 \u0b9a\u0bbe\u0bb9\u0bbf\u0ba4\u0bcd\u0baf\u0bae\u0bcd", "T": "\u0b9a\u0bc1\u0baa\u0bb0\u0bcd\u0ba3 \u0bb5\u0bbe\u0bb9 \u0b9a\u0bc7\u0bb5\u0bbf\u0ba4\u0bae\u0bcd <br/> \u0b9a\u0bc1\u0bb0 \u0b95\u0bc1\u0bb0\u0bc1 \u0b95\u0bc1\u0bb9 \u0baa\u0bbe\u0bb5\u0bbf\u0ba4\u0bae\u0bcd <br/> \u0b95\u0baa\u0bbf\u0ba4\u0bcd\u0ba4\u0bbe\u0bae\u0bcd\u0bb0 \u0baa\u0ba9\u0b9a \u0b9c\u0bae\u0bcd\u0baa\u0bc2 - <br/> \u0b95\u0ba4\u0bb2\u0bc0 \u0baa\u0bb2 \u0baa\u0b95\u0bcd\u0bb7\u0bbf\u0ba4\u0bae\u0bcd"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c2e\u0c39\u0c3e \u0c17\u0c23 \u0c2a\u0c24\u0c3f\u0c02 \u0c35\u0c28\u0c4d\u0c26\u0c47 <br/> \u0c2e\u0c3e\u0c27\u0c35\u0c3e\u0c26\u0c4d\u0c2f\u0c2e\u0c30 \u0c2c\u0c43\u0c28\u0c4d\u0c26\u0c2e\u0c4d"}, {"M": "\u0c05\u0c28\u0c41\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c05\u0c39\u0c28\u0c4d\u0c24\u0c3e\u0c26\u0c3f \u0c30\u0c39\u0c3f\u0c24\u0c02 \u0c36\u0c15\u0c4d\u0c24\u0c3f \u0c38\u0c39\u0c3f\u0c24\u0c02 <br/> \u0c06\u0c28\u0c28\u0c4d\u0c26\u0c26\u0c02 \u0c24\u0c2e\u0c47\u0c15 \u0c26\u0c28\u0c4d\u0c24\u0c2e\u0c4d"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c24\u0c4d\u0c30\u0c3f\u0c2a\u0c41\u0c30 \u0c35\u0c27\u0c3e\u0c30\u0c4d\u0c25\u0c02 \u0c36\u0c3f\u0c35\u0c47\u0c28 - <br/> \u0c24\u0c4d\u0c30\u0c4d\u0c2f\u0c2e\u0c4d\u0c2c\u0c15\u0c47\u0c28\u0c3e\u0c30\u0c4d\u0c1a\u0c3f\u0c24\u0c02 <br/> \u0c09\u0c2a\u0c28\u0c3f\u0c37\u0c24\u0c4d \u0c2a\u0c4d\u0c30\u0c24\u0c3f\u0c2a\u0c3e\u0c26\u0c3f\u0c24\u0c02 <br/> \u0c09\u0c2e\u0c3e \u0c2e\u0c39\u0c47\u0c36\u0c4d\u0c35\u0c30 \u0c38\u0c41\u0c24\u0c2e\u0c4d <br/> \u0c15\u0c2a\u0c3f\u0c32 \u0c35\u0c38\u0c3f\u0c37\u0c4d\u0c20\u0c3e\u0c26\u0c3f \u0c28\u0c24\u0c02 <br/> \u0c15\u0c28\u0c4d\u0c1c\u0c1c\u0c3e\u0c26\u0c3f\u0c2d\u0c3f\u0c30\u0c40\u0c21\u0c3f\u0c24\u0c02 <br/> \u0c15\u0c2a\u0c3f\u0c32\u0c02 \u0c15\u0c43\u0c37\u0c4d\u0c23 \u0c2a\u0c42\u0c1c\u0c3f\u0c24\u0c02 <br/> \u0c15\u0c30\u0c3f \u0c35\u0c26\u0c28 \u0c38\u0c41-\u0c36\u0c4b\u0c2d\u0c3f\u0c24\u0c2e\u0c4d"}, {"M": "\u0c2e\u0c27\u0c4d\u0c2f\u0c2e\u0c15\u0c3e\u0c32 \u0c38\u0c3e\u0c39\u0c3f\u0c24\u0c4d\u0c2f\u0c2e\u0c4d", "T": "\u0c38\u0c41\u0c2a\u0c30\u0c4d\u0c23 \u0c35\u0c3e\u0c39 \u0c38\u0c47\u0c35\u0c3f\u0c24\u0c02 <br/> \u0c38\u0c41\u0c30 \u0c17\u0c41\u0c30\u0c41 \u0c17\u0c41\u0c39 \u0c2d\u0c3e\u0c35\u0c3f\u0c24\u0c02 <br/> \u0c15\u0c2a\u0c3f\u0c24\u0c4d\u0c25\u0c3e\u0c2e\u0c4d\u0c30 \u0c2a\u0c28\u0c38 \u0c1c\u0c2e\u0c4d\u0c2c\u0c42 - <br/> \u0c15\u0c26\u0c32\u0c40 \u0c2b\u0c32 \u0c2d\u0c15\u0c4d\u0c37\u0c3f\u0c24\u0c2e\u0c4d"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cae\u0cb9\u0cbe \u0c97\u0ca3 \u0caa\u0ca4\u0cbf\u0c82 \u0cb5\u0ca8\u0ccd\u0ca6\u0cc7 <br/> \u0cae\u0cbe\u0ca7\u0cb5\u0cbe\u0ca6\u0ccd\u0caf\u0cae\u0cb0 \u0cac\u0cc3\u0ca8\u0ccd\u0ca6\u0cae\u0ccd"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0c85\u0cb9\u0ca8\u0ccd\u0ca4\u0cbe\u0ca6\u0cbf \u0cb0\u0cb9\u0cbf\u0ca4\u0c82 \u0cb6\u0c95\u0ccd\u0ca4\u0cbf \u0cb8\u0cb9\u0cbf\u0ca4\u0c82 <br/> \u0c86\u0ca8\u0ca8\u0ccd\u0ca6\u0ca6\u0c82 \u0ca4\u0cae\u0cc7\u0c95 \u0ca6\u0ca8\u0ccd\u0ca4\u0cae\u0ccd"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0ca4\u0ccd\u0cb0\u0cbf\u0caa\u0cc1\u0cb0 \u0cb5\u0ca7\u0cbe\u0cb0\u0ccd\u0ca5\u0c82 \u0cb6\u0cbf\u0cb5\u0cc7\u0ca8 - <br/> \u0ca4\u0ccd\u0cb0\u0ccd\u0caf\u0cae\u0ccd\u0cac\u0c95\u0cc7\u0ca8\u0cbe\u0cb0\u0ccd\u0c9a\u0cbf\u0ca4\u0c82 <br/> \u0c89\u0caa\u0ca8\u0cbf\u0cb7\u0ca4\u0ccd \u0caa\u0ccd\u0cb0\u0ca4\u0cbf\u0caa\u0cbe\u0ca6\u0cbf\u0ca4\u0c82 <br/> \u0c89\u0cae\u0cbe \u0cae\u0cb9\u0cc7\u0cb6\u0ccd\u0cb5\u0cb0 \u0cb8\u0cc1\u0ca4\u0cae\u0ccd <br/> \u0c95\u0caa\u0cbf\u0cb2 \u0cb5\u0cb8\u0cbf\u0cb7\u0ccd\u0ca0\u0cbe\u0ca6\u0cbf \u0ca8\u0ca4\u0c82 <br/> \u0c95\u0ca8\u0ccd\u0c9c\u0c9c\u0cbe\u0ca6\u0cbf\u0cad\u0cbf\u0cb0\u0cc0\u0ca1\u0cbf\u0ca4\u0c82 <br/> \u0c95\u0caa\u0cbf\u0cb2\u0c82 \u0c95\u0cc3\u0cb7\u0ccd\u0ca3 \u0caa\u0cc2\u0c9c\u0cbf\u0ca4\u0c82 <br/> \u0c95\u0cb0\u0cbf \u0cb5\u0ca6\u0ca8 \u0cb8\u0cc1-\u0cb6\u0ccb\u0cad\u0cbf\u0ca4\u0cae\u0ccd"}, {"M": "\u0cae\u0ca7\u0ccd\u0caf\u0cae\u0c95\u0cbe\u0cb2 \u0cb8\u0cbe\u0cb9\u0cbf\u0ca4\u0ccd\u0caf\u0cae\u0ccd", "T": "\u0cb8\u0cc1\u0caa\u0cb0\u0ccd\u0ca3 \u0cb5\u0cbe\u0cb9 \u0cb8\u0cc7\u0cb5\u0cbf\u0ca4\u0c82 <br/> \u0cb8\u0cc1\u0cb0 \u0c97\u0cc1\u0cb0\u0cc1 \u0c97\u0cc1\u0cb9 \u0cad\u0cbe\u0cb5\u0cbf\u0ca4\u0c82 <br/> \u0c95\u0caa\u0cbf\u0ca4\u0ccd\u0ca5\u0cbe\u0cae\u0ccd\u0cb0 \u0caa\u0ca8\u0cb8 \u0c9c\u0cae\u0ccd\u0cac\u0cc2 - <br/> \u0c95\u0ca6\u0cb2\u0cc0 \u0cab\u0cb2 \u0cad\u0c95\u0ccd\u0cb7\u0cbf\u0ca4\u0cae\u0ccd"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d2e\u0d39\u0d3e \u0d17\u0d23 \u0d2a\u0d24\u0d3f\u0d02 \u0d35\u0d28\u0d4d\u0d26\u0d47 <br/> \u0d2e\u0d3e\u0d27\u0d35\u0d3e\u0d26\u0d4d\u0d2f\u0d2e\u0d30 \u0d2c\u0d43\u0d28\u0d4d\u0d26\u0d2e\u0d4d"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d05\u0d39\u0d28\u0d4d\u0d24\u0d3e\u0d26\u0d3f \u0d30\u0d39\u0d3f\u0d24\u0d02 \u0d36\u0d15\u0d4d\u0d24\u0d3f \u0d38\u0d39\u0d3f\u0d24\u0d02 <br/> \u0d06\u0d28\u0d28\u0d4d\u0d26\u0d26\u0d02 \u0d24\u0d2e\u0d47\u0d15 \u0d26\u0d28\u0d4d\u0d24\u0d2e\u0d4d"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d24\u0d4d\u0d30\u0d3f\u0d2a\u0d41\u0d30 \u0d35\u0d27\u0d3e\u0d30\u0d4d\u0d25\u0d02 \u0d36\u0d3f\u0d35\u0d47\u0d28 - <br/> \u0d24\u0d4d\u0d30\u0d4d\u0d2f\u0d2e\u0d4d\u0d2c\u0d15\u0d47\u0d28\u0d3e\u0d30\u0d4d\u0d1a\u0d3f\u0d24\u0d02 <br/> \u0d09\u0d2a\u0d28\u0d3f\u0d37\u0d24\u0d4d \u0d2a\u0d4d\u0d30\u0d24\u0d3f\u0d2a\u0d3e\u0d26\u0d3f\u0d24\u0d02 <br/> \u0d09\u0d2e\u0d3e \u0d2e\u0d39\u0d47\u0d36\u0d4d\u0d35\u0d30 \u0d38\u0d41\u0d24\u0d2e\u0d4d <br/> \u0d15\u0d2a\u0d3f\u0d32 \u0d35\u0d38\u0d3f\u0d37\u0d4d\u0d20\u0d3e\u0d26\u0d3f \u0d28\u0d24\u0d02 <br/> \u0d15\u0d28\u0d4d\u0d1c\u0d1c\u0d3e\u0d26\u0d3f\u0d2d\u0d3f\u0d30\u0d40\u0d21\u0d3f\u0d24\u0d02 <br/> \u0d15\u0d2a\u0d3f\u0d32\u0d02 \u0d15\u0d43\u0d37\u0d4d\u0d23 \u0d2a\u0d42\u0d1c\u0d3f\u0d24\u0d02 <br/> \u0d15\u0d30\u0d3f \u0d35\u0d26\u0d28 \u0d38\u0d41-\u0d36\u0d4b\u0d2d\u0d3f\u0d24\u0d2e\u0d4d"}, {"M": "\u0d2e\u0d27\u0d4d\u0d2f\u0d2e\u0d15\u0d3e\u0d32 \u0d38\u0d3e\u0d39\u0d3f\u0d24\u0d4d\u0d2f\u0d2e\u0d4d", "T": "\u0d38\u0d41\u0d2a\u0d30\u0d4d\u0d23 \u0d35\u0d3e\u0d39 \u0d38\u0d47\u0d35\u0d3f\u0d24\u0d02 <br/> \u0d38\u0d41\u0d30 \u0d17\u0d41\u0d30\u0d41 \u0d17\u0d41\u0d39 \u0d2d\u0d3e\u0d35\u0d3f\u0d24\u0d02 <br/> \u0d15\u0d2a\u0d3f\u0d24\u0d4d\u0d25\u0d3e\u0d2e\u0d4d\u0d30 \u0d2a\u0d28\u0d38 \u0d1c\u0d2e\u0d4d\u0d2c\u0d42 - <br/> \u0d15\u0d26\u0d32\u0d40 \u0d2b\u0d32 \u0d2d\u0d15\u0d4d\u0d37\u0d3f\u0d24\u0d2e\u0d4d"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u092e\u0939\u093e \u0917\u0923 \u092a\u0924\u093f\u0902 \u0935\u0928\u094d\u0926\u0947 <br/> \u092e\u093e\u0927\u0935\u093e\u0926\u094d\u092f\u092e\u0930 \u092c\u0943\u0928\u094d\u0926\u092e\u094d"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0905\u0939\u0928\u094d\u0924\u093e\u0926\u093f \u0930\u0939\u093f\u0924\u0902 \u0936\u0915\u094d\u0924\u093f \u0938\u0939\u093f\u0924\u0902 <br/> \u0906\u0928\u0928\u094d\u0926\u0926\u0902 \u0924\u092e\u0947\u0915 \u0926\u0928\u094d\u0924\u092e\u094d"}, {"M": "\u091a\u0930\u0923\u092e\u094d", "T": "\u0924\u094d\u0930\u093f\u092a\u0941\u0930 \u0935\u0927\u093e\u0930\u094d\u0925\u0902 \u0936\u093f\u0935\u0947\u0928 - <br/> \u0924\u094d\u0930\u094d\u092f\u092e\u094d\u092c\u0915\u0947\u0928\u093e\u0930\u094d\u091a\u093f\u0924\u0902 <br/> \u0909\u092a\u0928\u093f\u0937\u0924\u094d \u092a\u094d\u0930\u0924\u093f\u092a\u093e\u0926\u093f\u0924\u0902 <br/> \u0909\u092e\u093e \u092e\u0939\u0947\u0936\u094d\u0935\u0930 \u0938\u0941\u0924\u092e\u094d <br/> \u0915\u092a\u093f\u0932 \u0935\u0938\u093f\u0937\u094d\u0920\u093e\u0926\u093f \u0928\u0924\u0902 <br/> \u0915\u0928\u094d\u091c\u091c\u093e\u0926\u093f\u092d\u093f\u0930\u0940\u0921\u093f\u0924\u0902 <br/> \u0915\u092a\u093f\u0932\u0902 \u0915\u0943\u0937\u094d\u0923 \u092a\u0942\u091c\u093f\u0924\u0902 <br/> \u0915\u0930\u093f \u0935\u0926\u0928 \u0938\u0941-\u0936\u094b\u092d\u093f\u0924\u092e\u094d"}, {"M": "\u092e\u0927\u094d\u092f\u092e\u0915\u093e\u0932 \u0938\u093e\u0939\u093f\u0924\u094d\u092f\u092e\u094d", "T": "\u0938\u0941\u092a\u0930\u094d\u0923 \u0935\u093e\u0939 \u0938\u0947\u0935\u093f\u0924\u0902 <br/> \u0938\u0941\u0930 \u0917\u0941\u0930\u0941 \u0917\u0941\u0939 \u092d\u093e\u0935\u093f\u0924\u0902 <br/> \u0915\u092a\u093f\u0924\u094d\u0925\u093e\u092e\u094d\u0930 \u092a\u0928\u0938 \u091c\u092e\u094d\u092c\u0942 - <br/> \u0915\u0926\u0932\u0940 \u092b\u0932 \u092d\u0915\u094d\u0937\u093f\u0924\u092e\u094d"}]}], "L": "l", "lyricsref": [{"links": [{"N": "guru-guha.blogspot.com", "L": "http://guru-guha.blogspot.com/2008/04/dikshitar-kriti-maha-ganapatim-vande.html"}, {"N": "www.medieval.org", "L": "http://www.medieval.org/music/world/carnatic/lyrics/TKG/mahaganapatim_vande.html"}]}]}