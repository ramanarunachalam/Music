35\u0c28"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c38\u0c30\u0c4d\u0c35\u0c47\u0c36\u0c4d\u0c35\u0c30 \u0c15\u0c30\u0c41\u0c23\u0c3e\u0c15\u0c30 \u0c2e\u0c42\u0c30\u0c4d\u0c24\u0c47 \u0c38\u0c3e\u0c2e\u0c17\u0c3e\u0c28 \u0c2a\u0c4d\u0c30\u0c3f\u0c2f \u0c35\u0c47\u0c26 \u0c2a\u0c42\u0c30\u0c4d\u0c24\u0c47 <br/> \u0c2a\u0c30\u0c2e\u0c47\u0c36\u0c4d\u0c35\u0c30 \u0c17\u0c02\u0c17\u0c3e\u0c27\u0c30 \u0c15\u0c40\u0c30\u0c4d\u0c24\u0c47 \u0c2a\u0c24\u0c3f\u0c24 \u0c2a\u0c3e\u0c35\u0c28 \u0c36\u0c4d\u0c30\u0c40 \u0c2a\u0c36\u0c41\u0c2a\u0c24\u0c47"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cae\u0cb9\u0cbe\u0ca6\u0cc7\u0cb5 \u0cb6\u0cbf\u0cb5 \u0cb6\u0cae\u0ccd\u0cad\u0ccb \u0cae\u0cbe\u0cb0\u0c95\u0ccb\u0c9f\u0cbf \u0cb8\u0cc1\u0ca8\u0ccd\u0ca6\u0cb0 \u0caa\u0ccd\u0cb0\u0cad\u0ccb \u0cb6\u0ccd\u0cb0\u0cc0"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cb8\u0cb9\u0cb8\u0ccd\u0cb0\u0c95\u0ccb\u0c9f\u0cbf \u0c9c\u0ca8 \u0caa\u0cbe\u0cb2\u0ca8 \u0cb8\u0cbe\u0ca7\u0cc1 \u0cb8\u0cae\u0ccd\u0cb0\u0c95\u0ccd\u0cb7\u0ca3 \u0caa\u0cbe\u0cb5\u0ca8"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0cb8\u0cb0\u0ccd\u0cb5\u0cc7\u0cb6\u0ccd\u0cb5\u0cb0 \u0c95\u0cb0\u0cc1\u0ca3\u0cbe\u0c95\u0cb0 \u0cae\u0cc2\u0cb0\u0ccd\u0ca4\u0cc7 \u0cb8\u0cbe\u0cae\u0c97\u0cbe\u0ca8 \u0caa\u0ccd\u0cb0\u0cbf\u0caf \u0cb5\u0cc7\u0ca6 \u0caa\u0cc2\u0cb0\u0ccd\u0ca4\u0cc7 <br/> \u0caa\u0cb0\u0cae\u0cc7\u0cb6\u0ccd\u0cb5\u0cb0 \u0c97\u0c82\u0c97\u0cbe\u0ca7\u0cb0 \u0c95\u0cc0\u0cb0\u0ccd\u0ca4\u0cc7 \u0caa\u0ca4\u0cbf\u0ca4 \u0caa\u0cbe\u0cb5\u0ca8 \u0cb6\u0ccd\u0cb0\u0cc0 \u0caa\u0cb6\u0cc1\u0caa\u0ca4\u0cc7"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d2e\u0d39\u0d3e\u0d26\u0d47\u0d35 \u0d36\u0d3f\u0d35 \u0d36\u0d2e\u0d4d\u0d2d\u0d4b \u0d2e\u0d3e\u0d30\u0d15\u0d4b\u0d1f\u0d3f \u0d38\u0d41\u0d28\u0d4d\u0d26\u0d30 \u0d2a\u0d4d\u0d30\u0d2d\u0d4b \u0d36\u0d4d\u0d30\u0d40"}, {"M": "\u0d