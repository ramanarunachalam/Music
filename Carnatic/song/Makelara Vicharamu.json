AgarAja girISa vinuta"}]}, {"L": "Tamil", "text": [{"M": "\u0baa\u0bb2\u0bcd\u0bb2\u0bb5\u0bbf", "T": "\u0bae\u0bbe\u0b95\u0bc7\u0bb2\u0bb0\u0bbe \u0bb5\u0bbf\u0b9a\u0bbe\u0bb0\u0bae\u0bc1 <br/> \u0bae\u0bb0\u0bc1\u0b95\u0ba9\u0bcd\u0ba9 \u0bb6\u0bcd\u0bb0\u0bc0 \u0bb0\u0bbe\u0bae \u0b9a\u0ba8\u0bcd\u0ba4\u0bcd\u0bb0"}, {"M": "\u0b85\u0ba9\u0bc1\u0baa\u0bb2\u0bcd\u0bb2\u0bb5\u0bbf", "T": "\u0b9a\u0bbe\u0b95\u0bc7\u0ba4 \u0bb0\u0bbe\u0b9c \u0b95\u0bc1\u0bae\u0bbe\u0bb0 <br/> \u0b9a\u0ba4\u0bcd-\u0baa\u0b95\u0bcd\u0ba4 \u0bae\u0ba8\u0bcd\u0ba4\u0bbe\u0bb0 \u0bb6\u0bcd\u0bb0\u0bc0 \u0b95\u0bb0"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd", "T": "\u0b9c\u0ba4 \u0b95\u0bc2\u0bb0\u0bcd\u0b9a\u0bbf \u0ba8\u0bbe\u0b9f\u0b95 \u0b9a\u0bc2\u0ba4\u0bcd\u0bb0\u0bae\u0bc1\u0ba9\u0bc1 <br/> \u0b9c\u0b95\u0bae\u0bc6\u0bb2\u0bcd\u0bb2 \u0bae\u0bc6\u0b9a\u0bcd\u0b9a\u0b95 \u0b95\u0bb0\u0bae\u0bc1\u0ba9\u0ba9\u0bbf\u0b9f\u0bbf <br/> \u0b95\u0ba4\u0bbf \u0ba4\u0baa\u0bcd\u0baa\u0b95 \u0b86\u0b9f\u0bbf\u0ba9\u0bcd\u0b9a\u0bc6\u0ba4\u0bb5\u0bc1 \u0b9a\u0bc1\u0bae\u0bc0 <br/> \u0ba8\u0ba4 \u0ba4\u0bcd\u0baf\u0bbe\u0b95\u0bb0\u0bbe\u0b9c \u0b95\u0bbf\u0bb0\u0bc0\u0b9a \u0bb5\u0bbf\u0ba9\u0bc1\u0ba4"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c2e\u0c3e\u0c15\u0c47\u0c32\u0c30\u0c3e \u0c35\u0c3f\u0c1a\u0c3e\u0c30\u0c2e\u0c41 <br/> \u0c2e\u0c30\u0c41\u0c15\u0c28\u0c4d\u0c28 \u0c36\u0c4d\u0c30\u0c40 \u0c30\u0c3e\u0c2e \u0c1a\u0c28\u0c4d\u0c26\u0c4d\u0c30"}, {"M": "\u0c05\u0c28\u0c41\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c38\u0c3e\u0c15\u0c47\u0c24 \u0c30\u0c3e\u0c1c \u0c15\u0c41\u0c2e\u0c3e\u0c30 <br/> \u0c38\u0c26\u0c4d-\u0c2d\u0c15\u0c4d\u0c24 \u0c2e\u0c28\u0c4d\u0c26\u0c3e\u0c30 \u0c36\u0c4d\u0c30\u0c40 \u0c15\u0c30"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c1c\u0c24 \u0c15\u0c42\u0c30\u0c4d\u0c1a\u0c3f \u0c28\u0c3e\u0c1f\u0c15 \u0c38\u0c42\u0c24\u0c4d\u0c30\u0c2e\u0c41\u0c28\u0c41 <br/> \u0c1c\u0c17\u0c2e\u0c46\u0c32\u0c4d\u0c32 \u0c2e\u0c46\u0c1a\u0c4d\u0c1a\u0c17 \u0c15\u0c30\u0c2e\u0c41\u0c28\u0c28\u0c3f\u0c21\u0c3f <br/> \u0c17\u0c24\u0c3f \u0c24\u0c2a\u0c4d\u0c2a\u0c15 \u0c06\u0c21\u0c3f\u0c28\u0c4d\u0c1a\u0c46\u0c26\u0c35\u0c41 \u0c38\u0c41\u0c2e\u0c40 <br/> \u0c28\u0c24 \u0c24\u0c4d\u0c2f\u0c3e\u0c17\u0c30\u0c3e\u0c1c \u0c17\u0c3f\u0c30\u0c40\u0c36 \u0c35\u0c3f\u0c28\u0c41\u0c24"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cae\u0cbe\u0c95\u0cc7\u0cb2\u0cb0\u0cbe \u0cb5\u0cbf\u0c9a\u0cbe\u0cb0\u0cae\u0cc1 <br/> \u0cae\u0cb0\u0cc1\u0c95\u0ca8\u0ccd\u0ca8 \u0cb6\u0ccd\u0cb0\u0cc0 \u0cb0\u0cbe\u0cae \u0c9a\u0ca8\u0ccd\u0ca6\u0ccd\u0cb0"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cb8\u0cbe\u0c95\u0cc7\u0ca4 \u0cb0\u0cbe\u0c9c \u0c95\u0cc1\u0cae\u0cbe\u0cb0 <br/> \u0cb8\u0ca6\u0ccd-\u0cad\u0c95\u0ccd\u0ca4 \u0cae\u0ca8\u0ccd\u0ca6\u0cbe\u0cb0 \u0cb6\u0ccd\u0cb0\u0cc0 \u0c95\u0cb0"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0c9c\u0ca4 \u0c95\u0cc2\u0cb0\u0ccd\u0c9a\u0cbf \u0ca8\u0cbe\u0c9f\u0c95 \u0cb8\u0cc2\u0ca4\u0ccd\u0cb0\u0cae\u0cc1\u0ca8\u0cc1 <br/> \u0c9c\u0c97\u0cae\u0cc6\u0cb2\u0ccd\u0cb2 \u0cae\u0cc6\u0c9a\u0ccd\u0c9a\u0c97 \u0c95\u0cb0\u0cae\u0cc1\u0ca8\u0ca8\u0cbf\u0ca1\u0cbf <br/> \u0c97\u0ca4\u0cbf \u0ca4\u0caa\u0ccd\u0caa\u0c95 \u0c86\u0ca1\u0cbf\u0ca8\u0ccd\u0c9a\u0cc6\u0ca6\u0cb5\u0cc1 \u0cb8\u0cc1\u0cae\u0cc0 <br/> \u0ca8\u0ca4 \u0ca4\u0ccd\u0caf\u0cbe\u0c97\u0cb0\u0cbe\u0c9c \u0c97\u0cbf\u0cb0\u0cc0\u0cb6 \u0cb5\u0cbf\u0ca8\u0cc1\u0ca4"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d2e\u0d3e\u0d15\u0d47\u0d32\u0d30\u0d3e \u0d35\u0d3f\u0d1a\u0d3e\u0d30\u0d2e\u0d41 <br/> \u0d2e\u0d30\u0d41\u0d15\u0d28\u0d4d\u0d28 \u0d36\u0d4d\u0d30\u0d40 \u0d30\u0d3e\u0d2e \u0d1a\u0d28\u0d4d\u0d26\u0d4d\u0d30"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d38\u0d3e\u0d15\u0d47\u0d24 \u0d30\u0d3e\u0d1c \u0d15\u0d41\u0d2e\u0d3e\u0d30 <br/> \u0d38\u0d26\u0d4d-\u0d2d\u0d15\u0d4d\u0d24 \u0d2e\u0d28\u0d4d\u0d26\u0d3e\u0d30 \u0d36\u0d4d\u0d30\u0d40 \u0d15\u0d30"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d1c\u0d24 \u0d15\u0d42\u0d30\u0d4d\u0d1a\u0d3f \u0d28\u0d3e\u0d1f\u0d15 \u0d38\u0d42\u0d24\u0d4d\u0d30\u0d2e\u0d41\u0d28\u0d41 <br/> \u0d1c\u0d17\u0d2e\u0d46\u0d32\u0d4d\u0d32 \u0d2e\u0d46\u0d1a\u0d4d\u0d1a\u0d17 \u0d15\u0d30\u0d2e\u0d41\u0d28\u0d28\u0d3f\u0d21\u0d3f <br/> \u0d17\u0d24\u0d3f \u0d24\u0d2a\u0d4d\u0d2a\u0d15 \u0d06\u0d21\u0d3f\u0d28\u0d4d\u0d1a\u0d46\u0d26\u0d35\u0d41 \u0d38\u0d41\u0d2e\u0d40 <br/> \u0d28\u0d24 \u0d24\u0d4d\u0d2f\u0d3e\u0d17\u0d30\u0d3e\u0d1c \u0d17\u0d3f\u0d30\u0d40\u0d36 \u0d35\u0d3f\u0d28\u0d41\u0d24"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u092e\u093e\u0915\u0947\u0932\u0930\u093e \u0935\u093f\u091a\u093e\u0930\u092e\u0941 <br/> \u092e\u0930\u0941\u0915\u0928\u094d\u0928 \u0936\u094d\u0930\u0940 \u0930\u093e\u092e \u091a\u0928\u094d\u0926\u094d\u0930"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0938\u093e\u0915\u0947\u0924 \u0930\u093e\u091c \u0915\u0941\u092e\u093e\u0930 <br/> \u0938\u0926\u094d-\u092d\u0915\u094d\u0924 \u092e\u0928\u094d\u0926\u093e\u0930 \u0936\u094d\u0930\u0940 \u0915\u0930"}, {"M": "\u091a\u0930\u0923\u092e\u094d", "T": "\u091c\u0924 \u0915\u0942\u0930\u094d\u091a\u093f \u0928\u093e\u091f\u0915 \u0938\u0942\u0924\u094d\u0930\u092e\u0941\u0928\u0941 <br/> \u091c\u0917\u092e\u0947\u0932\u094d\u0932 \u092e\u0947\u091a\u094d\u091a\u0917 \u0915\u0930\u092e\u0941\u0928\u0928\u093f\u0921\u093f <br/> \u0917\u0924\u093f \u0924\u092a\u094d\u092a\u0915 \u0906\u0921\u093f\u0928\u094d\u091a\u0947\u0926\u0935\u0941 \u0938\u0941\u092e\u0940 <br/> \u0928\u0924 \u0924\u094d\u092f\u093e\u0917\u0930\u093e\u091c \u0917\u093f\u0930\u0940\u0936 \u0935\u093f\u0928\u0941\u0924"}]}], "L": "l", "lyricsref": [{"links": [{"N": "thyagaraja-vaibhavam.blogspot.com", "L": "http://thyagaraja-vaibhavam.blogspot.c