": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c2e\u0c28\u0c38\u0c3e \u0c0e\u0c1f\u0c41\u0c32\u0c4b\u0c30\u0c4d\u0c24\u0c41\u0c28\u0c47 \u0c28\u0c3e \u0c2e\u0c28\u0c35\u0c3f \u0c1a\u0c47\u0c15\u0c4a\u0c28\u0c35\u0c47 \u0c13"}, {"M": "\u0c05\u0c28\u0c41\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c26\u0c3f\u0c28-\u0c15\u0c30 \u0c15\u0c41\u0c32 \u0c2d\u0c42\u0c37\u0c23\u0c41\u0c28\u0c3f \u0c26\u0c40\u0c28\u0c41\u0c21\u0c35\u0c48 \u0c2d\u0c1c\u0c28 \u0c1c\u0c47\u0c38\u0c3f <br/> \u0c26\u0c3f\u0c28\u0c2e\u0c41 \u0c17\u0c21\u0c41\u0c2a\u0c41\u0c2e\u0c28\u0c3f\u0c28 \u0c28\u0c40\u0c35\u0c41 \u0c35\u0c3f\u0c28\u0c35\u0c26\u0c47\u0c32 \u0c17\u0c41\u0c23 \u0c35\u0c3f\u0c39\u0c40\u0c28"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c15\u0c32\u0c3f\u0c32\u0c4b \u0c30\u0c3e\u0c1c\u0c38 \u0c24\u0c3e\u0c2e\u0c38 \u0c17\u0c41\u0c23\u0c2e\u0c41\u0c32\u0c41 \u0c15\u0c32 \u0c35\u0c3e\u0c30\u0c3f \u0c1a\u0c46\u0c32\u0c3f\u0c2e\u0c3f <br/> \u0c15\u0c32\u0c38\u0c3f \u0c2e\u0c46\u0c32\u0c38\u0c3f \u0c24\u0c3f\u0c30\u0c41\u0c17\u0c41\u0c1a\u0c41 \u0c2e\u0c30\u0c3f \u0c15\u0c3e\u0c32\u0c2e\u0c41 \u0c17\u0c21\u0c2a\u0c15\u0c28\u0c47 <br/> \u0c38\u0c41\u0c32\u0c2d\u0c2e\u0c41\u0c17\u0c3e \u0c15\u0c21 \u0c24\u0c47\u0c30\u0c28\u0c41 \u0c38\u0c42\u0c1a\u0c28\u0c32\u0c28\u0c41 \u0c24\u0c46\u0c32\u0c3f\u0c2f \u0c1c\u0c47\u0c2f\u0c41 <br/> \u0c07\u0c32\u0c28\u0c41 \u0c24\u0c4d\u0c2f\u0c3e\u0c17\u0c30\u0c3e\u0c1c\u0c41 \u0c2e\u0c3e\u0c1f \u0c35\u0c3f\u0c28\u0c35\u0c26\u0c47\u0c32 \u0c17\u0c41\u0c23 \u0c35\u0c3f\u0c39\u0c40\u0c28"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cae\u0ca8\u0cb8\u0cbe \u0c8e\u0c9f\u0cc1\u0cb2\u0ccb\u0cb0\u0ccd\u0ca4\u0cc1\u0ca8\u0cc7 \u0ca8\u0cbe \u0cae\u0ca8\u0cb5\u0cbf \u0c9a\u0cc7\u0c95\u0cca\u0ca8\u0cb5\u0cc7 \u0c93"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0ca6\u0cbf\u0ca8-\u0c95\u0cb0 \u0c95\u0cc1\u0cb2 \u0cad\u0cc2\u0cb7\u0ca3\u0cc1\u0ca8\u0cbf \u0ca6\u0cc0\u0ca8\u0cc1\u0ca1\u0cb5\u0cc8 \u0cad\u0c9c\u0ca8 \u0c9c\u0cc7\u0cb8\u0cbf <br/> \u0ca6\u0cbf\u0ca8\u0cae\u0cc1 \u0c97\u0ca1\u0cc1\u0caa\u0cc1\u0cae\u0ca8\u0cbf\u0ca8 \u0ca8\u0cc0\u0cb5\u0cc1 \u0cb5\u0cbf\u0ca8\u0cb5\u0ca6\u0cc7\u0cb2 \u0c97\u0cc1\u0ca3 \u0cb5\u0cbf\u0cb9\u0cc0\u0ca8"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0c95\u0cb2\u0cbf\u0cb2\u0ccb \u0cb0\u0cbe\u0c9c\u0cb8 \u0ca4\u0cbe\u0cae\u0cb8 \u0c97\u0cc1\u0ca3\u0cae\u0cc1\u0cb2\u0cc1 \u0c95\u0cb2 \u0cb5\u0cbe\u0cb0\u0cbf \u0c9a\u0cc6\u0cb2\u0cbf\u0cae\u0cbf <br/> \u0c95\u0cb2\u0cb8\u0cbf \u0cae\u0cc6\u0cb2\u0cb8\u0cbf \u0ca4\u0cbf\u0cb0\u0cc1\u0c97\u0cc1\u0c9a\u0cc1 \u0cae\u0cb0\u0cbf \u0c95\u0cbe\u0cb2\u0cae\u0cc1 \u0c97\u0ca1\u0caa\u0c95\u0ca8\u0cc7 <br/> \u0cb8\u0cc1\u0cb2\u0cad\u0cae\u0cc1\u0c97\u0cbe \u0c95\u0ca1 \u0ca4\u0cc7\u0cb0\u0ca8\u0cc1 \u0cb8\u0cc2\u0c9a\u0ca8\u0cb2\u0ca8\u0cc1 \u0ca4\u0cc6\u0cb2\u0cbf\u0caf \u0c9c\u0cc7\u0caf\u0cc1 <br/> \u0c87\u0cb2\u0ca8\u0cc1 \u0ca4\u0ccd\u0caf\u0cbe\u0c97\u0cb0\u0cbe\u0c9c\u0cc1 \u0cae\u0cbe\u0c9f \u0cb5\u0cbf\u0ca8\u0cb5\u0ca6\u0cc7\u0cb2 \u0c97\u0cc1\u0ca3 \u0cb5\u0cbf\u0cb9\u0cc0\u0ca8"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d2e\u0d28\u0d38\u0d3e \u0d0e\u0d1f\u0d41\u0d32\u0d4b\u0d30\u0d4d\u0d24\u0d41\u0d28\u0d47 \u0d28\u0d3e \u0d2e\u0d28\u0d35\u0d3f \u0d1a\u0d47\u0d15\u0d4a\u0d28\u0d35\u0d47 \u0d13"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d26\u0d3f\u0d28-\u0d15\u0d30 \u0d15\u0d41\u0d32 \u0d2d\u0d42\u0d37\u0d23\u0d41\u0d28\u0d3f \u0d26\u0d40\u0d28\u0d41\u0d21\u0d35\u0d48 \u0d2d\u0d1c\u0d28 \u0d1c\u0d47\u0d38\u0d3f <br/> \u0d26\u0d3f\u0d28\u0d2e\u0d41 \u0d17\u0d21\u0d41\u0d2a\u0d41\u0d2e\u0d28\u0d3f\u0d28 \u0d28\u0d40\u0d35\u0d41 \u0d35\u0d3f\u0d28\u0d35\u0d26\u0d47\u0d32 \u0d17\u0d41\u0d23 \u0d35\u0d3f\u0d39\u0d40\u0d28"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d15\u0d32\u0d3f\u0d32\u0d4b \u0d30\u0d3e\u0d1c\u0d38 \u0d24\u0d3e\u0d2e\u0d38 \u0d17\u0d41\u0d23\u0d2e\u0d41\u0d32\u0d41 \u0d15\u0d32 \u0d35\u0d3e\u0d30\u0d3f \u0d1a\u0d46\u0d32\u0d3f\u0d2e\u0d3f <br/> \u0d15\u0d32\u0d38\u0d3f \u0d2e\u0d46\u0d32\u0d38\u0d3f \u0d24\u0d3f\u0d30\u0d41\u0d17\u0d41\u0d1a\u0d41 \u0d2e\u0d30\u0d3f \u0d15\u0d3e\u0d32\u0d2e\u0d41 \u0d17\u0d21\u0d2a\u0d15\u0d28\u0d47 <br/> \u0d38\u0d41\u0d32\u0d2d\u0d2e\u0d41\u0d17\u0d3e \u0d15\u0d21 \u0d24\u0d47\u0d30\u0d28\u0d41 \u0d38\u0d42\u0d1a\u0d28\u0d32\u0d28\u0d41 \u0d24\u0d46\u0d32\u0d3f\u0d2f \u0d1c\u0d47\u0d2f\u0d41 <br/> \u0d07\u0d32\u0d28\u0d41 \u0d24\u0d4d\u0d2f\u0d3e\u0d17\u0d30\u0d3e\u0d1c\u0d41 \u0d2e\u0d3e\u0d1f \u0d35\u0d3f\u0d28\u0d35\u0d26\u0d47\u0d32 \u0d17\u0d41\u0d23 \u0d35\u0d3f\u0d39\u0d40\u0d28"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u092e\u0928\u0938\u093e \u090f\u091f\u0941\u0932\u094b\u0930\u094d\u0924\u0941\u0928\u0947 \u0928\u093e \u092e\u0928\u0935\u093f \u091a\u0947\u0915\u094b\u0928\u0935\u0947 \u0913"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0926\u093f\u0928-\u0915\u0930 \u0915\u0941\u0932 \u092d\u0942\u0937\u0923\u0941\u0928\u093f \u0926\u0940\u0928\u0941\u0921\u0935\u0948 \u092d\u091c\u0928 \u091c\u0947\u0938\u093f <br/> \u0926\u093f\u0928\u092e\u0941 \u0917\u0921\u0941\u092a\u0941\u092e\u0928\u093f\u0928 \u0928\u0940\u0935\u0941 \u0935\u093f\u0928\u0935\u0926\u0947\u0932 \u0917\u0941\u0923 \u0935\u093f\u0939\u0940\u0928"}, {"M": "\u091a\u0930\u0923\u092e\u094d", "T": "\u0915\u0932\u093f\u0932\u094b \u0930\u093e\u091c\u0938 \u0924\u093e\u092e\u0938 \u0917\u0941\u0923\u092e\u0941\u0932\u0941 \u0915\u0932 \u0935\u093e\u0930\u093f \u091a\u0947\u0932\u093f\u092e\u093f <br/> \u0915\u0932\u0938\u093f \u092e\u0947\u0932\u0938\u093f \u0924\u093f\u0930\u0941\u0917\u0941\u091a\u0941 \u092e\u0930\u093f \u0915\u093e\u0932\u092e\u0941 \u0917\u0921\u092a\u0915\u0928\u0947 <br/> \u0938\u0941\u0932\u092d\u092e\u0941\u0917\u093e \u0915\u0921 \u0924\u0947\u0930\u0928\u0941 \u0938\u0942\u091a\u0928\u0932\u0928\u0941 \u0924\u0947\u0932\u093f\u092f \u091c\u0947\u092f\u0941 <br/> \u0907\u0932\u0928\u0941 \u0924\u094d\u092f\u093e\u0917\u0930\u093e\u091c\u0941 \u092e\u093e\u091f \u0935\u093f\u0928\u0935\u0926\u0947\u0932 \u0917\u0941\u0923 \u0935\u093f\u0939\u0940\u0928"}]}], "L": "l", "lyricsref": [{"links": [{"N": "thyagaraja-vaibhavam.blogspot.com", "L": "http://thyagaraja-vaibhavam.blogspot.com/2007/04/thyagaraja-kriti-manasaa-etulorthunae.html"}, {"N": "www.karnatik.com", "L": "http://www.karnatik.com/c1486.shtml"}, {"N": "www.sangeetasudha.org", "L": "http://www.sangeetasudha.org/thyagaraja/m.html#MARK_MANASA"}, {"N": "www.shivkumar.org", "L": "http://www.shivkumar.org/music/manasayetu.htm"}]}]}