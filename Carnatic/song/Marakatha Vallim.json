0bb2\u0bbf\u0ba9\u0bc0\u0bae\u0bcd"}, {"M": "\u0b9a\u0bae\u0bb8\u0bcd\u0ba4\u0bbf \u0b9a\u0bb0\u0ba3\u0bae\u0bcd", "T": "\u0bb9\u0bb0\u0bbf\u0bb9\u0bcd\u0bb0\u0bc1\u0ba4\u0baf\u0bbe \u0bb5\u0bc7\u0b9a\u0bbf\u0ba9\u0bc0\u0bae\u0bcd \u0bae\u0bcb\u0bb9\u0bbf\u0ba9\u0bc0\u0bae\u0bcd <br/> \u0bb9\u0bb0\u0bbf\u0bb9\u0bb0 \u0baa\u0bc1\u0ba4\u0bcd\u0bb0 \u0b9c\u0ba9\u0ba9\u0bc0\u0bae\u0bcd \u0ba8\u0bb3\u0bbf\u0ba9\u0bc0\u0bae\u0bcd"}, {"M": "\u0bae\u0ba4\u0bcd\u0baf\u0bae\u0b95\u0bbe\u0bb2 \u0b9a\u0bbe\u0bb9\u0bbf\u0ba4\u0bcd\u0baf\u0bae\u0bcd", "T": "\u0b95\u0bcd\u0bb0\u0bc2\u0bb0 \u0ba4\u0bc8\u0ba4\u0bcd\u0baf\u0bbe\u0ba4\u0bbf \u0baa\u0bcd\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4 \u0bae\u0bb0\u0bcd\u0ba4\u0bcd\u0ba4\u0bbf\u0ba9\u0bc0\u0bae\u0bcd <br/> \u0b95\u0bc1\u0bb0\u0bc1 \u0b95\u0bc1\u0bb9\u0bbe\u0ba4\u0bbf \u0ba8\u0bc1\u0ba4 \u0bb5\u0bb9\u0bcd\u0ba9\u0bbf \u0bb5\u0bbe\u0b9a\u0bbf\u0ba9\u0bc0\u0bae\u0bcd"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c2e\u0c30\u0c15\u0c24 \u0c35\u0c32\u0c4d\u0c32\u0c40\u0c2e\u0c4d \u0c2e\u0c28\u0c38\u0c3e \u0c38\u0c4d\u0c2e\u0c30\u0c3e\u0c2e\u0c3f <br/> \u0c2e\u0c26\u0c28\u0c1c\u0c28\u0c15\u0c3e\u0c26\u0c3f \u0c26\u0c47\u0c35\u0c2a\u0c3e\u0c32\u0c3f\u0c28\u0c40\u0c2e\u0c4d"}, {"M": "\u0c38\u0c2e\u0c38\u0c4d\u0c24\u0c3f \u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c39\u0c30\u0c3f\u0c39\u0c43\u0c26\u0c2f\u0c3e \u0c35\u0c47\u0c36\u0c3f\u0c28\u0c40\u0c2e\u0c4d \u0c2e\u0c4b\u0c39\u0c3f\u0c28\u0c40\u0c2e\u0c4d <br/> \u0c39\u0c30\u0c3f\u0c39\u0c30 \u0c2a\u0c41\u0c24\u0c4d\u0c30 \u0c1c\u0c28\u0c28\u0c40\u0c2e\u0c4d \u0c28\u0c33\u0c3f\u0c28\u0c40\u0c2e\u0c4d"}, {"M": "\u0c2e\u0c27\u0c4d\u0c2f\u0c2e\u0c15\u0c3e\u0c32 \u0c38\u0c3e\u0c39\u0c3f\u0c24\u0c4d\u0c2f\u0c2e\u0c4d", "T": "\u0c15\u0c4d\u0c30\u0c42\u0c30 \u0c26\u0c48\u0c24\u0c4d\u0c2f\u0c3e\u0c26\u0c3f \u0c2c\u0c43\u0c28\u0c4d\u0c26 \u0c2e\u0c30\u0c4d\u0c26\u0c4d\u0c26\u0c3f\u0c28\u0c40\u0c2e\u0c4d <br/> \u0c17\u0c41\u0c30\u0c41 \u0c17\u0c41\u0c39\u0c3e\u0c26\u0c3f \u0c28\u0c41\u0c24 \u0c35\u0c39\u0c4d\u0c28\u0c3f \u0c35\u0c3e\u0c38\u0c3f\u0c28\u0c40\u0c2e\u0c4d"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cae\u0cb0\u0c95\u0ca4 \u0cb5\u0cb2\u0ccd\u0cb2\u0cc0\u0cae\u0ccd \u0cae\u0ca8\u0cb8\u0cbe \u0cb8\u0ccd\u0cae\u0cb0\u0cbe\u0cae\u0cbf <br/> \u0cae\u0ca6\u0ca8\u0c9c\u0ca8\u0c95\u0cbe\u0ca6\u0cbf \u0ca6\u0cc7\u0cb5\u0caa\u0cbe\u0cb2\u0cbf\u0ca8\u0cc0\u0cae\u0ccd"}, {"M": "\u0cb8\u0cae\u0cb8\u0ccd\u0ca4\u0cbf \u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0cb9\u0cb0\u0cbf\u0cb9\u0cc3\u0ca6\u0caf\u0cbe \u0cb5\u0cc7\u0cb6\u0cbf\u0ca8\u0cc0\u0cae\u0ccd \u0cae\u0ccb\u0cb9\u0cbf\u0ca8\u0cc0\u0cae\u0ccd <br/> \u0cb9\u0cb0\u0cbf\u0cb9\u0cb0 \u0caa\u0cc1\u0ca4\u0ccd\u0cb0 \u0c9c\u0ca8\u0ca8\u0cc0\u0cae\u0ccd \u0ca8\u0cb3\u0cbf\u0ca8\u0cc0\u0cae\u0ccd"}, {"M": "\u0cae\u0ca7\u0ccd\u0caf\u0cae\u0c95\u0cbe\u0cb2 \u0cb8\u0cbe\u0cb9\u0cbf\u0ca4\u0ccd\u0caf\u0cae\u0ccd", "T": "\u0c95\u0ccd\u0cb0\u0cc2\u0cb0 \u0ca6\u0cc8\u0ca4\u0ccd\u0caf\u0cbe\u0ca6\u0cbf \u0cac\u0cc3\u0ca8\u0ccd\u0ca6 \u0cae\u0cb0\u0ccd\u0ca6\u0ccd\u0ca6\u0cbf\u0ca8\u0cc0\u0cae\u0ccd <br/> \u0c97\u0cc1\u0cb0\u0cc1 \u0c97\u0cc1\u0cb9\u0cbe\u0ca6\u0cbf \u0ca8\u0cc1\u0ca4 \u0cb5\u0cb9\u0ccd\u0ca8\u0cbf \u0cb5\u0cbe\u0cb8\u0cbf\u0ca8\u0cc0\u0cae\u0ccd"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d2e\u0d30\u0d15\u0d24 \u0d35\u0d32\u0d4d\u0d32\u0d40\u0d2e\u0d4d \u0d2e\u0d28\u0d38\u0d3e \u0d38\u0d4d\u0d2e\u0d30\u0d3e\u0d2e\u0d3f <br/> \u0d2e\u0d26\u0d28\u0d1c\u0d28\u0d15\u0d3e\u0d26\u0d3f \u0d26\u0d47\u0d35\u0d2a\u0d3e\u0d32\u0d3f\u0d28\u0d40\u0d2e\u0d4d"}, {"M": "\u0d38\u0d2e\u0d38\u0d4d\u0d24\u0d3f \u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d39\u0d30\u0d3f\u0d39\u0d43\u0d26\u0d2f\u0d3e \u0d35\u0d47\u0d36\u0d3f\u0d28\u0d40\u0d2e\u0d4d \u0d2e\u0d4b\u0d39\u0d3f\u0d28\u0d40\u0d2e\u0d4d <br/> \u0d39\u0d30\u0d3f\u0d39\u0d30 \u0d2a\u0d41\u0d24\u0d4d\u0d30 \u0d1c\u0d28\u0d28\u0d40\u0d2e\u0d4d \u0d28\u0d33\u0d3f\u0d28\u0d40\u0d2e\u0d4d"}, {"M": "\u0d2e\u0d27\u0d4d\u0d2f\u0d2e\u0d15\u0d3e\u0d32 \u0d38\u0d3e\u0d39\u0d3f\u0d24\u0d4d\u0d2f\u0d2e\u0d4d", "T": "\u0d15\u0d4d\u0d30\u0d42\u0d30 \u0d26\u0d48\u0d24\u0d4d\u0d2f\u0d3e\u0d26\u0d3f \u0d2c\u0d43\u0d28\u0d4d\u0d26 \u0d2e\u0d30\u0d4d\u0d26\u0d4d\u0d26\u0d3f\u0d28\u0d40\u0d2e\u0d4d <br/> \u0d17\u0d41\u0d30\u0d41 \u0d17\u0d41\u0d39\u0d3e\u0d26\u0d3f \u0d28\u0d41\u0d24 \u0d35\u0d39\u0d4d\u0d28\u0d3f \u0d35\u0d3e\u0d38\u0d3f\u0d28\u0d40\u0d2e\u0d4d"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u092e\u0930\u0915\u0924 \u0935\u0932\u094d\u0932\u0940\u092e\u094d \u092e\u0928\u0938\u093e \u0938\u094d\u092e\u0930\u093e\u092e\u093f <br/> \u092e\u0926\u0928\u091c\u0928\u0915\u093e\u0926\u093f \u0926\u0947\u0935\u092a\u093e\u0932\u093f\u0928\u0940\u092e\u094d"}, {"M": "\u0938\u092e\u0938\u094d\u0924\u093f \u091a\u0930\u0923\u092e\u094d", "T": "\u0939\u0930\u093f\u0939\u0943\u0926\u092f\u093e \u0935\u0947\u0936\u093f\u0928\u0940\u092e\u094d \u092e\u094b\u0939\u093f\u0928\u0940\u092e\u094d <br/> \u0939\u0930\u093f\u0939\u0930 \u092a\u0941\u0924\u094d\u0930 \u091c\u0928\u0928\u0940\u092e\u094d \u0928\u0932\u093f\u0928\u0940\u092e\u094d"}, {"M": "\u092e\u0927\u094d\u092f\u092e\u0915\u093e\u0932 \u0938\u093e\u0939\u093f\u0924\u094d\u092f\u092e\u094d", "T": "\u0915\u094d\u0930\u0942\u0930 \u0926\u0948\u0924\u094d\u092f\u093e\u0926\u093f \u092c\u0943\u0928\u094d\u0926 \u092e\u0930\u094d\u0926\u094d\u0926\u093f\u0928\u0940\u092e\u094d <br/> \u0917\u0941\u0930\u0941 \u0917\u0941\u0939\u093e\u0926\u093f \u0928\u0941\u0924 \u0935\u0939\u094d\u0928\u093f \u0935\u093e\u0938\u093f\u0928\u0940\u092e\u094d"}]}], "L": "l", "lyricsref": [{"links": [{"N": "www.medieval.org", "L": "http://www.medieval.org/music/world/carnatic/lyrics/TKG/marakatavallim.html"}, {"N": "guru-guha.blogspot.com", "L": "http://guru-guha.blogspot.com/2008/04/dikshitar-kriti-marakata-valleem-raga.html"}, {"N": "www.karnatik.com", "L": "http: