"Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c2e\u0c30\u0c3f\u0c35\u0c46\u0c30\u0c46 \u0c26\u0c3f\u0c15\u0c4d\u0c15\u0c46\u0c35\u0c30\u0c2f\u0c4d\u0c2f \u0c30\u0c2e <br/> \u0c2e\u0c3e\u0c1f\u0c3f \u0c2e\u0c3e\u0c1f\u0c3f\u0c15\u0c3f\u0c28\u0c3f \u0c24\u0c46\u0c32\u0c41\u0c2a\u0c35\u0c32\u0c47\u0c28"}, {"M": "\u0c05\u0c28\u0c41\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c26\u0c30\u0c3f\u0c26\u0c3e\u0c2a\u0c41 \u0c32\u0c47\u0c28\u0c3f \u0c28\u0c3e \u0c1c\u0c3e\u0c32\u0c3f \u0c24\u0c46\u0c30\u0c4d\u0c1a\u0c3f <br/> \u0c26\u0c2f\u0c1a\u0c47\u0c38\u0c3f \u0c2c\u0c4d\u0c30\u0c4a\u0c1a\u0c47 \u0c26\u0c4a\u0c30 \u0c28\u0c40\u0c35\u0c41 \u0c15\u0c3e\u0c26"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c28\u0c3f\u0c28\u0c4d\u0c28\u0c41 \u0c1a\u0c3e\u0c32 \u0c28\u0c2e\u0c4d\u0c2e\u0c3f \u0c09\u0c28\u0c4d\u0c28\u0c35\u0c3e\u0c26\u0c28\u0c41\u0c1a\u0c41 <br/> \u0c28\u0c40 \u0c1b\u0c3f\u0c24\u0c4d\u0c24\u0c2e\u0c41\u0c28\u0c15\u0c47 \u0c24\u0c46\u0c32\u0c3f\u0c38\u0c3f \u0c09\u0c28\u0c4d\u0c21\u0c17\u0c3e <br/> \u0c38\u0c28\u0c4d\u0c28\u0c41\u0c24\u0c3e\u0c02\u0c17 \u0c36\u0c4d\u0c30\u0c40 \u0c35\u0c46\u0c02\u0c15\u0c1f\u0c46\u0c36 \u0c28\u0c40\u0c35\u0c41 <br/> \u0c28\u0c28\u0c4d\u0c28\u0c41 \u0c2c\u0c4d\u0c30\u0c4b\u0c35\u0c15\u0c2f\u0c41\u0c28\u0c4d\u0c26\u0c41\u0c24 \u0c28\u0c4d\u0c2f\u0c2f\u0c2e\u0c3e"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cae\u0cb0\u0cbf\u0cb5\u0cc6\u0cb0\u0cc6 \u0ca6\u0cbf\u0c95\u0ccd\u0c95\u0cc6\u0cb5\u0cb0\u0caf\u0ccd\u0caf \u0cb0\u0cae <br/> \u0cae\u0cbe\u0c9f\u0cbf \u0cae\u0cbe\u0c9f\u0cbf\u0c95\u0cbf\u0ca8\u0cbf \u0ca4\u0cc6\u0cb2\u0cc1\u0caa\u0cb5\u0cb2\u0cc7\u0ca8"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0ca6\u0cb0\u0cbf\u0ca6\u0cbe\u0caa\u0cc1 \u0cb2\u0cc7\u0ca8\u0cbf \u0ca8\u0cbe \u0c9c\u0cbe\u0cb2\u0cbf \u0ca4\u0cc6\u0cb0\u0ccd\u0c9a\u0cbf <br/> \u0ca6\u0caf\u0c9a\u0cc7\u0cb8\u0cbf \u0cac\u0ccd\u0cb0\u0cca\u0c9a\u0cc7 \u0ca6\u0cca\u0cb0 \u0ca8\u0cc0\u0cb5\u0cc1 \u0c95\u0cbe\u0ca6"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0ca8\u0cbf\u0ca8\u0ccd\u0ca8\u0cc1 \u0c9a\u0cbe\u0cb2 \u0ca8\u0cae\u0ccd\u0cae\u0cbf \u0c89\u0ca8\u0ccd\u0ca8\u0cb5\u0cbe\u0ca6\u0ca8\u0cc1\u0c9a\u0cc1 <br/> \u0ca8\u0cc0 \u0c9b\u0cbf\u0ca4\u0ccd\u0ca4\u0cae\u0cc1\u0ca8\u0c95\u0cc7 \u0ca4\u0cc6\u0cb2\u0cbf\u0cb8\u0cbf \u0c89\u0ca8\u0ccd\u0ca1\u0c97\u0cbe <br/> \u0cb8\u0ca8\u0ccd\u0ca8\u0cc1\u0ca4\u0cbe\u0c82\u0c97 \u0cb6\u0ccd\u0cb0\u0cc0 \u0cb5\u0cc6\u0c82\u0c95\u0c9f\u0cc6\u0cb6 \u0ca8\u0cc0\u0cb5\u0cc1 <br/> \u0ca8\u0ca8\u0ccd\u0ca8\u0cc1 \u0cac\u0ccd\u0cb0\u0ccb\u0cb5\u0c95\u0caf\u0cc1\u0ca8\u0ccd\u0ca6\u0cc1\u0ca4 \u0ca8\u0ccd\u0caf\u0caf\u0cae\u0cbe"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d2e\u0d30\u0d3f\u0d35\u0d46\u0d30\u0d46 \u0d26\u0d3f\u0d15\u0d4d\u0d15\u0d46\u0d35\u0d30\u0d2f\u0d4d\u0d2f \u0d30\u0d2e <br/> \u0d2e\u0d3e\u0d1f\u0d3f \u0d2e\u0d3e\u0d1f\u0d3f\u0d15\u0d3f\u0d28\u0d3f \u0d24\u0d46\u0d32\u0d41\u0d2a\u0d35\u0d32\u0d47\u0d28"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d26\u0d30\u0d3f\u0d26\u0d3e\u0d2a\u0d41 \u0d32\u0d47\u0d28\u0d3f \u0d28\u0d3e \u0d1c\u0d3e\u0d32\u0d3f \u0d24\u0d46\u0d30\u0d4d\u0d1a\u0d3f <br/> \u0d26\u0d2f\u0d1a\u0d47\u0d38\u0d3f \u0d2c\u0d4d\u0d30\u0d4a\u0d1a\u0d47 \u0d26\u0d4a\u0d30 \u0d28\u0d40\u0d35\u0d41 \u0d15\u0d3e\u0d26"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d28\u0d3f\u0d28\u0d4d\u0d28\u0d41 \u0d1a\u0d3e\u0d32 \u0d28\u0d2e\u0d4d\u0d2e\u0d3f \u0d09\u0d28\u0d4d\u0d28\u0d35\u0d3e\u0d26\u0d28\u0d41\u0d1a\u0d41 <br/> \u0d28\u0d40 \u0d1b\u0d3f\u0d24\u0d4d\u0d24\u0d2e\u0d41\u0d28\u0d15\u0d47 \u0d24\u0d46\u0d32\u0d3f\u0d38\u0d3f \u0d09\u0d28\u0d4d\u0d21\u0d17\u0d3e <br/> \u0d38\u0d28\u0d4d\u0d28\u0d41\u0d24\u0d3e\u0d02\u0d17 \u0d36\u0d4d\u0d30\u0d40 \u0d35\u0d46\u0d02\u0d15\u0d1f\u0d46\u0d36 \u0d28\u0d40\u0d35\u0d41 <br/> \u0d28\u0d28\u0d4d\u0d28\u0d41 \u0d2c\u0d4d\u0d30\u0d4b\u0d35\u0d15\u0d2f\u0d41\u0d28\u0d4d\u0d26\u0d41\u0d24 \u0d28\u0d4d\u0d2f\u0d2f\u0d2e\u0d3e"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u092e\u0930\u093f\u0935\u0947\u0930\u0947 \u0926\u093f\u0915\u094d\u0915\u0947\u0935\u0930\u092f\u094d\u092f \u0930\u092e <br/> \u092e\u093e\u091f\u093f \u092e\u093e\u091f\u093f\u0915\u093f\u0928\u093f \u0924\u0947\u0932\u0941\u092a\u0935\u0932\u0947\u0928"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0926\u0930\u093f\u0926\u093e\u092a\u0941 \u0932\u0947\u0928\u093f \u0928\u093e \u091c\u093e\u0932\u093f \u0924\u0947\u0930\u094d\u091a\u093f <br/> \u0926\u092f\u091a\u0947\u0938\u093f \u092c\u094d\u0930\u094b\u091a\u0947 \u0926\u094b\u0930 \u0928\u0940\u0935\u0941 \u0915\u093e\u0926"}, {"M": "\u091a\u0930\u0923\u092e\u094d", "T": "\u0928\u093f\u0928\u094d\u0928\u0941 \u091a\u093e\u0932 \u0928\u092e\u094d\u092e\u093f \u0909\u0928\u094d\u0928\u0935\u093e\u0926\u0928\u0941\u091a\u0941 <br/> \u0928\u0940 \u091b\u093f\u0924\u094d\u0924\u092e\u0941\u0928\u0915\u0947 \u0924\u0947\u0932\u093f\u0938\u093f \u0909\u0928\u094d\u0921\u0917\u093e <br/> \u0938\u0928\u094d\u0928\u0941\u0924\u093e\u0902\u0917 \u0936\u094d\u0930\u0940 \u0935\u0947\u0902\u0915\u091f\u0947\u0936 \u0928\u0940\u0935\u0941 <br/> \u0928\u0928\u094d\u0928\u0941 \u092c\u094d\u0930\u094b\u0935\u0915\u092f\u0941\u0928\u094d\u0926\u0941\u0924 \u0928\u094d\u092f\u092f\u092e\u093e"}]}], "L": "l", "lyricsref": [{"links": [{"N": "www.karnatik.com", "L": "http://www.karnatik.com/c1112.shtml"}]}]}