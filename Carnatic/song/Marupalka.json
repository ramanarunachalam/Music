95\u0bca\u0ba9\u0bcd\u0ba9 <br/> \u0ba4\u0bbe\u0bb0\u0bbf\u0ba9\u0bc6\u0bb0\u0bbf\u0b95\u0bbf \u0b9a\u0ba8\u0bcd\u0ba4\u0b9a\u0bbf\u0bb2\u0bcd\u0bb2\u0bbf\u0ba9\u0bcd- <br/> \u0b85\u0b9f\u0bcd\u0b9f\u0bbf \u0ba4\u0bcd\u0baf\u0bbe\u0b95\u0bb0\u0bbe\u0b9c \u0ba8\u0bc1\u0ba4 \u0bae\u0bbe\u0bb0\u0bc1"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c2e\u0c3e\u0c30\u0c41 \u0c2a\u0c32\u0c4d\u0c15\u0c17\u0c41\u0c28\u0c4d\u0c28\u0c3e\u0c35\u0c47\u0c2e\u0c3f\u0c30\u0c3e <br/> \u0c2e\u0c3e \u0c2e\u0c28\u0c4b-\u0c30\u0c2e\u0c23"}, {"M": "\u0c05\u0c28\u0c41\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c1c\u0c3e\u0c30 \u0c1a\u0c4b\u0c30 \u0c2d\u0c1c\u0c28 \u0c1c\u0c46\u0c38\u0c3f\u0c24\u0c3f\u0c28\u0c3e <br/> \u0c38\u0c3e\u0c15\u0c47\u0c24 \u0c38\u0c26\u0c28"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c26\u0c42\u0c30-\u0c2d\u0c3e\u0c30\u0c2e\u0c28\u0c4d\u0c26\u0c41 \u0c28\u0c3e \u0c39\u0c43\u0c26\u0c2f\u0c4d- <br/> \u0c06\u0c30\u0c35\u0c3f\u0c28\u0c4d\u0c26\u0c2e\u0c28\u0c4d\u0c26\u0c41 \u0c28\u0c46\u0c32\u0c15\u0c4a\u0c28\u0c4d\u0c28 <br/> \u0c26\u0c3e\u0c30\u0c3f\u0c28\u0c46\u0c30\u0c3f\u0c17\u0c3f \u0c38\u0c28\u0c4d\u0c24\u0c38\u0c3f\u0c32\u0c4d\u0c32\u0c3f\u0c28\u0c4d- <br/> \u0c05\u0c1f\u0c4d\u0c1f\u0c3f \u0c24\u0c4d\u0c2f\u0c3e\u0c17\u0c30\u0c3e\u0c1c \u0c28\u0c41\u0c24 \u0c2e\u0c3e\u0c30\u0c41"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cae\u0cbe\u0cb0\u0cc1 \u0caa\u0cb2\u0ccd\u0c95\u0c97\u0cc1\u0ca8\u0ccd\u0ca8\u0cbe\u0cb5\u0cc7\u0cae\u0cbf\u0cb0\u0cbe <br/> \u0cae\u0cbe \u0cae\u0ca8\u0ccb-\u0cb0\u0cae\u0ca3"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0c9c\u0cbe\u0cb0 \u0c9a\u0ccb\u0cb0 \u0cad\u0c9c\u0ca8 \u0c9c\u0cc6\u0cb8\u0cbf\u0ca4\u0cbf\u0ca8\u0cbe <br/> \u0cb8\u0cbe\u0c95\u0cc7\u0ca4 \u0cb8\u0ca6\u0ca8"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0ca6\u0cc2\u0cb0-\u0cad\u0cbe\u0cb0\u0cae\u0ca8\u0ccd\u0ca6\u0cc1 \u0ca8\u0cbe \u0cb9\u0cc3\u0ca6\u0caf\u0ccd- <br/> \u0c86\u0cb0\u0cb5\u0cbf\u0ca8\u0ccd\u0ca6\u0cae\u0ca8\u0ccd\u0ca6\u0cc1 \u0ca8\u0cc6\u0cb2\u0c95\u0cca\u0ca8\u0ccd\u0ca8 <br/> \u0ca6\u0cbe\u0cb0\u0cbf\u0ca8\u0cc6\u0cb0\u0cbf\u0c97\u0cbf \u0cb8\u0ca8\u0ccd\u0ca4\u0cb8\u0cbf\u0cb2\u0ccd\u0cb2\u0cbf\u0ca8\u0ccd- <br/> \u0c85\u0c9f\u0ccd\u0c9f\u0cbf \u0ca4\u0ccd\u0caf\u0cbe\u0c97\u0cb0\u0cbe\u0c9c \u0ca8\u0cc1\u0ca4 \u0cae\u0cbe\u0cb0\u0cc1"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d2e\u0d3e\u0d30\u0d41 \u0d2a\u0d32\u0d4d\u0d15\u0d17\u0d41\u0d28\u0d4d\u0d28\u0d3e\u0d35\u0d47\u0d2e\u0d3f\u0d30\u0d3e <br/> \u0d2e\u0d3e \u0d2e\u0d28\u0d4b-\u0d30\u0d2e\u0d23"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d1c\u0d3e\u0d30 \u0d1a\u0d4b\u0d30 \u0d2d\u0d1c\u0d28 \u0d1c\u0d46\u0d38\u0d3f\u0d24\u0d3f\u0d28\u0d3e <br/> \u0d38\u0d3e\u0d15\u0d47\u0d24 \u0d38\u0d26\u0d28"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d26\u0d42\u0d30-\u0d2d\u0d3e\u0d30\u0d2e\u0d28\u0d4d\u0d26\u0d41 \u0d28\u0d3e \u0d39\u0d43\u0d26\u0d2f\u0d4d- <br/> \u0d06\u0d30\u0d35\u0d3f\u0d28\u0d4d\u0d26\u0d2e\u0d28\u0d4d\u0d26\u0d41 \u0d28\u0d46\u0d32\u0d15\u0d4a\u0d28\u0d4d\u0d28 <br/> \u0d26\u0d3e\u0d30\u0d3f\u0d28\u0d46\u0d30\u0d3f\u0d17\u0d3f \u0d38\u0d28\u0d4d\u0d24\u0d38\u0d3f\u0d32\u0d4d\u0d32\u0d3f\u0d28\u0d4d- <br/> \u0d05\u0d1f\u0d4d\u0d1f\u0d3f \u0d24\u0d4d\u0d2f\u0d3e\u0d17\u0d30\u0d3e\u0d1c \u0d28\u0d41\u0d24 \u0d2e\u0d3e\u0d30\u0d41"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u092e\u093e\u0930\u0941 \u092a\u0932\u094d\u0915\u0917\u0941\u0928\u094d\u0928\u093e\u0935\u0947\u092e\u093f\u0930\u093e <br/> \u092e\u093e \u092e\u0928\u094b-\u0930\u092e\u0923"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u091c\u093e\u0930 \u091a\u094b\u0930 \u092d\u091c\u0928 \u091c\u0947\u0938\u093f\u0924\u093f\u0928\u093e <br/> \u0938\u093e\u0915\u0947\u0924 \u0938\u0926\u0928"}, {"M": "\u091a\u0930\u0923\u092e\u094d", "T": "\u0926\u0942\u0930-\u092d\u093e\u0930\u092e\u0928\u094d\u0926\u0941 \u0928\u093e \u0939\u0943\u0926\u092f\u094d- <br/> \u0906\u0930\u0935\u093f\u0928\u094d\u0926\u092e\u0928\u094d\u0926\u0941 \u0928\u0947\u0932\u0915\u094b\u0928\u094d\u0928 <br/> \u0926\u093e\u0930\u093f\u0928\u0947\u0930\u093f\u0917\u093f \u0938\u0928\u094d\u0924\u0938\u093f\u0932\u094d\u0932\u093f\u0928\u094d- <br/> \u0905\u091f\u094d\u091f\u093f \u0924\u094d\u092f\u093e\u0917\u0930\u093e\u091c \u0928\u0941\u0924 \u092e\u093e\u0930\u0941"}]}], "L": "l", "lyricsref": [{"links": [{"N": "thyagaraja-vaibhavam.blogspot.com", "L": "http://thyagaraja-vaibhavam.blogspot.com/2007/10/thyagaraja-kriti-maaru-balka-raga-sri.html"}, {"N": "www.karnatik.com", "L": "http://www.karnatik.com/c1281.shtml"}, {"N": "www.sangeetasudha.org", "L": "http://www.sangeetasudha.org/thyagaraja/m.html#MARK_MARUBALKA"}, {"N": "www.shivkumar.org", "L": "http://www.shivkumar.org/music/marubalka.htm"}]}]}