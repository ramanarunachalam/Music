khada nija bhAva rasika vara dAtA mahiSUra nAda nAlvaTi SrI <br/> krshNa rAjEndrara tAyE sadA pore mahite harikESa manOharE sadayE"}, {"M": "caraNam", "T": "SyAmE sakala bhuvana sArvabhaumE SaSi maNDala madyagE <br/> ma, ma pani dada papa magamapa ma ma nida masani dapa dada SyAmE <br/> nidanida dapapama papa nidapama gamapa nidama sanidapa manida SyAmE <br/> sa sa sa nidanisa nidapa magamapa mamama samagama pasanida ni <br/> nidani padani mapadani gamapadani samagama padani samagari sasanida pada SyAmE"}]}, {"L": "Tamil", "text": [{"M": "\u0baa\u0bb2\u0bcd\u0bb2\u0bb5\u0bbf", "T": "\u0bae\u0bbe\u0ba4\u0bc7 \u0bae\u0bb2\u0baf\u0ba4\u0bcd\u0bb5\u0b9c \u0baa\u0bbe\u0ba3\u0bcd\u0b9f\u0bcd\u0baf \u0b9a\u0bae\u0bcd\u0b9c\u0bbe\u0ba4\u0bc7 \u0bae\u0bbe\u0ba4\u0b99\u0bcd\u0b95 \u0bb5\u0ba4\u0ba9 \u0b95\u0bc1\u0bb9"}, {"M": "\u0b85\u0ba9\u0bc1\u0baa\u0bb2\u0bcd\u0bb2\u0bb5\u0bbf", "T": "\u0b9a\u0bbe\u0ba4\u0bcb\u0ba4\u0bb0\u0bbf \u0b9a\u0b99\u0bcd\u0b95\u0bb0\u0bbf \u0b9a\u0bbe\u0bae\u0bc1\u0ba3\u0bcd\u0b9f\u0bc7\u0bb6\u0bcd\u0bb5\u0bb0\u0bbf \u0b9a\u0ba8\u0bcd\u0ba4\u0bcd\u0bb0\u0b95\u0bb2\u0bbe\u0ba4\u0bb0\u0bbf \u0ba4\u0bbe\u0baf\u0bc7 \u0b95\u0bcc\u0bb0\u0bc0"}, {"M": "\u0bae\u0bc1\u0b95\u0bcd\u0ba4\u0bbe\u0baf\u0bbf \u0b9a\u0bbe\u0bb9\u0bbf\u0ba4\u0bcd\u0baf\u0bae\u0bcd", "T": "\u0ba4\u0ba4 \u0ba8\u0bbf\u0ba4\u0ba9\u0bbf \u0ba4\u0ba4\u0ba9\u0bbf\u0ba4 \u0ba4\u0ba9\u0bbf\u0baa\u0bae \u0ba4\u0ba4 \u0ba8\u0bbf\u0bb0\u0bbf\u0b9a\u0ba9\u0bbf \u0b9a\u0ba4\u0ba9\u0bbf\u0b9a \u0ba4\u0baa\u0baa\u0bae \u0ba4\u0ba4 \u0ba8\u0bbf\u0b95\u0bb0\u0bbf\u0ba9\u0bbf \u0bb0\u0bbf\u0b9a\u0ba9\u0bbf\u0ba4 \u0baa\u0ba9\u0bbf\u0ba4\u0bae \u0ba4\u0ba4 \u0bae\u0b95\u0bae\u0baa \u0bae\u0baa \u0ba4\u0ba4 \u0ba8\u0bbf\u0ba9\u0bbf \u0ba4\u0bae \u0ba4\u0ba4 \u0bb0\u0bbf\u0b9a\u0ba9\u0bbf\u0ba4 \u0ba8\u0bbf \u0ba4\u0ba4\u0bcd \u0b85 \u0bae\u0ba4\u0ba9\u0bbf\u0bae \u0ba8\u0bbf \u0ba4\u0ba4 \u0baa \u0ba4\u0ba4\u0bcd \u0b85 \u0ba8\u0bbf \u0ba4\u0ba4\u0bcd \u0b85 \u0b9a\u0ba4 \u0ba8\u0bbf\u0ba4 \u0bae\u0b95\u0bb0\u0bbf \u0b9a\u0ba9\u0bbf \u0ba4 \u0ba8\u0bbf\u0b9a\u0ba9\u0bbf\u0ba9\u0bbf \u0ba4\u0ba4 \u0baa\u0bae <br/> \u0ba4\u0bbe\u0ba4\u0bbe \u0b9a\u0b95\u0bb2 \u0b95\u0bb2\u0bbe \u0ba8\u0bbf\u0baa\u0bc1\u0ba3 \u0b9a\u0ba4\u0bc1\u0bb0 \u0ba4\u0bbe\u0ba4\u0bbe \u0b9a\u0bc1\u0bb2\u0baa \u0bb9\u0bcd\u0bb0\u0bcd\u0ba4\u0baf \u0bae\u0ba4\u0bc1\u0bb0 \u0bb5\u0b9a\u0ba9 <br/> \u0ba4\u0bbe\u0ba4\u0bbe \u0b9a\u0bb0\u0b9a \u0bb0\u0bc1\u0b9a\u0bbf\u0bb0\u0ba4\u0bb0 \u0bb8\u0bcd\u0bb5\u0bb0 \u0bb2\u0baf \u0b95\u0bc0\u0ba4 \u0b9a\u0bc1\u0b95\u0ba4 \u0ba8\u0bbf\u0b9c \u0baa\u0bbe\u0bb5 \u0bb0\u0b9a\u0bbf\u0b95 \u0bb5\u0bb0 \u0ba4\u0bbe\u0ba4\u0bbe \u0bae\u0bb9\u0bbf\u0b9a\u0bc2\u0bb0 \u0ba8\u0bbe\u0ba4 \u0ba8\u0bbe\u0bb2\u0bcd\u0bb5\u0b9f\u0bbf \u0bb6\u0bcd\u0bb0\u0bc0 <br/> \u0b95\u0bcd\u0bb0\u0bcd\u0bb7\u0bcd\u0ba3 \u0bb0\u0bbe\u0b9c\u0bc7\u0ba8\u0bcd\u0ba4\u0bcd\u0bb0\u0bb0 \u0ba4\u0bbe\u0baf\u0bc7 \u0b9a\u0ba4\u0bbe \u0baa\u0bca\u0bb0\u0bc6 \u0bae\u0bb9\u0bbf\u0ba4\u0bc6 \u0bb9\u0bb0\u0bbf\u0b95\u0bc7\u0b9a \u0bae\u0ba9\u0bcb\u0bb9\u0bb0\u0bc7 \u0b9a\u0ba4\u0baf\u0bc7"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd", "T": "\u0bb6\u0bcd\u0baf\u0bbe\u0bae\u0bc7 \u0b9a\u0b95\u0bb2 \u0baa\u0bc1\u0bb5\u0ba9 \u0b9a\u0bbe\u0bb0\u0bcd\u0bb5\u0baa\u0bcc\u0bae\u0bc7 \u0b9a\u0b9a\u0bbf \u0bae\u0ba3\u0bcd\u0b9f\u0bb2 \u0bae\u0ba4\u0bcd\u0baf\u0b95\u0bc7 <br/> \u0bae, \u0bae \u0baa\u0ba9\u0bbf \u0ba4\u0ba4 \u0baa\u0baa \u0bae\u0b95\u0bae\u0baa \u0bae \u0bae \u0ba8\u0bbf\u0ba4 \u0bae\u0b9a\u0ba9\u0bbf \u0ba4\u0baa \u0ba4\u0ba4 \u0bb6\u0bcd\u0baf\u0bbe\u0bae\u0bc7 <br/> \u0ba8\u0bbf\u0ba4\u0ba9\u0bbf\u0ba4 \u0ba4\u0baa\u0baa\u0bae \u0baa\u0baa \u0ba8\u0bbf\u0ba4\u0baa\u0bae \u0b95\u0bae\u0baa \u0ba8\u0bbf\u0ba4\u0bae \u0b9a\u0ba9\u0bbf\u0ba4\u0baa \u0bae\u0ba9\u0bbf\u0ba4 \u0bb6\u0bcd\u0baf\u0bbe\u0bae\u0bc7 <br/> \u0b9a \u0b9a \u0b9a \u0ba8\u0bbf\u0ba4\u0ba9\u0bbf\u0b9a \u0ba8\u0bbf\u0ba4\u0baa \u0bae\u0b95\u0bae\u0baa \u0bae\u0bae\u0bae \u0b9a\u0bae\u0b95\u0bae \u0baa\u0b9a\u0ba9\u0bbf\u0ba4 \u0ba8\u0bbf <br/> \u0ba8\u0bbf\u0ba4\u0ba9\u0bbf \u0baa\u0ba4\u0ba9\u0bbf \u0bae\u0baa\u0ba4\u0ba9\u0bbf \u0b95\u0bae\u0baa\u0ba4\u0ba9\u0bbf \u0b9a\u0bae\u0b95\u0bae \u0baa\u0ba4\u0ba9\u0bbf \u0b9a\u0bae\u0b95\u0bb0\u0bbf \u0b9a\u0b9a\u0ba9\u0bbf\u0ba4 \u0baa\u0ba4 \u0bb6\u0bcd\u0baf\u0bbe\u0bae\u0bc7"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c2e\u0c3e\u0c24\u0c47 \u0c2e\u0c32\u0c2f\u0c26\u0c4d\u0c35\u0c1c \u0c2a\u0c3e\u0c23\u0c4d\u0c21\u0c4d\u0c2f \u0c38\u0c2e\u0c4d\u0c1c\u0c3e\u0c24\u0c47 \u0c2e\u0c3e\u0c24\u0c02\u0c17 \u0c35\u0c26\u0c28 \u0c17\u0c41\u0c39"}, {"M": "\u0c05\u0c28\u0c41\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c36\u0c3e\u0c24\u0c4b\u0c27\u0c30\u0c3f \u0c36\u0c02\u0c15\u0c30\u0c3f \u0c1a\u0c3e\u0c2e\u0c41\u0c23\u0c4d\u0c21\u0c47\u0c36\u0c4d\u0c35\u0c30\u0c3f \u0c1a\u0c28\u0c4d\u0c26\u0c4d\u0c30\u0c15\u0c32\u0c3e\u0c27\u0c30\u0c3f \u0c24\u0c3e\u0c2f\u0c47 \u0c17\u0c4c\u0c30\u0c40"}, {"M": "\u0c2e\u0c41\u0c15\u0c4d\u0c24\u0c3e\u0c2f\u0c3f \u0c38\u0c3e\u0c39\u0c3f\u0c24\u0c4d\u0c2f\u0c2e\u0c4d", "T": "\u0c26\u0c26 \u0c28\u0c3f\u0c26\u0c28\u0c3f \u0c26\u0c26\u0c28\u0c3f\u0c26 \u0c26\u0c28\u0c3f\u0c2a\u0c2e \u0c26\u0c26 \u0c28\u0c3f\u0c30\u0c3f\u0c38\u0c28\u0c3f \u0c38\u0c26\u0c28\u0c3f\u0c38 \u0c26\u0c2a\u0c2a\u0c2e \u0c26\u0c26 \u0c28\u0c3f\u0c17\u0c30\u0c3f\u0c28\u0c3f \u0c30\u0c3f\u0c38\u0c28\u0c3f\u0c26 \u0c2a\u0c28\u0c3f\u0c26\u0c2e \u0c26\u0c26 \u0c2e\u0c17\u0c2e\u0c2a \u0c2e\u0c2a \u0c26\u0c26 \u0c28\u0c3f\u0c28\u0c3f \u0c26\u0c2e \u0c26\u0c26 \u0c30\u0c3f\u0c38\u0c28\u0c3f\u0c26 \u0c28\u0c3f \u0c26\u0c26\u0c4d \u0c05 \u0c2e\u0c26\u0c28\u0c3f\u0c2e \u0c28\u0c3f \u0c26\u0c26 \u0c2a \u0c26\u0c26\u0c4d \u0c05 \u0c28\u0c3f \u0c26\u0c26\u0c4d \u0c05 \u0c38\u0c26 \u0c28\u0c3f\u0c26 \u0c2e\u0c17\u0c30\u0c3f \u0c38\u0c28\u0c3f \u0c26 \u0c28\u0c3f\u0c38\u0c28\u0c3f\u0c28\u0c3f \u0c26\u0c26 \u0c2a\u0c2e <br/> \u0c26\u0c3e\u0c24\u0c3e \u0c38\u0c15\u0c32 \u0c15\u0c32\u0c3e \u0c28\u0c3f\u0c2a\u0c41\u0c23 \u0c1a\u0c24\u0c41\u0c30 \u0c26\u0c3e\u0c24\u0c3e \u0c38\u0c41\u0c32\u0c2d \u0c39\u0c4d\u0c30\u0c4d\u0c26\u0c2f \u0c2e\u0c27\u0c41\u0c30 \u0c35\u0c1a\u0c28 <br/> \u0c26\u0c3e\u0c24\u0c3e \u0c38\u0c30\u0c38 \u0c30\u0c41\u0c1a\u0c3f\u0c30\u0c24\u0c30 \u0c38\u0c4d\u0c35\u0c30 \u0c32\u0c2f \u0c17\u0c40\u0c24 \u0c38\u0c41\u0c16\u0c26 \u0c28\u0c3f\u0c1c \u0c2d\u0c3e\u0c35 \u0c30\u0c38\u0c3f\u0c15 \u0c35\u0c30 \u0c26\u0c3e\u0c24\u0c3e \u0c2e\u0c39\u0c3f\u0c36\u0c42\u0c30 \u0c28\u0c3e\u0c26 \u0c28\u0c3e\u0c32\u0c4d\u0c35\u0c1f\u0c3f \u0c36\u0c4d\u0c30\u0c40 <br/> \u0c15\u0c4d\u0c30\u0c4d\u0c37\u0c4d\u0c23 \u0c30\u0c3e\u0c1c\u0c47\u0c28\u0c4d\u0c26\u0c4d\u0c30\u0c30 \u0c24\u0c3e\u0c2f\u0c47 \u0c38\u0c26\u0c3e \u0c2a\u0c4a\u0c30\u0c46 \u0c2e\u0c39\u0c3f\u0c24\u0c46 \u0c39\u0c30\u0c3f\u0c15\u0c47\u0c36 \u0c2e\u0c28\u0c4b\u0c39\u0c30\u0c47 \u0c38\u0c26\u0c2f\u0c47"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c36\u0c4d\u0c2f\u0c3e\u0c2e\u0c47 \u0c38\u0c15\u0c32 \u0c2d\u0c41\u0c35\u0c28 \u0c38\u0c3e\u0c30\u0c4d\u0c35\u0c2d\u0c4c\u0c2e\u0c47 \u0c36\u0c36\u0c3f \u0c2e\u0c23\u0c4d\u0c21\u0c32 \u0c2e\u0c26\u0c4d\u0c2f\u0c17\u0c47 <br/> \u0c2e, \u0c2e \u0c2a\u0c28\u0c3f \u0c26\u0c26 \u0c2a\u0c2a \u0c2e\u0c17\u0c2e\u0c2a \u0c2e \u0c2e \u0c28\u0c3f\u0c26 \u0c2e\u0c38\u0c28\u0c3f \u0c26\u0c2a \u0c26\u0c26 \u0c36\u0c4d\u0c2f\u0c3e\u0c2e\u0c47 <br/> \u0c28\u0c3f\u0c26\u0c28\u0c3f\u0c26 \u0c26\u0c2a\u0c2a\u0c2e \u0c2a\u0c2a \u0c28\u0c3f\u0c26\u0c2a\u0c2e \u0c17\u0c2e\u0c2a \u0c28\u0c3f\u0c26\u0c2e \u0c38\u0c28\u0c3f\u0c26\u0c2a \u0c2e\u0c28\u0c3f\u0c26 \u0c36\u0c4d\u0c2f\u0c3e\u0c2e\u0c47 <br/> \u0c38 \u0c38 \u0c38 \u0c28\u0c3f\u0c26\u0c28\u0c3f\u0c38 \u0c28\u0c3f\u0c26\u0c2a \u0c2e\u0c17\u0c2e\u0c2a \u0c2e\u0c2e\u0c2e \u0c38\u0c2e\u0c17\u0c2e \u0c2a\u0c38\u0c28\u0c3f\u0c26 \u0c28\u0c3f <br/> \u0c28\u0c3f\u0c26\u0c28\u0c3f \u0c2a\u0c26\u0c28\u0c3f \u0c2e\u0c2a\u0c26\u0c28\u0c3f \u0c17\u0c2e\u0c2a\u0c26\u0c28\u0c3f \u0c38\u0c2e\u0c17\u0c2e \u0c2a\u0c26\u0c28\u0c3f \u0c38\u0c2e\u0c17\u0c30\u0c3f \u0c38\u0c38\u0c28\u0c3f\u0c26 \u0c2a\u0c26 \u0c36\u0c4d\u0c2f\u0c3e\u0c2e\u0c47"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cae\u0cbe\u0ca4\u0cc7 \u0cae\u0cb2\u0caf\u0ca6\u0ccd\u0cb5\u0c9c \u0caa\u0cbe\u0ca3\u0ccd\u0ca1\u0ccd\u0caf \u0cb8\u0cae\u0ccd\u0c9c\u0cbe\u0ca4\u0cc7 \u0cae\u0cbe\u0ca4\u0c82\u0c97 \u0cb5\u0ca6\u0ca8 \u0c97\u0cc1\u0cb9"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cb6\u0cbe\u0ca4\u0ccb\u0ca7\u0cb0\u0cbf \u0cb6\u0c82\u0c95\u0cb0\u0cbf \u0c9a\u0cbe\u0cae\u0cc1\u0ca3\u0ccd\u0ca1\u0cc7\u0cb6\u0ccd\u0cb5\u0cb0\u0cbf \u0c9a\u0ca8\u0ccd\u0ca6\u0ccd\u0cb0\u0c95\u0cb2\u0cbe\u0ca7\u0cb0\u0cbf \u0ca4\u0cbe\u0caf\u0cc7 \u0c97\u0ccc\u0cb0\u0cc0"}, {"M": "\u0cae\u0cc1\u0c95\u0ccd\u0ca4\u0cbe\u0caf\u0cbf \u0cb8\u0cbe\u0cb9\u0cbf\u0ca4\u0ccd\u0caf\u0cae\u0ccd", "T": "\u0ca6\u0ca6 \u0ca8\u0cbf\u0ca6\u0ca8\u0cbf \u0ca6\u0ca6\u0ca8\u0cbf\u0ca6 \u0ca6\u0ca8\u0cbf\u0caa\u0cae \u0ca6\u0ca6 \u0ca8\u0cbf\u0cb0\u0cbf\u0cb8\u0ca8\u0cbf \u0cb8\u0ca6\u0ca8\u0cbf\u0cb8 \u0ca6\u0caa\u0caa\u0cae \u0ca6\u0ca6 \u0ca8\u0cbf\u0c97\u0cb0\u0cbf\u0ca8\u0cbf \u0cb0\u0cbf\u0cb8\u0ca8\u0cbf\u0ca6 \u0caa\u0ca8\u0cbf\u0ca6\u0cae \u0ca6\u0ca6 \u0cae\u0c97\u0cae\u0caa \u0cae\u0caa \u0ca6\u0ca6 \u0ca8\u0cbf\u0ca8\u0cbf \u0ca6\u0cae \u0ca6\u0ca6 \u0cb0\u0cbf\u0cb8\u0ca8\u0cbf\u0ca6 \u0ca8\u0cbf \u0ca6\u0ca6\u0ccd \u0c85 \u0cae\u0ca6\u0ca8\u0cbf\u0cae \u0ca8\u0cbf \u0ca6\u0ca6 \u0caa \u0ca6\u0ca6\u0ccd \u0c85 \u0ca8\u0cbf \u0ca6\u0ca6\u0ccd \u0c85 \u0cb8\u0ca6 \u0ca8\u0cbf\u0ca6 \u0cae\u0c97\u0cb0\u0cbf \u0cb8\u0ca8\u0cbf \u0ca6 \u0ca8\u0cbf\u0cb8\u0ca8\u0cbf\u0ca8\u0cbf \u0ca6\u0ca6 \u0caa\u0cae <br/> \u0ca6\u0cbe\u0ca4\u0cbe \u0cb8\u0c95\u0cb2 \u0c95\u0cb2\u0cbe \u0ca8\u0cbf\u0caa\u0cc1\u0ca3 \u0c9a\u0ca4\u0cc1\u0cb0 \u0ca6\u0cbe\u0ca4\u0cbe \u0cb8\u0cc1\u0cb2\u0cad \u0cb9\u0ccd\u0cb0\u0ccd\u0ca6\u0caf \u0cae\u0ca7\u0cc1\u0cb0 \u0cb5\u0c9a\u0ca8 <br/> \u0ca6\u0cbe\u0ca4\u0cbe \u0cb8\u0cb0\u0cb8 \u0cb0\u0cc1\u0c9a\u0cbf\u0cb0\u0ca4\u0cb0 \u0cb8\u0ccd\u0cb5\u0cb0 \u0cb2\u0caf \u0c97\u0cc0\u0ca4 \u0cb8\u0cc1\u0c96\u0ca6 \u0ca8\u0cbf\u0c9c \u0cad\u0cbe\u0cb5 \u0cb0\u0cb8\u0cbf\u0c95 \u0cb5\u0cb0 \u0ca6\u0cbe\u0ca4\u0cbe \u0cae\u0cb9\u0cbf\u0cb6\u0cc2\u0cb0 \u0ca8\u0cbe\u0ca6 \u0ca8\u0cbe\u0cb2\u0ccd\u0cb5\u0c9f\u0cbf \u0cb6\u0ccd\u0cb0\u0cc0 <br/> \u0c95\u0ccd\u0cb0\u0ccd\u0cb7\u0ccd\u0ca3 \u0cb0\u0cbe\u0c9c\u0cc7\u0ca8\u0ccd\u0ca6\u0ccd\u0cb0\u0cb0 \u0ca4\u0cbe\u0caf\u0cc7 \u0cb8\u0ca6\u0cbe \u0caa\u0cca\u0cb0\u0cc6 \u0cae\u0cb9\u0cbf\u0ca4\u0cc6 \u0cb9\u0cb0\u0cbf\u0c95\u0cc7\u0cb6 \u0cae\u0ca8\u0ccb\u0cb9\u0cb0\u0cc7 \u0cb8\u0ca6\u0caf\u0cc7"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0cb6\u0ccd\u0caf\u0cbe\u0cae\u0cc7 \u0cb8\u0c95\u0cb2 \u0cad\u0cc1\u0cb5\u0ca8 \u0cb8\u0cbe\u0cb0\u0ccd\u0cb5\u0cad\u0ccc\u0cae\u0cc7 \u0cb6\u0cb6\u0cbf \u0cae\u0ca3\u0ccd\u0ca1\u0cb2 \u0cae\u0ca6\u0ccd\u0caf\u0c97\u0cc7 <br/> \u0cae, \u0cae \u0caa\u0ca8\u0cbf \u0ca6\u0ca6 \u0caa\u0caa \u0cae\u0c97\u0cae\u0caa \u0cae \u0cae \u0ca8\u0cbf\u0ca6 \u0cae\u0cb8\u0ca8\u0cbf \u0ca6\u0caa \u0ca6\u0ca6 \u0cb6\u0ccd\u0caf\u0cbe\u0cae\u0cc7 <br/> \u0ca8\u0cbf\u0ca6\u0ca8\u0cbf\u0ca6 \u0ca6\u0caa\u0caa\u0cae \u0caa\u0caa \u0ca8\u0cbf\u0ca6\u0caa\u0cae \u0c97\u0cae\u0caa \u0ca8\u0cbf\u0ca6\u0cae \u0cb8\u0ca8\u0cbf\u0ca6\u0caa \u0cae\u0ca8\u0cbf\u0ca6 \u0cb6\u0ccd\u0caf\u0cbe\u0cae\u0cc7 <br/> \u0cb8 \u0cb8 \u0cb8 \u0ca8\u0cbf\u0ca6\u0ca8\u0cbf\u0cb8 \u0ca8\u0cbf\u0ca6\u0caa \u0cae\u0c97\u0cae\u0caa \u0cae\u0cae\u0cae \u0cb8\u0cae\u0c97\u0cae \u0caa\u0cb8\u0ca8\u0cbf\u0ca6 \u0ca8\u0cbf <br/> \u0ca8\u0cbf\u0ca6\u0ca8\u0cbf \u0caa\u0ca6\u0ca8\u0cbf \u0cae\u0caa\u0ca6\u0ca8\u0cbf \u0c97\u0cae\u0caa\u0ca6\u0ca8\u0cbf \u0cb8\u0cae\u0c97\u0cae \u0caa\u0ca6\u0ca8\u0cbf \u0cb8\u0cae\u0c97\u0cb0\u0cbf \u0cb8\u0cb8\u0ca8\u0cbf\u0ca6 \u0caa\u0ca6 \u0cb6\u0ccd\u0caf\u0cbe\u0cae\u0cc7"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d2e\u0d3e\u0d24\u0d47 \u0d2e\u0d32\u0d2f\u0d26\u0d4d\u0d35\u0d1c \u0d2a\u0d3e\u0d23\u0d4d\u0d21\u0d4d\u0d2f \u0d38\u0d2e\u0d4d\u0d1c\u0d3e\u0d24\u0d47 \u0d2e\u0d3e\u0d24\u0d02\u0d17 \u0d35\u0d26\u0d28 \u0d17\u0d41\u0d39"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d36\u0d3e\u0d24\u0d4b\u0d27\u0d30\u0d3f \u0d36\u0d02\u0d15\u0d30\u0d3f \u0d1a\u0d3e\u0d2e\u0d41\u0d23\u0d4d\u0d21\u0d47\u0d36\u0d4d\u0d35\u0d30\u0d3f \u0d1a\u0d28\u0d4d\u0d26\u0d4d\u0d30\u0d15\u0d32\u0d3e\u0d27\u0d30\u0d3f \u0d24\u0d3e\u0d2f\u0d47 \u0d17\u0d4c\u0d30\u0d40"}, {"M": "\u0d2e\u0d41\u0d15\u0d4d\u0d24\u0d3e\u0d2f\u0d3f \u0d38\u0d3e\u0d39\u0d3f\u0d24\u0d4d\u0d2f\u0d2e\u0d4d", "T": "\u0d26\u0d26 \u0d28\u0d3f\u0d26\u0d28\u0d3f \u0d26\u0d26\u0d28\u0d3f\u0d26 \u0d26\u0d28\u0d3f\u0d2a\u0d2e \u0d26\u0d26 \u0d28\u0d3f\u0d30\u0d3f\u0d38\u0d28\u0d3f \u0d38\u0d26\u0d28\u0d3f\u0d38 \u0d26\u0d2a\u0d2a\u0d2e \u0d26\u0d26 \u0d28\u0d3f\u0d17\u0d30\u0d3f\u0d28\u0d3f \u0d30\u0d3f\u0d38\u0d28\u0d3f\u0d26 \u0d2a\u0d28\u0d3f\u0d26\u0d2e \u0d26\u0d26 \u0d2e\u0d17\u0d2e\u0d2a \u0d2e\u0d2a \u0d26\u0d26 \u0d28\u0d3f\u0d28\u0d3f \u0d26\u0d2e \u0d26\u0d26 \u0d30\u0d3f\u0d38\u0d28\u0d3f\u0d26 \u0d28\u0d3f \u0d26\u0d26\u0d4d \u0d05 \u0d2e\u0d26\u0d28\u0d3f\u0d2e \u0d28\u0d3f \u0d26\u0d26 \u0d2a \u0d26\u0d26\u0d4d \u0d05 \u0d28\u0d3f \u0d26\u0d26\u0d4d \u0d05 \u0d38\u0d26 \u0d28\u0d3f\u0d26 \u0d2e\u0d17\u0d30\u0d3f \u0d38\u0d28\u0d3f \u0d26 \u0d28\u0d3f\u0d38\u0d28\u0d3f\u0d28\u0d3f \u0d26\u0d26 \u0d2a\u0d2e <br/> \u0d26\u0d3e\u0d24\u0d3e \u0d38\u0d15\u0d32 \u0d15\u0d32\u0d3e \u0d28\u0d3f\u0d2a\u0d41\u0d23 \u0d1a\u0d24\u0d41\u0d30 \u0d26\u0d3e\u0d24\u0d3e \u0d38\u0d41\u0d32\u0d2d \u0d39\u0d4d\u0d30\u0d4d\u0d26\u0d2f \u0d2e\u0d27\u0d41\u0d30 \u0d35\u0d1a\u0d28 <br/> \u0d26\u0d3e\u0d24\u0d3e \u0d38\u0d30\u0d38 \u0d30\u0d41\u0d1a\u0d3f\u0d30\u0d24\u0d30 \u0d38\u0d4d\u0d35\u0d30 \u0d32\u0d2f \u0d17\u0d40\u0d24 \u0d38\u0d41\u0d16\u0d26 \u0d28\u0d3f\u0d1c \u0d2d\u0d3e\u0d35 \u0d30\u0d38\u0d3f\u0d15 \u0d35\u0d30 \u0d26\u0d3e\u0d24\u0d3e \u0d2e\u0d39\u0d3f\u0d36\u0d42\u0d30 \u0d28\u0d3e\u0d26 \u0d28\u0d3e\u0d32\u0d4d\u0d35\u0d1f\u0d3f \u0d36\u0d4d\u0d30\u0d40 <br/> \u0d15\u0d4d\u0d30\u0d4d\u0d37\u0d4d\u0d23 \u0d30\u0d3e\u0d1c\u0d47\u0d28\u0d4d\u0d26\u0d4d\u0d30\u0d30 \u0d24\u0d3e\u0d2f\u0d47 \u0d38\u0d26\u0d3e \u0d2a\u0d4a\u0d30\u0d46 \u0d2e\u0d39\u0d3f\u0d24\u0d46 \u0d39\u0d30\u0d3f\u0d15\u0d47\u0d36 \u0d2e\u0d28\u0d4b\u0d39\u0d30\u0d47 \u0d38\u0d26\u0d2f\u0d47"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d36\u0d4d\u0d2f\u0d3e\u0d2e\u0d47 \u0d38\u0d15\u0d32 \u0d2d\u0d41\u0d35\u0d28 \u0d38\u0d3e\u0d30\u0d4d\u0d35\u0d2d\u0d4c\u0d2e\u0d47 \u0d36\u0d36\u0d3f \u0d2e\u0d23\u0d4d\u0d21\u0d32 \u0d2e\u0d26\u0d4d\u0d2f\u0d17\u0d47 <br/> \u0d2e, \u0d2e \u0d2a\u0d28\u0d3f \u0d26\u0d26 \u0d2a\u0d2a \u0d2e\u0d17\u0d2e\u0d2a \u0d2e \u0d2e \u0d28\u0d3f\u0d26 \u0d2e\u0d38\u0d28\u0d3f \u0d26\u0d2a \u0d26\u0d26 \u0d36\u0d4d\u0d2f\u0d3e\u0d2e\u0d47 <br/> \u0d28\u0d3f\u0d26\u0d28\u0d3f\u0d26 \u0d26\u0d2a\u0d2a\u0d2e \u0d2a\u0d2a \u0d28\u0d3f\u0d26\u0d2a\u0d2e \u0d17\u0d2e\u0d2a \u0d28\u0d3f\u0d26\u0d2e \u0d38\u0d28\u0d3f\u0d26\u0d2a \u0d2e\u0d28\u0d3f\u0d26 \u0d36\u0d4d\u0d2f\u0d3e\u0d2e\u0d47 <br/> \u0d38 \u0d38 \u0d38 \u0d28\u0d3f\u0d26\u0d28\u0d3f\u0d38 \u0d28\u0d3f\u0d26\u0d2a \u0d2e\u0d17\u0d2e\u0d2a \u0d2e\u0d2e\u0d2e \u0d38\u0d2e\u0d17\u0d2e \u0d2a\u0d38\u0d28\u0d3f\u0d26 \u0d28\u0d3f <br/> \u0d28\u0d3f\u0d26\u0d28\u0d3f \u0d2a\u0d26\u0d28\u0d3f \u0d2e\u0d2a\u0d26\u0d28\u0d3f \u0d17\u0d2e\u0d2a\u0d26\u0d28\u0d3f \u0d38\u0d2e\u0d17\u0d2e \u0d2a\u0d26\u0d28\u0d3f \u0d38\u0d2e\u0d17\u0d30\u0d3f \u0d38\u0d38\u0d28\u0d3f\u0d26 \u0d2a\u0d26 \u0d36\u0d4d\u0d2f\u0d3e\u0d2e\u0d47"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u092e\u093e\u0924\u0947 \u092e\u0932\u092f\u0926\u094d\u0935\u091c \u092a\u093e\u0923\u094d\u0921\u094d\u092f \u0938\u092e\u094d\u091c\u093e\u0924\u0947 \u092e\u093e\u0924\u0902\u0917 \u0935\u0926\u0928 \u0917\u0941\u0939"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0936\u093e\u0924\u094b\u0927\u0930\u093f \u0936\u0902\u0915\u0930\u093f \u091a\u093e\u092e\u0941\u0923\u094d\u0921\u0947\u0936\u094d\u0935\u0930\u093f \u091a\u0928\u094d\u0926\u094d\u0930\u0915\u0932\u093e\u0927\u0930\u093f \u0924\u093e\u092f\u0947 \u0917\u094c\u0930\u0940"}, {"M": "\u092e\u0941\u0915\u094d\u0924\u093e\u092f\u093f \u0938\u093e\u0939\u093f\u0924\u094d\u092f\u092e\u094d", "T": "\u0926\u0926 \u0928\u093f\u0926\u0928\u093f \u0926\u0926\u0928\u093f\u0926 \u0926\u0928\u093f\u092a\u092e \u0926\u0926 \u0928\u093f\u0930\u093f\u0938\u0928\u093f \u0938\u0926\u0928\u093f\u0938 \u0926\u092a\u092a\u092e \u0926\u0926 \u0928\u093f\u0917\u0930\u093f\u0928\u093f \u0930\u093f\u0938\u0928\u093f\u0926 \u092a\u0928\u093f\u0926\u092e \u0926\u0926 \u092e\u0917\u092e\u092a \u092e\u092a \u0926\u0926 \u0928\u093f\u0928\u093f \u0926\u092e \u0926\u0926 \u0930\u093f\u0938\u0928\u093f\u0926 \u0928\u093f \u0926\u0926\u094d \u0905 \u092e\u0926\u0928\u093f\u092e \u0928\u093f \u0926\u0926 \u092a \u0926\u0926\u094d \u0905 \u0928\u093f \u0926\u0926\u094d \u0905 \u0938\u0926 \u0928\u093f\u0926 \u092e\u0917\u0930\u093f \u0938\u0928\u093f \u0926 \u0928\u093f\u0938\u0928\u093f\u0928\u093f \u0926\u0926 \u092a\u092e <br/> \u0926\u093e\u0924\u093e \u0938\u0915\u0932 \u0915\u0932\u093e \u0928\u093f\u092a\u0941\u0923 \u091a\u0924\u0941\u0930 \u0926\u093e\u0924\u093e \u0938\u0941\u0932\u092d \u0939\u094d\u0930\u094d\u0926\u092f \u092e\u0927\u0941\u0930 \u0935\u091a\u0928 <br/> \u0926\u093e\u0924\u093e \u0938\u0930\u0938 \u0930\u0941\u091a\u093f\u0930\u0924\u0930 \u0938\u094d\u0935\u0930 \u0932\u092f \u0917\u0940\u0924 \u0938\u0941\u0916\u0926 \u0928\u093f\u091c \u092d\u093e\u0935 \u0930\u0938\u093f\u0915 \u0935\u0930 \u0926\u093e\u0924\u093e \u092e\u0939\u093f\u0936\u0942\u0930 \u0928\u093e\u0926 \u0928\u093e\u0932\u094d\u0935\u091f\u093f \u0936\u094d\u0930\u0940 <br/> \u0915\u094d\u0930\u094d\u0937\u094d\u0923 \u0930\u093e\u091c\u0947\u0928\u094d\u0926\u094d\u0930\u0930 \u0924\u093e\u092f\u0947 \u0938\u0926\u093e \u092a\u094b\u0930\u0947 \u092e\u0939\u093f\u0924\u0947 \u0939\u0930\u093f\u0915\u0947\u0936 \u092e\u0928\u094b\u0939\u0930\u0947 \u0938\u0926\u092f\u0947"}, {"M": "\u091a\u0930\u0923\u092e\u094d", "T": "\u0936\u094d\u092f\u093e\u092e\u0947 \u0938\u0915\u0932 \u092d\u0941\u0935\u0928 \u0938\u093e\u0930\u094d\u0935\u092d\u094c\u092e\u0947 \u0936\u0936\u093f \u092e\u0923\u094d\u0921\u0932 \u092e\u0926\u094d\u092f\u0917\u0947 <br/> \u092e, \u092e \u092a\u0928\u093f \u0926\u0926 \u092a\u092a \u092e\u0917\u092e\u092a \u092e \u092e \u0928\u093f\u0926 \u092e\u0938\u0928\u093f \u0926\u092a \u0926\u0926 \u0936\u094d\u092f\u093e\u092e\u0947 <br/> \u0928\u093f\u0926\u0928\u093f\u0926 \u0926\u092a\u092a\u092e \u092a\u092a \u0928\u093f\u0926\u092a\u092e \u0917\u092e\u092a \u0928\u093f\u0926\u092e \u0938\u0928\u093f\u0926\u092a \u092e\u0928\u093f\u0926 \u0936\u094d\u092f\u093e\u092e\u0947 <br/> \u0938 \u0938 \u0938 \u0928\u093f\u0926\u0928\u093f\u0938 \u0928\u093f\u0926\u092a \u092e\u0917\u092e\u092a \u092e\u092e\u092e \u0938\u092e\u0917\u092e \u092a\u0938\u0928\u093f\u0926 \u0928\u093f <br/> \u0928\u093f\u0926\u0928\u093f \u092a\u0926\u0928\u093f \u092e\u092a\u0926\u0928\u093f \u0917\u092e\u092a\u0926\u0928\u093f \u0938\u092e\u0917\u092e \u092a\u0926\u0928\u093f \u0938\u092e\u0917\u0930\u093f \u0938\u0938\u0928\u093f\u0926 \u092a\u0926 \u0936\u094d\u092f\u093e\u092e\u0947"}]}], "L": "l", "lyricsref": [{"links": [{"N": "www.karnatik.com", "L": "http://www.karnatik.com/c1466.shtml"}]}]}