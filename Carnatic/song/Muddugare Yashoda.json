0bae\u0bcd\u0baf\u0bc6 \u0b9a\u0b99\u0bcd\u0b95\u0b9a\u0b95\u0bcd\u0bb0\u0bbe\u0bb2 \u0b9a\u0ba8\u0bcd\u0ba4\u0bc1\u0bb2 \u0bb5\u0bc8\u0ba4\u0bc2\u0bb0\u0bcd\u0baf\u0bae\u0bc1 <br/> \u0b95\u0ba4\u0bbf\u0baf\u0bc8 \u0bae\u0bae\u0bcd\u0bae\u0bc1 \u0b95\u0bbe\u0b9a\u0bc6 \u0b95\u0bae\u0bb2\u0bbe\u0b95\u0bcd\u0b9a\u0bc1\u0ba4\u0bc1"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd 3", "T": "\u0b95\u0bbe\u0bb2\u0bbf\u0b99\u0bcd\u0b95\u0bc1\u0ba9\u0bbf \u0ba4\u0bb2\u0baa\u0bcd\u0baf\u0bc6 \u0b95\u0baa\u0bcd\u0baa\u0bbf\u0ba9 \u0baa\u0bc1\u0bb6\u0bcd\u0baf\u0bb0\u0bbe\u0b95\u0bae\u0bc1 <br/> \u0baf\u0bc6\u0bb2\u0bcd\u0bb2\u0bc6\u0ba4\u0bbf \u0bb6\u0bcd\u0bb0\u0bc0 \u0bb5\u0bc6\u0b99\u0bcd\u0b95\u0ba4\u0bbe\u0ba4\u0bcd\u0bb0\u0bbf \u0b87\u0ba8\u0bcd\u0ba4\u0bcd\u0bb0\u0ba9\u0bc0\u0bb2\u0bae\u0bc1 <br/> \u0baa\u0bbe\u0bb2\u0b9c\u0bb2\u0ba9\u0bbf\u0ba4\u0bbf\u0bb2\u0bca\u0ba9 \u0baa\u0bbe\u0baf\u0ba9\u0bbf \u0ba4\u0bbf\u0bb5\u0bcd\u0baf \u0bb0\u0ba4\u0bcd\u0ba9\u0bae\u0bc1 <br/> \u0baa\u0bbe\u0bb2\u0bc1\u0ba9\u0bc0\u0bb5\u0bb2\u0bc6 \u0ba4\u0bcd\u0bb0\u0bbf\u0b95\u0bbf \u0baa\u0ba4\u0bcd\u0bae\u0ba9\u0bbe\u0baa\u0bc1\u0ba4\u0bc1"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c2e\u0c41\u0c26\u0c4d\u0c26\u0c41\u0c17\u0c3e\u0c30\u0c46 \u0c2f\u0c38\u0c4a\u0c26\u0c3e \u0c2e\u0c41\u0c02\u0c17\u0c3f\u0c24\u0c3f \u0c2e\u0c41\u0c25\u0c4d\u0c2f\u0c2e\u0c41\u0c35\u0c3f\u0c26\u0c41 <br/> \u0c26\u0c3f\u0c26\u0c4d\u0c26\u0c46\u0c30\u0c3e\u0c28\u0c3f \u0c2e\u0c39\u0c3f\u0c2e\u0c32 \u0c26\u0c47\u0c35\u0c15\u0c3f \u0c38\u0c41\u0c25\u0c41\u0c26\u0c41"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d 1", "T": "\u0c05\u0c28\u0c4d\u0c25\u0c28\u0c3f\u0c28\u0c4d\u0c25 \u0c17\u0c4a\u0c32\u0c4d\u0c32\u0c46\u0c25\u0c32 \u0c05\u0c30\u0c1b\u0c46\u0c25\u0c3f \u0c2e\u0c3e\u0c28\u0c3f\u0c15\u0c4d\u0c2f\u0c2e\u0c41 <br/> \u0c2a\u0c28\u0c4d\u0c25\u0c2e\u0c3e\u0c26\u0c46\u0c2f\u0c4d \u0c15\u0c2e\u0c4d\u0c38\u0c41\u0c28\u0c3f \u0c2a\u0c3e\u0c32\u0c3f \u0c35\u0c1c\u0c4d\u0c30\u0c2e\u0c41 <br/> \u0c15\u0c3e\u0c28\u0c4d\u0c25\u0c41\u0c32 \u0c2e\u0c42\u0c26\u0c41 \u0c32\u0c4a\u0c15\u0c3e\u0c32 \u0c19\u0c30\u0c41\u0c26\u0c2a\u0c1b\u0c2a\u0c42\u0c38 <br/> \u0c1b\u0c46\u0c28\u0c4d\u0c25\u0c32 \u0c2e\u0c3e\u0c32\u0c4a\u0c28\u0c41\u0c28\u0c4d\u0c28 C\u0c39\u0c3f\u0c28\u0c4d\u0c28\u0c3f \u0c15\u0c43\u0c36\u0c4d\u0c28\u0c41\u0c26\u0c41"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d 2", "T": "\u0c30\u0c24\u0c3f\u0c15\u0c46\u0c32\u0c3f \u0c30\u0c41\u0c15\u0c4d\u0c2e\u0c3f\u0c28\u0c3f\u0c15\u0c3f \u0c30\u0c02\u0c17\u0c41\u0c2e\u0c4a\u0c35\u0c3f \u0c2a\u0c17\u0c26\u0c2e\u0c41 <br/> \u0c2e\u0c3f\u0c25\u0c3f \u0c17\u0c4b\u0c35\u0c30\u0c4d\u0c27\u0c28\u0c2a\u0c41 \u0c17\u0c4a\u0c2e\u0c46\u0c26\u0c3f\u0c15\u0c2e\u0c41 <br/> \u0c38\u0c25\u0c2e\u0c4d\u0c2f\u0c46 \u0c36\u0c02\u0c16\u0c1b\u0c15\u0c4d\u0c30\u0c3e\u0c32 \u0c38\u0c28\u0c4d\u0c26\u0c41\u0c32 \u0c35\u0c48\u0c26\u0c42\u0c30\u0c4d\u0c2f\u0c2e\u0c41 <br/> \u0c17\u0c25\u0c3f\u0c2f\u0c48 \u0c2e\u0c2e\u0c4d\u0c2e\u0c41 \u0c17\u0c3e\u0c1b\u0c46 \u0c15\u0c2e\u0c32\u0c3e\u0c15\u0c4d\u0c36\u0c41\u0c26\u0c41"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d 3", "T": "\u0c15\u0c3e\u0c32\u0c3f\u0c02\u0c17\u0c41\u0c28\u0c3f \u0c24\u0c32\u0c2a\u0c4d\u0c2f\u0c46 \u0c17\u0c2a\u0c4d\u0c2a\u0c3f\u0c28 \u0c2a\u0c41\u0c36\u0c4d\u0c2f\u0c30\u0c3e\u0c17\u0c2e\u0c41 <br/> \u0c2f\u0c46\u0c32\u0c4d\u0c32\u0c46\u0c24\u0c3f \u0c36\u0c4d\u0c30\u0c40 \u0c35\u0c46\u0c02\u0c15\u0c24\u0c3e\u0c26\u0c4d\u0c30\u0c3f \u0c07\u0c28\u0c4d\u0c26\u0c4d\u0c30\u0c28\u0c40\u0c32\u0c2e\u0c41 <br/> \u0c2a\u0c3e\u0c32\u0c1c\u0c32\u0c28\u0c3f\u0c27\u0c3f\u0c32\u0c4a\u0c28 \u0c2c\u0c3e\u0c2f\u0c28\u0c3f \u0c26\u0c3f\u0c35\u0c4d\u0c2f \u0c30\u0c24\u0c4d\u0c28\u0c2e\u0c41 <br/> \u0c2c\u0c3e\u0c32\u0c41\u0c28\u0c40\u0c35\u0c32\u0c46 \u0c27\u0c4d\u0c30\u0c3f\u0c17\u0c3f \u0c2a\u0c26\u0c4d\u0c2e\u0c28\u0c3e\u0c2d\u0c41\u0c26\u0c41"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cae\u0cc1\u0ca6\u0ccd\u0ca6\u0cc1\u0c97\u0cbe\u0cb0\u0cc6 \u0caf\u0cb8\u0cca\u0ca6\u0cbe \u0cae\u0cc1\u0c82\u0c97\u0cbf\u0ca4\u0cbf \u0cae\u0cc1\u0ca5\u0ccd\u0caf\u0cae\u0cc1\u0cb5\u0cbf\u0ca6\u0cc1 <br/> \u0ca6\u0cbf\u0ca6\u0ccd\u0ca6\u0cc6\u0cb0\u0cbe\u0ca8\u0cbf \u0cae\u0cb9\u0cbf\u0cae\u0cb2 \u0ca6\u0cc7\u0cb5\u0c95\u0cbf \u0cb8\u0cc1\u0ca5\u0cc1\u0ca6\u0cc1"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd 1", "T": "\u0c85\u0ca8\u0ccd\u0ca5\u0ca8\u0cbf\u0ca8\u0ccd\u0ca5 \u0c97\u0cca\u0cb2\u0ccd\u0cb2\u0cc6\u0ca5\u0cb2 \u0c85\u0cb0\u0c9b\u0cc6\u0ca5\u0cbf \u0cae\u0cbe\u0ca8\u0cbf\u0c95\u0ccd\u0caf\u0cae\u0cc1 <br/> \u0caa\u0ca8\u0ccd\u0ca5\u0cae\u0cbe\u0ca6\u0cc6\u0caf\u0ccd \u0c95\u0cae\u0ccd\u0cb8\u0cc1\u0ca8\u0cbf \u0caa\u0cbe\u0cb2\u0cbf \u0cb5\u0c9c\u0ccd\u0cb0\u0cae\u0cc1 <br/> \u0c95\u0cbe\u0ca8\u0ccd\u0ca5\u0cc1\u0cb2 \u0cae\u0cc2\u0ca6\u0cc1 \u0cb2\u0cca\u0c95\u0cbe\u0cb2 \u0c99\u0cb0\u0cc1\u0ca6\u0caa\u0c9b\u0caa\u0cc2\u0cb8 <br/> \u0c9b\u0cc6\u0ca8\u0ccd\u0ca5\u0cb2 \u0cae\u0cbe\u0cb2\u0cca\u0ca8\u0cc1\u0ca8\u0ccd\u0ca8 C\u0cb9\u0cbf\u0ca8\u0ccd\u0ca8\u0cbf \u0c95\u0cc3\u0cb6\u0ccd\u0ca8\u0cc1\u0ca6\u0cc1"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd 2", "T": "\u0cb0\u0ca4\u0cbf\u0c95\u0cc6\u0cb2\u0cbf \u0cb0\u0cc1\u0c95\u0ccd\u0cae\u0cbf\u0ca8\u0cbf\u0c95\u0cbf \u0cb0\u0c82\u0c97\u0cc1\u0cae\u0cca\u0cb5\u0cbf \u0caa\u0c97\u0ca6\u0cae\u0cc1 <br/> \u0cae\u0cbf\u0ca5\u0cbf \u0c97\u0ccb\u0cb5\u0cb0\u0ccd\u0ca7\u0ca8\u0caa\u0cc1 \u0c97\u0cca\u0cae\u0cc6\u0ca6\u0cbf\u0c95\u0cae\u0cc1 <br/> \u0cb8\u0ca5\u0cae\u0ccd\u0caf\u0cc6 \u0cb6\u0c82\u0c96\u0c9b\u0c95\u0ccd\u0cb0\u0cbe\u0cb2 \u0cb8\u0ca8\u0ccd\u0ca6\u0cc1\u0cb2 \u0cb5\u0cc8\u0ca6\u0cc2\u0cb0\u0ccd\u0caf\u0cae\u0cc1 <br/> \u0c97\u0ca5\u0cbf\u0caf\u0cc8 \u0cae\u0cae\u0ccd\u0cae\u0cc1 \u0c97\u0cbe\u0c9b\u0cc6 \u0c95\u0cae\u0cb2\u0cbe\u0c95\u0ccd\u0cb6\u0cc1\u0ca6\u0cc1"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd 3", "T": "\u0c95\u0cbe\u0cb2\u0cbf\u0c82\u0c97\u0cc1\u0ca8\u0cbf \u0ca4\u0cb2\u0caa\u0ccd\u0caf\u0cc6 \u0c97\u0caa\u0ccd\u0caa\u0cbf\u0ca8 \u0caa\u0cc1\u0cb6\u0ccd\u0caf\u0cb0\u0cbe\u0c97\u0cae\u0cc1 <br/> \u0caf\u0cc6\u0cb2\u0ccd\u0cb2\u0cc6\u0ca4\u0cbf \u0cb6\u0ccd\u0cb0\u0cc0 \u0cb5\u0cc6\u0c82\u0c95\u0ca4\u0cbe\u0ca6\u0ccd\u0cb0\u0cbf \u0c87\u0ca8\u0ccd\u0ca6\u0ccd\u0cb0\u0ca8\u0cc0\u0cb2\u0cae\u0cc1 <br/> \u0caa\u0cbe\u0cb2\u0c9c\u0cb2\u0ca8\u0cbf\u0ca7\u0cbf\u0cb2\u0cca\u0ca8 \u0cac\u0cbe\u0caf\u0ca8\u0cbf \u0ca6\u0cbf\u0cb5\u0ccd\u0caf \u0cb0\u0ca4\u0ccd\u0ca8\u0cae\u0cc1 <br/> \u0cac\u0cbe\u0cb2\u0cc1\u0ca8\u0cc0\u0cb5\u0cb2\u0cc6 \u0ca7\u0ccd\u0cb0\u0cbf\u0c97\u0cbf \u0caa\u0ca6\u0ccd\u0cae\u0ca8\u0cbe\u0cad\u0cc1\u0ca6\u0cc1"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d2e\u0d41\u0d26\u0d4d\u0d26\u0d41\u0d17\u0d3e\u0d30\u0d46 \u0d2f\u0d38\u0d4a\u0d26\u0d3e \u0d2e\u0d41\u0d02\u0d17\u0d3f\u0d24\u0d3f \u0d2e\u0d41\u0d25\u0d4d\u0d2f\u0d2e\u0d41\u0d35\u0d3f\u0d26\u0d41 <br/> \u0d26\u0d3f\u0d26\u0d4d\u0d26\u0d46\u0d30\u0d3e\u0d28\u0d3f \u0d2e\u0d39\u0d3f\u0d2e\u0d32 \u0d26\u0d47\u0d35\u0d15\u0d3f \u0d38\u0d41\u0d25\u0d41\u0d26\u0d41"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 1", "T": "\u0d05\u0d28\u0d4d\u0d25\u0d28\u0d3f\u0d28\u0d4d\u0d25 \u0d17\u0d4a\u0d32\u0d4d\u0d32\u0d46\u0d25\u0d32 \u0d05\u0d30\u0d1b\u0d46\u0d25\u0d3f \u0d2e\u0d3e\u0d28\u0d3f\u0d15\u0d4d\u0d2f\u0d2e\u0d41 <br/> \u0d2a\u0d28\u0d4d\u0d25\u0d2e\u0d3e\u0d26\u0d46\u0d2f\u0d4d \u0d15\u0d2e\u0d4d\u0d38\u0d41\u0d28\u0d3f \u0d2a\u0d3e\u0d32\u0d3f \u0d35\u0d1c\u0d4d\u0d30\u0d2e\u0d41 <br/> \u0d15\u0d3e\u0d28\u0d4d\u0d25\u0d41\u0d32 \u0d2e\u0d42\u0d26\u0d41 \u0d32\u0d4a\u0d15\u0d3e\u0d32 \u0d19\u0d30\u0d41\u0d26\u0d2a\u0d1b\u0d2a\u0d42\u0d38 <br/> \u0d1b\u0d46\u0d28\u0d4d\u0d25\u0d32 \u0d2e\u0d3e\u0d32\u0d4a\u0d28\u0d41\u0d28\u0d4d\u0d28 C\u0d39\u0d3f\u0d28\u0d4d\u0d28\u0d3f \u0d15\u0d43\u0d36\u0d4d\u0d28\u0d41\u0d26\u0d41"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 2", "T": "\u0d30\u0d24\u0d3f\u0d15\u0d46\u0d32\u0d3f \u0d30\u0d41\u0d15\u0d4d\u0d2e\u0d3f\u0d28\u0d3f\u0d15\u0d3f \u0d30\u0d02\u0d17\u0d41\u0d2e\u0d4a\u0d35\u0d3f \u0d2a\u0d17\u0d26\u0d2e\u0d41 <br/> \u0d2e\u0d3f\u0d25\u0d3f \u0d17\u0d4b\u0d35\u0d30\u0d4d\u0d27\u0d28\u0d2a\u0d41 \u0d17\u0d4a\u0d2e\u0d46\u0d26\u0d3f\u0d15\u0d2e\u0d41 <br/> \u0d38\u0d25\u0d2e\u0d4d\u0d2f\u0d46 \u0d36\u0d02\u0d16\u0d1b\u0d15\u0d4d\u0d30\u0d3e\u0d32 \u0d38\u0d28\u0d4d\u0d26\u0d41\u0d32 \u0d35\u0d48\u0d26\u0d42\u0d30\u0d4d\u0d2f\u0d2e\u0d41 <br/> \u0d17\u0d25\u0d3f\u0d2f\u0d48 \u0d2e\u0d2e\u0d4d\u0d2e\u0d41 \u0d17\u0d3e\u0d1b\u0d46 \u0d15\u0d2e\u0d32\u0d3e\u0d15\u0d4d\u0d36\u0d41\u0d26\u0d41"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 3", "T": "\u0d15\u0d3e\u0d32\u0d3f\u0d02\u0d17\u0d41\u0d28\u0d3f \u0d24\u0d32\u0d2a\u0d4d\u0d2f\u0d46 \u0d17\u0d2a\u0d4d\u0d2a\u0d3f\u0d28 \u0d2a\u0d41\u0d36\u0d4d\u0d2f\u0d30\u0d3e\u0d17\u0d2e\u0d41 <br/> \u0d2f\u0d46\u0d32\u0d4d\u0d32\u0d46\u0d24\u0d3f \u0d36\u0d4d\u0d30\u0d40 \u0d35\u0d46\u0d02\u0d15\u0d24\u0d3e\u0d26\u0d4d\u0d30\u0d3f \u0d07\u0d28\u0d4d\u0d26\u0d4d\u0d30\u0d28\u0d40\u0d32\u0d2e\u0d41 <br/> \u0d2a\u0d3e\u0d32\u0d1c\u0d32\u0d28\u0d3f\u0d27\u0d3f\u0d32\u0d4a\u0d28 \u0d2c\u0d3e\u0d2f\u0d28\u0d3f \u0d26\u0d3f\u0d35\u0d4d\u0d2f \u0d30\u0d24\u0d4d\u0d28\u0d2e\u0d41 <br/> \u0d2c\u0d3e\u0d32\u0d41\u0d28\u0d40\u0d35\u0d32\u0d46 \u0d27\u0d4d\u0d30\u0d3f\u0d17\u0d3f \u0d2a\u0d26\u0d4d\u0d2e\u0d28\u0d3e\u0d2d\u0d41\u0d26\u0d41"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u092e\u0941\u0926\u094d\u0926\u0941\u0917\u093e\u0930\u0947 \u092f\u0938\u094b\u0926\u093e \u092e\u0941\u0902\u0917\u093f\u0924\u093f \u092e\u0941\u0925\u094d\u092f\u092e\u0941\u0935\u093f\u0926\u0941 <br/> \u0926\u093f\u0926\u094d\u0926\u0947\u0930\u093e\u0928\u093f \u092e\u0939\u093f\u092e\u0932 \u0926\u0947\u0935\u0915\u093f \u0938\u0941\u0925\u0941\u0926\u0941"}, {"M": "\u091a\u0930\u0923\u092e\u094d 1", "T": "\u0905\u0928\u094d\u0925\u0928\u093f\u0928\u094d\u0925 \u0917\u094b\u0932\u094d\u0932\u0947\u0925\u0932 \u0905\u0930\u091b\u0947\u0925\u093f \u092e\u093e\u0928\u093f\u0915\u094d\u092f\u092e\u0941 <br/> \u092a\u0928\u094d\u0925\u092e\u093e\u0926\u0947\u092f\u094d \u0915\u092e\u094d\u0938\u0941\u0928\u093f \u092a\u093e\u0932\u093f \u0935\u091c\u094d\u0930\u092e\u0941 <br/> \u0915\u093e\u0928\u094d\u0925\u0941\u0932 \u092e\u0942\u0926\u0941 \u0932\u094b\u0915\u093e\u0932 \u0919\u0930\u0941\u0926\u092a\u091b\u092a\u0942\u0938 <br/> \u091b\u0947\u0928\u094d\u0925\u0932 \u092e\u093e\u0932\u094b\u0928\u0941\u0928\u094d\u0928 C\u0939\u093f\u0928\u094d\u0928\u093f \u0915\u0943\u0936\u094d\u0928\u0941\u0926\u0941"}, {"M": "\u091a\u0930\u0923\u092e\u094d 2", "T": "\u0930\u0924\u093f\u0915\u0947\u0932\u093f \u0930\u0941\u0915\u094d\u092e\u093f\u0928\u093f\u0915\u093f \u0930\u0902\u0917\u0941\u092e\u094b\u0935\u093f \u092a\u0917\u0926\u092e\u0941 <br/> \u092e\u093f\u0925\u093f \u0917\u094b\u0935\u0930\u094d\u0927\u0928\u092a\u0941 \u0917\u094b\u092e\u0947\u0926\u093f\u0915\u092e\u0941 <br/> \u0938\u0925\u092e\u094d\u092f\u0947 \u0936\u0902\u0916\u091b\u0915\u094d\u0930\u093e\u0932 \u0938\u0928\u094d\u0926\u0941\u0932 \u0935\u0948\u0926\u0942\u0930\u094d\u092f\u092e\u0941 <br/> \u0917\u0925\u093f\u092f\u0948 \u092e\u092e\u094d\u092e\u0941 \u0917\u093e\u091b\u0947 \u0915\u092e\u0932\u093e\u0915\u094d\u0936\u0941\u0926\u0941"}, {"M": "\u091a\u0930\u0923\u092e\u094d 3", "T": "\u0915\u093e\u0932\u093f\u0902\u0917\u0941\u0928\u093f \u0924\u0932\u092a\u094d\u092f\u0947 \u0917\u092a\u094d\u092a\u093f\u0928 \u092a\u0941\u0936\u094d\u092f\u0930\u093e\u0917\u092e\u0941 <br/> \u092f\u0947\u0932\u094d\u0932\u0947\u0924\u093f \u0936\u094d\u0930\u0940 \u0935\u0947\u0902\u0915\u0924\u093e\u0926\u094d\u0930\u093f \u0907\u0928\u094d\u0926\u094d\u0930\u0928\u0940\u0932\u092e\u0941 <br/> \u092a\u093e\u0932\u091c\u0932\u0928\u093f\u0927\u093f\u0932\u094b\u0928 \u092c\u093e\u092f\u0928\u093f \u0926\u093f\u0935\u094d\u092f \u0930\u0924\u094d\u0928\u092e\u0941 <br/> \u092c\u093e\u0932\u0941\u0928\u0940\u0935\u0932\u0947 \u0927\u094d\u0930\u093f\u0917\u093f \u092a\u0926\u094d\u092e\u0928\u093e\u092d\u0941\u0926\u0941"}]}], "L": "l", "lyricsref": [{"links": [{"N": "www.karnatik.com", "L": "http://www.karnatik.com/c1182.shtml"}]}]}