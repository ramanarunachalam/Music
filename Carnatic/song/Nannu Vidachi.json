0bb0\u0bbe"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd 1", "T": "\u0ba4\u0bb0\u0bae\u0bc1 \u0b95\u0bbe\u0ba9\u0bbf\u0baf\u0bc6\u0ba3\u0bcd\u0b9f \u0bb5\u0bc7\u0bb3 \u0b95\u0bb2\u0bcd\u0baa <br/> \u0ba4\u0bb0\u0bc1 \u0ba8\u0bc0\u0b9f \u0ba4\u0bca\u0bb0\u0bbf\u0b95\u0bbf\u0ba9\u0b9f\u0bcd\u0bb2\u0bbe\u0baf\u0bc6\u0ba9\u0bc0 \u0bb5\u0bc7\u0bb3"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd 2", "T": "\u0b85\u0baa\u0bcd\u0ba4\u0bbf\u0bb2\u0bcb \u0bae\u0bc1\u0ba9\u0bbf\u0b95\u0bbf \u0bb6\u0bcd\u0bb5\u0bbe\u0b9a\u0bae\u0bc1\u0ba9\u0bc1 \u0baa\u0b9f\u0bcd\u0b9f\u0bbf <br/> \u0b86\u0ba3\u0bbf \u0bae\u0bc1\u0ba4\u0bcd\u0baf\u0bae\u0bc1 \u0b95\u0ba9\u0bcd\u0ba9\u0b9f\u0bcd\u0bb2\u0bbe\u0baf\u0bc6 \u0bb6\u0bcd\u0bb0\u0bc0 \u0bb0\u0bae\u0ba3"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd 3", "T": "\u0bb5\u0b9a\u0bc1\u0ba4\u0ba9\u0bc1 \u0b95\u0ba9\u0ba9\u0bae\u0bc1 \u0b9a\u0bc7\u0b9a\u0bbf \u0ba4\u0ba9 <br/> \u0baa\u0bbe\u0ba3\u0bcd\u0b9f\u0bae\u0baa\u0bcd\u0baa\u0bbf\u0ba9 \u0bb0\u0bc0\u0ba4\u0bbf \u0b95\u0ba9\u0bc1\u0b95\u0bca\u0ba3\u0bcd\u0b9f\u0bbf \u0b9f\u0bbe\u0b9a\u0bbf"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd 4", "T": "\u0bb5\u0b9f\u0bb2\u0bc1 \u0ba4\u0b95\u0bbf\u0bb2\u0bbf\u0baf\u0bc1\u0ba9\u0bcd\u0ba9 \u0bb5\u0bc7\u0bb3 \u0b95\u0bca\u0baa\u0bcd\u0baa <br/> \u0bb5\u0b9f-\u0b95\u0ba3\u0bcd\u0b9f\u0bcd\u0bb2\u0bc1 \u0b95\u0bc1\u0bb0\u0bbf\u0b9a\u0bbf\u0ba9\u0b9f\u0bcd\u0bb2\u0bbe\u0baf\u0bc6\u0ba9\u0bc0 \u0bb5\u0bc7\u0bb3"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd 5", "T": "\u0baa\u0bbe\u0b95\u0bc1\u0b95 \u0ba8\u0ba9\u0bcd\u0ba9\u0bc7\u0bb2\u0bc1\u0b95\u0bca\u0bae\u0bcd\u0bae\u0bc1\u0baf\u0bbf\u0bb2 <br/> \u0ba4\u0bcd\u0baf\u0bbe\u0b95\u0bb0\u0bbe\u0b9c \u0ba8\u0bc1\u0ba4 \u0ba4\u0ba9\u0bc1\u0bb5\u0bc1 \u0ba8\u0bc0 \u0b9a\u0bca\u0bae\u0bcd\u0bae\u0bc1"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c28\u0c28\u0c4d\u0c28\u0c41 \u0c35\u0c3f\u0c21\u0c3f\u0c1a\u0c3f \u0c15\u0c26\u0c32\u0c15\u0c41\u0c30\u0c3e \u0c30\u0c3e\u0c2e\u0c2f\u0c4d\u0c2f \u0c35\u0c26