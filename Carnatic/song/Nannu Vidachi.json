c2e\u0c41"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0ca8\u0ca8\u0ccd\u0ca8\u0cc1 \u0cb5\u0cbf\u0ca1\u0cbf\u0c9a\u0cbf \u0c95\u0ca6\u0cb2\u0c95\u0cc1\u0cb0\u0cbe \u0cb0\u0cbe\u0cae\u0caf\u0ccd\u0caf \u0cb5\u0ca6\u0cb2\u0c95\u0cc1\u0cb0\u0cbe"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0ca8\u0cbf\u0ca8\u0ccd\u0ca8\u0cc1 \u0cac\u0cbe\u0cb8\u0cbf\u0caf\u0cb0 \u0ca8\u0cbf\u0cae\u0cbf\u0cb7\u0cae\u0ccb\u0cb0\u0ccd\u0cb5\u0ca8\u0cc1\u0cb0\u0cbe"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd 1", "T": "\u0ca4\u0cb0\u0cae\u0cc1 \u0c95\u0cbe\u0ca8\u0cbf\u0caf\u0cc6\u0ca3\u0ccd\u0ca1 \u0cb5\u0cc7\u0cb3 \u0c95\u0cb2\u0ccd\u0caa <br/> \u0ca4\u0cb0\u0cc1 \u0ca8\u0cc0\u0ca1 \u0ca6\u0cca\u0cb0\u0cbf\u0c97\u0cbf\u0ca8\u0c9f\u0ccd\u0cb2\u0cbe\u0caf\u0cc6\u0ca8\u0cc0 \u0cb5\u0cc7\u0cb3"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd 2", "T": "\u0c85\u0cac\u0ccd\u0ca7\u0cbf\u0cb2\u0ccb \u0cae\u0cc1\u0ca8\u0cbf\u0c97\u0cbf \u0cb6\u0ccd\u0cb5\u0cbe\u0cb8\u0cae\u0cc1\u0ca8\u0cc1 \u0caa\u0c9f\u0ccd\u0c9f\u0cbf <br/> \u0c86\u0ca3\u0cbf \u0cae\u0cc1\u0ca4\u0ccd\u0caf\u0cae\u0cc1 \u0c95\u0ca8\u0ccd\u0ca8\u0c9f\u0ccd\u0cb2\u0cbe\u0caf\u0cc6 \u0cb6\u0ccd\u0cb0\u0cc0 \u0cb0\u0cae\u0ca3"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd 3", "T": "\u0cb5\u0cb8\u0cc1\u0ca7\u0ca8\u0cc1 \u0c96\u0ca8\u0ca8\u0cae\u0cc1 \u0c9a\u0cc7\u0cb8\u0cbf \u0ca7\u0ca8 <br/> \u0cad\u0cbe\u0ca3\u0ccd\u0ca1\u0cae\u0cac\u0ccd\u0cac\u0cbf\u0ca8 \u0cb0\u0cc0\u0ca4\u0cbf \u0c95\u0ca8\u0cc1\u0c95\u0cca\u0ca3\u0ccd\u0c9f\u0cbf \u0ca1\u0cbe\u0cb8\u0cbf"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd 4", "T": "\u0cb5\u0ca1\u0cb2\u0cc1 \u0ca4\u0c97\u0cbf\u0cb2\u0cbf\u0caf\u0cc1\u0ca8\u0ccd\u0ca8 \u0cb5\u0cc7\u0cb3 \u0c97\u0cca\u0caa\u0ccd\u0caa <br/> \u0cb5\u0ca1-\u0c97\u0ca3\u0ccd\u0ca1\u0ccd\u0cb2\u0cc1 \u0c95\u0cc1\u0cb0\u0cbf\u0cb8\u0cbf\u0ca8\u0c9f\u0ccd\u0cb2\u0cbe\u0caf\u0cc6\u0ca8\u0cc0 \u0cb5\u0cc7\u0cb3"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd 5", "T": "\u0cac\u0cbe\u0c97\u0cc1\u0c97 \u0ca8\u0ca8\u0ccd\u0ca8\u0cc7\u0cb2\u0cc1\u0c95\u0cca\u0cae\u0ccd\u0cae\u0cc1\u0caf\u0cbf\u0cb2 <br/> \u0ca4\u0ccd\u0caf\u0cbe\u0c97\u0cb0\u0cbe\u0c9c \u0ca8\u0cc1\u0ca4 \u0ca4\u0ca8\u0cc1\u0cb5\u0cc1 \u0ca8\u0cc0 \u0cb8\u0cca\u0cae\u0ccd\u0cae\u0cc1"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d28\u0d28\u0d4d\u0d28\u0d41 \u0d35\u0d3f\u0d21\u0d3f\u0d1a\u0d3f \u0d15\u0d26\u0d32\u0d15\u0d41\u0d30\u0d3e \u0d30\u0d3e\u0d2e\u0d2f\u0d4d\u0d2f \u0d35\u0d26\u0d32\u0d15\u0d41\u0d30\u0d3e"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d28\u0d3f\u0d28\u0d4d\u0d28\u0d41 \u0d2c\u0d3e\u0d38\u0d3f\u0d2f\u0d30 \u0d28\u0d3f\u0d2e\u0d3f\u0d37\u0d2e\u0d4b\u0d30\u0d4d\u0d35\u0d28\u0d41\u0d30\u0d3e"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 1", "T": "\u0d24\u0d30\u0d2e\u0d41 \u0d15\u0d3e\u0d28\u0d3f\u0d2f\u0d46\u0d23\u0d4d\u0d21 \u0d35\u0d47\u0d33 \u0d15\u0d32\u0d4d\u0d2a <br/> \u0d24\u0d30\u0d41 \u0d28\u0d40\u0d21 \u0d26\u0d4a\u0d30\u0d3f\u0d17\u0d3f\u0d28\u0d1f\u0d4d\u0d32\u0d3e\u0d2f\u0d46\u0d28\u0d40 \u0d35\u0d47\u0d33"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 2", "T": "\u0d05\u0d2c\u0d4d\u0d27\u0d3f\u0d32\u0d4b \u0d2e\u0d41\u0d28\u0d3f\u0d17\u0d3f \u0d36\u0d4d\u0d35\u0d3e\u0d38\u0d2e\u0d41\u0d28\u0d41 \u0d2a\u0d1f\u0d4d\u0d1f\u0d3f <br/> \u0d06\u0d23\u0d3f \u0d2e\u0d41\u0d24\u0d4d\u0d2f\u0d2e\u0d41 \u0d15\u0d28\u0d4d\u0d28\u0d1f\u0d4d\u0d32\u0d3e\u0d2f\u0d46 \u0d36\u0d4d\u0d30\u0d40 \u0d30\u0d2e\u0d23"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 3", "T": "\u0d35\u0d38\u0d41\u0d27\u0d28\u0d41 \u0d16\u0d28\u0d28\u0d2e\u0d41 \u0d1a\u0d47\u0d38\u0d3f \u0d27\u0d28 <br/> \u0d2d\u0d3e\u0d23\u0d4d\u0d21\u0d2e\u0d2c\u0d4d\u0d2c\u0d3f\u0d28 \u0d30\u0d40\u0d24\u0d3f \u0d15\u0d28\u0d41\u0d15\u0d4a\u0d23\u0d4d\u0d1f\u0d3f \u0d21\u0d3e\u0d38\u0d3f"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 4", "T": "\u0d35\u0d21\u0d32\u0d41 \u0d24\u0d17\u0d3f\u0d32\u0d3f\u0d2f\u0d41\u0d28\u0d4d\u0d28 \u0d35\u0d47\u0d33 \u0d17\u0d4a\u0d2a\u0d4d\u0d2a <br/> \u0d35\u0d21-\u0d17\u0d23\u0d4d\u0d21\u0d4d\u0d32\u0d41 \u0d15\u0d41\u0d30\u0d3f\u0d38\u0d3f\u0d28\u0d1f\u0d4d\u0d32\u0d3e\u0d2f\u0d46\u0d28\u0d40 \u0d35\u0d47\u0d33"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 5", "T": "\u0d2c\u0d3e\u0d17\u0d41\u0d17 \u0d28\u0d28\u0d4d\u0d28\u0d47\u0d32\u0d41\u0d15\u0d4a\u0d2e\u0d4d\u0d2e\u0d41\u0d2f\u0d3f\u0d32 <br/> \u0d24\u0d4d\u0d2f\u0d3e\u0d17\u0d30\u0d3e\u0d1c \u0d28\u0d41\u0d24 \u0d24\u0d28\u0d41\u0d35\u0d41 \u0d28\u0d40 \u0d38\u0d4a\u0d2e\u0d4d\u0d2e\u0d41"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0928\u0928\u094d\u0928\u0941 \u0935\u093f\u0921\u093f\u091a\u093f \u0915\u0926\u0932\u0915\u0941\u0930\u093e \u0930\u093e\u092e\u092f\u094d\u092f \u0935\u0926\u0932\u0915\u0941\u0930\u093e"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0928\u093f\u0928\u094d\u0928\u0941 \u092c\u093e\u0938\u093f\u092f\u0930 \u0928\u093f\u092e\u093f\u0937\u092e\u094b\u0930\u094d\u0935\u0928\u0941\u0930\u093e"}, {"M": "\u091a\u0930\u0923\u092e\u094d 1", "T": "\u0924\u0930\u092e\u0941 \u0915\u093e\u0928\u093f\u092f\u0947\u0923\u094d\u0921 \u0935\u0947\u0932 \u0915\u0932\u094d\u092a <br/> \u0924\u0930\u0941 \u0928\u0940\u0921 \u0926\u094b\u0930\u093f\u0917\u093f\u0928\u091f\u094d\u0932\u093e\u092f\u0947\u0928\u0940 \u0935\u0947\u0932"}, {"M": "\u091a\u0930\u0923\u092e\u094d 2", "T": "\u0905\u092c\u094d\u0927\u093f\u0932\u094b \u092e\u0941\u0928\u093f\u0917\u093f \u0936\u094d\u0935\u093e\u0938\u092e\u0941\u0928\u0941 \u092a\u091f\u094d\u091f\u093f <br/> \u0906\u0923\u093f \u092e\u0941\u0924\u094d\u092f\u092e\u0941 \u0915\u0928\u094d\u0928\u091f\u094d\u0932\u093e\u092f\u0947 \u0936\u094d\u0930\u0940 \u0930\u092e\u0923"}, {"M": "\u091a\u0930\u0923\u092e\u094d 3", "T": "\u0935\u0938\u0941\u0927\u0928\u0941 \u0916\u0928\u0928\u092e\u0941 \u091a\u0947\u0938\u093f \u0927\u0928 <br/> \u092d\u093e\u0923\u094d\u0921\u092e\u092c\u094d\u092c\u093f\u0928 \u0930\u0940\u0924\u093f \