c3e\u0c30\u0c46\u0c15\u0c41 \u0c36\u0c4d\u0c30\u0c40 \u0c39\u0c30\u0c3f \u0c2a\u0c26 \u0c38\u0c3e\u0c30\u0c38\u0c2e\u0c41\u0c32 <br/> \u0c27\u0c4d\u0c2f\u0c3e\u0c28\u0c3f\u0c28\u0c4d\u0c1a\u0c41\u0c1a\u0c41 \u0c28\u0c3e\u0c30\u0c3e\u0c2f\u0c23 \u0c28\u0c3e\u0c2e\u0c2e\u0c41\u0c32\u0c28\u0c41 <br/> \u0c2a\u0c3e\u0c30\u0c3e\u0c2f\u0c23\u0c2e\u0c4a\u0c28\u0c30\u0c3f\u0c28\u0c4d\u0c1a\u0c41\u0c1a\u0c41"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d 1", "T": "\u0c2d\u0c47\u0c26\u0c3e\u0c2d\u0c47\u0c26 \u0c30\u0c39\u0c3f\u0c24\u0c2e\u0c17\u0c41 \u0c35\u0c47\u0c26\u0c3e\u0c28\u0c4d\u0c24 <br/> \u0c30\u0c38 \u0c2d\u0c30\u0c3f\u0c24\u0c41\u0c21\u0c3e\u0c39\u0c4d\u0c32\u0c3e\u0c26\u0c2e\u0c41 \u0c2e\u0c40\u0c30\u0c17\u0c28\u0c41 <br/> \u0c2a\u0c4d\u0c30\u0c39\u0c4d\u0c32\u0c3e\u0c26\u0c41\u0c28\u0c3f\u0c15\u0c3f \u0c36\u0c41\u0c2d\u0c2e\u0c41 \u0c24\u0c46\u0c32\u0c41\u0c2a\u0c28\u0c41"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d 2", "T": "\u0c15\u0c21\u0c41 \u0c24\u0c46\u0c32\u0c4d\u0c32 \u0c26\u0c47\u0c39\u0c2e\u0c41\u0c28 \u0c2a\u0c38\u0c3f\u0c21\u0c3f <br/> \u0c35\u0c40\u0c23\u0c46 \u0c2e\u0c46\u0c30\u0c2f\u0c17 \u0c24\u0c3e\u0c28\u0c46\u0c21\u0c2c\u0c3e\u0c2f\u0c28\u0c3f <br/> \u0c2a\u0c4d\u0c30\u0c47\u0c2e\u0c24\u0c4b\u0c28\u0c21\u0c41\u0c17\u0c21\u0c41\u0c17\u0c41\u0c15\u0c41 \u0c35\u0c3e\u0c2f\u0c3f\u0c28\u0c4d\u0c1a\u0c41\u0c1a\u0c41"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d 3", "T": "\u0c30\u0c3e\u0c1c\u0c3f\u0c32\u0c4d\u0c32\u0c3f\u0c28 \u0c36\u0c4d\u0c30\u0c40 \u0c24\u0c4d\u0c2f\u0c3e\u0c17\u0c30\u0c3e\u0c1c \u0c38\u0c16\u0c41\u0c28\u0c3f <br/> \u0c2e\u0c30\u0c4d\u0c2e\u0c2e\u0c41\u0c32\u0c28\u0c41 \u0c08 \u0c1c\u0c17\u0c24\u0c3f\u0c28\u0c3f \u0c35\u0c3f\u0c28\u0c4d\u0c28\u0c35\u0c3e\u0c30\u0c3f\u0c15\u0c47 <br/> \u0c1c\u0c2f\u0c2e\u0c41 \u0c1c\u0c2f\u0c2e\u0c41 \u0c1c\u0c2f\u0c2e\u0c28\u0c3f"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0ca8\u0cbe\u0cb0\u0ca6 \u0cae\u0cc1\u0ca8\u0cbf \u0cb5\u0cc6\u0ca1\u0cb2\u0cbf\u0ca8 <br/> \u0cb8\u0c