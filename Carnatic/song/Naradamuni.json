: "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d28\u0d3e\u0d30\u0d26 \u0d2e\u0d41\u0d28\u0d3f \u0d35\u0d46\u0d21\u0d32\u0d3f\u0d28 <br/> \u0d38\u0d41-\u0d17\u0d41\u0d23\u0d3e\u0d24\u0d3f\u0d36\u0d2f\u0d2e\u0d41 \u0d35\u0d3f\u0d28\u0d30\u0d47"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d38\u0d3e\u0d30\u0d46\u0d15\u0d41 \u0d36\u0d4d\u0d30\u0d40 \u0d39\u0d30\u0d3f \u0d2a\u0d26 \u0d38\u0d3e\u0d30\u0d38\u0d2e\u0d41\u0d32 <br/> \u0d27\u0d4d\u0d2f\u0d3e\u0d28\u0d3f\u0d28\u0d4d\u0d1a\u0d41\u0d1a\u0d41 \u0d28\u0d3e\u0d30\u0d3e\u0d2f\u0d23 \u0d28\u0d3e\u0d2e\u0d2e\u0d41\u0d32\u0d28\u0d41 <br/> \u0d2a\u0d3e\u0d30\u0d3e\u0d2f\u0d23\u0d2e\u0d4a\u0d28\u0d30\u0d3f\u0d28\u0d4d\u0d1a\u0d41\u0d1a\u0d41"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 1", "T": "\u0d2d\u0d47\u0d26\u0d3e\u0d2d\u0d47\u0d26 \u0d30\u0d39\u0d3f\u0d24\u0d2e\u0d17\u0d41 \u0d35\u0d47\u0d26\u0d3e\u0d28\u0d4d\u0d24 <br/> \u0d30\u0d38 \u0d2d\u0d30\u0d3f\u0d24\u0d41\u0d21\u0d3e\u0d39\u0d4d\u0d32\u0d3e\u0d26\u0d2e\u0d41 \u0d2e\u0d40\u0d30\u0d17\u0d28\u0d41 <br/> \u0d2a\u0d4d\u0d30\u0d39\u0d4d\u0d32\u0d3e\u0d26\u0d41\u0d28\u0d3f\u0d15\u0d3f \u0d36\u0d41\u0d2d\u0d2e\u0d41 \u0d24\u0d46\u0d32\u0d41\u0d2a\u0d28\u0d41"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 2", "T": "\u0d15\u0d21\u0d41 \u0d24\u0d46\u0d32\u0d4d\u0d32 \u0d26\u0d47\u0d39\u0d2e\u0d41\u0d28 \u0d2a\u0d38\u0d3f\u0d21\u0d3f <br/> \u0d35\u0d40\u0d23\u0d46 \u0d2e\u0d46\u0d30\u0d2f\u0d17 \u0d24\u0d3e\u0d28\u0d46\u0d21\u0d2c\u0d3e\u0d2f\u0d28\u0d3f <br/> \u0d2a\u0d4d\u0d30\u0d47\u0d2e\u0d24\u0d4b\u0d28\u0d21\u0d41\u0d17\u0d21\u0d41\u0d17\u0d41\u0d15\u0d41 \u0d35\u0d3e\u0d2f\u0d3f\u0d28\u0d4d\u0d1a\u0d41\u0d1a\u0d41"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 3", "T": "\u0d30\u0d3e\u0d1c\u0d3f\u0d32\u0d4d\u0d32\u0d3f\u0d28 \u0d36\u0d4d\u0d30\u0d40 \u0d24\u0d4d\u0d2f\u0d3e\u0d17\u0d30\u0d3e\u0d1c \u0d38\u0d16\u0d41\u0d28\u0d3f <br/> \u0d2e\u0d30\u0d4d\u0d2e\u0d2e\u0d41\u0d32\u0d28\u0d41 \u0d08 \u0d1c\u0d17\u0d24\u0d3f\u0d28\u0d3f \u0d35\u0d3f\u0d28\u0d4d\u0d28\u0d35\u0d3e\u0d30\u0d3f\u0d15\u0d47 <br/> \u0d1c\u0d2f\u0d2e\u0d41 \u0d1c\u0d2f\u0d2e\u0d41 \u0d1c\u0d2f\u0d2e\u0d28\u0d3f"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0928\u093e\u0930\u0926 \u092e\u0941\u0928\u093f \u0935\u0947\u0921\u0932\u093f\u0928 <br/> \u0938\u0941-\u0917\u0941\u0923\u093e\u0924\u093f\u0936\u092f\u092e\u0941 \u0935\u093f\u0928\u0930\u0947"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0938\u093e\u0930\u0947\u0915\u0941 \u0936\u094d\u0930\u0940 \u0939\u0930\u093f \u092a\u0926 \u0938\u093e\u0930\u0938\u092e\u0941\u0932 <br/> \u0927\u094d\u092f\u093e\u0928\u093f\u0928\u094d\u091a\u0941\u091a\u0941 \u0928\u093e\u0930\u093e\u092f\u0923 \u0928\u093e\u092e\u092e\u0941\u0932\u0928\u0941 <br/> \u092a\u093e\u0930\u093e\u092f\u0923\u092e\u094b\u0928\u0930\u093f\u0928\u094d\u091a\u0941\u091a\u0941"}, {"M": "\u091a\u0930\u0923\u092e\u094d 1", "T": "\u092d\u0947\u0926\u093e\u092d\u0947\u0926 \u0930\u0939\u093f\u0924\u092e\u0917\u0941 \u0935\u0947\u0926\u093e\u0928\u094d\u0924 <br/> \u0930\u0938 \u092d\u0930\u093f\u0924\u0941\u0921\u093e\u0939\u094d\u0932\u093e\u0926\u092e\u0941 \u092e\u0940\u0930\u0917\u0928\u0941 <br/> \u092a\u094d\u0930\u0939\u094d\u0932\u093e\u0926\u0941\u0928\u093f\u0915\u093f \u0936\u0941\u092d\u092e\u0941 \u0924\u0947\u0932\u0941\u092a\u0928\u0941"}, {"M": "\u091a\u0930\u0923\u092e\u094d 2", "T": "\u0915\u0921\u0941 \u0924\u0947\u0932\u094d\u0932 \u0926\u0947\u0939\u092e\u0941\u0928 \u092a\u0938\u093f\u0921\u093f <br/> \u0935\u0940\u0923\u0947 \u092e\u0947\u0930\u092f\u0917 \u0924\u093e\u0928\u0947\u0921\u092c\u093e\u092f\u0928\u093f <br/> \u092a\u094d\u0930\u0947\u092e\u0924\u094b\u0928\u0921\u0941\u0917\u0921\u0941\u0917\u0941\u0915\u0941 \u0935\u093e\u092f\u093f\u0928\u094d\u091a\u0941\u091a\u0941"}, {"M": "\u091a\u0930\u0923\u092e\u094d 3", "T": "\u0930\u093e\u091c\u093f\u0932\u094d\u0932\u093f\u0928 \u0936\u094d\u0930\u0940 \u0924\u094d\u092f\u093e\u0917\u0930\u093e\u091c \u0938\u0916\u0941\u0928\u093f <br/> \u092e\u0930\u094d\u092e\u092e\u0941\u0932\u0928\u0941 \u0908 \u091c\u0917\u0924\u093f\u0928\u093f \u0935\u093f\u0928\u094d\u0928\u0935\u093e\u0930\u093f\u0915\u0947 <br/> \u091c\u092f\u092e\u0941 \u091c\u092f\u092e\u0941 \u091c\u092f\u092e\u0928\u093f"}]}], "L": "l", "lyricsref": [{"links": [{"N": "thyagaraja-vaibhavam.blogspot.com", "L": "http://thyagaraja-vaibhavam.blogspot.com/2008/08/thyagaraja-kriti-narada-muni-raga.html"}, {"N": "www.sangeetasudha.org", "L": "http://www.sangeetasudha.org/thyagaraja/n.html#MARK_NARADA"}, {"N": "www.karnatik.com", "L": "http://www.karnatik.com/c2589.shtml"}]}]}