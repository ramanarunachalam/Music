\u0bc7\u0bb0\u0ba9\u0bc1\u0bb0 <br/> \u0bb6\u0bcd\u0bb0\u0bc0 \u0ba4\u0bcd\u0baf\u0bbe\u0b95\u0bb0\u0bbe\u0b9c\u0bbe\u0baa\u0bcd\u0ba4 \u0ba8\u0bc0\u0baf\u0bc6\u0b9f"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c28\u0c46\u0c28\u0c30\u0c41\u0c28\u0c4d\u0c1a\u0c3f\u0c28\u0c3e\u0c28\u0c41 \u0c05\u0c28\u0c4d\u0c28\u0c3f\u0c1f\u0c3f\u0c15\u0c3f <br/> \u0c28\u0c3f\u0c26\u0c3e\u0c28\u0c41\u0c21\u0c28\u0c3f \u0c28\u0c47\u0c28\u0c41 \u0c28\u0c40\u0c26\u0c41\u0c2a\u0c48"}, {"M": "\u0c05\u0c28\u0c41\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c18\u0c28\u0c3e\u0c18 \u0c1c\u0c40\u0c2e\u0c42\u0c24\u0c3e\u0c36\u0c41\u0c17 \u0c1c\u0c32\u0c27\u0c3f <br/> \u0c17\u0c2e\u0c4d\u0c2d\u0c40\u0c30 \u0c28\u0c40 \u0c2a\u0c3e\u0c26\u0c2e\u0c41\u0c32\u0c2a\u0c48"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c15\u0c32\u0c3f\u0c32\u0c4b \u0c2e\u0c3e\u0c1f\u0c32 \u0c28\u0c47\u0c30\u0c4d\u0c1a\u0c41\u0c15\u0c4a\u0c28\u0c3f <br/> \u0c15\u0c3e\u0c28\u0c4d\u0c24\u0c32\u0c28\u0c41 \u0c24\u0c28\u0c2f\u0c41\u0c32 \u0c2c\u0c4d\u0c30\u0c4b\u0c1a\u0c41\u0c1f\u0c15\u0c48 <br/> \u0c36\u0c3f\u0c32\u0c3e\u0c24\u0c4d\u0c2e\u0c41\u0c21\u0c48 \u0c2a\u0c32\u0c41\u0c15 \u0c28\u0c47\u0c30\u0c28\u0c41\u0c30 <br/> \u0c36\u0c4d\u0c30\u0c40 \u0c24\u0c4d\u0c2f\u0c3e\u0c17\u0c30\u0c3e\u0c1c\u0c3e\u0c2a\u0c4d\u0c24 \u0c28\u0c40\u0c2f\u0c46\u0c21"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0ca8\u0cc6\u0ca8\u0cb0\u0cc1\u0ca8\u0ccd\u0c9a\u0cbf\u0ca8\u0cbe\u0ca8\u0cc1 \u0c85\u0ca8\u0ccd\u0ca8\u0cbf\u0c9f\u0cbf\u0c95\u0cbf <br/> \u0ca8\u0cbf\u0ca6\u0cbe\u0ca8\u0cc1\u0ca1\u0ca8\u0cbf \u0ca8\u0cc7\u0ca8\u0cc1 \u0ca8\u0cc0\u0ca6\u0cc1\u0caa\u0cc8"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0c98\u0ca8\u0cbe\u0c98 \u0c9c\u0cc0\u0cae\u0cc2\u0ca4\u0cbe\u0cb6\u0cc1\u0c97 \u0c9c\u0cb2\u0ca7\u0cbf <br/> \u0c97\u0cae\u0ccd\u0cad\u0cc0\u0cb0 \u0ca8\u0cc0 \u0caa\u0cbe\u0ca6\u0cae\u0cc1\u0cb2\u0caa\u0cc8"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0c95\u0cb2\u0cbf\u0cb2\u0ccb \u0cae\u0cbe\u0c9f\u0cb2 \u0ca8\u0cc7\u0cb0\u0ccd\u0c9a\u0cc1\u0c95\u0cca\u0ca8\u0cbf <br/> \u0c95\u0cbe\u0ca8\u0ccd\u0ca4\u0cb2\u0ca8\u0cc1 \u0ca4\u0ca8\u0caf\u0cc1\u0cb2 \u0cac\u0ccd\u0cb0\u0ccb\u0c9a\u0cc1\u0c9f\u0c95\u0cc8 <br/> \u0cb6\u0cbf\u0cb2\u0cbe\u0ca4\u0ccd\u0cae\u0cc1\u0ca1\u0cc8 \u0caa\u0cb2\u0cc1\u0c95 \u0ca8\u0cc7\u0cb0\u0ca8\u0cc1\u0cb0 <br/> \u0cb6\u0ccd\u0cb0\u0cc0 \u0ca4\u0ccd\u0caf\u0cbe\u0c97\u0cb0\u0cbe\u0c9c\u0cbe\u0caa\u0ccd\u0ca4 \u0ca8\u0cc0\u0caf\u0cc6\u0ca1"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d28\u0d46\u0d28\u0d30\u0d41\u0d28\u0d4d\u0d1a\u0d3f\u0d28\u0d3e\u0d28\u0d41 \u0d05\u0d28\u0d4d\u0d28\u0d3f\u0d1f\u0d3f\u0d15\u0d3f <br/> \u0d28\u0d3f\u0d26\u0d3e\u0d28\u0d41\u0d21\u0d28\u0d3f \u0d28\u0d47\u0d28\u0d41 \u0d28\u0d40\u0d26\u0d41\u0d2a\u0d48"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d18\u0d28\u0d3e\u0d18 \u0d1c\u0d40\u0d2e\u0d42\u0d24\u0d3e\u0d36\u0d41\u0d17 \u0d1c\u0d32\u0d27\u0d3f <br/> \u0d17\u0d2e\u0d4d\u0d2d\u0d40\u0d30 \u0d28\u0d40 \u0d2a\u0d3e\u0d26\u0d2e\u0d41\u0d32\u0d2a\u0d48"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d15\u0d32\u0d3f\u0d32\u0d4b \u0d2e\u0d3e\u0d1f\u0d32 \u0d28\u0d47\u0d30\u0d4d\u0d1a\u0d41\u0d15\u0d4a\u0d28\u0d3f <br/> \u0d15\u0d3e\u0d28\u0d4d\u0d24\u0d32\u0d28\u0d41 \u0d24\u0d28\u0d2f\u0d41\u0d32 \u0d2c\u0d4d\u0d30\u0d4b\u0d1a\u0d41\u0d1f\u0d15\u0d48 <br/> \u0d36\u0d3f\u0d32\u0d3e\u0d24\u0d4d\u0d2e\u0d41\u0d21\u0d48 \u0d2a\u0d32\u0d41\u0d15 \u0d28\u0d47\u0d30\u0d28\u0d41\u0d30 <br/> \u0d36\u0d4d\u0d30\u0d40 \u0d24\u0d4d\u0d2f\u0d3e\u0d17\u0d30\u0d3e\u0d1c\u0d3e\u0d2a\u0d4d\u0d24 \u0d28\u0d40\u0d2f\u0d46\u0d21"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0928\u0947\u0928\u0930\u0941\u0928\u094d\u091a\u093f\u0928\u093e\u0928\u0941 \u0905\u0928\u094d\u0928\u093f\u091f\u093f\u0915\u093f <br/> \u0928\u093f\u0926\u093e\u0928\u0941\u0921\u0928\u093f \u0928\u0947\u0928\u0941 \u0928\u0940\u0926\u0941\u092a\u0948"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0918\u0928\u093e\u0918 \u091c\u0940\u092e\u0942\u0924\u093e\u0936\u0941\u0917 \u091c\u0932\u0927\u093f <br/> \u0917\u092e\u094d\u092d\u0940\u0930 \u0928\u0940 \u092a\u093e\u0926\u092e\u0941\u0932\u092a\u0948"}, {"M": "\u091a\u0930\u0923\u092e\u094d", "T": "\u0915\u0932\u093f\u0932\u094b \u092e\u093e\u091f\u0932 \u0928\u0947\u0930\u094d\u091a\u0941\u0915\u094b\u0928\u093f <br/> \u0915\u093e\u0928\u094d\u0924\u0932\u0928\u0941 \u0924\u0928\u092f\u0941\u0932 \u092c\u094d\u0930\u094b\u091a\u0941\u091f\u0915\u0948 <br/> \u0936\u093f\u0932\u093e\u0924\u094d\u092e\u0941\u0921\u0948 \u092a\u0932\u0941\u0915 \u0928\u0947\u0930\u0928\u0941\u0930 <br/> \u0936\u094d\u0930\u0940 \u0924\u094d\u092f\u093e\u0917\u0930\u093e\u091c\u093e\u092a\u094d\u0924 \u0928\u0940\u092f\u0947\u0921"}]}], "L": "l", "lyricsref": [{"links": [{"N": "thyagaraja-vaibhavam.blogspot.com", "L": "http://thyagaraja-vaibhavam.blogspot.com/2008/01/thyagaraja-kriti-nenarunchinaanu-raga.html"}, {"N": "sangeetasudha.org", "L": "http://sangeetasudha.org/thyagaraja/vol3/g36.html#MARK_NENARUNCHI"}, {"N": "www.karnatik.com", "L": "http://www.karnatik.com/c2598.shtml"}]}]}