, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c2e\u0c3e\u0c2e\u0c4d-\u0c05\u0c35 \u0c2e\u0c30\u0c15\u0c24 \u0c2e\u0c23\u0c3f \u0c28\u0c3f\u0c2d \u0c26\u0c47\u0c39 <br/> \u0c36\u0c4d\u0c30\u0c40 \u0c2e\u0c23\u0c3f \u0c32\u0c4b\u0c32 \u0c36\u0c4d\u0c30\u0c3f\u0c24 \u0c1c\u0c28 \u0c2a\u0c3e\u0c32 <br/> \u0c2d\u0c40\u0c2e \u0c2a\u0c30\u0c3e\u0c15\u0c4d\u0c30\u0c2e \u0c2d\u0c40\u0c2e \u0c15\u0c30\u0c3e\u0c30\u0c4d\u0c1a\u0c3f\u0c24 <br/> \u0c24\u0c3e\u0c2e\u0c38 \u0c30\u0c3e\u0c1c\u0c38 \u0c2e\u0c3e\u0c28\u0c35 \u0c26\u0c42\u0c30 <br/> \u0c24\u0c4d\u0c2f\u0c3e\u0c17\u0c30\u0c3e\u0c1c \u0c35\u0c3f\u0c28\u0c41\u0c24 \u0c1a\u0c30\u0c23"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0ca8\u0cbf\u0cb0\u0cb5\u0ca7\u0cbf \u0cb8\u0cc1\u0c96\u0ca6 \u0ca8\u0cbf\u0cb0\u0ccd\u0cae\u0cb2 \u0cb0\u0cc2\u0caa <br/> \u0ca8\u0cbf\u0cb0\u0ccd\u0c9c\u0cbf\u0ca4 \u0cae\u0cc1\u0ca8\u0cbf \u0cb6\u0cbe\u0caa"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cb6\u0cb0\u0ca7\u0cbf \u0cac\u0ca8\u0ccd\u0ca7\u0ca8 \u0ca8\u0ca4 \u0cb8\u0c82\u0c95\u0ccd\u0cb0\u0ca8\u0ccd\u0ca6\u0ca8 <br/> \u0cb6\u0c82\u0c95\u0cb0\u0cbe\u0ca6\u0cbf \u0c97\u0cc0\u0caf\u0cae\u0cbe\u0ca8 \u0cb8\u0cbe\u0ca7\u0cc1 \u0cae\u0cbe\u0ca8\u0cb8 \u0cb8\u0cc1-\u0cb8\u0ca6\u0ca8"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0cae\u0cbe\u0cae\u0ccd-\u0c85\u0cb5 \u0cae\u0cb0\u0c95\u0ca4 \u0cae\u0ca3\u0cbf \u0ca8\u0cbf\u0cad \u0ca6\u0cc7\u0cb9 <br/> \u0cb6\u0ccd\u0cb0\u0cc0 \u0cae\u0ca3\u0cbf \u0cb2\u0ccb\u0cb2 \u0cb6\u0ccd\u0cb0\u0cbf\u0ca4 \u0c9c\u0ca8 \u0caa\u0cbe\u0cb2 <br/> \u0cad\u0cc0\u0cae \u0caa\u0cb0\u0cbe\u0c95\u0ccd\u0cb0\u0cae \u0cad\u0cc0\u0cae \u0c95\u0cb0\u0cbe\u0cb0\u0ccd\u0c9a\u0cbf\u0ca4 <br/> \u0ca4\u0cbe\u0cae\u0cb8 \u0cb0\u0cbe\u0c9c\u0cb8 \u0cae\u0cbe\u0ca8\u0cb5 \u0ca6\u0cc2\u0cb0 <br/> \u0ca4\u0ccd\u0caf\u0cbe\u0c97\u0cb0\u0cbe\u0c9c \u0cb5\u0cbf\u0ca8\u0cc1\u0ca4 \u0c9a\u0cb0\u0ca3"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d