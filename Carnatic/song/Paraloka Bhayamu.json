, "marathi": "0,33,9,35,10,8,14,23,24,7,31,2,4,5,32,28,3,29,34,16,15,18,17,36,19,1,13,12,11,21,20,22,30,27,25,26,6", "bengali": "0,33,9,35,10,8,14,23,24,7,31,2,4,5,32,28,3,29,34,16,15,18,17,36,19,30,1,13,12,11,21,20,22,27,25,26,6", "gujarati": "0,33,9,35,10,8,14,23,24,7,31,2,4,5,32,28,3,29,34,16,15,18,17,36,19,1,13,12,11,21,20,22,30,27,25,26,6", "punjabi": "0,33,9,35,10,8,14,23,24,7,31,2,4,5,32,28,3,29,34,16,15,18,17,36,19,1,13,12,11,21,20,22,30,27,25,26,6", "odia": "0,33,9,35,10,8,14,23,24,7,31,2,4,5,32,28,3,29,34,16,15,18,17,36,19,1,13,12,11,21,20,22,30,27,25,26,6", "assamese": "0,33,9,35,10,8,14,23,24,7,31,2,4,5,32,28,3,29,34,16,15,18,17,36,19,30,1,13,12,11,21,20,22,27,25,26,6"}, "lyricstext": [{"L": "English", "text": [{"M": "pallavi", "T": "para lOka bhayamu lEka <br/> bhava pASa baddhulaiyEru"}, {"M": "anupallavi", "T": "kari vAji SrungArArAma <br/> SibikAdulella manakE kaligenani"}, {"M": "caraNam", "T": "konna kAntalanu kanna biDDalanu <br/> vanne cIralanu vAna guDiselanu <br/> tinnagA kani daiva lOkamani <br/> tannukoLLalO tyAgarAja nuta"}]}, {"L": "Tamil", "text": [{"M": "\u0baa\u0bb2\u0bcd\u0bb2\u0bb5\u0bbf", "T": "\u0baa\u0bb0 \u0bb2\u0bcb\u0b95 \u0baa\u0baf\u0bae\u0bc1 \u0bb2\u0bc7\u0b95 <br/> \u0baa\u0bb5 \u0baa\u0bbe\u0b9a \u0baa\u0ba4\u0bcd\u0ba4\u0bc1\u0bb2\u0bc8\u0baf\u0bc7\u0bb0\u0bc1"}, {"M": "\u0b85\u0ba9\u0bc1\u0baa\u0bb2\u0bcd\u0bb2\u0bb5\u0bbf", "T": "\u0b95\u0bb0\u0bbf \u0bb5\u0bbe\u0b9c\u0bbf \u0b9a\u0bcd\u0bb0\u0bc1\u0b99\u0bcd\u0b95\u0bbe\u0bb0\u0bbe\u0bb0\u0bbe\u0bae <br/> \u0b9a\u0bbf\u0baa\u0bbf\u0b95\u0bbe\u0ba4\u0bc1\u0bb2\u0bc6\u0bb2\u0bcd\u0bb2 \u0bae\u0ba9\u0b95\u0bc7 \u0b95\u0bb2\u0bbf\u0b95\u0bc6\u0ba9\u0ba9\u0bbf"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd", "T": "\u0b95\u0bca\u0ba9\u0bcd\u0ba9 \u0b95\u0bbe\u0ba8\u0bcd\u0ba4\u0bb2\u0ba9\u0bc1 \u0b95\u0ba9\u0bcd\u0ba9 \u0baa\u0bbf\u0b9f\u0bcd\u0b9f\u0bb2\u0ba9\u0bc1 <br/> \u0bb5\u0ba9\u0bcd\u0ba9\u0bc6 \u0b9a\u0bc0\u0bb0\u0bb2\u0ba9\u0bc1 \u0bb5\u0bbe\u0ba9 \u0b95\u0bc1\u0b9f\u0bbf\u0b9a\u0bc6\u0bb2\u0ba9\u0bc1 <br/> \u0ba4\u0bbf\u0ba9\u0bcd\u0ba9\u0b95\u0bbe \u0b95\u0ba9\u0bbf \u0ba4\u0bc8\u0bb5 \u0bb2\u0bcb\u0b95\u0bae\u0ba9\u0bbf <br/> \u0ba4\u0ba9\u0bcd\u0ba9\u0bc1\u0b95\u0bca\u0bb3\u0bcd\u0bb3\u0bb2\u0bcb \u0ba4\u0bcd\u0baf\u0bbe\u0b95\u0bb0\u0bbe\u0b9c \u0ba8\u0bc1\u0ba4"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c2a\u0c30 \u0c32\u0c4b\u0c15 \u0c2d\u0c2f\u0c2e\u0c41 \u0c32\u0c47\u0c15 <br/> \u0c2d\u0c35 \u0c2a\u0c3e\u0c36 \u0c2c\u0c26\u0c4d\u0c27\u0c41\u0c32\u0c48\u0c2f\u0c47\u0c30\u0c41"}, {"M": "\u0c05\u0c28\u0c41\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c15\u0c30\u0c3f \u0c35\u0c3e\u0c1c\u0c3f \u0c36\u0c43\u0c02\u0c17\u0c3e\u0c30\u0c3e\u0c30\u0c3e\u0c2e <br/> \u0c36\u0c3f\u0c2c\u0c3f\u0c15\u0c3e\u0c26\u0c41\u0c32\u0c46\u0c32\u0c4d\u0c32 \u0c2e\u0c28\u0c15\u0c47 \u0c15\u0c32\u0c3f\u0c17\u0c46\u0c28\u0c28\u0c3f"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c15\u0c4a\u0c28\u0c4d\u0c28 \u0c15\u0c3e\u0c28\u0c4d\u0c24\u0c32\u0c28\u0c41 \u0c15\u0c28\u0c4d\u0c28 \u0c2c\u0c3f\u0c21\u0c4d\u0c21\u0c32\u0c28\u0c41 <br/> \u0c35\u0c28\u0c4d\u0c28\u0c46 \u0c1a\u0c40\u0c30\u0c32\u0c28\u0c41 \u0c35\u0c3e\u0c28 \u0c17\u0c41\u0c21\u0c3f\u0c38\u0c46\u0c32\u0c28\u0c41 <br/> \u0c24\u0c3f\u0c28\u0c4d\u0c28\u0c17\u0c3e \u0c15\u0c28\u0c3f \u0c26\u0c48\u0c35 \u0c32\u0c4b\u0c15\u0c2e\u0c28\u0c3f <br/> \u0c24\u0c28\u0c4d\u0c28\u0c41\u0c15\u0c4a\u0c33\u0c4d\u0c33\u0c32\u0c4b \u0c24\u0c4d\u0c2f\u0c3e\u0c17\u0c30\u0c3e\u0c1c \u0c28\u0c41\u0c24"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0caa\u0cb0 \u0cb2\u0ccb\u0c95 \u0cad\u0caf\u0cae\u0cc1 \u0cb2\u0cc7\u0c95 <br/> \u0cad\u0cb5 \u0caa\u0cbe\u0cb6 \u0cac\u0ca6\u0ccd\u0ca7\u0cc1\u0cb2\u0cc8\u0caf\u0cc7\u0cb0\u0cc1"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0c95\u0cb0\u0cbf \u0cb5\u0cbe\u0c9c\u0cbf \u0cb6\u0cc3\u0c82\u0c97\u0cbe\u0cb0\u0cbe\u0cb0\u0cbe\u0cae <br/> \u0cb6\u0cbf\u0cac\u0cbf\u0c95\u0cbe\u0ca6\u0cc1\u0cb2\u0cc6\u0cb2\u0ccd\u0cb2 \u0cae\u0ca8\u0c95\u0cc7 \u0c95\u0cb2\u0cbf\u0c97\u0cc6\u0ca8\u0ca8\u0cbf"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0c95\u0cca\u0ca8\u0ccd\u0ca8 \u0c95\u0cbe\u0ca8\u0ccd\u0ca4\u0cb2\u0ca8\u0cc1 \u0c95\u0ca8\u0ccd\u0ca8 \u0cac\u0cbf\u0ca1\u0ccd\u0ca1\u0cb2\u0ca8\u0cc1 <br/> \u0cb5\u0ca8\u0ccd\u0ca8\u0cc6 \u0c9a\u0cc0\u0cb0\u0cb2\u0ca8\u0cc1 \u0cb5\u0cbe\u0ca8 \u0c97\u0cc1\u0ca1\u0cbf\u0cb8\u0cc6\u0cb2\u0ca8\u0cc1 <br/> \u0ca4\u0cbf\u0ca8\u0ccd\u0ca8\u0c97\u0cbe \u0c95\u0ca8\u0cbf \u0ca6\u0cc8\u0cb5 \u0cb2\u0ccb\u0c95\u0cae\u0ca8\u0cbf <br/> \u0ca4\u0ca8\u0ccd\u0ca8\u0cc1\u0c95\u0cca\u0cb3\u0ccd\u0cb3\u0cb2\u0ccb \u0ca4\u0ccd\u0caf\u0cbe\u0c97\u0cb0\u0cbe\u0c9c \u0ca8\u0cc1\u0ca4"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d2a\u0d30 \u0d32\u0d4b\u0d15 \u0d2d\u0d2f\u0d2e\u0d41 \u0d32\u0d47\u0d15 <br/> \u0d2d\u0d35 \u0d2a\u0d3e\u0d36 \u0d2c\u0d26\u0d4d\u0d27\u0d41\u0d32\u0d48\u0d2f\u0d47\u0d30\u0d41"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d15\u0d30\u0d3f \u0d35\u0d3e\u0d1c\u0d3f \u0d36\u0d43\u0d02\u0d17\u0d3e\u0d30\u0d3e\u0d30\u0d3e\u0d2e <br/> \u0d36\u0d3f\u0d2c\u0d3f\u0d15\u0d3e\u0d26\u0d41\u0d32\u0d46\u0d32\u0d4d\u0d32 \u0d2e\u0d28\u0d15\u0d47 \u0d15\u0d32\u0d3f\u0d17\u0d46\u0d28\u0d28\u0d3f"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d15\u0d4a\u0d28\u0d4d\u0d28 \u0d15\u0d3e\u0d28\u0d4d\u0d24\u0d32\u0d28\u0d41 \u0d15\u0d28\u0d4d\u0d28 \u0d2c\u0d3f\u0d21\u0d4d\u0d21\u0d32\u0d28\u0d41 <br/> \u0d35\u0d28\u0d4d\u0d28\u0d46 \u0d1a\u0d40\u0d30\u0d32\u0d28\u0d41 \u0d35\u0d3e\u0d28 \u0d17\u0d41\u0d21\u0d3f\u0d38\u0d46\u0d32\u0d28\u0d41 <br/> \u0d24\u0d3f\u0d28\u0d4d\u0d28\u0d17\u0d3e \u0d15\u0d28\u0d3f \u0d26\u0d48\u0d35 \u0d32\u0d4b\u0d15\u0d2e\u0d28\u0d3f <br/> \u0d24\u0d28\u0d4d\u0d28\u0d41\u0d15\u0d4a\u0d33\u0d4d\u0d33\u0d32\u0d4b \u0d24\u0d4d\u0d2f\u0d3e\u0d17\u0d30\u0d3e\u0d1c \u0d28\u0d41\u0d24"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u092a\u0930 \u0932\u094b\u0915 \u092d\u092f\u092e\u0941 \u0932\u0947\u0915 <br/> \u092d\u0935 \u092a\u093e\u0936 \u092c\u0926\u094d\u0927\u0941\u0932\u0948\u092f\u0947\u0930\u0941"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0915\u0930\u093f \u0935\u093e\u091c\u093f \u0936\u0943\u0902\u0917\u093e\u0930\u093e\u0930\u093e\u092e <br/> \u0936\u093f\u092c\u093f\u0915\u093e\u0926\u0941\u0932\u0947\u0932\u094d\u0932 \u092e\u0928\u0915\u0947 \u0915\u0932\u093f\u0917\u0947\u0928\u0928\u093f"}, {"M": "\u091a\u0930\u0923\u092e\u094d", "T": "\u0915\u094b\u0928\u094d\u0928 \u0915\u093e\u0928\u094d\u0924\u0932\u0928\u0941 \u0915\u0928\u094d\u0928 \u092c\u093f\u0921\u094d\u0921\u0932\u0928\u0941 <br/> \u0935\u0928\u094d\u0928\u0947 \u091a\u0940\u0930\u0932\u0928\u0941 \u0935\u093e\u0928 \u0917\u0941\u0921\u093f\u0938\u0947\u0932\u0928\u0941 <br/> \u0924\u093f\u0928\u094d\u0928\u0917\u093e \u0915\u0928\u093f \u0926\u0948\u0935 \u0932\u094b\u0915\u092e\u0928\u093f <br/> \u0924\u0928\u094d\u0928\u0941\u0915\u094b\u0932\u094d\u0932\u0932\u094b \u0924\u094d\u092f\u093e\u0917\u0930\u093e\u091c \u0928\u0941\u0924"}]}], "L": "l", "lyricsref": [{"links": [{"N": "thyagaraja-vaibhavam.blogspot.com", "L": "http://thyagaraja-vaibhavam.blogspot.com/2008/08/thyagaraja-kriti-paraloka-bhayamu-raga.html"}, {"N": "www.karnatik.com", "L": "http://www.karnatik.com/c2713.shtml"}, {"N": "www.shivkumar.org", "L": "http://www.shivkumar.org/music/paraloka-bhaya.htm"}]}]}