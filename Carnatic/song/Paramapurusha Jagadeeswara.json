u0cad\u0cc2\u0cb7\u0ca3 \u0cad\u0cc2\u0cb7\u0cbf\u0ca4 \u0ca6\u0cc7\u0cb9 <br/> \u0cad\u0cc1\u0c9c \u0caf\u0cc1\u0c97\u0cb3\u0ccb\u0ca6\u0ccd\u0ca7\u0caf\u0ca4 \u0cb6\u0c82\u0c95\u0cb0\u0ca6 \u0c9a\u0cb0\u0ca3 \u0cac\u0ccb\u0ca7\u0cbe\u0c95\u0cb0 \u0ca7\u0cc1\u0ca4\u0cae\u0ccb\u0cb9"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd 3", "T": "\u0c9a\u0cbe\u0cb0\u0cc1 \u0cb5\u0cbf\u0ca7\u0ccd\u0cb0\u0cc1\u0ca4 \u0cb5\u0ca8\u0cae\u0cbe\u0cb2\u0cbe \u0c95\u0ccc\u0cb8\u0ccd\u0ca4\u0cc1\u0cad \u0cb8\u0cbe\u0ca4\u0ccd\u0cb5\u0ca4 \u0c95\u0cae\u0cb2 \u0ca6\u0cbf\u0ca8\u0cc7\u0cb6 <br/> \u0cb8\u0cbe\u0cb0\u0c82\u0c97\u0cbe\u0ca7\u0cbf\u0caa \u0ca4\u0cbe\u0caa \u0cb5\u0cbf\u0cae\u0ccb\u0c9a\u0ca8 \u0cb8\u0ccd\u0caf\u0cbe\u0ca8\u0ca8\u0ccd\u0ca6\u0cc2\u0cb0\u0caa\u0cc1\u0cb0\u0cc7\u0cb6"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d2a\u0d30\u0d2e \u0d2a\u0d41\u0d30\u0d41\u0d37 \u0d1c\u0d17\u0d26\u0d40\u0d36\u0d4d\u0d35\u0d30 \u0d1c\u0d2f \u0d1c\u0d2f \u0d2a\u0d02\u0d15\u0d1c\u0d28\u0d3e\u0d2d \u0d2e\u0d41\u0d30\u0d3e\u0d30\u0d47"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d38\u0d30\u0d38\u0d40\u0d30\u0d41\u0d39 \u0d2d\u0d35 \u0d36\u0d02\u0d15\u0d30 \u0d35\u0d3e\u0d38\u0d35 \u0d38\u0d28\u0d4d\u0d28\u0d41\u0d24 \u0d1a\u0d30\u0d3f\u0d24 \u0d36\u0d4c\u0d30\u0d47"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 1", "T": "\u0d15\u0d32\u0d3f\u0d24\u0d26\u0d30 \u0d39\u0d38\u0d3f\u0d24 \u0d15\u0d2e\u0d4d\u0d30 \u0d2e\u0d41\u0d16\u0d3e\u0d2e\u0d4d\u0d2c\u0d41\u0d1c \u0d16\u0d17\u0d35\u0d30 \u0d35\u0d3e\u0d39\u0d28 \u0d26\u0d47\u0d35 <br/> \u0d16\u0d32\u0d26\u0d28\u0d41\u0d1c\u0d3e\u0d28\u0d4d\u0d24\u0d15 \u0d28\u0d3f\u0d1c\u0d2a\u0d26 \u0d38\u0d47\u0d35\u0d15 \u0d15\u0d32\u0d41\u0d37\u0d2e\u0d2f \u0d35\u0d28\u0d26\u0d3e\u0d35"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 2", "T": "\u0d2d\u0d41\u0d1c\u0d17\u0d3e\u0d27\u0d3f\u0d2a\u0d36\u0d2f \u0d2a\u0d41\u0d30\u0d1f\u0d2e\u0d2f \u0d35\u0d3f\u0d2e\u0d32 \u0d2d\u0d42\u0d37\u0d23 \u0d2d\u0d42\u0d37\u0d3f\u0d24 \u0d26\u0d47\u0d39 <br/> \u0d2d\u0d41\u0d1c \u0d2f\u0d41\u0d17\u0d33\u0d4b\u0d26\u0d4d\u0d27\u0d2f\u0d24 \u0d36\u0d02\u0d15\u0d30\u0d26 \u0d1a\u0d30\u0d23 \u0d2c\u0d4b\u0d27\u0d3e\u0d15\u0d30 \u0d27\u0d41\u0d24\u0d2e\u0d4b\u0d39"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 3", "T": "\u0d1a\u0d3e\u0d30\u0d41 \u0d35\u0d3f\u0d27\u0d4d\u0d30\u0d41\u0d24 \u0d35\u0d28\u0d2e\u0d3e\u0d32\u0d3e \u0d15\u0d4c\u0d38\u0d4d\u0d24\u0d41\u0d2d \u0d38\u0d3e\u0d24\u0d4d\u0d35\u0d24 \u0d15\u0d2e\u0d32 \u0d26\u0d3f\u0d28\u0d47\u0d36 <br/> \u0d38\u0d3e\u0d30\u0d02\u0d17\u0d3e\u0d27\u0d3f\u0d2a \u0d24\u0d3e\u0d2a \u0d35\u0d3f\u0d2e\u0d4b\u0d1a\u0d28 \u0d38\u0d4d\u0d2f\u0d3e\u0d28\u0d28\u0d4d\u0d26\u0d42\u0d30\u0d2a\u0d41\u0d30\u0d47\u0d36"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u092a\u0930\u092e \u092a\u0941\u0930\u0941\u0937 \u091c\u0917\u0926\u0940\u0936\u094d\u0935\u0930 \u091c\u092f \u091c\u092f \u092a\u0902\u0915\u091c\u0928\u093e\u092d \u092e\u0941\u0930\u093e\u0930\u0947"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0938\u0930\u0938\u0940\u0930\u0941\u0939 \u092d\u0935 \u0936\u0902\u0915\u0930 \u0935\u093e\u0938\u0935 \u0938\u0928\u094d\u0928\u0941\u0924 \u091a\u0930\u093f\u0924 \u0936\u094c\u0930\u0947"}, {"M": "\u091a\u0930\u0923\u092e\u094d 1", "T": "\u0915\u0932\u093f\u0924\u0926\u0930 \u0939\u0938\u093f\u0924 \u0915\u092e\u094d\u0930 \u092e\u0941\u0916\u093e\u092e\u094d\u092c\u0941\u091c \u0916\u0917\u0935\u0930 \u0935\u093e\u0939\u0928 \u0926\u0947\u0935 <br/> \u0916\u0932\u0926\u0928\u0941\u091c\u093e\u0928\u094d\u0924\u0915 \u0928\u093f\u091c\u092a\u0926 \u0938\u0947\u0935\u0915 \u0915\u0932\u0941\u0937\u092e\u092f \u0935\u0928\u0926\u093e\u0935"}, {"M": "\u091a\u0930\u0923\u092e\u094d 2", "T": "\u092d\u0941\u091c\u0917\u093e\u0927\u093f\u092a\u0936\u092f \u092a\u0941\u0930\u091f\u092e\u092f \u0935\u093f\u092e\u0932 \u092d\u0942\u0937\u0923 \u092d\u0942\u0937\u093f\u0924 \u0926\u0947\u0939 <br/> \u092d\u0941\u091c \u092f\u0941\u0917\u0932\u094b\u0926\u094d\u0927\u092f\u0924 \u0936\u0902\u0915\u0930\u0926 \u091a\u0930\u0923 \u092c\u094b\u0927\u093e\u0915\u0930 \u0927\u0941\u0924\u092e\u094b\u0939"}, {"M": "\u091a\u0930\u0923\u092e\u094d 3", "T": "\u091a\u093e\u0930\u0941 \u0935\u093f\u0927\u094d\u0930\u0941\u0924 \u0935\u0928\u092e\u093e\u0932\u093e \u0915\u094c\u0938\u094d\u0924\u0941\u092d \u0938\u093e\u0924\u094d\u0935\u0924 \u0915\u092e\u0932 \u0926\u093f\u0928\u0947\u0936 <br/> \u0938\u093e\u0930\u0902\u0917\u093e\u0927\u093f\u092a \u0924\u093e\u092a \u0935\u093f\u092e\u094b\u091a\u0928 \u0938\u094d\u092f\u093e\u0928\u0928\u094d\u0926\u0942\u0930\u092a\u0941\u0930\u0947\u0936"}]}], "L": "l", "lyricsref": [{"links": [{"N": "swathithirunalfestival.org", "L": "http://swathithirunalfestival.org/compositions/paramapurusha-jagadishwara"}]}]}