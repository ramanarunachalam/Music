bf\u0b95\u0bc7 \u0bae\u0bc1\u0b9a\u0bcd\u0b9a\u0b9f <br/> \u0baa\u0bbe\u0b95 \u0ba4\u0bc6\u0bb2\u0bc1\u0b9a\u0bc1\u0b95\u0bcb\u0bb0\u0bc7"}, {"M": "\u0b85\u0ba9\u0bc1\u0baa\u0bb2\u0bcd\u0bb2\u0bb5\u0bbf", "T": "\u0bb9\u0bb0\u0bbf\u0baf\u0b9f \u0bb9\u0bb0\u0bc1\u0b9f\u0b9f \u0b9a\u0bc1\u0bb0\u0bc1\u0bb2\u0b9f \u0ba8\u0bb0\u0bc1\u0bb2\u0b9f <br/> \u0b85\u0b95\u0bbf\u0bb2\u0bbe\u0ba3\u0bcd\u0b9f \u0b95\u0bcb\u0b9f\u0bc1\u0bb2\u0b9f \u0b85\u0ba8\u0bcd\u0ba4\u0bb0\u0bbf\u0bb2\u0bcb"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd", "T": "\u0b95\u0b95\u0ba9\u0bbe\u0ba9\u0bbf\u0bb2 \u0ba4\u0bc7\u0b9c\u0bcb-\u0b9c\u0bb2 \u0baa\u0bc2-\u0bae\u0baf\u0bae\u0b95\u0bc1 <br/> \u0bae\u0bcd\u0bb0\u0bc1\u0b95 \u0b95\u0b95 \u0ba8\u0b95 \u0ba4\u0bb0\u0bc1 \u0b95\u0bcb\u0b9f\u0bc1\u0bb2\u0bb2\u0bcb <br/> \u0b9a\u0b95\u0bc1\u0ba3\u0bae\u0bc1\u0bb2\u0bcb \u0bb5\u0bbf\u0b95\u0bc1\u0ba3\u0bae\u0bc1\u0bb2\u0bcb \u0b9a\u0ba4\u0ba4\u0bae\u0bc1 <br/> \u0b9a\u0bbe\u0ba4\u0bc1 \u0ba4\u0bcd\u0baf\u0bbe\u0b95\u0bb0\u0bbe\u0b9c\u0bbe\u0ba4\u0bbf \u0b86\u0bb6\u0bcd\u0bb0\u0bbf\u0ba4\u0bc1\u0bb2\u0bb2\u0bcb"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c2a\u0c30\u0c2e\u0c3e\u0c24\u0c4d\u0c2e\u0c41\u0c21\u0c41 \u0c35\u0c46\u0c32\u0c3f\u0c17\u0c47 \u0c2e\u0c41\u0c1a\u0c4d\u0c1a\u0c1f <br/> \u0c2c\u0c3e\u0c17 \u0c24\u0c46\u0c32\u0c41\u0c38\u0c41\u0c15\u0c4b\u0c30\u0c47"}, {"M": "\u0c05\u0c28\u0c41\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c39\u0c30\u0c3f\u0c2f\u0c1f \u0c39\u0c30\u0c41\u0c21\u0c1f \u0c38\u0c41\u0c30\u0c41\u0c32\u0c1f \u0c28\u0c30\u0c41\u0c32\u0c1f <br/> \u0c05\u0c16\u0c3f\u0c32\u0c3e\u0c23\u0c4d\u0c21 \u0c15\u0c4b\u0c1f\u0c41\u0c32\u0c1f \u0c05\u0c28\u0c4d\u0c26\u0c30\u0c3f\u0c32\u0c4b"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c17\u0c17\u0c28\u0c3e\u0c28\u0c3f\u0c32 \u0c24\u0c47\u0c1c\u0c4b-\u0c1c\u0c32 \u0c2d\u0c42-\u0c2e\u0c2f\u0c2e\u0c17\u0c41 <br/> \u0c2e\u0c43\u0c17 \u0c16\u0c17 \u0c28\u0c17 \u0c24\u0c30\u0c41 \u0c15\u0c4b\u0c1f\u0c41\u0c32\u0c32\u0c4b <br/> \u0c38\u0c17\u0c41\u0c23\u0c2e\u0c41\u0c32\u0c4b \u0c35\u0c3f\u0c17\u0c41\u0c23\u0c2e\u0c41\u0c32\u0c4b \u0c38\u0c24\u0c24\u0c2e\u0c41 <br/> \u0c38\u0c3e\u0c27\u0c41 \u0c24\u0c4d\u0c2f\u0c3e\u0c17\u0c30\u0c3e\u0c1c\u0c3e\u0c26\u0c3f \u0c06\u0c36\u0c4d\u0c30\u0c3f\u0c24\u0c41\u0c32\u0c32\u0c4b"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0caa\u0cb0\u0cae\u0cbe\u0ca4\u0ccd\u0cae\u0cc1\u0ca1\u0cc1 \u0cb5\u0cc6\u0cb2\u0cbf\u0c97\u0cc7 \u0cae\u0cc1\u0c9a\u0ccd\u0c9a\u0c9f <br/> \u0cac\u0cbe\u0c97 \u0ca4\u0cc6\u0cb2\u0cc1\u0cb8\u0cc1\u0c95\u0ccb\u0cb0\u0cc7"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cb9\u0cb0\u0cbf\u0caf\u0c9f \u0cb9\u0cb0\u0cc1\u0ca1\u0c9f \u0cb8\u0cc1\u0cb0\u0cc1\u0cb2\u0c9f \u0ca8\u0cb0\u0cc1\u0cb2\u0c9f <br/> \u0c85\u0c96\u0cbf\u0cb2\u0cbe\u0ca3\u0ccd\u0ca1 \u0c95\u0ccb\u0c9f\u0cc1\u0cb2\u0c9f \u0c85\u0ca8\u0ccd\u0ca6\u0cb0\u0cbf\u0cb2\u0ccb"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0c97\u0c97\u0ca8\u0cbe\u0ca8\u0cbf\u0cb2 \u0ca4\u0cc7\u0c9c\u0ccb-\u0c9c\u0cb2 \u0cad\u0cc2-\u0cae\u0caf\u0cae\u0c97\u0cc1 <br/> \u0cae\u0cc3\u0c97 \u0c96\u0c97 \u0ca8\u0c97 \u0ca4\u0cb0\u0cc1 \u0c95\u0ccb\u0c9f\u0cc1\u0cb2\u0cb2\u0ccb <br/> \u0cb8\u0c97\u0cc1\u0ca3\u0cae\u0cc1\u0cb2\u0ccb \u0cb5\u0cbf\u0c97\u0cc1\u0ca3\u0cae\u0cc1\u0cb2\u0ccb \u0cb8\u0ca4\u0ca4\u0cae\u0cc1 <br/> \u0cb8\u0cbe\u0ca7\u0cc1 \u0ca4\u0ccd\u0caf\u0cbe\u0c97\u0cb0\u0cbe\u0c9c\u0cbe\u0ca6\u0cbf \u0c86\u0cb6\u0ccd\u0cb0\u0cbf\u0ca4\u0cc1\u0cb2\u0cb2\u0ccb"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d2a\u0d30\u0d2e\u0d3e\u0d24\u0d4d\u0d2e\u0d41\u0d21\u0d41 \u0d35\u0d46\u0d32\u0d3f\u0d17\u0d47 \u0d2e\u0d41\u0d1a\u0d4d\u0d1a\u0d1f <br/> \u0d2c\u0d3e\u0d17 \u0d24\u0d46\u0d32\u0d41\u0d38\u0d41\u0d15\u0d4b\u0d30\u0d47"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d39\u0d30\u0d3f\u0d2f\u0d1f \u0d39\u0d30\u0d41\u0d21\u0d1f \u0d38\u0d41\u0d30\u0d41\u0d32\u0d1f \u0d28\u0d30\u0d41\u0d32\u0d1f <br/> \u0d05\u0d16\u0d3f\u0d32\u0d3e\u0d23\u0d4d\u0d21 \u0d15\u0d4b\u0d1f\u0d41\u0d32\u0d1f \u0d05\u0d28\u0d4d\u0d26\u0d30\u0d3f\u0d32\u0d4b"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d17\u0d17\u0d28\u0d3e\u0d28\u0d3f\u0d32 \u0d24\u0d47\u0d1c\u0d4b-\u0d1c\u0d32 \u0d2d\u0d42-\u0d2e\u0d2f\u0d2e\u0d17\u0d41 <br/> \u0d2e\u0d43\u0d17 \u0d16\u0d17 \u0d28\u0d17 \u0d24\u0d30\u0d41 \u0d15\u0d4b\u0d1f\u0d41\u0d32\u0d32\u0d4b <br/> \u0d38\u0d17\u0d41\u0d23\u0d2e\u0d41\u0d32\u0d4b \u0d35\u0d3f\u0d17\u0d41\u0d23\u0d2e\u0d41\u0d32\u0d4b \u0d38\u0d24\u0d24\u0d2e\u0d41 <br/> \u0d38\u0d3e\u0d27\u0d41 \u0d24\u0d4d\u0d2f\u0d3e\u0d17\u0d30\u0d3e\u0d1c\u0d3e\u0d26\u0d3f \u0d06\u0d36\u0d4d\u0d30\u0d3f\u0d24\u0d41\u0d32\u0d32\u0d4b"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u092a\u0930\u092e\u093e\u0924\u094d\u092e\u0941\u0921\u0941 \u0935\u0947\u0932\u093f\u0917\u0947 \u092e\u0941\u091a\u094d\u091a\u091f <br/> \u092c\u093e\u0917 \u0924\u0947\u0932\u0941\u0938\u0941\u0915\u094b\u0930\u0947"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0939\u0930\u093f\u092f\u091f \u0939\u0930\u0941\u0921\u091f \u0938\u0941\u0930\u0941\u0932\u091f \u0928\u0930\u0941\u0932\u091f <br/> \u0905\u0916\u093f\u0932\u093e\u0923\u094d\u0921 \u0915\u094b\u091f\u0941\u0932\u091f \u0905\u0928\u094d\u0926\u0930\u093f\u0932\u094b"}, {"M": "\u091a\u0930\u0923\u092e\u094d", "T": "\u0917\u0917\u0928\u093e\u0928\u093f\u0932 \u0924\u0947\u091c\u094b-\u091c\u0932 \u092d\u0942-\u092e\u092f\u092e\u0917\u0941 <br/> \u092e\u0943\u0917 \u0916\u0917 \u0928\u0917 \u0924\u0930\u0941 \u0915\u094b\u091f\u0941\u0932\u0932\u094b <br/> \u0938\u0917\u0941\u0923\u092e\u0941\u0932\u094b \u0935\u093f\u0917\u0941\u0923\u092e\u0941\u0932\u094b \u0938\u0924\u0924\u092e\u0941 <br/> \u0938\u093e\u0927\u0941 \u0924\u094d\u092f\u093e\u0917\u0930\u093e\u091c\u093e\u0926\u093f \u0906\u0936\u094d\u0930\u093f\u0924\u0941\u0932\u0932\u094b"}]}], "L": "l", "lyricsref": [{"links": [{"N": "thyagaraja-vaibhavam.blogspot.com", "L": "http://thyagaraja-vaibhavam.blogspot.com/2008/07/thyagaraja-kriti-paramatmudu-raga.html"}, {"N": "www.karnatik.com", "L": "http://www.karnatik.com/c2716.shtml"}, {"N": "www.sangeetasudha.org", "L": "http://www.sangeetasudha.org/thyagaraja/vol2/p.html#MARK_PARAMATMUDU"}]}]}