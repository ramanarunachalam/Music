u0bae\u0ba4\u0bbe\u0b99\u0bcd\u0b95\u0b9c \u0b9a\u0bbe\u0bb0\u0bc1\u0bb5\u0bbf\u0bb2\u0bbe\u0b9a\u0b95\u0ba4\u0bc7 \u0ba4\u0baa\u0ba9\u0bc0\u0baf \u0bb5\u0b9a\u0ba9 \u0bae\u0bc1\u0ba9\u0bbf- <br/> \u0bae\u0bbe\u0ba9\u0b9a \u0ba4\u0bbe\u0bae \u0bb0\u0b9a\u0bbe\u0bb2\u0baf \u0bae\u0ba3\u0bc0\u0bae\u0baf \u0bae\u0b95\u0bc1\u0b9f \u0baa\u0bb0\u0bbf\u0bb2\u0b9a\u0bbf\u0ba4"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd 3", "T": "\u0ba8\u0bc0\u0bb2 \u0b95\u0ba9\u0bcb\u0baa\u0bae \u0b9a\u0bc1\u0ba8\u0bcd\u0ba4\u0bb0 \u0ba4\u0bc7\u0bb9\u0bb0\u0bc1\u0b9a\u0bc7 \u0ba8\u0bbf\u0b95\u0bbf\u0bb2\u0bbe\u0bae\u0bb0 \u0baa\u0baf\u0bb9\u0bb0 <br/> \u0b9a\u0bc8\u0bb2 \u0b9a\u0bc1\u0ba4\u0bbe\u0ba4\u0bb5 \u0b9a\u0ba9\u0bcd\u0ba9\u0bc1\u0ba4 \u0b9a\u0bae\u0baf \u0bae\u0bae \u0b9a\u0b95\u0bb2 \u0b95\u0ba4\u0bae\u0bbf\u0bb9"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c2a\u0c30\u0c3f\u0c2a\u0c3e\u0c32\u0c2f \u0c2e\u0c3e\u0c2e\u0c4d \u0c36\u0c4d\u0c30\u0c40 \u0c2a\u0c26\u0c4d\u0c2e\u0c28\u0c3e\u0c2d \u0c2e\u0c41\u0c30\u0c3e\u0c30\u0c47"}, {"M": "\u0c05\u0c28\u0c41\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c36\u0c30\u0c23\u0c3e\u0c17\u0c24 \u0c2d\u0c30\u0c23\u0c4b\u0c24\u0c4d\u0c38\u0c41\u0c15 \u0c36\u0c3e\u0c30\u0c26 <br/> \u0c38\u0c4b\u0c2e \u0c38\u0c2e\u0c3e\u0c28 \u0c35\u0c3f\u0c30\u0c3f\u0c02\u0c1a \u0c38\u0c41\u0c30\u0c47\u0c36\u0c4d\u0c35\u0c30 \u0c38\u0c47\u0c35\u0c4d\u0c2f"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d 1", "T": "\u0c24\u0c3e\u0c2e\u0c30\u0c38\u0c3e\u0c2f\u0c24 \u0c32\u0c4b\u0c1a\u0c28 \u0c1a\u0c3e\u0c30\u0c41\u0c24\u0c28\u0c4b \u0c27\u0c30\u0c23\u0c40\u0c27\u0c30 \u0c27\u0c30\u0c35\u0c28- <br/> \u0c26\u0c3e\u0c2e \u0c35\u0c3f\u0c30\u0c3e\u0c1c\u0c3f\u0c24 \u0c26\u0c3e\u0c30\u0c41\u0c23\u0c26\u0c28\u0c41\u0c2d\u0c35 \u0c18\u0c28\u0c35\u0c3f\u0c2a\u0c3f\u0c28 \u0c26\u0c39\u0c28"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d 2", "T": "\u0c26\u0c3e\u0c28\u0c2e\u0c24\u0c3e\u0c02\u0c17\u0c1c \u0c1a\u0c3e\u0c30\u0c41\u0c35\u0c3f\u0c32\u0c3e\u0c38\u0c17\u0c24\u0c47 \u0c24\u0c2a\u0c28\u0c40\u0c2f \u0c35\u0c38\u0c28 \u0c2e\u0c41\u0c28\u0c3f- <br/> \u0c2e\u0c3e\u0c28\u0c38 \u0c24\u0c3e\u0c2e \u0c30\u0c38\u0c3e\u0c32\u0c2f \u0c2e\u0c23\u0c40\u0c2e\u0c2f \u0c2e\u0c15\u0c41\u0c1f \u0c2a\u0c30\u0c3f\u0c32\u0c38\u0c3f\u0c24"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d 3", "T": "\u0c28\u0c40\u0c32 \u0c18\u0c28\u0c4b\u0c2a\u0c2e \u0c38\u0c41\u0c28\u0c4d\u0c26\u0c30 \u0c26\u0c47\u0c39\u0c30\u0c41\u0c1a\u0c47 \u0c28\u0c3f\u0c16\u0c3f\u0c32\u0c3e\u0c2e\u0c30 \u0c2d\u0c2f\u0c39\u0c30 <br/> \u0c36\u0c48\u0c32 \u0c38\u0c41\u0c24\u0c3e\u0c27\u0c35 \u0c38\u0c28\u0c4d\u0c28\u0c41\u0c24 \u0c36\u0c2e\u0c2f \u0c2e\u0c2e \u0c38\u0c15\u0c32 \u0c17\u0c26\u0c2e\u0c3f\u0c39"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0caa\u0cb0\u0cbf\u0caa\u0cbe\u0cb2\u0caf \u0cae\u0cbe\u0cae\u0ccd \u0cb6\u0ccd\u0cb0\u0cc0 \u0caa\u0ca6\u0ccd\u0cae\u0ca8\u0cbe\u0cad \u0cae\u0cc1\u0cb0\u0cbe\u0cb0\u0cc7"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cb6\u0cb0\u0ca3\u0cbe\u0c97\u0ca4 \u0cad\u0cb0\u0ca3\u0ccb\u0ca4\u0ccd\u0cb8\u0cc1\u0c95 \u0cb6\u0cbe\u0cb0\u0ca6 <br/> \u0cb8\u0ccb\u0cae \u0cb8\u0cae\u0cbe\u0ca8 \u0cb5\u0cbf\u0cb0\u0cbf\u0c82\u0c9a \u0cb8\u0cc1\u0cb0\u0cc7\u0cb6\u0ccd\u0cb5\u0cb0 \u0cb8\u0cc7\u0cb5\u0ccd\u0caf"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd 1", "T": "\u0ca4\u0cbe\u0cae\u0cb0\u0cb8\u0cbe\u0caf\u0ca4 \u0cb2\u0ccb\u0c9a\u0ca8 \u0c9a\u0cbe\u0cb0\u0cc1\u0ca4\u0ca8\u0ccb \u0ca7\u0cb0\u0ca3\u0cc0\u0ca7\u0cb0 \u0ca7\u0cb0\u0cb5\u0ca8- <br/> \u0ca6\u0cbe\u0cae \u0cb5\u0cbf\u0cb0\u0cbe\u0c9c\u0cbf\u0ca4 \u0ca6\u0cbe\u0cb0\u0cc1\u0ca3\u0ca6\u0ca8\u0cc1\u0cad\u0cb5 \u0c98\u0ca8\u0cb5\u0cbf\u0caa\u0cbf\u0ca8 \u0ca6\u0cb9\u0ca8"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd 2", "T": "\u0ca6\u0cbe\u0ca8\u0cae\u0ca4\u0cbe\u0c82\u0c97\u0c9c \u0c9a\u0cbe\u0cb0\u0cc1\u0cb5\u0cbf\u0cb2\u0cbe\u0cb8\u0c97\u0ca4\u0cc7 \u0ca4\u0caa\u0ca8\u0cc0\u0caf \u0cb5\u0cb8\u0ca8 \u0cae\u0cc1\u0ca8\u0cbf