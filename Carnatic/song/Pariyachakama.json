", "T": "\u0b92\u0b95 \u0bae\u0bc1\u0ba9\u0bbf\u0b95\u0bc8 \u0ba4\u0bcd\u0bb0\u0bcc\u0baa\u0ba4\u0bbf \u0ba4\u0bcd\u0bb5\u0bbe\u0bb0\u0b95 \u0ba8\u0bbf\u0bb2\u0baf\u0bbe \u0b9a\u0bb0\u0ba3\u0ba9\u0b95 <br/> \u0b92\u0b95 \u0bae\u0bbe\u0b9f\u0b95\u0bc1 \u0bb5\u0bbf\u0baa\u0bc0\u0bb7\u0ba3\u0bc1\u0b9f\u0bc1 \u0b93\u0bb0\u0bcd\u0bb5 \u0bb2\u0bc7\u0b95 \u0b9a\u0bb0\u0ba3\u0ba9\u0b95 <br/> \u0b9a\u0b95\u0bb2\u0bc7\u0bb6\u0bcd\u0bb5\u0bb0 \u0baa\u0bcd\u0bb0\u0bb9\u0bcd\u0bb2\u0bbe\u0ba4\u0bc1\u0b9f\u0bc1 \u0b9c\u0bbe\u0bb2\u0bbf\u0b9a\u0bc7 \u0b9a\u0bb0\u0ba3\u0ba9\u0b95 <br/> \u0bb9\u0bbf\u0ba4-\u0b95\u0bb0\u0bc1\u0ba3\u0bcd\u0b9f\u0bc8 \u0baa\u0bcd\u0bb0\u0bcb\u0b9a\u0bbf\u0ba4\u0bbf\u0bb5\u0bc7 \u0ba4\u0bcd\u0baf\u0bbe\u0b95\u0bb0\u0bbe\u0b9c\u0bc1\u0ba9\u0bbf \u0bae\u0bbe\u0b9f"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c2a\u0c30\u0c3f\u0c2f\u0c3e\u0c1a\u0c15\u0c2e\u0c3e \u0c2e\u0c3e\u0c1f \u0c2a\u0c26\u0c3f-\u0c17\u0c41\u0c30\u0c3f\u0c32\u0c4b \u0c2a\u0c4a\u0c17\u0c21\u0c3f\u0c28\u0c26\u0c3f"}, {"M": "\u0c05\u0c28\u0c41\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c35\u0c46\u0c30\u0c2a\u0c41\u0c28\u0c28\u0c28\u0c41\u0c2e\u0c3e\u0c28\u0c2e\u0c4d\u0c2c\u0c41\u0c28 \u0c35\u0c46\u0c38\u0c28\u0c2e\u0c4d\u0c2c\u0c41\u0c28 \u0c28\u0c47 \u0c15\u0c4b\u0c30\u0c3f <br/> \u0c36\u0c30\u0c23\u0c3e\u0c17\u0c24 \u0c30\u0c15\u0c4d\u0c37\u0c15 \u0c28\u0c3f\u0c28\u0c4d\u0c28\u0c41 \u0c38\u0c28\u0c4d\u0c24\u0c24\u0c2e\u0c41\u0c28\u0c41 \u0c36\u0c30\u0c23\u0c28\u0c17"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c12\u0c15 \u0c2e\u0c41\u0c28\u0c3f\u0c15\u0c48 \u0c26\u0c4d\u0c30\u0c4c\u0c2a\u0c26\u0c3f \u0c26\u0c4d\u0c35\u0c3e\u0c30\u0c15 \u0c28\u0c3f\u0c32\u0c2f\u0c3e \u0c36\u0c30\u0c23\u0c28\u0c17 <br/> \u0c12\u0c15 \u0c2e\u0c3e\u0c1f\u0c15\u0c41 \u0c35\u0c3f\u0c2d\u0c40\u0c37\u0c23\u0c41\u0c21\u0c41 \u0c13\u0c30\u0c4d\u0c35 \u0c32\u0c47\u0c15 \u0c36\u0c30\u0c23\u0c28\u0c17 <br/> \u0c38\u0c15\u0c32\u0c47\u0c36\u0c4d\u0c35\u0c30 \u0c2a\u0c4d\u0c30\u0c39\u0c4d\u0c32\u0c3e\u0c26\u0c41\u0c21\u0c41 \u0c1c\u0c3e\u0c32\u0c3f\u0c1a\u0c47 \u0c36\u0c30\u0c23\u0c28\u0c17 <br/> \u0c39\u0c3f\u0c24-\u0c15\u0c30\u0c41\u0c23\u0c4d\u0c21\u0c48 \u0c2c\u0c4d\u0c30\u0c4b\u0c1a\u0c3f\u0c24\u0c3f\u0c35\u0c47 \u0c24\u0c4d\u0c2f\u0c3e\u0c17\u0c30\u0c3e\u0c1c\u0c41\u0c28\u0c3f \u0c2e\u0c3e\u0c1f"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0caa\u0cb0\u0cbf\u0caf\u0cbe\u0c9a\u0c95\u0cae\u0cbe \u0cae\u0cbe\u0c9f \u0caa\u0ca6\u0cbf-\u0c97\u0cc1\u0cb0\u0cbf\u0cb2\u0ccb \u0caa\u0cca\u0c97\u0ca1\u0cbf\u0ca8\u0ca6\u0cbf"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cb5\u0cc6\u0cb0\u0caa\u0cc1\u0ca8\u0ca8\u0ca8\u0cc1\u0cae\u0cbe\u0ca8\u0cae\u0ccd\u0cac\u0cc1\u0ca8 \u0cb5\u0cc6\u0cb8\u0ca8\u0cae\u0ccd\u0cac\u0cc1\u0ca8 \u0ca8\u0cc7 \u0c95\u0ccb\u0cb0\u0cbf <br/> \u0cb6\u0cb0\u0ca3\u0cbe\u0c97\u0ca4 \u0cb0\u0c95\u0ccd\u0cb7\u0c95 \u0ca8\u0cbf\u0ca8\u0ccd\u0ca8\u0cc1 \u0cb8\u0ca8\u0ccd\u0ca4\u0ca4\u0cae\u0cc1\u0ca8\u0cc1 \u0cb6\u0cb0\u0ca3\u0ca8\u0c97"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0c92\u0c95 \u0cae\u0cc1\u0ca8\u0cbf\u0c95\u0cc8 \u0ca6\u0ccd\u0cb0\u0ccc\u0caa\u0ca6\u0cbf \u0ca6\u0ccd\u0cb5\u0cbe\u0cb0\u0c95 \u0ca8\u0cbf\u0cb2\u0caf\u0cbe \u0cb6\u0cb0\u0ca3\u0ca8\u0c97 <br/> \u0c92\u0c95 \u0cae\u0cbe\u0c9f\u0c95\u0cc1 \u0cb5\u0cbf\u0cad\u0cc0\u0cb7\u0ca3\u0cc1\u0ca1\u0cc1 \u0c93\u0cb0\u0ccd\u0cb5 \u0cb2\u0cc7\u0c95 \u0cb6\u0cb0\u0ca3\u0ca8\u0c97 <br/> \u0cb8\u0c95\u0cb2\u0cc7\u0cb6\u0ccd\u0cb5\u0cb0 \u0caa\u0ccd\u0cb0\u0cb9\u0ccd\u0cb2\u0cbe\u0ca6\u0cc1\u0ca1\u0cc1 \u0c9c\u0cbe\u0cb2\u0cbf\u0c9a\u0cc7 \u0cb6\u0cb0\u0ca3\u0ca8\u0c97 <br/> \u0cb9\u0cbf\u0ca4-\u0c95\u0cb0\u0cc1\u0ca3\u0ccd\u0ca1\u0cc8 \u0cac\u0ccd\u0cb0\u0ccb\u0c9a\u0cbf\u0ca4\u0cbf\u0cb5\u0cc7 \u0ca4\u0ccd\u0caf\u0cbe\u0c97\u0cb0\u0cbe\u0c9c\u0cc1\u0ca8\u0cbf \u0cae\u0cbe\u0c9f"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d2a\u0d30\u0d3f\u0d2f\u0d3e\u0d1a\u0d15\u0d2e\u0d3e \u0d2e\u0d3e\u0d1f \u0d2a\u0d26\u0d3f-\u0d17\u0d41\u0d30\u0d3f\u0d32\u0d4b \u0d2a\u0d4a\u0d17\u0d21\u0d3f\u0d28\u0d26\u0d3f"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d35\u0d46\u0d30\u0d2a\u0d41\u0d28\u0d28\u0d28\u0d41\u0d2e\u0d3e\u0d28\u0d2e\u0d4d\u0d2c\u0d41\u0d28 \u0d35\u0d46\u0d38\u0d28\u0d2e\u0d4d\u0d2c\u0d41\u0d28 \u0d28\u0d47 \u0d15\u0d4b\u0d30\u0d3f <br/> \u0d36\u0d30\u0d23\u0d3e\u0d17\u0d24 \u0d30\u0d15\u0d4d\u0d37\u0d15 \u0d28\u0d3f\u0d28\u0d4d\u0d28\u0d41 \u0d38\u0d28\u0d4d\u0d24\u0d24\u0d2e\u0d41\u0d28\u0d41 \u0d36\u0d30\u0d23\u0d28\u0d17"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d12\u0d15 \u0d2e\u0d41\u0d28\u0d3f\u0d15\u0d48 \u0d26\u0d4d\u0d30\u0d4c\u0d2a\u0d26\u0d3f \u0d26\u0d4d\u0d35\u0d3e\u0d30\u0d15 \u0d28\u0d3f\u0d32\u0d2f\u0d3e \u0d36\u0d30\u0d23\u0d28\u0d17 <br/> \u0d12\u0d15 \u0d2e\u0d3e\u0d1f\u0d15\u0d41 \u0d35\u0d3f\u0d2d\u0d40\u0d37\u0d23\u0d41\u0d21\u0d41 \u0d13\u0d30\u0d4d\u0d35 \u0d32\u0d47\u0d15 \u0d36\u0d30\u0d23\u0d28\u0d17 <br/> \u0d38\u0d15\u0d32\u0d47\u0d36\u0d4d\u0d35\u0d30 \u0d2a\u0d4d\u0d30\u0d39\u0d4d\u0d32\u0d3e\u0d26\u0d41\u0d21\u0d41 \u0d1c\u0d3e\u0d32\u0d3f\u0d1a\u0d47 \u0d36\u0d30\u0d23\u0d28\u0d17 <br/> \u0d39\u0d3f\u0d24-\u0d15\u0d30\u0d41\u0d23\u0d4d\u0d21\u0d48 \u0d2c\u0d4d\u0d30\u0d4b\u0d1a\u0d3f\u0d24\u0d3f\u0d35\u0d47 \u0d24\u0d4d\u0d2f\u0d3e\u0d17\u0d30\u0d3e\u0d1c\u0d41\u0d28\u0d3f \u0d2e\u0d3e\u0d1f"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u092a\u0930\u093f\u092f\u093e\u091a\u0915\u092e\u093e \u092e\u093e\u091f \u092a\u0926\u093f-\u0917\u0941\u0930\u093f\u0932\u094b \u092a\u094b\u0917\u0921\u093f\u0928\u0926\u093f"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0935\u0947\u0930\u092a\u0941\u0928\u0928\u0928\u0941\u092e\u093e\u0928\u092e\u094d\u092c\u0941\u0928 \u0935\u0947\u0938\u0928\u092e\u094d\u092c\u0941\u0928 \u0928\u0947 \u0915\u094b\u0930\u093f <br/> \u0936\u0930\u0923\u093e\u0917\u0924 \u0930\u0915\u094d\u0937\u0915 \u0928\u093f\u0928\u094d\u0928\u0941 \u0938\u0928\u094d\u0924\u0924\u092e\u0941\u0928\u0941 \u0936\u0930\u0923\u0928\u0917"}, {"M": "\u091a\u0930\u0923\u092e\u094d", "T": "\u0913\u0915 \u092e\u0941\u0928\u093f\u0915\u0948 \u0926\u094d\u0930\u094c\u092a\u0926\u093f \u0926\u094d\u0935\u093e\u0930\u0915 \u0928\u093f\u0932\u092f\u093e \u0936\u0930\u0923\u0928\u0917 <br/> \u0913\u0915 \u092e\u093e\u091f\u0915\u0941 \u0935\u093f\u092d\u0940\u0937\u0923\u0941\u0921\u0941 \u0913\u0930\u094d\u0935 \u0932\u0947\u0915 \u0936\u0930\u0923\u0928\u0917 <br/> \u0938\u0915\u0932\u0947\u0936\u094d\u0935\u0930 \u092a\u094d\u0930\u0939\u094d\u0932\u093e\u0926\u0941\u0921\u0941 \u091c\u093e\u0932\u093f\u091a\u0947 \u0936\u0930\u0923\u0928\u0917 <br/> \u0939\u093f\u0924-\u0915\u0930\u0941\u0923\u094d\u0921\u0948 \u092c\u094d\u0930\u094b\u091a\u093f\u0924\u093f\u0935\u0947 \u0924\u094d\u092f\u093e\u0917\u0930\u093e\u091c\u0941\u0928\u093f \u092e\u093e\u091f"}]}], "L": "l", "lyricsref": [{"links": [{"N": "thyagaraja-vaibhavam.blogspot.com", "L": "http://thyagaraja-vaibhavam.blogspot.com/2008/10/thyagaraja-kriti-pariyaachakama-raga.html"}, {"N": "www.karnatik.com", "L": "http://www.karnatik.com/c2724.shtml"}]}]}