u0ba9 \u0b9a\u0ba4"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c30\u0c3e\u0c17 \u0c30\u0c24\u0c4d\u0c28 \u0c2e\u0c3e\u0c32\u0c3f\u0c15\u0c1a\u0c47 \u0c30\u0c28\u0c4d\u0c1c\u0c3f\u0c32\u0c4d\u0c32\u0c41\u0c28\u0c1f \u0c39\u0c30\u0c3f \u0c36\u0c24"}, {"M": "\u0c05\u0c28\u0c41\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c2c\u0c3e\u0c17 \u0c38\u0c47\u0c35\u0c3f\u0c28\u0c4d\u0c1a\u0c3f \u0c38\u0c15\u0c32 \u0c2d\u0c3e\u0c17\u0c4d\u0c2f\u0c2e\u0c28\u0c4d\u0c26\u0c41\u0c26\u0c3e\u0c2e\u0c41 \u0c30\u0c3e\u0c30\u0c47"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c28\u0c48\u0c17\u0c2e \u0c37\u0c1f\u0c4d-\u0c36\u0c3e\u0c38\u0c4d\u0c24\u0c4d\u0c30 \u0c2a\u0c41\u0c30\u0c3e\u0c23\u0c3e\u0c17\u0c2e\u0c3e\u0c30\u0c4d\u0c25 \u0c38\u0c39\u0c3f\u0c24\u0c2e\u0c1f <br/> \u0c2f\u0c4b\u0c17\u0c3f \u0c35\u0c30\u0c41\u0c32\u0c41 \u0c06\u0c28\u0c28\u0c4d\u0c26\u0c2e\u0c41\u0c28\u0c4a\u0c28\u0c4d\u0c26\u0c47 \u0c38\u0c28\u0c4d-\u0c2e\u0c3e\u0c30\u0c4d\u0c17\u0c2e\u0c1f <br/> \u0c2d\u0c3e\u0c17\u0c35\u0c24\u0c4b\u0c24\u0c4d\u0c24\u0c2e\u0c41\u0c32\u0c41 \u0c15\u0c42\u0c21\u0c3f \u0c2a\u0c3e\u0c21\u0c47 \u0c15\u0c40\u0c30\u0c4d\u0c24\u0c2e\u0c41\u0c32\u0c1f <br/> \u0c24\u0c4d\u0c2f\u0c3e\u0c17\u0c30\u0c3e\u0c1c\u0c41 \u0c15\u0c21 \u0c24\u0c47\u0c30 \u0c24\u0c3e\u0c30\u0c15\u0c2e\u0c28\u0c3f \u0c1a\u0c47\u0c38\u0c3f\u0c28 \u0c36\u0c24"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cb0\u0cbe\u0c97 \u0cb0\u0ca4\u0ccd\u0ca8 \u0cae\u0cbe\u0cb2\u0cbf\u0c95\u0c9a\u0cc7 \u0cb0\u0ca8\u0ccd\u0c9c\u0cbf\u0cb2\u0ccd\u0cb2\u0cc1\u0ca8\u0c9f \u0cb9\u0cb0\u0cbf \u0cb6\u0ca4"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cac\u0cbe\u0c97 \u0cb8\u0cc7\u0cb5\u0cbf\u0ca8\u0ccd\u0c9a\u0cbf \u0cb8\u0c95\u0cb2 \u0cad\u0cbe\u0c97\u0ccd\u0caf\u0cae\u0ca8\u0ccd\u0ca6\u0cc1\u0ca6\u0cbe\u0cae\u0cc1 \u0cb0\u0cbe\u0cb0\u0cc7"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0ca8\u0cc8\u0c97\u0cae \u0cb7\u0c9f\u0ccd-\u0cb6\u0cbe\u0cb8\u0ccd\u0ca4\u0ccd\u0cb0 \u0caa\u0cc1\u0cb0\u0cbe\u0ca3\u0cbe\u0c97\u0cae\u0cbe\u0cb0\u0ccd\u0ca5 \u0cb8\u0cb9\u0cbf\u0ca4\u0cae\u0c9f <br/> \u0caf\u0ccb\u0c97\u0cbf \u0cb5\u0cb0\u0cc1\u0cb2\u0cc1 \u0c86\u0ca8\u0ca8\u0ccd\u0ca6\u0cae\u0cc1\u0ca8\u0cca\u0ca8\u0ccd\u0ca6\u0cc7 \u0cb8\u0ca8\u0ccd-\u0cae\u0cbe\u0cb0\u0ccd\u0c97\u0cae\u0c9f <br/> \u0cad\u0cbe\u0c97\u0cb5\u0ca4\u0ccb\u0ca4\u0ccd\u0ca4\u0cae\u0cc1\u0cb2\u0cc1 \u0c95\u0cc2\u0ca1\u0cbf \u0caa\u0cbe\u0ca1\u0cc7 \u0c95\u0cc0\u0cb0\u0ccd\u0ca4\u0cae\u0cc1\u0cb2\u0c9f <br/> \u0ca4\u0ccd\u0caf\u0cbe\u0c97\u0cb0\u0cbe\u0c9c\u0cc1 \u0c95\u0ca1 \u0ca4\u0cc7\u0cb0 \u0ca4\u0cbe\u0cb0\u0c95\u0cae\u0ca8\u0cbf \u0c9a\u0cc7\u0cb8\u0cbf\u0ca8 \u0cb6\u0ca4"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d30\u0d3e\u0d17 \u0d30\u0d24\u0d4d\u0d28 \u0d2e\u0d3e\u0d32\u0d3f\u0d15\u0d1a\u0d47 \u0d30\u0d28\u0d4d\u0d1c\u0d3f\u0d32\u0d4d\u0d32\u0d41\u0d28\u0d1f \u0d39\u0d30\u0d3f \u0d36\u0d24"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d2c\u0d3e\u0d17 \u0d38\u0d47\u0d35\u0d3f\u0d28\u0d4d\u0d1a\u0d3f \u0d38\u0d15\u0d32 \u0d2d\u0d3e\u0d17\u0d4d\u0d2f\u0d2e\u0d28\u0d4d\u0d26\u0d41\u0d26\u0d3e\u0d2e\u0d41 \u0d30\u0d3e\u0d30\u0d47"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d28\u0d48\u0d17\u0d2e \u0d37\u0d1f\u0d4d-\u0d36\u0d3e\u0d38\u0d4d\u0d24\u0d4d\u0d30 \u0d2a\u0d41\u0d30\u0d3e\u0d23\u0d3e\u0d17\u0d2e\u0d3e\u0d30\u0d4d\u0d25 \u0d38\u0d39\u0d3f\u0d24\u0d2e\u0d1f <br/> \u0d2f\u0d4b\u0d17\u0d3f \u0d35\u0d30\u0d41\u0d32\u0d41 \u0d06\u0d28\u0d28\u0d4d\u0d26\u0d2e\u0d41\u0d28\u0d4a\u0d28\u0d4d\u0d26\u0d47 \u0d38\u0d28\u0d4d-\u0d2e\u0d3e\u0d30\u0d4d\u0d17\u0d2e\u0d1f <br/> \u0d2d\u0d3e\u0d17\u0d35\u0d24\u0d4b\u0d24\u0d4d\u0d24\u0d2e\u0d41\u0d32\u0d41 \u0d15\u0d42\u0d21\u0d3f \u0d2a\u0d3e\u0d21\u0d47 \u0d15\u0d40\u0d30\u0d4d\u0d24\u0d2e\u0d41\u0d32\u0d1f <br/> \u0d24\u0d4d\u0d2f\u0d3e\u0d17\u0d30\u0d3e\u0d1c\u0d41 \u0d15\u0d21 \u0d24\u0d47\u0d30 \u0d24\u0d3e\u0d30\u0d15\u0d2e\u0d28\u0d3f \u0d1a\u0d47\u0d38\u0d3f\u0d28 \u0d36\u0d24"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0930\u093e\u0917 \u0930\u0924\u094d\u0928 \u092e\u093e\u0932\u093f\u0915\u091a\u0947 \u0930\u0928\u094d\u091c\u093f\u0932\u094d\u0932\u0941\u0928\u091f \u0939\u0930\u093f \u0936\u0924"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u092c\u093e\u0917 \u0938\u0947\u0935\u093f\u0928\u094d\u091a\u093f \u0938\u0915\u0932 \u092d\u093e\u0917\u094d\u092f\u092e\u0928\u094d\u0926\u0941\u0926\u093e\u092e\u0941 \u0930\u093e\u0930\u0947"}, {"M": "\u091a\u0930\u0923\u092e\u094d", "T": "\u0928\u0948\u0917\u092e \u0937\u091f\u094d-\u0936\u093e\u0938\u094d\u0924\u094d\u0930 \u092a\u0941\u0930\u093e\u0923\u093e\u0917\u092e\u093e\u0930\u094d\u0925 \u0938\u0939\u093f\u0924\u092e\u091f <br/> \u092f\u094b\u0917\u093f \u0935\u0930\u0941\u0932\u0941 \u0906\u0928\u0928\u094d\u0926\u092e\u0941\u0928\u094b\u0928\u094d\u0926\u0947 \u0938\u0928\u094d-\u092e\u093e\u0930\u094d\u0917\u092e\u091f <br/> \u092d\u093e\u0917\u0935\u0924\u094b\u0924\u094d\u0924\u092e\u0941\u0932\u0941 \u0915\u0942\u0921\u093f \u092a\u093e\u0921\u0947 \u0915\u0940\u0930\u094d\u0924\u092e\u0941\u0932\u091f <br/> \u0924\u094d\u092f\u093e\u0917\u0930\u093e\u091c\u0941 \u0915\u0921 \u0924\u0947\u0930 \u0924\u093e\u0930\u0915\u092e\u0928\u093f \u091a\u0947\u0938\u093f\u0928 \u0936\u0924"}]}], "L": "l", "lyricsref": [{"links": [{"N": "thyagaraja-vaibhavam.blogspot.com", "L": "http://thyagaraja-vaibhavam.blogspot.com/2007/07/thyagaraja-kriti-raaga-ratna-raga.html"}, {"N": "www.karnatik.com", "L": "http://www.karnatik.com/c1077.shtml"}, {"N": "www.sangeetasudha.org", "L": "http://www.sangeetasudha.org/thyagaraja/vol2/r.html#MARK_RAGARATNA"}]}]}