0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c2f\u0c3e\u0c17 \u0c2f\u0c4b\u0c17 \u0c24\u0c4d\u0c2f\u0c3e\u0c17 \u0c2d\u0c4b\u0c17 <br/> \u0c2b\u0c32\u0c2e\u0c4a\u0c38\u0c02\u0c17\u0c47"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c38\u0c26\u0c3e\u0c36\u0c3f\u0c35 \u0c2e\u0c2f\u0c2e\u0c17\u0c41 <br/> \u0c28\u0c3e\u0c26\u0c4b\u0c02\u0c15\u0c3e\u0c30 \u0c38\u0c4d\u0c35\u0c30 <br/> \u0c35\u0c3f\u0c26\u0c41\u0c32\u0c41 \u0c1c\u0c40\u0c35\u0c28\u0c4d-\u0c2e\u0c41\u0c15\u0c4d\u0c24\u0c41\u0c32\u0c28\u0c3f <br/> \u0c24\u0c4d\u0c2f\u0c3e\u0c17\u0c30\u0c3e\u0c1c\u0c41 \u0c24\u0c46\u0c32\u0c3f\u0c2f\u0c41"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cb0\u0cbe\u0c97 \u0cb8\u0cc1\u0ca7\u0cbe \u0cb0\u0cb8 \u0caa\u0cbe\u0ca8\u0cae\u0cc1 \u0c9c\u0cc7\u0cb8\u0cbf <br/> \u0cb0\u0ca8\u0ccd\u0c9c\u0cbf\u0cb2\u0ccd\u0cb2\u0cb5\u0cc7 \u0c93 \u0cae\u0ca8\u0cb8\u0cbe"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0caf\u0cbe\u0c97 \u0caf\u0ccb\u0c97 \u0ca4\u0ccd\u0caf\u0cbe\u0c97 \u0cad\u0ccb\u0c97 <br/> \u0cab\u0cb2\u0cae\u0cca\u0cb8\u0c82\u0c97\u0cc7"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0cb8\u0ca6\u0cbe\u0cb6\u0cbf\u0cb5 \u0cae\u0caf\u0cae\u0c97\u0cc1 <br/> \u0ca8\u0cbe\u0ca6\u0ccb\u0c82\u0c95\u0cbe\u0cb0 \u0cb8\u0ccd\u0cb5\u0cb0 <br/> \u0cb5\u0cbf\u0ca6\u0cc1\u0cb2\u0cc1 \u0c9c\u0cc0\u0cb5\u0ca8\u0ccd-\u0cae\u0cc1\u0c95\u0ccd\u0ca4\u0cc1\u0cb2\u0ca8\u0cbf <br/> \u0ca4\u0ccd\u0caf\u0cbe\u0c97\u0cb0\u0cbe\u0c9c\u0cc1 \u0ca4\u0cc6\u0cb2\u0cbf\u0caf\u0cc1"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d30\u0d3e\u0d17 \u0d38\u0d41\u0d27\u0d3e \u0d30\u0d38 \u0d2a\u0d3e\u0d28\u0d2e\u0d41 \u0d1c\u0d47\u0d38\u0d3f <br/> \u0d30\u0d28\u0d4d\u0d1c\u0d3f\u0d32\u0d4d\u0d32\u0d35\u0d47 \u0d13 \u0d2e\u0d28\u0d38\u0d3e"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d2f\u0d3e\u0d17 \u0d2f\u0d4b\u0d17 \u0d24\u0d4d\u0d2f\u0d3e\u0d17 \u0d2d\u0d4b\u0d17 <br/> \u0d2b\u0d32\u0d2e\u0d4a\u0d38\u0d02\u0d17\u0d47"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d38\u0d26\u0d3e\u0d36\u0d3f\u0d35 \u0d2e\u0d2f\u0d2e\u0d17\u0d41 <br/> \u0d28\u0d3e\u0d26\u0d4b\u0d02\u0d15\u0d3e\u0d30 \u0d38\u0d4d\u0d35\u0d30 <br/> \u0d35\u0d3f\u0d26\u0d41\u0d32\u0d41 \u0d1c\u0d40\u0d35\u0d28\u0d4d-\u0d2e\u0d41\u0d15\u0d4d\u0d24\u0d41\u0d32\u0d28\u0d3f <br/> \u0d24\u0d4d\u0d2f\u0d3e\u0d17\u0d30\u0d3e\u0d1c\u0d41 \u0d24\u0d46\u0d32\u0d3f\u0d2f\u0d41"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0930\u093e\u0917 \u0938\u0941\u0927\u093e \u0930\u0938 \u092a\u093e\u0928\u092e\u0941 \u091c\u0947\u0938\u093f <br/> \u0930\u0928\u094d\u091c\u093f\u0932\u094d\u0932\u0935\u0947 \u0913 \u092e\u0928\u0938\u093e"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u092f\u093e\u0917 \u092f\u094b\u0917 \u0924\u094d\u092f\u093e\u0917 \u092d\u094b\u0917 <br/> \u092b\u0932\u092e\u094b\u0938\u0902\u0917\u0947"}, {"M": "\u091a\u0930\u0923\u092e\u094d", "T": "\u0938\u0926\u093e\u0936\u093f\u0935 \u092e\u092f\u092e\u0917\u0941 <br/> \u0928\u093e\u0926\u094b\u0902\u0915\u093e\u0930 \u0938\u094d\u0935\u0930 <br/> \u0935\u093f\u0926\u0941\u0932\u0941 \u091c\u0940\u0935\u0928\u094d-\u092e\u0941\u0915\u094d\u0924\u0941\u0932\u0928\u093f <br/> \u0924\u094d\u092f\u093e\u0917\u0930\u093e\u091c\u0941 \u0924\u0947\u0932\u093f\u092f\u0941"}]}], "L": "l", "lyricsref": [{"links": [{"N": "thyagaraja-vaibhavam.blogspot.com", "L": "http://thyagaraja-vaibhavam.blogspot.com/2007/09/thyagaraja-kriti-raga-sudhaa-raga.html"}, {"N": "www.karnatik.com", "L": "http://www.karnatik.com/c2735.shtml"}, {"N": "www.sangeetasudha.org", "L": "http://www.sangeetasudha.org/thyagaraja/vol2/r.html#MARK_RAGASUDHA"}]}]}