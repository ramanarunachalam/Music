u nAyaka nI pAda yuga <br/> rAjIvamula nE viDa jAla SrI"}, {"M": "anupallavi", "T": "agha jAlamula bAra-dOli <br/> nannAdarimpa nIvE gati kAda SrI"}, {"M": "caraNam", "T": "bhava sAgaramu dATa lEka nE <br/> balu gAsi-paDi nI marugu jEritini <br/> avanijAdhipASrita rakshaka <br/> Ananda-kara SrI tyAgarAja nuta"}]}, {"L": "Tamil", "text": [{"M": "\u0baa\u0bb2\u0bcd\u0bb2\u0bb5\u0bbf", "T": "\u0bb0\u0b95\u0bc1 \u0ba8\u0bbe\u0baf\u0b95 \u0ba8\u0bc0 \u0baa\u0bbe\u0ba4 \u0baf\u0bc1\u0b95 <br/> \u0bb0\u0bbe\u0b9c\u0bc0\u0bb5\u0bae\u0bc1\u0bb2 \u0ba8\u0bc7 \u0bb5\u0bbf\u0b9f \u0b9c\u0bbe\u0bb2 \u0bb6\u0bcd\u0bb0\u0bc0"}, {"M": "\u0b85\u0ba9\u0bc1\u0baa\u0bb2\u0bcd\u0bb2\u0bb5\u0bbf", "T": "\u0b85\u0b95 \u0b9c\u0bbe\u0bb2\u0bae\u0bc1\u0bb2 \u0baa\u0bbe\u0bb0-\u0ba4\u0bcb\u0bb2\u0bbf <br/> \u0ba8\u0ba9\u0bcd\u0ba9\u0bbe\u0ba4\u0bb0\u0bbf\u0bae\u0bcd\u0baa \u0ba8\u0bc0\u0bb5\u0bc7 \u0b95\u0ba4\u0bbf \u0b95\u0bbe\u0ba4 \u0bb6\u0bcd\u0bb0\u0bc0"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd", "T": "\u0baa\u0bb5 \u0b9a\u0bbe\u0b95\u0bb0\u0bae\u0bc1 \u0ba4\u0bbe\u0b9f \u0bb2\u0bc7\u0b95 \u0ba8\u0bc7 <br/> \u0baa\u0bb2\u0bc1 \u0b95\u0bbe\u0b9a\u0bbf-\u0baa\u0b9f\u0bbf \u0ba8\u0bc0 \u0bae\u0bb0\u0bc1\u0b95\u0bc1 \u0b9c\u0bc7\u0bb0\u0bbf\u0ba4\u0bbf\u0ba9\u0bbf <br/> \u0b85\u0bb5\u0ba9\u0bbf\u0b9c\u0bbe\u0ba4\u0bbf\u0baa\u0bbe\u0bb6\u0bcd\u0bb0\u0bbf\u0ba4 \u0bb0\u0b95\u0bcd\u0bb7\u0b95 <br/> \u0b86\u0ba9\u0ba8\u0bcd\u0ba4-\u0b95\u0bb0 \u0bb6\u0bcd\u0bb0\u0bc0 \u0ba4\u0bcd\u0baf\u0bbe\u0b95\u0bb0\u0bbe\u0b9c \u0ba8\u0bc1\u0ba4"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c30\u0c18\u0c41 \u0c28\u0c3e\u0c2f\u0c15 \u0c28\u0c40 \u0c2a\u0c3e\u0c26 \u0c2f\u0c41\u0c17 <br/> \u0c30\u0c3e\u0c1c\u0c40\u0c35\u0c2e\u0c41\u0c32 \u0c28\u0c47 \u0c35\u0c3f\u0c21 \u0c1c\u0c3e\u0c32 \u0c36\u0c4d\u0c30\u0c40"}, {"M": "\u0c05\u0c28\u0c41\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c05\u0c18 \u0c1c\u0c3e\u0c32\u0c2e\u0c41\u0c32 \u0c2c\u0c3e\u0c30-\u0c26\u0c4b\u0c32\u0c3f <br/> \u0c28\u0c28\u0c4d\u0c28\u0c3e\u0c26\u0c30\u0c3f\u0c2e\u0c4d\u0c2a \u0c28\u0c40\u0c35\u0c47 \u0c17\u0c24\u0c3f \u0c15\u0c3e\u0c26 \u0c36\u0c4d\u0c30\u0c40"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c2d\u0c35 \u0c38\u0c3e\u0c17\u0c30\u0c2e\u0c41 \u0c26\u0c3e\u0c1f \u0c32\u0c47\u0c15 \u0c28\u0c47 <br/> \u0c2c\u0c32\u0c41 \u0c17\u0c3e\u0c38\u0c3f-\u0c2a\u0c21\u0c3f \u0c28\u0c40 \u0c2e\u0c30\u0c41\u0c17\u0c41 \u0c1c\u0c47\u0c30\u0c3f\u0c24\u0c3f\u0c28\u0c3f <br/> \u0c05\u0c35\u0c28\u0c3f\u0c1c\u0c3e\u0c27\u0c3f\u0c2a\u0c3e\u0c36\u0c4d\u0c30\u0c3f\u0c24 \u0c30\u0c15\u0c4d\u0c37\u0c15 <br/> \u0c06\u0c28\u0c28\u0c4d\u0c26-\u0c15\u0c30 \u0c36\u0c4d\u0c30\u0c40 \u0c24\u0c4d\u0c2f\u0c3e\u0c17\u0c30\u0c3e\u0c1c \u0c28\u0c41\u0c24"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cb0\u0c98\u0cc1 \u0ca8\u0cbe\u0caf\u0c95 \u0ca8\u0cc0 \u0caa\u0cbe\u0ca6 \u0caf\u0cc1\u0c97 <br/> \u0cb0\u0cbe\u0c9c\u0cc0\u0cb5\u0cae\u0cc1\u0cb2 \u0ca8\u0cc7 \u0cb5\u0cbf\u0ca1 \u0c9c\u0cbe\u0cb2 \u0cb6\u0ccd\u0cb0\u0cc0"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0c85\u0c98 \u0c9c\u0cbe\u0cb2\u0cae\u0cc1\u0cb2 \u0cac\u0cbe\u0cb0-\u0ca6\u0ccb\u0cb2\u0cbf <br/> \u0ca8\u0ca8\u0ccd\u0ca8\u0cbe\u0ca6\u0cb0\u0cbf\u0cae\u0ccd\u0caa \u0ca8\u0cc0\u0cb5\u0cc7 \u0c97\u0ca4\u0cbf \u0c95\u0cbe\u0ca6 \u0cb6\u0ccd\u0cb0\u0cc0"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0cad\u0cb5 \u0cb8\u0cbe\u0c97\u0cb0\u0cae\u0cc1 \u0ca6\u0cbe\u0c9f \u0cb2\u0cc7\u0c95 \u0ca8\u0cc7 <br/> \u0cac\u0cb2\u0cc1 \u0c97\u0cbe\u0cb8\u0cbf-\u0caa\u0ca1\u0cbf \u0ca8\u0cc0 \u0cae\u0cb0\u0cc1\u0c97\u0cc1 \u0c9c\u0cc7\u0cb0\u0cbf\u0ca4\u0cbf\u0ca8\u0cbf <br/> \u0c85\u0cb5\u0ca8\u0cbf\u0c9c\u0cbe\u0ca7\u0cbf\u0caa\u0cbe\u0cb6\u0ccd\u0cb0\u0cbf\u0ca4 \u0cb0\u0c95\u0ccd\u0cb7\u0c95 <br/> \u0c86\u0ca8\u0ca8\u0ccd\u0ca6-\u0c95\u0cb0 \u0cb6\u0ccd\u0cb0\u0cc0 \u0ca4\u0ccd\u0caf\u0cbe\u0c97\u0cb0\u0cbe\u0c9c \u0ca8\u0cc1\u0ca4"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d30\u0d18\u0d41 \u0d28\u0d3e\u0d2f\u0d15 \u0d28\u0d40 \u0d2a\u0d3e\u0d26 \u0d2f\u0d41\u0d17 <br/> \u0d30\u0d3e\u0d1c\u0d40\u0d35\u0d2e\u0d41\u0d32 \u0d28\u0d47 \u0d35\u0d3f\u0d21 \u0d1c\u0d3e\u0d32 \u0d36\u0d4d\u0d30\u0d40"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d05\u0d18 \u0d1c\u0d3e\u0d32\u0d2e\u0d41\u0d32 \u0d2c\u0d3e\u0d30-\u0d26\u0d4b\u0d32\u0d3f <br/> \u0d28\u0d28\u0d4d\u0d28\u0d3e\u0d26\u0d30\u0d3f\u0d2e\u0d4d\u0d2a \u0d28\u0d40\u0d35\u0d47 \u0d17\u0d24\u0d3f \u0d15\u0d3e\u0d26 \u0d36\u0d4d\u0d30\u0d40"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d2d\u0d35 \u0d38\u0d3e\u0d17\u0d30\u0d2e\u0d41 \u0d26\u0d3e\u0d1f \u0d32\u0d47\u0d15 \u0d28\u0d47 <br/> \u0d2c\u0d32\u0d41 \u0d17\u0d3e\u0d38\u0d3f-\u0d2a\u0d21\u0d3f \u0d28\u0d40 \u0d2e\u0d30\u0d41\u0d17\u0d41 \u0d1c\u0d47\u0d30\u0d3f\u0d24\u0d3f\u0d28\u0d3f <br/> \u0d05\u0d35\u0d28\u0d3f\u0d1c\u0d3e\u0d27\u0d3f\u0d2a\u0d3e\u0d36\u0d4d\u0d30\u0d3f\u0d24 \u0d30\u0d15\u0d4d\u0d37\u0d15 <br/> \u0d06\u0d28\u0d28\u0d4d\u0d26-\u0d15\u0d30 \u0d36\u0d4d\u0d30\u0d40 \u0d24\u0d4d\u0d2f\u0d3e\u0d17\u0d30\u0d3e\u0d1c \u0d28\u0d41\u0d24"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0930\u0918\u0941 \u0928\u093e\u092f\u0915 \u0928\u0940 \u092a\u093e\u0926 \u092f\u0941\u0917 <br/> \u0930\u093e\u091c\u0940\u0935\u092e\u0941\u0932 \u0928\u0947 \u0935\u093f\u0921 \u091c\u093e\u0932 \u0936\u094d\u0930\u0940"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0905\u0918 \u091c\u093e\u0932\u092e\u0941\u0932 \u092c\u093e\u0930-\u0926\u094b\u0932\u093f <br/> \u0928\u0928\u094d\u0928\u093e\u0926\u0930\u093f\u092e\u094d\u092a \u0928\u0940\u0935\u0947 \u0917\u0924\u093f \u0915\u093e\u0926 \u0936\u094d\u0930\u0940"}, {"M": "\u091a\u0930\u0923\u092e\u094d", "T": "\u092d\u0935 \u0938\u093e\u0917\u0930\u092e\u0941 \u0926\u093e\u091f \u0932\u0947\u0915 \u0928\u0947 <br/> \u092c\u0932\u0941 \u0917\u093e\u0938\u093f-\u092a\u0921\u093f \u0928\u0940 \u092e\u0930\u0941\u0917\u0941 \u091c\u0947\u0930\u093f\u0924\u093f\u0928\u093f <br/> \u0905\u0935\u0928\u093f\u091c\u093e\u0927\u093f\u092a\u093e\u0936\u094d\u0930\u093f\u0924 \u0930\u0915\u094d\u0937\u0915 <br/> \u0906\u0928\u0928\u094d\u0926-\u0915\u0930 \u0936\u094d\u0930\u0940 \u0924\u094d\u092f\u093e\u0917\u0930\u093e\u091c \u0928\u0941\u0924"}]}], "L": "l", "lyricsref": [{"links": [{"N": "thyagaraja-vaibhavam.blogspot.com", "L": "http://thyagaraja-vaibhavam.blogspot.com/2008/07/thyagaraja-kriti-raghu-nayaka-raga.html"}, {"N": "www.karnatik.com", "L": "http://www.karnatik.com/c2455.shtml"}, {"N": "www.sangeetasudha.org", "L": "http://www.sangeetasudha.org/thyagaraja/r.html#MARK_RAGHUNAYAKA"}, {"N": "www.shivkumar.org", "L": "http://www.shivkumar.org/music/raghunayaka.htm"}]}]}