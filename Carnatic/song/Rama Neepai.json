br/> \u0c2c\u0c3e\u0c17\u0c41\u0c17 \u0c2c\u0c41\u0c26\u0c4d\u0c27\u0c3f \u0c28\u0c40\u0c2f\u0c28\u0c4d\u0c26\u0c41 <br/> \u0c24\u0c4d\u0c2f\u0c3e\u0c17\u0c30\u0c3e\u0c1c\u0c41\u0c28\u0c3f \u0c39\u0c43\u0c26\u0c2f\u0c2e\u0c28\u0c4d\u0c26\u0c41 <br/> \u0c35\u0c3e\u0c17\u0c4d-\u0c08\u0c36\u0c3e\u0c28\u0c28\u0c4d\u0c26\u0c2e\u0c28\u0c4d\u0c26\u0c41"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cb0\u0cbe\u0cae \u0ca8\u0cc0\u0caa\u0cc8 \u0ca4\u0ca8\u0c95\u0cc1 \u0caa\u0ccd\u0cb0\u0cc7\u0cae \u0caa\u0ccb\u0ca6\u0cc1 \u0cb8\u0cc0\u0ca4\u0cbe \u0cb0\u0cbe\u0cae"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0ca4\u0cbe\u0cae\u0cb0\u0cb8 \u0ca8\u0caf\u0ca8 \u0ca8\u0cc0\u0ca6\u0cc7\u0cae\u0ccb \u0cae\u0cbe\u0caf \u0c95\u0cbe\u0ca8\u0cbf"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd 1", "T": "\u0cae\u0ca8\u0cb8\u0cc1 \u0ca8\u0cc0 \u0caa\u0ca6\u0cae\u0cc1\u0cb2\u0ca8\u0cc7 \u0c9c\u0cc7\u0cb0 <br/> \u0c95\u0ca8\u0cc1\u0cb2\u0cc1 \u0ca8\u0cc0 \u0cb0\u0cc2\u0caa\u0cae\u0cc1\u0ca8\u0cc7 \u0c95\u0ccb\u0cb0 <br/> \u0cb5\u0cbf\u0ca8\u0cc1 \u0ca8\u0cc0 \u0caa\u0cc7\u0cb0\u0cc1\u0cb2\u0c95\u0cc7 \u0ca8\u0ccb\u0cb0\u0cc2\u0cb0 <br/> \u0ca4\u0ca8\u0caa\u0cc8 \u0c87\u0ca6\u0cbf \u0ca8\u0cc0 \u0c95\u0cb0\u0cc1\u0ca3\u0cc7\u0cb0\u0cbe"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd 2", "T": "\u0c9c\u0ca8\u0ca8\u0cbf \u0c9c\u0ca8\u0c95\u0cbe\u0caa\u0ccd\u0ca4\u0cc1\u0cb2\u0ca8\u0ccd\u0caf\u0cc1\u0cb2\u0cc1 <br/> \u0ca7\u0ca8 \u0c95\u0ca8\u0c95 \u0c97\u0cc1\u0cb0\u0cc1 \u0cb5\u0cc7\u0cb2\u0ccd\u0caa\u0cc1\u0cb2\u0cc1 <br/> \u0ca6\u0cbf\u0ca8\u0cae\u0cc1 \u0ca8\u0cc0\u0cb5\u0cc7\u0caf\u0ca8\u0cbf \u0cae\u0cbe\u0c9f\u0cb2\u0cc1 <br/> \u0c85\u0ca8\u0c98 \u0c87\u0cb5\u0cbf \u0ca8\u0cbe \u0cad\u0cc2\u0cb7\u0ca3\u0cae\u0cc1\u0cb2\u0cc1"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd 3", "T": "\u0cad\u0ccb\u0c97\u0cbe\u0ca8\u0cc1\u0cad\u0cb5\u0cae\u0cc1\u0cb2\u0ca8\u0ccd\u0ca6\u0cc1 <br/> \u0cac\u0cbe\u0c97\u0cc1\u0c97 \u0cac\u0cc1\u0ca6\u0ccd\u0ca7\u0cbf \u0ca8\u0cc0\u0caf\u0ca8\u0ccd\u0ca6\u0cc1 <br/> \u0ca4\u0ccd\u0caf\u0cbe\u0c97\u0cb0\u0cbe\u0c9c\u0cc1\u0ca8\u0cbf \u0cb9\u0cc3\u0ca6\u0caf\u0cae\u0ca8\u0ccd\u0ca6\u0cc1 <br/> \u0cb5\u0cbe\u0c97\u0ccd-\u0c88\u0cb6\u0cbe\u0ca8\u0ca8\u0ccd\u0ca6\u0cae\u0ca8\u0ccd\u0ca6\u0cc1"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d30\u0d3e\u0d2e \u0d28\u0d40\u0d2a\u0d48 \u0d24\u0d28\u0d15\u0d41 \u0d2a\u0d4d\u0d30\u0d47\u0d2e \u0d2a\u0d4b\u0d26\u0d41 \u0d38\u0d40\u0d24\u0d3e \u0d30\u0d3e\u0d2e"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d24\u0d3e\u0d2e\u0d30\u0d38 \u0d28\u0d2f\u0d28 \u0d28\u0d40\u0d26\u0d47\u0d2e\u0d4b \u0d2e\u0d3e\u0d2f \u0d15\u0d3e\u0d28\u0d3f"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 1", "T": "\u0d2e\u0d28\u0d38\u0d41 \u0d28\u0d40 \u0d2a\u0d26\u0d2e\u0d41\u0d32\u0d28\u0d47 \u0d1c\u0d47\u0d30 <br/> \u0d15\u0d28\u0d41\u0d32\u0d41 \u0d28\u0d40 \u0d30\u0d42\u0d2a\u0d2e\u0d41\u0d28\u0d47 \u0d15\u0d4b\u0d30 <br/> \u0d35\u0d3f\u0d28\u0d41 \u0d28\u0d40 \u0d2a\u0d47\u0d30\u0d41\u0d32\u0d15\u0d47 \u0d28\u0d4b\u0d30\u0d42\u0d30 <br/> \u0d24\u0d28\u0d2a\u0d48 \u0d07\u0d26\u0d3f \u0d28\u0d40 \u0d15\u0d30\u0d41\u0d23\u0d47\u0d30\u0d3e"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 2", "T": "\u0d1c\u0d28\u0d28\u0d3f \u0d1c\u0d28\u0d15\u0d3e\u0d2a\u0d4d\u0d24\u0d41\u0d32\u0d28\u0d4d\u0d2f\u0d41\u0d32\u0d41 <br/> \u0d27\u0d28 \u0d15\u0d28\u0d15 \u0d17\u0d41\u0d30\u0d41 \u0d35\u0d47\u0d32\u0d4d\u0d2a\u0d41\u0d32\u0d41 <br/> \u0d26\u0d3f\u0d28\u0d2e\u0d41 \u0d28\u0d40\u0d35\u0d47\u0d2f\u0d28\u0d3f \u0d2e\u0d3e\u0d1f\u0d32\u0d41 <br/> \u0d05\u0d28\u0d18 \u0d07\u0d35\u0d3f \u0d28\u0d3e \u0d2d\u0d42\u0d37\u0d23\u0d2e\u0d41\u0d32\u0d41"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 3", "T": "\u0d2d\u0d4b\u0d17\u0d3e\u0d28\u0d41\u0d2d\u0d35\u0d2e\u0d41\u0d32\u0d28\u0d4d\u0d26\u0d41 <br/> \u0d2c\u0d3e\u0d17\u0d41\u0d17 \u0d2c\u0d41\u0d26\u0d4d\u0d27\u0d3f \u0d28\u0d40\u0d2f\u0d28\u0d4d\u0d26\u0d41 <br/> \u0d24\u0d4d\u0d2f\u0d3e\u0d17\u0d30\u0d3e\u0d1c\u0d41\u0d28\u0d3f \u0d39\u0d43\u0d26\u0d2f\u0d2e\u0d28\u0d4d\u0d26\u0d41 <br/> \u0d35\u0d3e\u0d17\u0d4d-\u0d08\u0d36\u0d3e\u0d28\u0d28\u0d4d\u0d26\u0d2e\u0d28\u0d4d\u0d26\u0d41"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0930\u093e\u092e \u0928\u0940\u092a\u0948 \u0924\u0928\u0915\u0941 \u092a\u094d\u0930\u0947\u092e \u092a\u094b\u0926\u0941 \u0938\u0940\u0924\u093e \u0930\u093e\u092e"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0924\u093e\u092e\u0930\u0938 \u0928\u092f\u0928 \u0928\u0940\u0926\u0947\u092e\u094b \u092e\u093e\u092f \u0915\u093e\u0928\u093f"}, {"M": "\u091a\u0930\u0923\u092e\u094d 1", "T": "\u092e\u0928\u0938\u0941 \u0928\u0940 \u092a\u0926\u092e\u0941\u0932\u0928\u0947 \u091c\u0947\u0930 <br/> \u0915\u0928\u0941\u0932\u0941 \u0928\u0940 \u0930\u0942\u092a\u092e\u0941\u0928\u0947 \u0915\u094b\u0930 <br/> \u0935\u093f\u0928\u0941 \u0928\u0940 \u092a\u0947\u0930\u0941\u0932\u0915\u0947 \u0928\u094b\u0930\u0942\u0930 <br/> \u0924\u0928\u092a\u0948 \u0907\u0926\u093f \u0928\u0940 \u0915\u0930\u0941\u0923\u0947\u0930\u093e"}, {"M": "\u091a\u0930\u0923\u092e\u094d 2", "T": "\u091c\u0928\u0928\u093f \u091c\u0928\u0915\u093e\u092a\u094d\u0924\u0941\u0932\u0928\u094d\u092f\u0941\u0932\u0941 <br/> \u0927\u0928 \u0915\u0928\u0915 \u0917\u0941\u0930\u0941 \u0935\u0947\u0932\u094d\u092a\u0941\u0932\u0941 <br/> \u0926\u093f\u0928\u092e\u0941 \u0928\u0940\u0935\u0947\u092f\u0928\u093f \u092e\u093e\u091f\u0932\u0941 <br/> \u0905\u0928\u0918 \u0907\u0935\u093f \u0928\u093e \u092d\u0942\u0937\u0923\u092e\u0941\u0932\u0941"}, {"M": "\u091a\u0930\u0923\u092e\u094d 3", "T": "\u092d\u094b\u0917\u093e\u0928\u0941\u092d\u0935\u092e\u0941\u0932\u0928\u094d\u0926\u0941 <br/> \u092c\u093e\u0917\u0941\u0917 \u092c\u0941\u0926\u094d\u0927\u093f \u0928\u0940\u092f\u0928\u094d\u0926\u0941 <br/> \u0924\u094d\u092f\u093e\u0917\u0930\u093e\u091c\u0941\u0928\u093f \u0939\u0943\u0926\u092f\u092e\u0928\u094d\u0926\u0941 <br/> \u0935\u093e\u0917\u094d-\u0908\u0936\u093e\u0928\u0928\u094d\u0926\u092e\u0928\u094d\u0926\u0941"}]}], "L": "l", "lyricsref": [{"links": [{"N": "thyagaraja-vaibhavam.blogspot.com", "L": "http://thyagaraja-vaibhavam.blogspot.com/2008/05/thyagaraja-kriti-rama-neepai-thanaku.html"}, {"N": "www.shivkumar.org", "L": "http://www.shivkumar.org/music/ramanipai2.htm"}, {"N": "www.karnatik.com", "L": "http://www.karnatik.com/c2760.shtml"}, {"N": "www.sangeetasudha.org", "L": "http://www.sangeetasudha.org/thyagaraja/vol2/r.html#MARK_RAMANEEPAI"}]}]}