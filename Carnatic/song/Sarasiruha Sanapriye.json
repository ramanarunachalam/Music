0b9a\u0bbe\u0bae\u0ba4 \u0b95\u0bc1\u0bae\u0bcd\u0baa\u0bb8\u0bcd\u0ba4\u0ba9 \u0baf\u0bc1\u0b95\u0bb3\u0bc7 \u0ba4\u0bb5\u0bb3\u0bc7 <br/> \u0b9a\u0b95\u0bb2 \u0b9a\u0bbe\u0bae\u0bcd\u0bb0\u0bbe\u0b9c\u0bcd\u0baf \u0baa\u0bcd\u0bb0\u0ba4 \u0b95\u0bb0 \u0ba4\u0bcd\u0bb0\u0bc1\u0ba4 \u0baa\u0bc1\u0bb8\u0bcd\u0ba4\u0b95 \u0b9c\u0bbe\u0bb2\u0bc7"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c38\u0c30\u0c38\u0c40\u0c30\u0c41\u0c39\u0c3e \u0c38\u0c28\u0c2a\u0c4d\u0c30\u0c3f\u0c2f\u0c46 \u0c05\u0c2e\u0c4d\u0c2c <br/> \u0c38\u0c26\u0c3e \u0c35\u0c40\u0c23\u0c3e \u0c17\u0c3e\u0c28\u0c2a\u0c4d\u0c30\u0c3f\u0c2f\u0c47 <br/> \u0c38\u0c26\u0c3e\u0c28\u0c28\u0c4d\u0c26 \u0c39\u0c4d\u0c30\u0c41\u0c26\u0c2f\u0c47 \u0c2e\u0c39\u0c3f\u0c38\u0c26\u0c2f\u0c47"}, {"M": "\u0c05\u0c28\u0c41\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c36\u0c30\u0c23\u0c3e\u0c17\u0c24\u0c2e\u0c4d \u0c2e\u0c3e\u0c2e\u0c35 \u0c2e\u0c02\u0c1c\u0c41\u0c32 \u0c1a\u0c30\u0c23 \u0c15\u0c3f\u0c38\u0c32\u0c2f\u0c47 <br/> \u0c38\u0c2e\u0c4d\u0c2e\u0c4b\u0c26\u0c3f\u0c24 \u0c15\u0c35\u0c3f\u0c1c\u0c28 \u0c39\u0c4d\u0c30\u0c41\u0c26\u0c2f\u0c47 <br/> \u0c38\u0c30\u0c4b\u0c1c \u0c28\u0c3f\u0c32\u0c2f\u0c47 \u0c2e\u0c23\u0c3f\u0c35\u0c32\u0c2f\u0c47"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c38\u0c30\u0c38\u0c40\u0c30\u0c41\u0c39\u0c3e\u0c15\u0c4d\u0c36\u0c3f \u0c2f\u0c41\u0c17\u0c33\u0c47 <br/> \u0c36\u0c30\u0c23\u0c3e\u0c17\u0c25 \u0c26\u0c40\u0c28 \u0c35\u0c24\u0c4d\u0c38\u0c32\u0c47 <br/> \u0c38\u0c30\u0c26\u0c3f\u0c28\u0c4d\u0c26\u0c41 \u0c38\u0c41\u0c28\u0c4d\u0c26\u0c30 \u0c35\u0c26\u0c28\u0c47 \u0c35\u0c3f\u0c2e\u0c32\u0c47 <br/> \u0c38\u0c30\u0c38\u0c4d\u0c35\u0c25\u0c3f \u0c38\u0c26\u0c3f\u0c24\u0c47 \u0c38\u0c3f\u0c17\u0c23\u0c41\u0c24 \u0c17\u0c41\u0c23\u0c1c\u0c3e\u0c32\u0c47 <br/> \u0c38\u0c24\u0c24\u0c2e\u0c4d \u0c35\u0c3f\u0c26\u0c4d\u0c2f\u0c3e \u0c32\u0c4b\u0c32\u0c47 \u0c38\u0c26\u0c3e \u0c38\u0c41\u0c36\u0c40\u0c32\u0c47 <br/> \u0c38\u0c3e\u0c2e\u0c26 \u0c15\u0c41\u0c2e\u0c4d\u0c2c\u0c38\u0c4d\u0c24\u0c28 \u0c2f\u0c41\u0c17\u0c33\u0c47 \u0c27\u0c35\u0c33\u0c47 <br/> \u0c38\u0c15\u0c32 \u0c38\u0c3e\u0c2e\u0c4d\u0c30\u0c3e\u0c1c\u0c4d\u0c2f \u0c2a\u0c4d\u0c30\u0c26 \u0c15\u0c30 \u0c27\u0c4d\u0c30\u0c41\u0c25 \u0c2a\u0c41\u0c38\u0c4d\u0c24\u0c15 \u0c1c\u0c3e\u0c32\u0c47"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cb8\u0cb0\u0cb8\u0cc0\u0cb0\u0cc1\u0cb9\u0cbe \u0cb8\u0ca8\u0caa\u0ccd\u0cb0\u0cbf\u0caf\u0cc6 \u0c85\u0cae\u0ccd\u0cac <br/> \u0cb8\u0ca6\u0cbe \u0cb5\u0cc0\u0ca3\u0cbe \u0c97\u0cbe\u0ca8\u0caa\u0ccd\u0cb0\u0cbf\u0caf\u0cc7 <br/> \u0cb8\u0ca6\u0cbe\u0ca8\u0ca8\u0ccd\u0ca6 \u0cb9\u0ccd\u0cb0\u0cc1\u0ca6\u0caf\u0cc7 \u0cae\u0cb9\u0cbf\u0cb8\u0ca6\u0caf\u0cc7"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cb6\u0cb0\u0ca3\u0cbe\u0c97\u0ca4\u0cae\u0ccd \u0cae\u0cbe\u0cae\u0cb5 \u0cae\u0c82\u0c9c\u0cc1\u0cb2 \u0c9a\u0cb0\u0ca3 \u0c95\u0cbf\u0cb8\u0cb2\u0caf\u0cc7 <br/> \u0cb8\u0cae\u0ccd\u0cae\u0ccb\u0ca6\u0cbf\u0ca4 \u0c95\u0cb5\u0cbf\u0c9c\u0ca8 \u0cb9\u0ccd\u0cb0\u0cc1\u0ca6\u0caf\u0cc7 <br/> \u0cb8\u0cb0\u0ccb\u0c9c \u0ca8\u0cbf\u0cb2\u0caf\u0cc7 \u0cae\u0ca3\u0cbf\u0cb5\u0cb2\u0caf\u0cc7"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0cb8\u0cb0\u0cb8\u0cc0\u0cb0\u0cc1\u0cb9\u0cbe\u0c95\u0ccd\u0cb6\u0cbf \u0caf\u0cc1\u0c97\u0cb3\u0cc7 <br/> \u0cb6\u0cb0\u0ca3\u0cbe\u0c97\u0ca5 \u0ca6\u0cc0\u0ca8 \u0cb5\u0ca4\u0ccd\u0cb8\u0cb2\u0cc7 <br/> \u0cb8\u0cb0\u0ca6\u0cbf\u0ca8\u0ccd\u0ca6\u0cc1 \u0cb8\u0cc1\u0ca8\u0ccd\u0ca6\u0cb0 \u0cb5\u0ca6\u0ca8\u0cc7 \u0cb5\u0cbf\u0cae\u0cb2\u0cc7 <br/> \u0cb8\u0cb0\u0cb8\u0ccd\u0cb5\u0ca5\u0cbf \u0cb8\u0ca6\u0cbf\u0ca4\u0cc7 \u0cb8\u0cbf\u0c97\u0ca3\u0cc1\u0ca4 \u0c97\u0cc1\u0ca3\u0c9c\u0cbe\u0cb2\u0cc7 <br/> \u0cb8\u0ca4\u0ca4\u0cae\u0ccd \u0cb5\u0cbf\u0ca6\u0ccd\u0caf\u0cbe \u0cb2\u0ccb\u0cb2\u0cc7 \u0cb8\u0ca6\u0cbe \u0cb8\u0cc1\u0cb6\u0cc0\u0cb2\u0cc7 <br/> \u0cb8\u0cbe\u0cae\u0ca6 \u0c95\u0cc1\u