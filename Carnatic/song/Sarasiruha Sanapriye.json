\u0d38\u0d4d\u0d24\u0d28 \u0d2f\u0d41\u0d17\u0d33\u0d47 \u0d27\u0d35\u0d33\u0d47 <br/> \u0d38\u0d15\u0d32 \u0d38\u0d3e\u0d2e\u0d4d\u0d30\u0d3e\u0d1c\u0d4d\u0d2f \u0d2a\u0d4d\u0d30\u0d26 \u0d15\u0d30 \u0d27\u0d4d\u0d30\u0d41\u0d25 \u0d2a\u0d41\u0d38\u0d4d\u0d24\u0d15 \u0d1c\u0d3e\u0d32\u0d47"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0938\u0930\u0938\u0940\u0930\u0941\u0939\u093e \u0938\u0928\u092a\u094d\u0930\u093f\u092f\u0947 \u0905\u092e\u094d\u092c <br/> \u0938\u0926\u093e \u0935\u0940\u0923\u093e \u0917\u093e\u0928\u092a\u094d\u0930\u093f\u092f\u0947 <br/> \u0938\u0926\u093e\u0928\u0928\u094d\u0926 \u0939\u094d\u0930\u0941\u0926\u092f\u0947 \u092e\u0939\u093f\u0938\u0926\u092f\u0947"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0936\u0930\u0923\u093e\u0917\u0924\u092e\u094d \u092e\u093e\u092e\u0935 \u092e\u0902\u091c\u0941\u0932 \u091a\u0930\u0923 \u0915\u093f\u0938\u0932\u092f\u0947 <br/> \u0938\u092e\u094d\u092e\u094b\u0926\u093f\u0924 \u0915\u0935\u093f\u091c\u0928 \u0939\u094d\u0930\u0941\u0926\u092f\u0947 <br/> \u0938\u0930\u094b\u091c \u0928\u093f\u0932\u092f\u0947 \u092e\u0923\u093f\u0935\u0932\u092f\u0947"}, {"M": "\u091a\u0930\u0923\u092e\u094d", "T": "\u0938\u0930\u0938\u0940\u0930\u0941\u0939\u093e\u0915\u094d\u0936\u093f \u092f\u0941\u0917\u0932\u0947 <br/> \u0936\u0930\u0923\u093e\u0917\u0925 \u0926\u0940\u0928 \u0935\u0924\u094d\u0938\u0932\u0947 <br/> \u0938\u0930\u0926\u093f\u0928\u094d\u0926\u0941 \u0938\u0941\u0928\u094d\u0926\u0930 \u0935\u0926\u0928\u0947 \u0935\u093f\u092e\u0932\u0947 <br/> \u0938\u0930\u0938\u094d\u0935\u0925\u093f \u0938\u0926\u093f\u0924\u0947 \u0938\u093f\u0917\u0923\u0941\u0924 \u0917\u0941\u0923\u091c\u093e\u0932\u0947 <br/> \u0938\u0924\u0924\u092e\u094d \u0935\u093f\u0926\u094d\u092f\u093e \u0932\u094b\u0932\u0947 \u0938\u0926\u093e \u0938\u0941\u0936\u0940\u0932\u0947 <br/> \u0938\u093e\u092e\u0926 \u0915\u0941\u092e\u094d\u092c\u0938\u094d\u092