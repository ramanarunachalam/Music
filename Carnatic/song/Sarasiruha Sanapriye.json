9,56,57,66,60,58,27,28,85,76,39,73,37,36,38,83,82,46,47,48,50,49,43,44,51,52,45,19"}, "lyricstext": [{"L": "English", "text": [{"M": "pallavi", "T": "sarasIruhA sanapriye amba <br/> sadA vINA gAnapriyE <br/> sadAnanda hrudayE mahisadayE"}, {"M": "anupallavi", "T": "SaraNAgatam mAmava manjula caraNa kisalayE <br/> sammOdita kavijana hrudayE <br/> sarOja nilayE maNivalayE"}, {"M": "caraNam", "T": "sarasIruhAkSi yugaLE <br/> SaraNAgatha dIna vatsalE <br/> saradindu sundara vadanE vimalE <br/> sarasvathi saditE sigaNuta guNajAlE <br/> satatam vidyA lOlE sadA suSIlE <br/> sAmada kumbastana yugaLE dhavaLE <br/> sakala sAmrAjya prada kara dhrutha pustaka jAlE"}]}, {"L": "Tamil", "text": [{"M": "\u0baa\u0bb2\u0bcd\u0bb2\u0bb5\u0bbf", "T": "\u0b9a\u0bb0\u0b9a\u0bc0\u0bb0\u0bc1\u0bb9\u0bbe \u0b9a\u0ba9\u0baa\u0bcd\u0bb0\u0bbf\u0baf\u0bc6 \u0b85\u0bae\u0bcd\u0baa <br/> \u0b9a\u0ba4\u0bbe \u0bb5\u0bc0\u0ba3\u0bbe \u0b95\u0bbe\u0ba9\u0baa\u0bcd\u0bb0\u0bbf\u0baf\u0bc7 <br/> \u0b9a\u0ba4\u0bbe\u0ba9\u0ba8\u0bcd\u0ba4 \u0bb9\u0bcd\u0bb0\u0bc1\u0ba4\u0baf\u0bc7 \u0bae\u0bb9\u0bbf\u0b9a\u0ba4\u0baf\u0bc7"}, {"M": "\u0b85\u0ba9\u0bc1\u0baa\u0bb2\u0bcd\u0bb2\u0bb5\u0bbf", "T": "\u0b9a\u0bb0\u0ba3\u0bbe\u0b95\u0ba4\u0bae\u0bcd \u0bae\u0bbe\u0bae\u0bb5 \u0bae\u0b9e\u0bcd\u0b9c\u0bc1\u0bb2 \u0b9a\u0bb0\u0ba3 \u0b95\u0bbf\u0b9a\u0bb2\u0baf\u0bc7 <br/> \u0b9a\u0bae\u0bcd\u0bae\u0bcb\u0ba4\u0bbf\u0ba4 \u0b95\u0bb5\u0bbf\u0b9c\u0ba9 \u0bb9\u0bcd\u0bb0\u0bc1\u0ba4\u0baf\u0bc7 <br/> \u0b9a\u0bb0\u0bcb\u0b9c \u0ba8\u0bbf\u0bb2\u0baf\u0bc7 \u0bae\u0ba3\u0bbf\u0bb5\u0bb2\u0baf\u0bc7"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd", "T": "\u0b9a\u0bb0\u0b9a\u0bc0\u0bb0\u0bc1\u0bb9\u0bbe\u0b95\u0bcd\u0b9a\u0bbf \u0baf\u0bc1\u0b95\u0bb3\u0bc7 <br/> \u0b9a\u0bb0\u0ba3\u0bbe\u0b95\u0ba4 \u0ba4\u0bc0\u0ba9 \u0bb5\u0ba4\u0bcd\u0b9a\u0bb2\u0bc7 <br/> \u0b9a\u0bb0\u0ba4\u0bbf\u0ba8\u0bcd\u0ba4\u0bc1 \u0b9a\u0bc1\u0ba8\u0bcd\u0ba4\u0bb0 \u0bb5\u0ba4\u0ba9\u0bc7 \u0bb5\u0bbf\u0bae\u0bb2\u0bc7 <br/> \u0b9a\u0bb0\u0bb8\u0bcd\u0bb5\u0ba4\u0bbf \u0b9a\u0ba4\u0bbf\u0ba4\u0bc7 \u0b9a\u0bbf\u0b95\u0ba3\u0bc1\u0ba4 \u0b95\u0bc1\u0ba3\u0b9c\u0bbe\u0bb2\u0bc7 <br/> \u0b9a\u0ba4\u0ba4\u0bae\u0bcd \u0bb5\u0bbf\u0ba4\u0bcd\u0baf\u0bbe \u0bb2\u0bcb\u0bb2\u0bc7 \u0b9a\u0ba4\u0bbe \u0b9a\u0bc1\u0b9a\u0bc0\u0bb2\u0bc7 <br/> \u0b9a\u0bbe\u0bae\u0ba4 \u0b95\u0bc1\u0bae\u0bcd\u0baa\u0bb8\u0bcd\u0ba4\u0ba9 \u0baf\u0bc1\u0b95\u0bb3\u0bc7 \u0ba4\u0bb5\u0bb3\u0bc7 <br/> \u0b9a\u0b95\u0bb2 \u0b9a\u0bbe\u0bae\u0bcd\u0bb0\u0bbe\u0b9c\u0bcd\u0baf \u0baa\u0bcd\u0bb0\u0ba4 \u0b95\u0bb0 \u0ba4\u0bcd\u0bb0\u0bc1\u0ba4 \u0baa\u0bc1\u0bb8\u0bcd\u0ba4\u0b95 \u0b9c\u0bbe\u0bb2\u0bc7"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c38\u0c30\u0c38\u0c40\u0c30\u0c41\u0c39\u0c3e \u0c38\u0c28\u0c2a\u0c4d\u0c30\u0c3f\u0c2f\u0c46 \u0c05\u0c2e\u0c4d\u0c2c <br/> \u0c38\u0c26\u0c3e \u0c35\u0c40\u0c23\u0c3e \u0c17\u0c3e\u0c28\u0c2a\u0c4d\u0c30\u0c3f\u0c2f\u0c47 <br/> \u0c38\u0c26\u0c3e\u0c28\u0c28\u0c4d\u0c26 \u0c39\u0c4d\u0c30\u0c41\u0c26\u0c2f\u0c47 \u0c2e\u0c39\u0c3f\u0c38\u0c26\u0c2f\u0c47"}, {"M": "\u0c05\u0c28\u0c41\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c36\u0c30\u0c23\u0c3e\u0c17\u0c24\u0c2e\u0c4d \u0c2e\u0c3e\u0c2e\u0c35 \u0c2e\u0c02\u0c1c\u0c41\u0c32 \u0c1a\u0c30\u0c23 \u0c15\u0c3f\u0c38\u0c32\u0c2f\u0c47 <br/> \u0c38\u0c2e\u0c4d\u0c2e\u0c4b\u0c26\u0c3f\u0c24 \u0c15\u0c35\u0c3f\u0c1c\u0c28 \u0c39\u0c4d\u0c30\u0c41\u0c26\u0c2f\u0c47 <br/> \u0c38\u0c30\u0c4b\u0c1c \u0c28\u0c3f\u0c32\u0c2f\u0c47 \u0c2e\u0c23\u0c3f\u0c35\u0c32\u0c2f\u0c47"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c38\u0c30\u0c38\u0c40\u0c30\u0c41\u0c39\u0c3e\u0c15\u0c4d\u0c36\u0c3f \u0c2f\u0c41\u0c17\u0c33\u0c47 <br/> \u0c36\u0c30\u0c23\u0c3e\u0c17\u0c25 \u0c26\u0c40\u0c28 \u0c35\u0c24\u0c4d\u0c38\u0c32\u0c47 <br/> \u0c38\u0c30\u0c26\u0c3f\u0c28\u0c4d\u0c26\u0c41 \u0c38\u0c41\u0c28\u0c4d\u0c26\u0c30 \u0c35\u0c26\u0c28\u0c47 \u0c35\u0c3f\u0c2e\u0c32\u0c47 <br/> \u0c38\u0c30\u0c38\u0c4d\u0c35\u0c25\u0c3f \u0c38\u0c26\u0c3f\u0c24\u0c47 \u0c38\u0c3f\u0c17\u0c23\u0c41\u0c24 \u0c17\u0c41\u0c23\u0c1c\u0c3e\u0c32\u0c47 <br/> \u0c38\u0c24\u0c24\u0c2e\u0c4d \u0c35\u0c3f\u0c26\u0c4d\u0c2f\u0c3e \u0c32\u0c4b\u0c32\u0c47 \u0c38\u0c26\u0c3e \u0c38\u0c41\u0c36\u0c40\u0c32\u0c47 <br/> \u0c38\u0c3e\u0c2e\u0c26 \u0c15\u0c41\u0c2e\u0c4d\u0c2c\u0c38\u0c4d\u0c24\u0c28 \u0c2f\u0c41\u0c17\u0c33\u0c47 \u0c27\u0c35\u0c33\u0c47 <br/> \u0c38\u0c15\u0c32 \u0c38\u0c3e\u0c2e\u0c4d\u0c30\u0c3e\u0c1c\u0c4d\u0c2f \u0c2a\u0c4d\u0c30\u0c26 \u0c15\u0c30 \u0c27\u0c4d\u0c30\u0c41\u0c25 \u0c2a\u0c41\u0c38\u0c4d\u0c24\u0c15 \u0c1c\u0c3e\u0c32\u0c47"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cb8\u0cb0\u0cb8\u0cc0\u0cb0\u0cc1\u0cb9\u0cbe \u0cb8\u0ca8\u0caa\u0ccd\u0cb0\u0cbf\u0caf\u0cc6 \u0c85\u0cae\u0ccd\u0cac <br/> \u0cb8\u0ca6\u0cbe \u0cb5\u0cc0\u0ca3\u0cbe \u0c97\u0cbe\u0ca8\u0caa\u0ccd\u0cb0\u0cbf\u0caf\u0cc7 <br/> \u0cb8\u0ca6\u0cbe\u0ca8\u0ca8\u0ccd\u0ca6 \u0cb9\u0ccd\u0cb0\u0cc1\u0ca6\u0caf\u0cc7 \u0cae\u0cb9\u0cbf\u0cb8\u0ca6\u0caf\u0cc7"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cb6\u0cb0\u0ca3\u0cbe\u0c97\u0ca4\u0cae\u0ccd \u0cae\u0cbe\u0cae\u0cb5 \u0cae\u0c82\u0c9c\u0cc1\u0cb2 \u0c9a\u0cb0\u0ca3 \u0c95\u0cbf\u0cb8\u0cb2\u0caf\u0cc7 <br/> \u0cb8\u0cae\u0ccd\u0cae\u0ccb\u0ca6\u0cbf\u0ca4 \u0c95\u0cb5\u0cbf\u0c9c\u0ca8 \u0cb9\u0ccd\u0cb0\u0cc1\u0ca6\u0caf\u0cc7 <br/> \u0cb8\u0cb0\u0ccb\u0c9c \u0ca8\u0cbf\u0cb2\u0caf\u0cc7 \u0cae\u0ca3\u0cbf\u0cb5\u0cb2\u0caf\u0cc7"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0cb8\u0cb0\u0cb8\u0cc0\u0cb0\u0cc1\u0cb9\u0cbe\u0c95\u0ccd\u0cb6\u0cbf \u0caf\u0cc1\u0c97\u0cb3\u0cc7 <br/> \u0cb6\u0cb0\u0ca3\u0cbe\u0c97\u0ca5 \u0ca6\u0cc0\u0ca8 \u0cb5\u0ca4\u0ccd\u0cb8\u0cb2\u0cc7 <br/> \u0cb8\u0cb0\u0ca6\u0cbf\u0ca8\u0ccd\u0ca6\u0cc1 \u0cb8\u0cc1\u0ca8\u0ccd\u0ca6\u0cb0 \u0cb5\u0ca6\u0ca8\u0cc7 \u0cb5\u0cbf\u0cae\u0cb2\u0cc7 <br/> \u0cb8\u0cb0\u0cb8\u0ccd\u0cb5\u0ca5\u0cbf \u0cb8\u0ca6\u0cbf\u0ca4\u0cc7 \u0cb8\u0cbf\u0c97\u0ca3\u0cc1\u0ca4 \u0c97\u0cc1\u0ca3\u0c9c\u0cbe\u0cb2\u0cc7 <br/> \u0cb8\u0ca4\u0ca4\u0cae\u0ccd \u0cb5\u0cbf\u0ca6\u0ccd\u0caf\u0cbe \u0cb2\u0ccb\u0cb2\u0cc7 \u0cb8\u0ca6\u0cbe \u0cb8\u0cc1\u0cb6\u0cc0\u0cb2\u0cc7 <br/> \u0cb8\u0cbe\u0cae\u0ca6 \u0c95\u0cc1\u0cae\u0ccd\u0cac\u0cb8\u0ccd\u0ca4\u0ca8 \u0caf\u0cc1\u0c97\u0cb3\u0cc7 \u0ca7\u0cb5\u0cb3\u0cc7 <br/> \u0cb8\u0c95\u0cb2 \u0cb8\u0cbe\u0cae\u0ccd\u0cb0\u0cbe\u0c9c\u0ccd\u0caf \u0caa\u0ccd\u0cb0\u0ca6 \u0c95\u0cb0 \u0ca7\u0ccd\u0cb0\u0cc1\u0ca5 \u0caa\u0cc1\u0cb8\u0ccd\u0ca4\u0c95 \u0c9c\u0cbe\u0cb2\u0cc7"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d38\u0d30\u0d38\u0d40\u0d30\u0d41\u0d39\u0d3e \u0d38\u0d28\u0d2a\u0d4d\u0d30\u0d3f\u0d2f\u0d46 \u0d05\u0d2e\u0d4d\u0d2c <br/> \u0d38\u0d26\u0d3e \u0d35\u0d40\u0d23\u0d3e \u0d17\u0d3e\u0d28\u0d2a\u0d4d\u0d30\u0d3f\u0d2f\u0d47 <br/> \u0d38\u0d26\u0d3e\u0d28\u0d28\u0d4d\u0d26 \u0d39\u0d4d\u0d30\u0d41\u0d26\u0d2f\u0d47 \u0d2e\u0d39\u0d3f\u0d38\u0d26\u0d2f\u0d47"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d36\u0d30\u0d23\u0d3e\u0d17\u0d24\u0d2e\u0d4d \u0d2e\u0d3e\u0d2e\u0d35 \u0d2e\u0d02\u0d1c\u0d41\u0d32 \u0d1a\u0d30\u0d23 \u0d15\u0d3f\u0d38\u0d32\u0d2f\u0d47 <br/> \u0d38\u0d2e\u0d4d\u0d2e\u0d4b\u0d26\u0d3f\u0d24 \u0d15\u0d35\u0d3f\u0d1c\u0d28 \u0d39\u0d4d\u0d30\u0d41\u0d26\u0d2f\u0d47 <br/> \u0d38\u0d30\u0d4b\u0d1c \u0d28\u0d3f\u0d32\u0d2f\u0d47 \u0d2e\u0d23\u0d3f\u0d35\u0d32\u0d2f\u0d47"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d38\u0d30\u0d38\u0d40\u0d30\u0d41\u0d39\u0d3e\u0d15\u0d4d\u0d36\u0d3f \u0d2f\u0d41\u0d17\u0d33\u0d47 <br/> \u0d36\u0d30\u0d23\u0d3e\u0d17\u0d25 \u0d26\u0d40\u0d28 \u0d35\u0d24\u0d4d\u0d38\u0d32\u0d47 <br/> \u0d38\u0d30\u0d26\u0d3f\u0d28\u0d4d\u0d26\u0d41 \u0d38\u0d41\u0d28\u0d4d\u0d26\u0d30 \u0d35\u0d26\u0d28\u0d47 \u0d35\u0d3f\u0d2e\u0d32\u0d47 <br/> \u0d38\u0d30\u0d38\u0d4d\u0d35\u0d25\u0d3f \u0d38\u0d26\u0d3f\u0d24\u0d47 \u0d38\u0d3f\u0d17\u0d23\u0d41\u0d24 \u0d17\u0d41\u0d23\u0d1c\u0d3e\u0d32\u0d47 <br/> \u0d38\u0d24\u0d24\u0d2e\u0d4d \u0d35\u0d3f\u0d26\u0d4d\u0d2f\u0d3e \u0d32\u0d4b\u0d32\u0d47 \u0d38\u0d26\u0d3e \u0d38\u0d41\u0d36\u0d40\u0d32\u0d47 <br/> \u0d38\u0d3e\u0d2e\u0d26 \u0d15\u0d41\u0d2e\u0d4d\u0d2c\u0d38\u0d4d\u0d24\u0d28 \u0d2f\u0d41\u0d17\u0d33\u0d47 \u0d27\u0d35\u0d33\u0d47 <br/> \u0d38\u0d15\u0d32 \u0d38\u0d3e\u0d2e\u0d4d\u0d30\u0d3e\u0d1c\u0d4d\u0d2f \u0d2a\u0d4d\u0d30\u0d26 \u0d15\u0d30 \u0d27\u0d4d\u0d30\u0d41\u0d25 \u0d2a\u0d41\u0d38\u0d4d\u0d24\u0d15 \u0d1c\u0d3e\u0d32\u0d47"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0938\u0930\u0938\u0940\u0930\u0941\u0939\u093e \u0938\u0928\u092a\u094d\u0930\u093f\u092f\u0947 \u0905\u092e\u094d\u092c <br/> \u0938\u0926\u093e \u0935\u0940\u0923\u093e \u0917\u093e\u0928\u092a\u094d\u0930\u093f\u092f\u0947 <br/> \u0938\u0926\u093e\u0928\u0928\u094d\u0926 \u0939\u094d\u0930\u0941\u0926\u092f\u0947 \u092e\u0939\u093f\u0938\u0926\u092f\u0947"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0936\u0930\u0923\u093e\u0917\u0924\u092e\u094d \u092e\u093e\u092e\u0935 \u092e\u0902\u091c\u0941\u0932 \u091a\u0930\u0923 \u0915\u093f\u0938\u0932\u092f\u0947 <br/> \u0938\u092e\u094d\u092e\u094b\u0926\u093f\u0924 \u0915\u0935\u093f\u091c\u0928 \u0939\u094d\u0930\u0941\u0926\u092f\u0947 <br/> \u0938\u0930\u094b\u091c \u0928\u093f\u0932\u092f\u0947 \u092e\u0923\u093f\u0935\u0932\u092f\u0947"}, {"M": "\u091a\u0930\u0923\u092e\u094d", "T": "\u0938\u0930\u0938\u0940\u0930\u0941\u0939\u093e\u0915\u094d\u0936\u093f \u092f\u0941\u0917\u0932\u0947 <br/> \u0936\u0930\u0923\u093e\u0917\u0925 \u0926\u0940\u0928 \u0935\u0924\u094d\u0938\u0932\u0947 <br/> \u0938\u0930\u0926\u093f\u0928\u094d\u0926\u0941 \u0938\u0941\u0928\u094d\u0926\u0930 \u0935\u0926\u0928\u0947 \u0935\u093f\u092e\u0932\u0947 <br/> \u0938\u0930\u0938\u094d\u0935\u0925\u093f \u0938\u0926\u093f\u0924\u0947 \u0938\u093f\u0917\u0923\u0941\u0924 \u0917\u0941\u0923\u091c\u093e\u0932\u0947 <br/> \u0938\u0924\u0924\u092e\u094d \u0935\u093f\u0926\u094d\u092f\u093e \u0932\u094b\u0932\u0947 \u0938\u0926\u093e \u0938\u0941\u0936\u0940\u0932\u0947 <br/> \u0938\u093e\u092e\u0926 \u0915\u0941\u092e\u094d\u092c\u0938\u094d\u0924\u0928 \u092f\u0941\u0917\u0932\u0947 \u0927\u0935\u0932\u0947 <br/> \u0938\u0915\u0932 \u0938\u093e\u092e\u094d\u0930\u093e\u091c\u094d\u092f \u092a\u094d\u0930\u0926 \u0915\u0930 \u0927\u094d\u0930\u0941\u0925 \u092a\u0941\u0938\u094d\u0924\u0915 \u091c\u093e\u0932\u0947"}]}], "L": "l", "lyricsref": [{"links": [{"N": "www.karnatik.com", "L": "http://www.karnatik.com/c1081.shtml"}, {"N": "www.shivkumar.org", "L": "http://www.shivkumar.org/music/saraseeruhasana.htm"}]}]}