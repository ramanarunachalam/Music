0bcd\u0bb2 \u0ba8\u0bbf\u0ba3\u0bcd\u0b9f\u0bbe\u0bb0 \u0b9c\u0bc2\u0baa\u0bbf <br/> \u0b88 \u0bae\u0bb9\u0bbf\u0ba9\u0bbf \u0baa\u0baf\u0bae\u0bc7\u0b9f\u0bbf\u0b95\u0ba9\u0bcd\u0ba9 \u0bae\u0b9f <br/> \u0bb0\u0bbe\u0bae \u0b9a\u0ba8\u0bcd\u0ba4\u0bcd\u0bb0 \u0ba4\u0bcd\u0baf\u0bbe\u0b95\u0bb0\u0bbe\u0b9c \u0bb5\u0bbf\u0ba9\u0bc1\u0ba4"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c38\u0c40\u0c24\u0c3e \u0c2a\u0c24\u0c40 \u0c28\u0c3e \u0c2e\u0c28\u0c38\u0c41\u0c28 <br/> \u0c38\u0c3f\u0c26\u0c4d\u0c27\u0c3e\u0c28\u0c4d\u0c24\u0c2e\u0c28\u0c3f\u0c2f\u0c41\u0c28\u0c4d\u0c28\u0c3e\u0c28\u0c41\u0c30\u0c3e"}, {"M": "\u0c05\u0c28\u0c41\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c35\u0c3e\u0c24\u0c3e\u0c24\u0c4d\u0c2e\u0c1c\u0c3e\u0c26\u0c41\u0c32 \u0c1a\u0c46\u0c28\u0c4d\u0c24\u0c28\u0c47 <br/> \u0c35\u0c30\u0c4d\u0c23\u0c3f\u0c28\u0c4d\u0c1a\u0c3f\u0c28 \u0c28\u0c40 \u0c2a\u0c32\u0c41\u0c15\u0c41\u0c32\u0c46\u0c32\u0c4d\u0c32"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c2a\u0c4d\u0c30\u0c47\u0c2e \u0c1c\u0c42\u0c1a\u0c3f \u0c28\u0c3e\u0c2a\u0c48 \u0c2a\u0c46\u0c26\u0c4d\u0c26 \u0c2e\u0c28\u0c38\u0c41 \u0c1c\u0c47\u0c38\u0c3f <br/> \u0c28\u0c40 \u0c2e\u0c39\u0c3f\u0c2e\u0c32\u0c46\u0c32\u0c4d\u0c32 \u0c28\u0c3f\u0c23\u0c4d\u0c21\u0c3e\u0c30 \u0c1c\u0c42\u0c2a\u0c3f <br/> \u0c08 \u0c2e\u0c39\u0c3f\u0c28\u0c3f \u0c2d\u0c2f\u0c2e\u0c47\u0c1f\u0c3f\u0c15\u0c28\u0c4d\u0c28 \u0c2e\u0c1f <br/> \u0c30\u0c3e\u0c2e \u0c1a\u0c28\u0c4d\u0c26\u0c4d\u0c30 \u0c24\u0c4d\u0c2f\u0c3e\u0c17\u0c30\u0c3e\u0c1c \u0c35\u0c3f\u0c28\u0c41\u0c24"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cb8\u0cc0\u0ca4\u0cbe \u0caa\u0ca4\u0cc0 \u0ca8\u0cbe \u0cae\u0ca8\u0cb8\u0cc1\u0ca8 <br/> \u0cb8\u0cbf\u0ca6\u0ccd\u0ca7\u0cbe\u0ca8\u0ccd\u0ca4\u0cae\u0ca8\u0cbf\u0caf\u0cc1\u0ca8\u0ccd\u0ca8\u0cbe\u0ca8\u0cc1\u0cb0\u0cbe"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cb5\u0cbe\u0ca4\u0cbe\u0ca4\u0ccd\u0cae\u0c9c\u0cbe\u0ca6\u0cc1\u0cb2 \u0c9a\u0cc6\u0ca8\u0ccd\u0ca4\u0ca8\u0cc7 <br/> \u0cb5\u0cb0\u0ccd\u0ca3\u0cbf\u0ca8\u0ccd\u0c9a\u0cbf\u0ca8 \u0ca8\u0cc0 \u0caa\u0cb2\u0cc1\u0c95\u0cc1\u0cb2\u0cc6\u0cb2\u0ccd\u0cb2"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0caa\u0ccd\u0cb0\u0cc7\u0cae \u0c9c\u0cc2\u0c9a\u0cbf \u0ca8\u0cbe\u0caa\u0cc8 \u0caa\u0cc6\u0ca6\u0ccd\u0ca6 \u0cae\u0ca8\u0cb8\u0cc1 \u0c9c\u0cc7\u0cb8\u0cbf <br/> \u0ca8\u0cc0 \u0cae\u0cb9\u0cbf\u0cae\u0cb2\u0cc6\u0cb2\u0ccd\u0cb2 \u0ca8\u0cbf\u0ca3\u0ccd\u0ca1\u0cbe\u0cb0 \u0c9c\u0cc2\u0caa\u0cbf <br/> \u0c88 \u0cae\u0cb9\u0cbf\u0ca8\u0cbf \u0cad\u0caf\u0cae\u0cc7\u0c9f\u0cbf\u0c95\u0ca8\u0ccd\u0ca8 \u0cae\u0c9f <br/> \u0cb0\u0cbe\u0cae \u0c9a\u0ca8\u0ccd\u0ca6\u0ccd\u0cb0 \u0ca4\u0ccd\u0caf\u0cbe\u0c97\u0cb0\u0cbe\u0c9c \u0cb5\u0cbf\u0ca8\u0cc1\u0ca4"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d38\u0d40\u0d24\u0d3e \u0d2a\u0d24\u0d40 \u0d28\u0d3e \u0d2e\u0d28\u0d38\u0d41\u0d28 <br/> \u0d38\u0d3f\u0d26\u0d4d\u0d27\u0d3e\u0d28\u0d4d\u0d24\u0d2e\u0d28\u0d3f\u0d2f\u0d41\u0d28\u0d4d\u0d28\u0d3e\u0d28\u0d41\u0d30\u0d3e"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d35\u0d3e\u0d24\u0d3e\u0d24\u0d4d\u0d2e\u0d1c\u0d3e\u0d26\u0d41\u0d32 \u0d1a\u0d46\u0d28\u0d4d\u0d24\u0d28\u0d47 <br/> \u0d35\u0d30\u0d4d\u0d23\u0d3f\u0d28\u0d4d\u0d1a\u0d3f\u0d28 \u0d28\u0d40 \u0d2a\u0d32\u0d41\u0d15\u0d41\u0d32\u0d46\u0d32\u0d4d\u0d32"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d2a\u0d4d\u0d30\u0d47\u0d2e \u0d1c\u0d42\u0d1a\u0d3f \u0d28\u0d3e\u0d2a\u0d48 \u0d2a\u0d46\u0d26\u0d4d\u0d26 \u0d2e\u0d28\u0d38\u0d41 \u0d1c\u0d47\u0d38\u0d3f <br/> \u0d28\u0d40 \u0d2e\u0d39\u0d3f\u0d2e\u0d32\u0d46\u0d32\u0d4d\u0d32 \u0d28\u0d3f\u0d23\u0d4d\u0d21\u0d3e\u0d30 \u0d1c\u0d42\u0d2a\u0d3f <br/> \u0d08 \u0d2e\u0d39\u0d3f\u0d28\u0d3f \u0d2d\u0d2f\u0d2e\u0d47\u0d1f\u0d3f\u0d15\u0d28\u0d4d\u0d28 \u0d2e\u0d1f <br/> \u0d30\u0d3e\u0d2e \u0d1a\u0d28\u0d4d\u0d26\u0d4d\u0d30 \u0d24\u0d4d\u0d2f\u0d3e\u0d17\u0d30\u0d3e\u0d1c \u0d35\u0d3f\u0d28\u0d41\u0d24"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0938\u0940\u0924\u093e \u092a\u0924\u0940 \u0928\u093e \u092e\u0928\u0938\u0941\u0928 <br/> \u0938\u093f\u0926\u094d\u0927\u093e\u0928\u094d\u0924\u092e\u0928\u093f\u092f\u0941\u0928\u094d\u0928\u093e\u0928\u0941\u0930\u093e"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0935\u093e\u0924\u093e\u0924\u094d\u092e\u091c\u093e\u0926\u0941\u0932 \u091a\u0947\u0928\u094d\u0924\u0928\u0947 <br/> \u0935\u0930\u094d\u0923\u093f\u0928\u094d\u091a\u093f\u0928 \u0928\u0940 \u092a\u0932\u0941\u0915\u0941\u0932\u0947\u0932\u094d\u0932"}, {"M": "\u091a\u0930\u0923\u092e\u094d", "T": "\u092a\u094d\u0930\u0947\u092e \u091c\u0942\u091a\u093f \u0928\u093e\u092a\u0948 \u092a\u0947\u0926\u094d\u0926 \u092e\u0928\u0938\u0941 \u091c\u0947\u0938\u093f <br/> \u0928\u0940 \u092e\u0939\u093f\u092e\u0932\u0947\u0932\u094d\u0932 \u0928\u093f\u0923\u094d\u0921\u093e\u0930 \u091c\u0942\u092a\u093f <br/> \u0908 \u092e\u0939\u093f\u0928\u093f \u092d\u092f\u092e\u0947\u091f\u093f\u0915\u0928\u094d\u0928 \u092e\u091f <br/> \u0930\u093e\u092e \u091a\u0928\u094d\u0926\u094d\u0930 \u0924\u094d\u092f\u093e\u0917\u0930\u093e\u091c \u0935\u093f\u0928\u0941\u0924"}]}], "L": "l", "lyricsref": [{"links": [{"N": "thyagaraja-vaibhavam.blogspot.com", "L": "http://thyagaraja-vaibhavam.blogspot.com/2007/11/thyagaraja-kriti-seetha-pathi-naa.html"}, {"N": "www.shivkumar.org", "L": "http://www.shivkumar.org/music/seethapathe.htm"}, {"N": "www.sangeetasudha.org", "L": "http://www.sangeetasudha.org/thyagaraja/vol3/a5.html#MARK_SITA"}, {"N": "www.karnatik.com", "L": "http://www.karnatik.com/c2867.shtml"}]}]}