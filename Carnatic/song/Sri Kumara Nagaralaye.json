rE <br/> manjuLAnana sudhAkarE nava kanjadaLa kalita vilasita cikurE <br/> anjanAncita drugancala bhanjita ganjanad-vidya manjimapunjE <br/> niranjanASaya nikunja kELi rasikE ava mrgamada tilakE"}, {"M": "caraNam 2", "T": "kambu vara sadrSa kandarE jagadamba pAlita vasundharE <br/> bimba phala rucirAdharE lOlambajAla ruci vilasita cikurE <br/> amba kaccavi viTambita daLada sitAmbuja dyuti kadamba kaDambarE <br/> SambarAri hari SambarArcitapadE pada natajana SubhadE"}, {"M": "caraNam 3", "T": "manda gamana jita vAraNE susura vrndavairi vinivAraNE <br/> indirE bhuvana kAraNE kuruvinda danti kisalaya mrdu caraNE <br/> manda hAsa ruci ninditEndu kara kunda vrnda makaranda bindu <br/> sandOha samvalita sundarAmbujajAsyE jagadupAsyE"}]}, {"L": "Tamil", "text": [{"M": "\u0baa\u0bb2\u0bcd\u0bb2\u0bb5\u0bbf", "T": "\u0bb6\u0bcd\u0bb0\u0bc0 \u0b95\u0bc1\u0bae\u0bbe\u0bb0 \u0ba8\u0b95\u0bb0\u0bbe\u0bb2\u0baf\u0bc7 \u0b95\u0bb0\u0bc1\u0ba3\u0bbe\u0bb2\u0baf\u0bc7 \u0b95\u0bae\u0bb2\u0bbe\u0bb2\u0baf\u0bc7"}, {"M": "\u0b85\u0ba9\u0bc1\u0baa\u0bb2\u0bcd\u0bb2\u0bb5\u0bbf", "T": "\u0bb6\u0bcd\u0bb0\u0bcd\u0ba4\u0b9c\u0ba9 \u0b95\u0bb2\u0bcd\u0baa\u0b95 \u0baa\u0bbe\u0ba4\u0baa\u0bc7 \u0bb6\u0bcd\u0bb0\u0bc0 \u0baa\u0ba4\u0bcd\u0bae\u0ba9\u0bbe\u0baa \u0bb5\u0ba4\u0ba9\u0bbe\u0bae\u0bcd\u0baa\u0bc1\u0b9c \u0bae\u0ba4\u0bc1\u0baa\u0bc7"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd 1", "T": "\u0bae\u0b9e\u0bcd\u0b9c\u0bc1 \u0bb0\u0bae\u0ba3\u0bbf\u0ba4 \u0ba8\u0bc2\u0baa\u0bc1\u0bb0\u0bc7 \u0b95\u0bb0\u0b9a\u0bbf\u0b9e\u0bcd\u0b9a\u0bbf\u0ba4 \u0b95\u0b99\u0bcd\u0b95\u0ba3 \u0baa\u0bbe\u0b9a\u0bc1\u0bb0\u0bc7 <br/> \u0bae\u0b9e\u0bcd\u0b9c\u0bc1\u0bb3\u0bbe\u0ba9\u0ba9 \u0b9a\u0bc1\u0ba4\u0bbe\u0b95\u0bb0\u0bc7 \u0ba8\u0bb5 \u0b95\u0b9e\u0bcd\u0b9c\u0ba4\u0bb3 \u0b95\u0bb2\u0bbf\u0ba4 \u0bb5\u0bbf\u0bb2\u0b9a\u0bbf\u0ba4 \u0b9a\u0bbf\u0b95\u0bc1\u0bb0\u0bc7 <br/> \u0b85\u0b9e\u0bcd\u0b9c\u0ba9\u0bbe\u0b9e\u0bcd\u0b9a\u0bbf\u0ba4 \u0ba4\u0bcd\u0bb0\u0bc1\u0b95\u0b9e\u0bcd\u0b9a\u0bb2 \u0baa\u0b9e\u0bcd\u0b9c\u0bbf\u0ba4 \u0b95\u0b9e\u0bcd\u0b9c\u0ba9\u0ba4\u0bcd-\u0bb5\u0bbf\u0ba4\u0bcd\u0baf \u0bae\u0b9e\u0bcd\u0b9c\u0bbf\u0bae\u0baa\u0bc1\u0b9e\u0bcd\u0b9c\u0bc7 <br/> \u0ba8\u0bbf\u0bb0\u0b9e\u0bcd\u0b9c\u0ba9\u0bbe\u0b9a\u0baf \u0ba8\u0bbf\u0b95\u0bc1\u0b9e\u0bcd\u0b9c \u0b95\u0bc7\u0bb3\u0bbf \u0bb0\u0b9a\u0bbf\u0b95\u0bc7 \u0b85\u0bb5 \u0bae\u0bcd\u0bb0\u0bcd\u0b95\u0bae\u0ba4 \u0ba4\u0bbf\u0bb2\u0b95\u0bc7"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd 2", "T": "\u0b95\u0bae\u0bcd\u0baa\u0bc1 \u0bb5\u0bb0 \u0b9a\u0ba4\u0bcd\u0bb0\u0bcd\u0b9a \u0b95\u0ba8\u0bcd\u0ba4\u0bb0\u0bc7 \u0b9c\u0b95\u0ba4\u0bae\u0bcd\u0baa \u0baa\u0bbe\u0bb2\u0bbf\u0ba4 \u0bb5\u0b9a\u0bc1\u0ba8\u0bcd\u0ba4\u0bb0\u0bc7 <br/> \u0baa\u0bbf\u0bae\u0bcd\u0baa \u0baa\u0bb2 \u0bb0\u0bc1\u0b9a\u0bbf\u0bb0\u0bbe\u0ba4\u0bb0\u0bc7 \u0bb2\u0bcb\u0bb2\u0bae\u0bcd\u0baa\u0b9c\u0bbe\u0bb2 \u0bb0\u0bc1\u0b9a\u0bbf \u0bb5\u0bbf\u0bb2\u0b9a\u0bbf\u0ba4 \u0b9a\u0bbf\u0b95\u0bc1\u0bb0\u0bc7 <br/> \u0b85\u0bae\u0bcd\u0baa \u0b95\u0b9a\u0bcd\u0b9a\u0bb5\u0bbf \u0bb5\u0bbf\u0b9f\u0bae\u0bcd\u0baa\u0bbf\u0ba4 \u0ba4\u0bb3\u0ba4 \u0b9a\u0bbf\u0ba4\u0bbe\u0bae\u0bcd\u0baa\u0bc1\u0b9c \u0ba4\u0bcd\u0baf\u0bc1\u0ba4\u0bbf \u0b95\u0ba4\u0bae\u0bcd\u0baa \u0b95\u0b9f\u0bae\u0bcd\u0baa\u0bb0\u0bc7 <br/> \u0b9a\u0bae\u0bcd\u0baa\u0bb0\u0bbe\u0bb0\u0bbf \u0bb9\u0bb0\u0bbf \u0b9a\u0bae\u0bcd\u0baa\u0bb0\u0bbe\u0bb0\u0bcd\u0b9a\u0bbf\u0ba4\u0baa\u0ba4\u0bc7 \u0baa\u0ba4 \u0ba8\u0ba4\u0b9c\u0ba9 \u0b9a\u0bc1\u0baa\u0ba4\u0bc7"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd 3", "T": "\u0bae\u0ba8\u0bcd\u0ba4 \u0b95\u0bae\u0ba9 \u0b9c\u0bbf\u0ba4 \u0bb5\u0bbe\u0bb0\u0ba3\u0bc7 \u0b9a\u0bc1\u0b9a\u0bc1\u0bb0 \u0bb5\u0bcd\u0bb0\u0bcd\u0ba8\u0bcd\u0ba4\u0bb5\u0bc8\u0bb0\u0bbf \u0bb5\u0bbf\u0ba9\u0bbf\u0bb5\u0bbe\u0bb0\u0ba3\u0bc7 <br/> \u0b87\u0ba8\u0bcd\u0ba4\u0bbf\u0bb0\u0bc7 \u0baa\u0bc1\u0bb5\u0ba9 \u0b95\u0bbe\u0bb0\u0ba3\u0bc7 \u0b95\u0bc1\u0bb0\u0bc1\u0bb5\u0bbf\u0ba8\u0bcd\u0ba4 \u0ba4\u0ba8\u0bcd\u0ba4\u0bbf \u0b95\u0bbf\u0b9a\u0bb2\u0baf \u0bae\u0bcd\u0bb0\u0bcd\u0ba4\u0bc1 \u0b9a\u0bb0\u0ba3\u0bc7 <br/> \u0bae\u0ba8\u0bcd\u0ba4 \u0bb9\u0bbe\u0b9a \u0bb0\u0bc1\u0b9a\u0bbf \u0ba8\u0bbf\u0ba8\u0bcd\u0ba4\u0bbf\u0ba4\u0bc7\u0ba8\u0bcd\u0ba4\u0bc1 \u0b95\u0bb0 \u0b95\u0bc1\u0ba8\u0bcd\u0ba4 \u0bb5\u0bcd\u0bb0\u0bcd\u0ba8\u0bcd\u0ba4 \u0bae\u0b95\u0bb0\u0ba8\u0bcd\u0ba4 \u0baa\u0bbf\u0ba8\u0bcd\u0ba4\u0bc1 <br/> \u0b9a\u0ba8\u0bcd\u0ba4\u0bcb\u0bb9 \u0b9a\u0bae\u0bcd\u0bb5\u0bb2\u0bbf\u0ba4 \u0b9a\u0bc1\u0ba8\u0bcd\u0ba4\u0bb0\u0bbe\u0bae\u0bcd\u0baa\u0bc1\u0b9c\u0b9c\u0bbe\u0bb8\u0bcd\u0baf\u0bc7 \u0b9c\u0b95\u0ba4\u0bc1\u0baa\u0bbe\u0bb8\u0bcd\u0baf\u0bc7"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c36\u0c4d\u0c30\u0c40 \u0c15\u0c41\u0c2e\u0c3e\u0c30 \u0c28\u0c17\u0c30\u0c3e\u0c32\u0c2f\u0c47 \u0c15\u0c30\u0c41\u0c23\u0c3e\u0c32\u0c2f\u0c47 \u0c15\u0c2e\u0c32\u0c3e\u0c32\u0c2f\u0c47"}, {"M": "\u0c05\u0c28\u0c41\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c36\u0c4d\u0c30\u0c4d\u0c24\u0c1c\u0c28 \u0c15\u0c32\u0c4d\u0c2a\u0c15 \u0c2a\u0c3e\u0c26\u0c2a\u0c47 \u0c36\u0c4d\u0c30\u0c40 \u0c2a\u0c26\u0c4d\u0c2e\u0c28\u0c3e\u0c2d \u0c35\u0c26\u0c28\u0c3e\u0c2e\u0c4d\u0c2c\u0c41\u0c1c \u0c2e\u0c27\u0c41\u0c2a\u0c47"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d 1", "T": "\u0c2e\u0c02\u0c1c\u0c41 \u0c30\u0c2e\u0c23\u0c3f\u0c24 \u0c28\u0c42\u0c2a\u0c41\u0c30\u0c47 \u0c15\u0c30\u0c36\u0c3f\u0c02\u0c1a\u0c3f\u0c24 \u0c15\u0c02\u0c15\u0c23 \u0c2d\u0c3e\u0c38\u0c41\u0c30\u0c47 <br/> \u0c2e\u0c02\u0c1c\u0c41\u0c33\u0c3e\u0c28\u0c28 \u0c38\u0c41\u0c27\u0c3e\u0c15\u0c30\u0c47 \u0c28\u0c35 \u0c15\u0c02\u0c1c\u0c26\u0c33 \u0c15\u0c32\u0c3f\u0c24 \u0c35\u0c3f\u0c32\u0c38\u0c3f\u0c24 \u0c1a\u0c3f\u0c15\u0c41\u0c30\u0c47 <br/> \u0c05\u0c02\u0c1c\u0c28\u0c3e\u0c02\u0c1a\u0c3f\u0c24 \u0c26\u0c4d\u0c30\u0c41\u0c17\u0c02\u0c1a\u0c32 \u0c2d\u0c02\u0c1c\u0c3f\u0c24 \u0c17\u0c02\u0c1c\u0c28\u0c26\u0c4d-\u0c35\u0c3f\u0c26\u0c4d\u0c2f \u0c2e\u0c02\u0c1c\u0c3f\u0c2e\u0c2a\u0c41\u0c02\u0c1c\u0c47 <br/> \u0c28\u0c3f\u0c30\u0c02\u0c1c\u0c28\u0c3e\u0c36\u0c2f \u0c28\u0c3f\u0c15\u0c41\u0c02\u0c1c \u0c15\u0c47\u0c33\u0c3f \u0c30\u0c38\u0c3f\u0c15\u0c47 \u0c05\u0c35 \u0c2e\u0c4d\u0c30\u0c4d\u0c17\u0c2e\u0c26 \u0c24\u0c3f\u0c32\u0c15\u0c47"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d 2", "T": "\u0c15\u0c2e\u0c4d\u0c2c\u0c41 \u0c35\u0c30 \u0c38\u0c26\u0c4d\u0c30\u0c4d\u0c36 \u0c15\u0c28\u0c4d\u0c26\u0c30\u0c47 \u0c1c\u0c17\u0c26\u0c2e\u0c4d\u0c2c \u0c2a\u0c3e\u0c32\u0c3f\u0c24 \u0c35\u0c38\u0c41\u0c28\u0c4d\u0c27\u0c30\u0c47 <br/> \u0c2c\u0c3f\u0c2e\u0c4d\u0c2c \u0c2b\u0c32 \u0c30\u0c41\u0c1a\u0c3f\u0c30\u0c3e\u0c27\u0c30\u0c47 \u0c32\u0c4b\u0c32\u0c2e\u0c4d\u0c2c\u0c1c\u0c3e\u0c32 \u0c30\u0c41\u0c1a\u0c3f \u0c35\u0c3f\u0c32\u0c38\u0c3f\u0c24 \u0c1a\u0c3f\u0c15\u0c41\u0c30\u0c47 <br/> \u0c05\u0c2e\u0c4d\u0c2c \u0c15\u0c1a\u0c4d\u0c1a\u0c35\u0c3f \u0c35\u0c3f\u0c1f\u0c2e\u0c4d\u0c2c\u0c3f\u0c24 \u0c26\u0c33\u0c26 \u0c38\u0c3f\u0c24\u0c3e\u0c2e\u0c4d\u0c2c\u0c41\u0c1c \u0c26\u0c4d\u0c2f\u0c41\u0c24\u0c3f \u0c15\u0c26\u0c2e\u0c4d\u0c2c \u0c15\u0c21\u0c2e\u0c4d\u0c2c\u0c30\u0c47 <br/> \u0c36\u0c2e\u0c4d\u0c2c\u0c30\u0c3e\u0c30\u0c3f \u0c39\u0c30\u0c3f \u0c36\u0c2e\u0c4d\u0c2c\u0c30\u0c3e\u0c30\u0c4d\u0c1a\u0c3f\u0c24\u0c2a\u0c26\u0c47 \u0c2a\u0c26 \u0c28\u0c24\u0c1c\u0c28 \u0c36\u0c41\u0c2d\u0c26\u0c47"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d 3", "T": "\u0c2e\u0c28\u0c4d\u0c26 \u0c17\u0c2e\u0c28 \u0c1c\u0c3f\u0c24 \u0c35\u0c3e\u0c30\u0c23\u0c47 \u0c38\u0c41\u0c38\u0c41\u0c30 \u0c35\u0c4d\u0c30\u0c4d\u0c28\u0c4d\u0c26\u0c35\u0c48\u0c30\u0c3f \u0c35\u0c3f\u0c28\u0c3f\u0c35\u0c3e\u0c30\u0c23\u0c47 <br/> \u0c07\u0c28\u0c4d\u0c26\u0c3f\u0c30\u0c47 \u0c2d\u0c41\u0c35\u0c28 \u0c15\u0c3e\u0c30\u0c23\u0c47 \u0c15\u0c41\u0c30\u0c41\u0c35\u0c3f\u0c28\u0c4d\u0c26 \u0c26\u0c28\u0c4d\u0c24\u0c3f \u0c15\u0c3f\u0c38\u0c32\u0c2f \u0c2e\u0c4d\u0c30\u0c4d\u0c26\u0c41 \u0c1a\u0c30\u0c23\u0c47 <br/> \u0c2e\u0c28\u0c4d\u0c26 \u0c39\u0c3e\u0c38 \u0c30\u0c41\u0c1a\u0c3f \u0c28\u0c3f\u0c28\u0c4d\u0c26\u0c3f\u0c24\u0c47\u0c28\u0c4d\u0c26\u0c41 \u0c15\u0c30 \u0c15\u0c41\u0c28\u0c4d\u0c26 \u0c35\u0c4d\u0c30\u0c4d\u0c28\u0c4d\u0c26 \u0c2e\u0c15\u0c30\u0c28\u0c4d\u0c26 \u0c2c\u0c3f\u0c28\u0c4d\u0c26\u0c41 <br/> \u0c38\u0c28\u0c4d\u0c26\u0c4b\u0c39 \u0c38\u0c2e\u0c4d\u0c35\u0c32\u0c3f\u0c24 \u0c38\u0c41\u0c28\u0c4d\u0c26\u0c30\u0c3e\u0c2e\u0c4d\u0c2c\u0c41\u0c1c\u0c1c\u0c3e\u0c38\u0c4d\u0c2f\u0c47 \u0c1c\u0c17\u0c26\u0c41\u0c2a\u0c3e\u0c38\u0c4d\u0c2f\u0c47"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cb6\u0ccd\u0cb0\u0cc0 \u0c95\u0cc1\u0cae\u0cbe\u0cb0 \u0ca8\u0c97\u0cb0\u0cbe\u0cb2\u0caf\u0cc7 \u0c95\u0cb0\u0cc1\u0ca3\u0cbe\u0cb2\u0caf\u0cc7 \u0c95\u0cae\u0cb2\u0cbe\u0cb2\u0caf\u0cc7"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cb6\u0ccd\u0cb0\u0ccd\u0ca4\u0c9c\u0ca8 \u0c95\u0cb2\u0ccd\u0caa\u0c95 \u0caa\u0cbe\u0ca6\u0caa\u0cc7 \u0cb6\u0ccd\u0cb0\u0cc0 \u0caa\u0ca6\u0ccd\u0cae\u0ca8\u0cbe\u0cad \u0cb5\u0ca6\u0ca8\u0cbe\u0cae\u0ccd\u0cac\u0cc1\u0c9c \u0cae\u0ca7\u0cc1\u0caa\u0cc7"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd 1", "T": "\u0cae\u0c82\u0c9c\u0cc1 \u0cb0\u0cae\u0ca3\u0cbf\u0ca4 \u0ca8\u0cc2\u0caa\u0cc1\u0cb0\u0cc7 \u0c95\u0cb0\u0cb6\u0cbf\u0c82\u0c9a\u0cbf\u0ca4 \u0c95\u0c82\u0c95\u0ca3 \u0cad\u0cbe\u0cb8\u0cc1\u0cb0\u0cc7 <br/> \u0cae\u0c82\u0c9c\u0cc1\u0cb3\u0cbe\u0ca8\u0ca8 \u0cb8\u0cc1\u0ca7\u0cbe\u0c95\u0cb0\u0cc7 \u0ca8\u0cb5 \u0c95\u0c82\u0c9c\u0ca6\u0cb3 \u0c95\u0cb2\u0cbf\u0ca4 \u0cb5\u0cbf\u0cb2\u0cb8\u0cbf\u0ca4 \u0c9a\u0cbf\u0c95\u0cc1\u0cb0\u0cc7 <br/> \u0c85\u0c82\u0c9c\u0ca8\u0cbe\u0c82\u0c9a\u0cbf\u0ca4 \u0ca6\u0ccd\u0cb0\u0cc1\u0c97\u0c82\u0c9a\u0cb2 \u0cad\u0c82\u0c9c\u0cbf\u0ca4 \u0c97\u0c82\u0c9c\u0ca8\u0ca6\u0ccd-\u0cb5\u0cbf\u0ca6\u0ccd\u0caf \u0cae\u0c82\u0c9c\u0cbf\u0cae\u0caa\u0cc1\u0c82\u0c9c\u0cc7 <br/> \u0ca8\u0cbf\u0cb0\u0c82\u0c9c\u0ca8\u0cbe\u0cb6\u0caf \u0ca8\u0cbf\u0c95\u0cc1\u0c82\u0c9c \u0c95\u0cc7\u0cb3\u0cbf \u0cb0\u0cb8\u0cbf\u0c95\u0cc7 \u0c85\u0cb5 \u0cae\u0ccd\u0cb0\u0ccd\u0c97\u0cae\u0ca6 \u0ca4\u0cbf\u0cb2\u0c95\u0cc7"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd 2", "T": "\u0c95\u0cae\u0ccd\u0cac\u0cc1 \u0cb5\u0cb0 \u0cb8\u0ca6\u0ccd\u0cb0\u0ccd\u0cb6 \u0c95\u0ca8\u0ccd\u0ca6\u0cb0\u0cc7 \u0c9c\u0c97\u0ca6\u0cae\u0ccd\u0cac \u0caa\u0cbe\u0cb2\u0cbf\u0ca4 \u0cb5\u0cb8\u0cc1\u0ca8\u0ccd\u0ca7\u0cb0\u0cc7 <br/> \u0cac\u0cbf\u0cae\u0ccd\u0cac \u0cab\u0cb2 \u0cb0\u0cc1\u0c9a\u0cbf\u0cb0\u0cbe\u0ca7\u0cb0\u0cc7 \u0cb2\u0ccb\u0cb2\u0cae\u0ccd\u0cac\u0c9c\u0cbe\u0cb2 \u0cb0\u0cc1\u0c9a\u0cbf \u0cb5\u0cbf\u0cb2\u0cb8\u0cbf\u0ca4 \u0c9a\u0cbf\u0c95\u0cc1\u0cb0\u0cc7 <br/> \u0c85\u0cae\u0ccd\u0cac \u0c95\u0c9a\u0ccd\u0c9a\u0cb5\u0cbf \u0cb5\u0cbf\u0c9f\u0cae\u0ccd\u0cac\u0cbf\u0ca4 \u0ca6\u0cb3\u0ca6 \u0cb8\u0cbf\u0ca4\u0cbe\u0cae\u0ccd\u0cac\u0cc1\u0c9c \u0ca6\u0ccd\u0caf\u0cc1\u0ca4\u0cbf \u0c95\u0ca6\u0cae\u0ccd\u0cac \u0c95\u0ca1\u0cae\u0ccd\u0cac\u0cb0\u0cc7 <br/> \u0cb6\u0cae\u0ccd\u0cac\u0cb0\u0cbe\u0cb0\u0cbf \u0cb9\u0cb0\u0cbf \u0cb6\u0cae\u0ccd\u0cac\u0cb0\u0cbe\u0cb0\u0ccd\u0c9a\u0cbf\u0ca4\u0caa\u0ca6\u0cc7 \u0caa\u0ca6 \u0ca8\u0ca4\u0c9c\u0ca8 \u0cb6\u0cc1\u0cad\u0ca6\u0cc7"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd 3", "T": "\u0cae\u0ca8\u0ccd\u0ca6 \u0c97\u0cae\u0ca8 \u0c9c\u0cbf\u0ca4 \u0cb5\u0cbe\u0cb0\u0ca3\u0cc7 \u0cb8\u0cc1\u0cb8\u0cc1\u0cb0 \u0cb5\u0ccd\u0cb0\u0ccd\u0ca8\u0ccd\u0ca6\u0cb5\u0cc8\u0cb0\u0cbf \u0cb5\u0cbf\u0ca8\u0cbf\u0cb5\u0cbe\u0cb0\u0ca3\u0cc7 <br/> \u0c87\u0ca8\u0ccd\u0ca6\u0cbf\u0cb0\u0cc7 \u0cad\u0cc1\u0cb5\u0ca8 \u0c95\u0cbe\u0cb0\u0ca3\u0cc7 \u0c95\u0cc1\u0cb0\u0cc1\u0cb5\u0cbf\u0ca8\u0ccd\u0ca6 \u0ca6\u0ca8\u0ccd\u0ca4\u0cbf \u0c95\u0cbf\u0cb8\u0cb2\u0caf \u0cae\u0ccd\u0cb0\u0ccd\u0ca6\u0cc1 \u0c9a\u0cb0\u0ca3\u0cc7 <br/> \u0cae\u0ca8\u0ccd\u0ca6 \u0cb9\u0cbe\u0cb8 \u0cb0\u0cc1\u0c9a\u0cbf \u0ca8\u0cbf\u0ca8\u0ccd\u0ca6\u0cbf\u0ca4\u0cc7\u0ca8\u0ccd\u0ca6\u0cc1 \u0c95\u0cb0 \u0c95\u0cc1\u0ca8\u0ccd\u0ca6 \u0cb5\u0ccd\u0cb0\u0ccd\u0ca8\u0ccd\u0ca6 \u0cae\u0c95\u0cb0\u0ca8\u0ccd\u0ca6 \u0cac\u0cbf\u0ca8\u0ccd\u0ca6\u0cc1 <br/> \u0cb8\u0ca8\u0ccd\u0ca6\u0ccb\u0cb9 \u0cb8\u0cae\u0ccd\u0cb5\u0cb2\u0cbf\u0ca4 \u0cb8\u0cc1\u0ca8\u0ccd\u0ca6\u0cb0\u0cbe\u0cae\u0ccd\u0cac\u0cc1\u0c9c\u0c9c\u0cbe\u0cb8\u0ccd\u0caf\u0cc7 \u0c9c\u0c97\u0ca6\u0cc1\u0caa\u0cbe\u0cb8\u0ccd\u0caf\u0cc7"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d36\u0d4d\u0d30\u0d40 \u0d15\u0d41\u0d2e\u0d3e\u0d30 \u0d28\u0d17\u0d30\u0d3e\u0d32\u0d2f\u0d47 \u0d15\u0d30\u0d41\u0d23\u0d3e\u0d32\u0d2f\u0d47 \u0d15\u0d2e\u0d32\u0d3e\u0d32\u0d2f\u0d47"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d36\u0d4d\u0d30\u0d4d\u0d24\u0d1c\u0d28 \u0d15\u0d32\u0d4d\u0d2a\u0d15 \u0d2a\u0d3e\u0d26\u0d2a\u0d47 \u0d36\u0d4d\u0d30\u0d40 \u0d2a\u0d26\u0d4d\u0d2e\u0d28\u0d3e\u0d2d \u0d35\u0d26\u0d28\u0d3e\u0d2e\u0d4d\u0d2c\u0d41\u0d1c \u0d2e\u0d27\u0d41\u0d2a\u0d47"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 1", "T": "\u0d2e\u0d02\u0d1c\u0d41 \u0d30\u0d2e\u0d23\u0d3f\u0d24 \u0d28\u0d42\u0d2a\u0d41\u0d30\u0d47 \u0d15\u0d30\u0d36\u0d3f\u0d02\u0d1a\u0d3f\u0d24 \u0d15\u0d02\u0d15\u0d23 \u0d2d\u0d3e\u0d38\u0d41\u0d30\u0d47 <br/> \u0d2e\u0d02\u0d1c\u0d41\u0d33\u0d3e\u0d28\u0d28 \u0d38\u0d41\u0d27\u0d3e\u0d15\u0d30\u0d47 \u0d28\u0d35 \u0d15\u0d02\u0d1c\u0d26\u0d33 \u0d15\u0d32\u0d3f\u0d24 \u0d35\u0d3f\u0d32\u0d38\u0d3f\u0d24 \u0d1a\u0d3f\u0d15\u0d41\u0d30\u0d47 <br/> \u0d05\u0d02\u0d1c\u0d28\u0d3e\u0d02\u0d1a\u0d3f\u0d24 \u0d26\u0d4d\u0d30\u0d41\u0d17\u0d02\u0d1a\u0d32 \u0d2d\u0d02\u0d1c\u0d3f\u0d24 \u0d17\u0d02\u0d1c\u0d28\u0d26\u0d4d-\u0d35\u0d3f\u0d26\u0d4d\u0d2f \u0d2e\u0d02\u0d1c\u0d3f\u0d2e\u0d2a\u0d41\u0d02\u0d1c\u0d47 <br/> \u0d28\u0d3f\u0d30\u0d02\u0d1c\u0d28\u0d3e\u0d36\u0d2f \u0d28\u0d3f\u0d15\u0d41\u0d02\u0d1c \u0d15\u0d47\u0d33\u0d3f \u0d30\u0d38\u0d3f\u0d15\u0d47 \u0d05\u0d35 \u0d2e\u0d4d\u0d30\u0d4d\u0d17\u0d2e\u0d26 \u0d24\u0d3f\u0d32\u0d15\u0d47"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 2", "T": "\u0d15\u0d2e\u0d4d\u0d2c\u0d41 \u0d35\u0d30 \u0d38\u0d26\u0d4d\u0d30\u0d4d\u0d36 \u0d15\u0d28\u0d4d\u0d26\u0d30\u0d47 \u0d1c\u0d17\u0d26\u0d2e\u0d4d\u0d2c \u0d2a\u0d3e\u0d32\u0d3f\u0d24 \u0d35\u0d38\u0d41\u0d28\u0d4d\u0d27\u0d30\u0d47 <br/> \u0d2c\u0d3f\u0d2e\u0d4d\u0d2c \u0d2b\u0d32 \u0d30\u0d41\u0d1a\u0d3f\u0d30\u0d3e\u0d27\u0d30\u0d47 \u0d32\u0d4b\u0d32\u0d2e\u0d4d\u0d2c\u0d1c\u0d3e\u0d32 \u0d30\u0d41\u0d1a\u0d3f \u0d35\u0d3f\u0d32\u0d38\u0d3f\u0d24 \u0d1a\u0d3f\u0d15\u0d41\u0d30\u0d47 <br/> \u0d05\u0d2e\u0d4d\u0d2c \u0d15\u0d1a\u0d4d\u0d1a\u0d35\u0d3f \u0d35\u0d3f\u0d1f\u0d2e\u0d4d\u0d2c\u0d3f\u0d24 \u0d26\u0d33\u0d26 \u0d38\u0d3f\u0d24\u0d3e\u0d2e\u0d4d\u0d2c\u0d41\u0d1c \u0d26\u0d4d\u0d2f\u0d41\u0d24\u0d3f \u0d15\u0d26\u0d2e\u0d4d\u0d2c \u0d15\u0d21\u0d2e\u0d4d\u0d2c\u0d30\u0d47 <br/> \u0d36\u0d2e\u0d4d\u0d2c\u0d30\u0d3e\u0d30\u0d3f \u0d39\u0d30\u0d3f \u0d36\u0d2e\u0d4d\u0d2c\u0d30\u0d3e\u0d30\u0d4d\u0d1a\u0d3f\u0d24\u0d2a\u0d26\u0d47 \u0d2a\u0d26 \u0d28\u0d24\u0d1c\u0d28 \u0d36\u0d41\u0d2d\u0d26\u0d47"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 3", "T": "\u0d2e\u0d28\u0d4d\u0d26 \u0d17\u0d2e\u0d28 \u0d1c\u0d3f\u0d24 \u0d35\u0d3e\u0d30\u0d23\u0d47 \u0d38\u0d41\u0d38\u0d41\u0d30 \u0d35\u0d4d\u0d30\u0d4d\u0d28\u0d4d\u0d26\u0d35\u0d48\u0d30\u0d3f \u0d35\u0d3f\u0d28\u0d3f\u0d35\u0d3e\u0d30\u0d23\u0d47 <br/> \u0d07\u0d28\u0d4d\u0d26\u0d3f\u0d30\u0d47 \u0d2d\u0d41\u0d35\u0d28 \u0d15\u0d3e\u0d30\u0d23\u0d47 \u0d15\u0d41\u0d30\u0d41\u0d35\u0d3f\u0d28\u0d4d\u0d26 \u0d26\u0d28\u0d4d\u0d24\u0d3f \u0d15\u0d3f\u0d38\u0d32\u0d2f \u0d2e\u0d4d\u0d30\u0d4d\u0d26\u0d41 \u0d1a\u0d30\u0d23\u0d47 <br/> \u0d2e\u0d28\u0d4d\u0d26 \u0d39\u0d3e\u0d38 \u0d30\u0d41\u0d1a\u0d3f \u0d28\u0d3f\u0d28\u0d4d\u0d26\u0d3f\u0d24\u0d47\u0d28\u0d4d\u0d26\u0d41 \u0d15\u0d30 \u0d15\u0d41\u0d28\u0d4d\u0d26 \u0d35\u0d4d\u0d30\u0d4d\u0d28\u0d4d\u0d26 \u0d2e\u0d15\u0d30\u0d28\u0d4d\u0d26 \u0d2c\u0d3f\u0d28\u0d4d\u0d26\u0d41 <br/> \u0d38\u0d28\u0d4d\u0d26\u0d4b\u0d39 \u0d38\u0d2e\u0d4d\u0d35\u0d32\u0d3f\u0d24 \u0d38\u0d41\u0d28\u0d4d\u0d26\u0d30\u0d3e\u0d2e\u0d4d\u0d2c\u0d41\u0d1c\u0d1c\u0d3e\u0d38\u0d4d\u0d2f\u0d47 \u0d1c\u0d17\u0d26\u0d41\u0d2a\u0d3e\u0d38\u0d4d\u0d2f\u0d47"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0936\u094d\u0930\u0940 \u0915\u0941\u092e\u093e\u0930 \u0928\u0917\u0930\u093e\u0932\u092f\u0947 \u0915\u0930\u0941\u0923\u093e\u0932\u092f\u0947 \u0915\u092e\u0932\u093e\u0932\u092f\u0947"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0936\u094d\u0930\u094d\u0924\u091c\u0928 \u0915\u0932\u094d\u092a\u0915 \u092a\u093e\u0926\u092a\u0947 \u0936\u094d\u0930\u0940 \u092a\u0926\u094d\u092e\u0928\u093e\u092d \u0935\u0926\u0928\u093e\u092e\u094d\u092c\u0941\u091c \u092e\u0927\u0941\u092a\u0947"}, {"M": "\u091a\u0930\u0923\u092e\u094d 1", "T": "\u092e\u0902\u091c\u0941 \u0930\u092e\u0923\u093f\u0924 \u0928\u0942\u092a\u0941\u0930\u0947 \u0915\u0930\u0936\u093f\u0902\u091a\u093f\u0924 \u0915\u0902\u0915\u0923 \u092d\u093e\u0938\u0941\u0930\u0947 <br/> \u092e\u0902\u091c\u0941\u0932\u093e\u0928\u0928 \u0938\u0941\u0927\u093e\u0915\u0930\u0947 \u0928\u0935 \u0915\u0902\u091c\u0926\u0932 \u0915\u0932\u093f\u0924 \u0935\u093f\u0932\u0938\u093f\u0924 \u091a\u093f\u0915\u0941\u0930\u0947 <br/> \u0905\u0902\u091c\u0928\u093e\u0902\u091a\u093f\u0924 \u0926\u094d\u0930\u0941\u0917\u0902\u091a\u0932 \u092d\u0902\u091c\u093f\u0924 \u0917\u0902\u091c\u0928\u0926\u094d-\u0935\u093f\u0926\u094d\u092f \u092e\u0902\u091c\u093f\u092e\u092a\u0941\u0902\u091c\u0947 <br/> \u0928\u093f\u0930\u0902\u091c\u0928\u093e\u0936\u092f \u0928\u093f\u0915\u0941\u0902\u091c \u0915\u0947\u0932\u093f \u0930\u0938\u093f\u0915\u0947 \u0905\u0935 \u092e\u094d\u0930\u094d\u0917\u092e\u0926 \u0924\u093f\u0932\u0915\u0947"}, {"M": "\u091a\u0930\u0923\u092e\u094d 2", "T": "\u0915\u092e\u094d\u092c\u0941 \u0935\u0930 \u0938\u0926\u094d\u0930\u094d\u0936 \u0915\u0928\u094d\u0926\u0930\u0947 \u091c\u0917\u0926\u092e\u094d\u092c \u092a\u093e\u0932\u093f\u0924 \u0935\u0938\u0941\u0928\u094d\u0927\u0930\u0947 <br/> \u092c\u093f\u092e\u094d\u092c \u092b\u0932 \u0930\u0941\u091a\u093f\u0930\u093e\u0927\u0930\u0947 \u0932\u094b\u0932\u092e\u094d\u092c\u091c\u093e\u0932 \u0930\u0941\u091a\u093f \u0935\u093f\u0932\u0938\u093f\u0924 \u091a\u093f\u0915\u0941\u0930\u0947 <br/> \u0905\u092e\u094d\u092c \u0915\u091a\u094d\u091a\u0935\u093f \u0935\u093f\u091f\u092e\u094d\u092c\u093f\u0924 \u0926\u0932\u0926 \u0938\u093f\u0924\u093e\u092e\u094d\u092c\u0941\u091c \u0926\u094d\u092f\u0941\u0924\u093f \u0915\u0926\u092e\u094d\u092c \u0915\u0921\u092e\u094d\u092c\u0930\u0947 <br/> \u0936\u092e\u094d\u092c\u0930\u093e\u0930\u093f \u0939\u0930\u093f \u0936\u092e\u094d\u092c\u0930\u093e\u0930\u094d\u091a\u093f\u0924\u092a\u0926\u0947 \u092a\u0926 \u0928\u0924\u091c\u0928 \u0936\u0941\u092d\u0926\u0947"}, {"M": "\u091a\u0930\u0923\u092e\u094d 3", "T": "\u092e\u0928\u094d\u0926 \u0917\u092e\u0928 \u091c\u093f\u0924 \u0935\u093e\u0930\u0923\u0947 \u0938\u0941\u0938\u0941\u0930 \u0935\u094d\u0930\u094d\u0928\u094d\u0926\u0935\u0948\u0930\u093f \u0935\u093f\u0928\u093f\u0935\u093e\u0930\u0923\u0947 <br/> \u0907\u0928\u094d\u0926\u093f\u0930\u0947 \u092d\u0941\u0935\u0928 \u0915\u093e\u0930\u0923\u0947 \u0915\u0941\u0930\u0941\u0935\u093f\u0928\u094d\u0926 \u0926\u0928\u094d\u0924\u093f \u0915\u093f\u0938\u0932\u092f \u092e\u094d\u0930\u094d\u0926\u0941 \u091a\u0930\u0923\u0947 <br/> \u092e\u0928\u094d\u0926 \u0939\u093e\u0938 \u0930\u0941\u091a\u093f \u0928\u093f\u0928\u094d\u0926\u093f\u0924\u0947\u0928\u094d\u0926\u0941 \u0915\u0930 \u0915\u0941\u0928\u094d\u0926 \u0935\u094d\u0930\u094d\u0928\u094d\u0926 \u092e\u0915\u0930\u0928\u094d\u0926 \u092c\u093f\u0928\u094d\u0926\u0941 <br/> \u0938\u0928\u094d\u0926\u094b\u0939 \u0938\u092e\u094d\u0935\u0932\u093f\u0924 \u0938\u0941\u0928\u094d\u0926\u0930\u093e\u092e\u094d\u092c\u0941\u091c\u091c\u093e\u0938\u094d\u092f\u0947 \u091c\u0917\u0926\u0941\u092a\u093e\u0938\u094d\u092f\u0947"}]}], "L": "l", "lyricsref": [{"links": [{"N": "karnatik.com", "L": "https://karnatik.com/c6961.shtml"}]}]}