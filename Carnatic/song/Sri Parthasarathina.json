,20,33,10,9,7,8,34,26,3,4,5,27,6,15,16,17,29,2,28,30,14,12,13,32,19,18,23,25,24,22,21", "gujarati": "1,0,31,11,35,20,33,10,9,7,8,34,26,3,4,5,27,6,15,16,17,2,14,12,13,32,19,18,29,28,30,23,25,24,22,21", "punjabi": "1,0,31,11,35,20,33,10,9,7,8,34,26,3,4,5,27,6,15,16,17,2,14,12,13,32,19,18,29,28,30,23,25,24,22,21", "odia": "1,0,31,11,35,20,33,10,9,7,8,34,26,3,4,5,27,6,15,16,17,2,14,12,13,32,19,18,29,28,30,23,25,24,22,21", "assamese": "1,0,31,11,35,20,33,10,9,7,8,34,26,3,4,5,27,6,15,16,17,29,2,28,30,14,12,13,32,19,18,23,25,24,22,21"}, "lyricstext": [{"L": "English", "text": [{"M": "pallavi", "T": "SrI pArtthasArathinA pAlitOsmyaham sadA"}, {"M": "samasti caraNam", "T": "gOpastrI mOhita vENugAnEna <br/> SrI rukmiNI manOllAsa karaNEna"}, {"M": "madhyamakAla sAhityam", "T": "prapancArtti hara dAna nipuNa <br/> vaikuNTha sthitEna <br/> tumburu nArada nutEna <br/> guruguha sammOditEna"}]}, {"L": "Tamil", "text": [{"M": "\u0baa\u0bb2\u0bcd\u0bb2\u0bb5\u0bbf", "T": "\u0bb6\u0bcd\u0bb0\u0bc0 \u0baa\u0bbe\u0bb0\u0bcd\u0ba4\u0bcd\u0ba4\u0b9a\u0bbe\u0bb0\u0ba4\u0bbf\u0ba9\u0bbe \u0baa\u0bbe\u0bb2\u0bbf\u0ba4\u0bcb\u0bb8\u0bcd\u0bae\u0bcd\u0baf\u0bb9\u0bae\u0bcd \u0b9a\u0ba4\u0bbe"}, {"M": "\u0b9a\u0bae\u0bb8\u0bcd\u0ba4\u0bbf \u0b9a\u0bb0\u0ba3\u0bae\u0bcd", "T": "\u0b95\u0bcb\u0baa\u0bb8\u0bcd\u0ba4\u0bcd\u0bb0\u0bc0 \u0bae\u0bcb\u0bb9\u0bbf\u0ba4 \u0bb5\u0bc7\u0ba3\u0bc1\u0b95\u0bbe\u0ba9\u0bc7\u0ba9 <br/> \u0bb6\u0bcd\u0bb0\u0bc0 \u0bb0\u0bc1\u0b95\u0bcd\u0bae\u0bbf\u0ba3\u0bc0 \u0bae\u0ba9\u0bcb\u0bb2\u0bcd\u0bb2\u0bbe\u0b9a \u0b95\u0bb0\u0ba3\u0bc7\u0ba9"}, {"M": "\u0bae\u0ba4\u0bcd\u0baf\u0bae\u0b95\u0bbe\u0bb2 \u0b9a\u0bbe\u0bb9\u0bbf\u0ba4\u0bcd\u0baf\u0bae\u0bcd", "T": "\u0baa\u0bcd\u0bb0\u0baa\u0b9e\u0bcd\u0b9a\u0bbe\u0bb0\u0bcd\u0ba4\u0bcd\u0ba4\u0bbf \u0bb9\u0bb0 \u0ba4\u0bbe\u0ba9 \u0ba8\u0bbf\u0baa\u0bc1\u0ba3 <br/> \u0bb5\u0bc8\u0b95\u0bc1\u0ba3\u0bcd\u0b9f \u0bb8\u0bcd\u0ba4\u0bbf\u0ba4\u0bc7\u0ba9 <br/> \u0ba4\u0bc1\u0bae\u0bcd\u0baa\u0bc1\u0bb0\u0bc1 \u0ba8\u0bbe\u0bb0\u0ba4 \u0ba8\u0bc1\u0ba4\u0bc7\u0ba9 <br/> \u0b95\u0bc1\u0bb0\u0bc1\u0b95\u0bc1\u0bb9 \u0b9a\u0bae\u0bcd\u0bae\u0bcb\u0ba4\u0bbf\u0ba4\u0bc7\u0ba9"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c36\u0c4d\u0c30\u0c40 \u0c2a\u0c3e\u0c30\u0c4d\u0c24\u0c4d\u0c25\u0c38\u0c3e\u0c30\u0c25\u0c3f\u0c28\u0c3e \u0c2a\u0c3e\u0c32\u0c3f\u0c24\u0c4b\u0c38\u0c4d\u0c2e\u0c4d\u0c2f\u0c39\u0c2e\u0c4d \u0c38\u0c26\u0c3e"}, {"M": "\u0c38\u0c2e\u0c38\u0c4d\u0c24\u0c3f \u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c17\u0c4b\u0c2a\u0c38\u0c4d\u0c24\u0c4d\u0c30\u0c40 \u0c2e\u0c4b\u0c39\u0c3f\u0c24 \u0c35\u0c47\u0c23\u0c41\u0c17\u0c3e\u0c28\u0c47\u0c28 <br/> \u0c36\u0c4d\u0c30\u0c40 \u0c30\u0c41\u0c15\u0c4d\u0c2e\u0c3f\u0c23\u0c40 \u0c2e\u0c28\u0c4b\u0c32\u0c4d\u0c32\u0c3e\u0c38 \u0c15\u0c30\u0c23\u0c47\u0c28"}, {"M": "\u0c2e\u0c27\u0c4d\u0c2f\u0c2e\u0c15\u0c3e\u0c32 \u0c38\u0c3e\u0c39\u0c3f\u0c24\u0c4d\u0c2f\u0c2e\u0c4d", "T": "\u0c2a\u0c4d\u0c30\u0c2a\u0c02\u0c1a\u0c3e\u0c30\u0c4d\u0c24\u0c4d\u0c24\u0c3f \u0c39\u0c30 \u0c26\u0c3e\u0c28 \u0c28\u0c3f\u0c2a\u0c41\u0c23 <br/> \u0c35\u0c48\u0c15\u0c41\u0c23\u0c4d\u0c20 \u0c38\u0c4d\u0c25\u0c3f\u0c24\u0c47\u0c28 <br/> \u0c24\u0c41\u0c2e\u0c4d\u0c2c\u0c41\u0c30\u0c41 \u0c28\u0c3e\u0c30\u0c26 \u0c28\u0c41\u0c24\u0c47\u0c28 <br/> \u0c17\u0c41\u0c30\u0c41\u0c17\u0c41\u0c39 \u0c38\u0c2e\u0c4d\u0c2e\u0c4b\u0c26\u0c3f\u0c24\u0c47\u0c28"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cb6\u0ccd\u0cb0\u0cc0 \u0caa\u0cbe\u0cb0\u0ccd\u0ca4\u0ccd\u0ca5\u0cb8\u0cbe\u0cb0\u0ca5\u0cbf\u0ca8\u0cbe \u0caa\u0cbe\u0cb2\u0cbf\u0ca4\u0ccb\u0cb8\u0ccd\u0cae\u0ccd\u0caf\u0cb9\u0cae\u0ccd \u0cb8\u0ca6\u0cbe"}, {"M": "\u0cb8\u0cae\u0cb8\u0ccd\u0ca4\u0cbf \u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0c97\u0ccb\u0caa\u0cb8\u0ccd\u0ca4\u0ccd\u0cb0\u0cc0 \u0cae\u0ccb\u0cb9\u0cbf\u0ca4 \u0cb5\u0cc7\u0ca3\u0cc1\u0c97\u0cbe\u0ca8\u0cc7\u0ca8 <br/> \u0cb6\u0ccd\u0cb0\u0cc0 \u0cb0\u0cc1\u0c95\u0ccd\u0cae\u0cbf\u0ca3\u0cc0 \u0cae\u0ca8\u0ccb\u0cb2\u0ccd\u0cb2\u0cbe\u0cb8 \u0c95\u0cb0\u0ca3\u0cc7\u0ca8"}, {"M": "\u0cae\u0ca7\u0ccd\u0caf\u0cae\u0c95\u0cbe\u0cb2 \u0cb8\u0cbe\u0cb9\u0cbf\u0ca4\u0ccd\u0caf\u0cae\u0ccd", "T": "\u0caa\u0ccd\u0cb0\u0caa\u0c82\u0c9a\u0cbe\u0cb0\u0ccd\u0ca4\u0ccd\u0ca4\u0cbf \u0cb9\u0cb0 \u0ca6\u0cbe\u0ca8 \u0ca8\u0cbf\u0caa\u0cc1\u0ca3 <br/> \u0cb5\u0cc8\u0c95\u0cc1\u0ca3\u0ccd\u0ca0 \u0cb8\u0ccd\u0ca5\u0cbf\u0ca4\u0cc7\u0ca8 <br/> \u0ca4\u0cc1\u0cae\u0ccd\u0cac\u0cc1\u0cb0\u0cc1 \u0ca8\u0cbe\u0cb0\u0ca6 \u0ca8\u0cc1\u0ca4\u0cc7\u0ca8 <br/> \u0c97\u0cc1\u0cb0\u0cc1\u0c97\u0cc1\u0cb9 \u0cb8\u0cae\u0ccd\u0cae\u0ccb\u0ca6\u0cbf\u0ca4\u0cc7\u0ca8"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d36\u0d4d\u0d30\u0d40 \u0d2a\u0d3e\u0d30\u0d4d\u0d24\u0d4d\u0d25\u0d38\u0d3e\u0d30\u0d25\u0d3f\u0d28\u0d3e \u0d2a\u0d3e\u0d32\u0d3f\u0d24\u0d4b\u0d38\u0d4d\u0d2e\u0d4d\u0d2f\u0d39\u0d2e\u0d4d \u0d38\u0d26\u0d3e"}, {"M": "\u0d38\u0d2e\u0d38\u0d4d\u0d24\u0d3f \u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d17\u0d4b\u0d2a\u0d38\u0d4d\u0d24\u0d4d\u0d30\u0d40 \u0d2e\u0d4b\u0d39\u0d3f\u0d24 \u0d35\u0d47\u0d23\u0d41\u0d17\u0d3e\u0d28\u0d47\u0d28 <br/> \u0d36\u0d4d\u0d30\u0d40 \u0d30\u0d41\u0d15\u0d4d\u0d2e\u0d3f\u0d23\u0d40 \u0d2e\u0d28\u0d4b\u0d32\u0d4d\u0d32\u0d3e\u0d38 \u0d15\u0d30\u0d23\u0d47\u0d28"}, {"M": "\u0d2e\u0d27\u0d4d\u0d2f\u0d2e\u0d15\u0d3e\u0d32 \u0d38\u0d3e\u0d39\u0d3f\u0d24\u0d4d\u0d2f\u0d2e\u0d4d", "T": "\u0d2a\u0d4d\u0d30\u0d2a\u0d02\u0d1a\u0d3e\u0d30\u0d4d\u0d24\u0d4d\u0d24\u0d3f \u0d39\u0d30 \u0d26\u0d3e\u0d28 \u0d28\u0d3f\u0d2a\u0d41\u0d23 <br/> \u0d35\u0d48\u0d15\u0d41\u0d23\u0d4d\u0d20 \u0d38\u0d4d\u0d25\u0d3f\u0d24\u0d47\u0d28 <br/> \u0d24\u0d41\u0d2e\u0d4d\u0d2c\u0d41\u0d30\u0d41 \u0d28\u0d3e\u0d30\u0d26 \u0d28\u0d41\u0d24\u0d47\u0d28 <br/> \u0d17\u0d41\u0d30\u0d41\u0d17\u0d41\u0d39 \u0d38\u0d2e\u0d4d\u0d2e\u0d4b\u0d26\u0d3f\u0d24\u0d47\u0d28"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0936\u094d\u0930\u0940 \u092a\u093e\u0930\u094d\u0924\u094d\u0925\u0938\u093e\u0930\u0925\u093f\u0928\u093e \u092a\u093e\u0932\u093f\u0924\u094b\u0938\u094d\u092e\u094d\u092f\u0939\u092e\u094d \u0938\u0926\u093e"}, {"M": "\u0938\u092e\u0938\u094d\u0924\u093f \u091a\u0930\u0923\u092e\u094d", "T": "\u0917\u094b\u092a\u0938\u094d\u0924\u094d\u0930\u0940 \u092e\u094b\u0939\u093f\u0924 \u0935\u0947\u0923\u0941\u0917\u093e\u0928\u0947\u0928 <br/> \u0936\u094d\u0930\u0940 \u0930\u0941\u0915\u094d\u092e\u093f\u0923\u0940 \u092e\u0928\u094b\u0932\u094d\u0932\u093e\u0938 \u0915\u0930\u0923\u0947\u0928"}, {"M": "\u092e\u0927\u094d\u092f\u092e\u0915\u093e\u0932 \u0938\u093e\u0939\u093f\u0924\u094d\u092f\u092e\u094d", "T": "\u092a\u094d\u0930\u092a\u0902\u091a\u093e\u0930\u094d\u0924\u094d\u0924\u093f \u0939\u0930 \u0926\u093e\u0928 \u0928\u093f\u092a\u0941\u0923 <br/> \u0935\u0948\u0915\u0941\u0923\u094d\u0920 \u0938\u094d\u0925\u093f\u0924\u0947\u0928 <br/> \u0924\u0941\u092e\u094d\u092c\u0941\u0930\u0941 \u0928\u093e\u0930\u0926 \u0928\u0941\u0924\u0947\u0928 <br/> \u0917\u0941\u0930\u0941\u0917\u0941\u0939 \u0938\u092e\u094d\u092e\u094b\u0926\u093f\u0924\u0947\u0928"}]}], "L": "l", "lyricsref": [{"links": [{"N": "www.medieval.org", "L": "http://www.medieval.org/music/world/carnatic/lyrics/TKG/shri_partthasarathina.html"}, {"N": "guru-guha.blogspot.in", "L": "http://guru-guha.blogspot.in/2008/08/dikshitar-kriti-sri-parthasarathina.html"}]}]}