lla pUjincE"}, {"M": "caraNam", "T": "dArini shilayai tApamu tALaka <br/> vAramu kannIrunu rAlcaga <br/> shUra ahalyanu jUci brOcitivi <br/> A rIti dhanyu sEyavE tyAgarAja gEyamA"}]}, {"L": "Tamil", "text": [{"M": "\u0baa\u0bb2\u0bcd\u0bb2\u0bb5\u0bbf", "T": "\u0bb6\u0bcd\u0bb0\u0bc0 \u0bb0\u0bbe\u0bae \u0baa\u0bbe\u0ba4\u0bae\u0bbe \u0ba8\u0bc0 \u0b95\u0bcd\u0bb0\u0bcd\u0baa \u0b9a\u0bbe\u0bb2\u0bc1\u0ba9\u0bc7 <br/> \u0b9a\u0bbf\u0ba4\u0bcd\u0ba4\u0bbe\u0ba9\u0bbf\u0b95\u0bbf \u0bb0\u0bbe\u0bb5\u0bc7"}, {"M": "\u0b85\u0ba9\u0bc1\u0baa\u0bb2\u0bcd\u0bb2\u0bb5\u0bbf", "T": "\u0bb5\u0bbe\u0bb0\u0bbf\u0b9c \u0baa\u0bb5 \u0b9a\u0ba9\u0b95 \u0b9a\u0ba9\u0ba8\u0bcd\u0ba4\u0ba9 <br/> \u0bb5\u0bbe\u0b9a\u0bb5\u0bbe\u0ba4\u0bbf \u0ba8\u0bbe\u0bb0\u0ba4\u0bc1\u0bb2\u0bc6\u0bb2\u0bcd\u0bb2 \u0baa\u0bc2\u0b9c\u0bbf\u0b9e\u0bcd\u0b9a\u0bc7"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd", "T": "\u0ba4\u0bbe\u0bb0\u0bbf\u0ba9\u0bbf \u0bb7\u0bbf\u0bb2\u0baf\u0bc8 \u0ba4\u0bbe\u0baa\u0bae\u0bc1 \u0ba4\u0bbe\u0bb3\u0b95 <br/> \u0bb5\u0bbe\u0bb0\u0bae\u0bc1 \u0b95\u0ba9\u0bcd\u0ba9\u0bc0\u0bb0\u0bc1\u0ba9\u0bc1 \u0bb0\u0bbe\u0bb2\u0bcd\u0b9a\u0b95 <br/> \u0bb7\u0bc2\u0bb0 \u0b85\u0bb9\u0bb2\u0bcd\u0baf\u0ba9\u0bc1 \u0b9c\u0bc2\u0b9a\u0bbf \u0baa\u0bcd\u0bb0\u0bcb\u0b9a\u0bbf\u0ba4\u0bbf\u0bb5\u0bbf <br/> \u0b86 \u0bb0\u0bc0\u0ba4\u0bbf \u0ba4\u0ba9\u0bcd\u0baf\u0bc1 \u0b9a\u0bc7\u0baf\u0bb5\u0bc7 \u0ba4\u0bcd\u0baf\u0bbe\u0b95\u0bb0\u0bbe\u0b9c \u0b95\u0bc7\u0baf\u0bae\u0bbe"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c36\u0c4d\u0c30\u0c40 \u0c30\u0c3e\u0c2e \u0c2a\u0c3e\u0c26\u0c2e\u0c3e \u0c28\u0c40 \u0c15\u0c4d\u0c30\u0c4d\u0c2a \u0c1a\u0c3e\u0c32\u0c41\u0c28\u0c47 <br/> \u0c1a\u0c3f\u0c24\u0c4d\u0c24\u0c3e\u0c28\u0c3f\u0c15\u0c3f \u0c30\u0c3e\u0c35\u0c47"}, {"M": "\u0c05\u0c28\u0c41\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c35\u0c3e\u0c30\u0c3f\u0c1c \u0c2d\u0c35 \u0c38\u0c28\u0c15 \u0c38\u0c28\u0c28\u0c4d\u0c26\u0c28 <br/> \u0c35\u0c3e\u0c38\u0c35\u0c3e\u0c26\u0c3f \u0c28\u0c3e\u0c30\u0c26\u0c41\u0c32\u0c46\u0c32\u0c4d\u0c32 \u0c2a\u0c42\u0c1c\u0c3f\u0c02\u0c1a\u0c47"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c26\u0c3e\u0c30\u0c3f\u0c28\u0c3f \u0c37\u0c3f\u0c32\u0c2f\u0c48 \u0c24\u0c3e\u0c2a\u0c2e\u0c41 \u0c24\u0c3e\u0c33\u0c15 <br/> \u0c35\u0c3e\u0c30\u0c2e\u0c41 \u0c15\u0c28\u0c4d\u0c28\u0c40\u0c30\u0c41\u0c28\u0c41 \u0c30\u0c3e\u0c32\u0c4d\u0c1a\u0c17 <br/> \u0c37\u0c42\u0c30 \u0c05\u0c39\u0c32\u0c4d\u0c2f\u0c28\u0c41 \u0c1c\u0c42\u0c1a\u0c3f \u0c2c\u0c4d\u0c30\u0c4b\u0c1a\u0c3f\u0c24\u0c3f\u0c35\u0c3f <br/> \u0c06 \u0c30\u0c40\u0c24\u0c3f \u0c27\u0c28\u0c4d\u0c2f\u0c41 \u0c38\u0c47\u0c2f\u0c35\u0c47 \u0c24\u0c4d\u0c2f\u0c3e\u0c17\u0c30\u0c3e\u0c1c \u0c17\u0c47\u0c2f\u0c2e\u0c3e"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cb6\u0ccd\u0cb0\u0cc0 \u0cb0\u0cbe\u0cae \u0caa\u0cbe\u0ca6\u0cae\u0cbe \u0ca8\u0cc0 \u0c95\u0ccd\u0cb0\u0ccd\u0caa \u0c9a\u0cbe\u0cb2\u0cc1\u0ca8\u0cc7 <br/> \u0c9a\u0cbf\u0ca4\u0ccd\u0ca4\u0cbe\u0ca8\u0cbf\u0c95\u0cbf \u0cb0\u0cbe\u0cb5\u0cc7"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cb5\u0cbe\u0cb0\u0cbf\u0c9c \u0cad\u0cb5 \u0cb8\u0ca8\u0c95 \u0cb8\u0ca8\u0ca8\u0ccd\u0ca6\u0ca8 <br/> \u0cb5\u0cbe\u0cb8\u0cb5\u0cbe\u0ca6\u0cbf \u0ca8\u0cbe\u0cb0\u0ca6\u0cc1\u0cb2\u0cc6\u0cb2\u0ccd\u0cb2 \u0caa\u0cc2\u0c9c\u0cbf\u0c82\u0c9a\u0cc7"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0ca6\u0cbe\u0cb0\u0cbf\u0ca8\u0cbf \u0cb7\u0cbf\u0cb2\u0caf\u0cc8 \u0ca4\u0cbe\u0caa\u0cae\u0cc1 \u0ca4\u0cbe\u0cb3\u0c95 <br/> \u0cb5\u0cbe\u0cb0\u0cae\u0cc1 \u0c95\u0ca8\u0ccd\u0ca8\u0cc0\u0cb0\u0cc1\u0ca8\u0cc1 \u0cb0\u0cbe\u0cb2\u0ccd\u0c9a\u0c97 <br/> \u0cb7\u0cc2\u0cb0 \u0c85\u0cb9\u0cb2\u0ccd\u0caf\u0ca8\u0cc1 \u0c9c\u0cc2\u0c9a\u0cbf \u0cac\u0ccd\u0cb0\u0ccb\u0c9a\u0cbf\u0ca4\u0cbf\u0cb5\u0cbf <br/> \u0c86 \u0cb0\u0cc0\u0ca4\u0cbf \u0ca7\u0ca8\u0ccd\u0caf\u0cc1 \u0cb8\u0cc7\u0caf\u0cb5\u0cc7 \u0ca4\u0ccd\u0caf\u0cbe\u0c97\u0cb0\u0cbe\u0c9c \u0c97\u0cc7\u0caf\u0cae\u0cbe"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d36\u0d4d\u0d30\u0d40 \u0d30\u0d3e\u0d2e \u0d2a\u0d3e\u0d26\u0d2e\u0d3e \u0d28\u0d40 \u0d15\u0d4d\u0d30\u0d4d\u0d2a \u0d1a\u0d3e\u0d32\u0d41\u0d28\u0d47 <br/> \u0d1a\u0d3f\u0d24\u0d4d\u0d24\u0d3e\u0d28\u0d3f\u0d15\u0d3f \u0d30\u0d3e\u0d35\u0d47"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d35\u0d3e\u0d30\u0d3f\u0d1c \u0d2d\u0d35 \u0d38\u0d28\u0d15 \u0d38\u0d28\u0d28\u0d4d\u0d26\u0d28 <br/> \u0d35\u0d3e\u0d38\u0d35\u0d3e\u0d26\u0d3f \u0d28\u0d3e\u0d30\u0d26\u0d41\u0d32\u0d46\u0d32\u0d4d\u0d32 \u0d2a\u0d42\u0d1c\u0d3f\u0d02\u0d1a\u0d47"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d26\u0d3e\u0d30\u0d3f\u0d28\u0d3f \u0d37\u0d3f\u0d32\u0d2f\u0d48 \u0d24\u0d3e\u0d2a\u0d2e\u0d41 \u0d24\u0d3e\u0d33\u0d15 <br/> \u0d35\u0d3e\u0d30\u0d2e\u0d41 \u0d15\u0d28\u0d4d\u0d28\u0d40\u0d30\u0d41\u0d28\u0d41 \u0d30\u0d3e\u0d32\u0d4d\u0d1a\u0d17 <br/> \u0d37\u0d42\u0d30 \u0d05\u0d39\u0d32\u0d4d\u0d2f\u0d28\u0d41 \u0d1c\u0d42\u0d1a\u0d3f \u0d2c\u0d4d\u0d30\u0d4b\u0d1a\u0d3f\u0d24\u0d3f\u0d35\u0d3f <br/> \u0d06 \u0d30\u0d40\u0d24\u0d3f \u0d27\u0d28\u0d4d\u0d2f\u0d41 \u0d38\u0d47\u0d2f\u0d35\u0d47 \u0d24\u0d4d\u0d2f\u0d3e\u0d17\u0d30\u0d3e\u0d1c \u0d17\u0d47\u0d2f\u0d2e\u0d3e"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0936\u094d\u0930\u0940 \u0930\u093e\u092e \u092a\u093e\u0926\u092e\u093e \u0928\u0940 \u0915\u094d\u0930\u094d\u092a \u091a\u093e\u0932\u0941\u0928\u0947 <br/> \u091a\u093f\u0924\u094d\u0924\u093e\u0928\u093f\u0915\u093f \u0930\u093e\u0935\u0947"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0935\u093e\u0930\u093f\u091c \u092d\u0935 \u0938\u0928\u0915 \u0938\u0928\u0928\u094d\u0926\u0928 <br/> \u0935\u093e\u0938\u0935\u093e\u0926\u093f \u0928\u093e\u0930\u0926\u0941\u0932\u0947\u0932\u094d\u0932 \u092a\u0942\u091c\u093f\u0902\u091a\u0947"}, {"M": "\u091a\u0930\u0923\u092e\u094d", "T": "\u0926\u093e\u0930\u093f\u0928\u093f \u0937\u093f\u0932\u092f\u0948 \u0924\u093e\u092a\u092e\u0941 \u0924\u093e\u0932\u0915 <br/> \u0935\u093e\u0930\u092e\u0941 \u0915\u0928\u094d\u0928\u0940\u0930\u0941\u0928\u0941 \u0930\u093e\u0932\u094d\u091a\u0917 <br/> \u0937\u0942\u0930 \u0905\u0939\u0932\u094d\u092f\u0928\u0941 \u091c\u0942\u091a\u093f \u092c\u094d\u0930\u094b\u091a\u093f\u0924\u093f\u0935\u093f <br/> \u0906 \u0930\u0940\u0924\u093f \u0927\u0928\u094d\u092f\u0941 \u0938\u0947\u092f\u0935\u0947 \u0924\u094d\u092f\u093e\u0917\u0930\u093e\u091c \u0917\u0947\u092f\u092e\u093e"}]}], "L": "l", "lyricsref": [{"links": [{"N": "thyagaraja-vaibhavam.blogspot.in", "L": "http://thyagaraja-vaibhavam.blogspot.in/2007/06/thyagaraja-kriti-sri-rama-paadamaa-raga.html"}, {"N": "www.karnatik.com", "L": "http://www.karnatik.com/c2848.shtml"}]}]}