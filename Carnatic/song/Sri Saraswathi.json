\u0bc0\u0bb0\u0bcd\u0ba4\u0bcd\u0ba4\u0bc7 \u0ba4\u0bb0"}, {"M": "\u0bae\u0ba4\u0bcd\u0baf\u0bae\u0b95\u0bbe\u0bb2 \u0b9a\u0bbe\u0bb9\u0bbf\u0ba4\u0bcd\u0baf\u0bae\u0bcd", "T": "\u0bb9\u0bbe\u0b9a \u0bae\u0bc1\u0b95\u0bbe\u0bae\u0bcd\u0baa\u0bc1\u0bb0\u0bc1\u0bb9\u0bc7 <br/> \u0b85\u0ba4\u0bcd\u0baa\u0bc1\u0ba4 \u0b9a\u0bb0\u0ba3\u0bbe\u0bae\u0bcd\u0baa\u0bc1\u0bb0\u0bc1\u0bb9\u0bc7 <br/> \u0b9a\u0bae\u0bcd\u0b9a\u0bbe\u0bb0 \u0baa\u0bc0\u0ba4\u0bcd\u0baf\u0bbe\u0baa\u0bb9\u0bc7 <br/> \u0b9a\u0b95\u0bb2 \u0bae\u0ba8\u0bcd\u0ba4\u0bcd\u0bb0\u0bbe\u0b95\u0bcd\u0bb7\u0bb0 \u0b95\u0bc1\u0bb9\u0bc7"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c36\u0c4d\u0c30\u0c40 \u0c38\u0c30\u0c38\u0c4d\u0c35\u0c24\u0c3f \u0c28\u0c2e\u0c4b\u0c38\u0c4d\u0c24\u0c41\u0c24\u0c47 <br/> \u0c35\u0c30\u0c26\u0c47 \u0c2a\u0c30\u0c26\u0c47\u0c35\u0c24\u0c47"}, {"M": "\u0c2e\u0c27\u0c4d\u0c2f\u0c2e\u0c15\u0c3e\u0c32 \u0c38\u0c3e\u0c39\u0c3f\u0c24\u0c4d\u0c2f\u0c2e\u0c4d", "T": "\u0c36\u0c4d\u0c30\u0c40\u0c2a\u0c24\u0c3f \u0c17\u0c4c\u0c30\u0c40\u0c2a\u0c24\u0c3f \u0c17\u0c41\u0c30\u0c41\u0c17\u0c41\u0c39 \u0c35\u0c3f\u0c28\u0c41\u0c24\u0c47 \u0c35\u0c3f\u0c27\u0c3f\u0c2f\u0c41\u0c35\u0c24\u0c47"}, {"M": "\u0c38\u0c2e\u0c38\u0c4d\u0c24\u0c3f \u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c35\u0c3e\u0c38\u0c28\u0c3e \u0c24\u0c4d\u0c30\u0c2f \u0c35\u0c3f\u0c35\u0c30\u0c4d\u0c1c\u0c3f\u0c24 <br/> \u0c35\u0c30\u0c2e\u0c41\u0c28\u0c3f \u0c2d\u0c3e\u0c35\u0c3f\u0c24 \u0c2e\u0c42\u0c30\u0c4d\u0c24\u0c4d\u0c24\u0c47 <br/> \u0c35\u0c3e\u0c38\u0c35\u0c3e\u0c26\u0c4d\u0c2f\u0c16\u0c3f\u0c32 \u0c28\u0c3f\u0c30\u0c4d\u0c1c\u0c30 <br/> \u0c35\u0c30 \u0c35\u0c3f\u0c24\u0c30\u0c23 \u0c2c\u0c39\u0c41\u0c15\u0c40\u0c30\u0c4d\u0c24\u0c4d\u0c24\u0c47 \u0c27\u0c30"}, {"M": "\u0c2e\u0c27\u0c4d\u0c2f\u0c2e\u0c15\u0c3e\u0c32 \u0c38\u0c3e\u0c39\u0c3f\u0c24\u0c4d\u0c2f\u0c2e\u0c4d", "T": "\u0c39\u0c3e\u0c38 \u0c2e\u0c41\u0c16\u0c3e\u0c2e\u0c4d\u0c2c\u0c41\u0c30\u0c41\u0c39\u0c47 <br/> \u0c05\u0c26\u0c4d\u0c2d\u0c41\u0c24 \u0c1a\u0c30\u0c23\u0c3e\u0c2e\u0c4d\u0c2c\u0c41\u0c30\u0c41\u0c39\u0c47 <br/> \u0c38\u0c2e\u0c4d\u0c38\u0c3e\u0c30 \u0c2d\u0c40\u0c24\u0c4d\u0c2f\u0c3e\u0c2a\u0c39\u0c47 <br/> \u0c38\u0c15\u0c32 \u0c2e\u0c28\u0c4d\u0c24\u0c4d\u0c30\u0c3e\u0c15\u0c4d\u0c37\u0c30 \u0c17\u0c41\u0c39\u0c47"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cb6\u0ccd\u0cb0\u0cc0 \u0cb8\u0cb0\u0cb8\u0ccd\u0cb5\u0ca4\u0cbf \u0ca8\u0cae\u0ccb\u0cb8\u0ccd\u0ca4\u0cc1\u0ca4\u0cc7 <br/> \u0cb5\u0cb0\u0ca6\u0cc7 \u0caa\u0cb0\u0ca6\u0cc7\u0cb5\u0ca4\u0cc7"}, {"M": "\u0cae\u0ca7\u0ccd\u0caf\u0cae\u0c95\u0cbe\u0cb2 \u0cb8\u0cbe\u0cb9\u0cbf\u0ca4\u0ccd\u0caf\u0cae\u0ccd", "T": "\u0cb6\u0ccd\u0cb0\u0cc0\u0caa\u0ca4\u0cbf \u0c97\u0ccc\u0cb0\u0cc0\u0caa\u0ca4\u0cbf \u0c97\u0cc1\u0cb0\u0cc1\u0c97\u0cc1\u0cb9 \u0cb5\u0cbf\u0ca8\u0cc1\u0ca4\u0cc7 \u0cb5\u0cbf\u0ca7\u0cbf\u0caf\u0cc1\u0cb5\u0ca4\u0cc7"}, {"M": "\u0cb8\u0cae\u0cb8\u0ccd\u0ca4\u0cbf \u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0cb5\u0cbe\u0cb8\u0ca8\u0cbe \u0ca4\u0ccd\u0cb0\u0caf \u0cb5\u0cbf\u0cb5\u0cb0\u0ccd\u0c9c\u0cbf\u0ca4 <br/> \u0cb5\u0cb0\u0cae\u0cc1\u0ca8\u0cbf \u0cad\u0cbe\u0cb5\u0cbf\u0ca4 \u0cae\u0cc2\u0cb0\u0ccd\u0ca4\u0ccd\u0ca4\u0cc7 <br/> \u0cb5\u0cbe\u0cb8\u0cb5\u0cbe\u0ca6\u0ccd\u0caf\u0c96\u0cbf\u0cb2 \u0ca8\u0cbf\u0cb0\u0ccd\u0c9c\u0cb0 <br/> \u0cb5\u0cb0 \u0cb5\u0cbf\u0ca4\u0cb0\u0ca3 \u0cac\u0cb9\u0cc1\u0c95\u0cc0\u0cb0\u0ccd\u0ca4\u0ccd\u0ca4\u0cc7 \u0ca7\u0cb0"}, {"M": "\u0cae\u0ca7\u0ccd\u0caf\u0cae\u0c95\u0cbe\u0cb2 \u0cb8\u0cbe\u0cb9\u0cbf\u0ca4\u0ccd\u0caf\u0cae\u0ccd", "T": "\u0cb9\u0cbe\u0cb8 \u0cae\u0cc1\u0c96\u0cbe\u0cae\u0ccd\u0cac\u0cc1\u0cb0\u0cc1\u0cb9\u0cc7 <br/> \u0c85\u0ca6\u0ccd\u0cad\u0cc1\u0ca4 \u0c9a\u0cb0\u0ca3\u0cbe\u0cae\u0ccd\u0cac\u0cc1\u0cb0\u0cc1\u0cb9\u0cc7 <br/> \u0cb8\u0cae\u0ccd\u0cb8\u0cbe\u0cb0 \u0cad\u0cc0\u0ca4\u0ccd\u0caf\u0cbe\u0caa\u0cb9\u0cc7 <br/> \u0cb8\u0c95\u0cb2 \u0cae\u0ca8\u0ccd\u0ca4\u0ccd\u0cb0\u0cbe\u0c95\u0ccd\u0cb7\u0cb0 \u0c97\u0cc1\u0cb9\u0cc7"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d36\u0d4d\u0d30\u0d40 \u0d38\u0d30\u0d38\u0d4d\u0d35\u0d24\u0d3f \u0d28\u0d2e\u0d4b\u0d38\u0d4d\u0d24\u0d41\u0d24\u0d47 <br/> \u0d35\u0d30\u0d26\u0d47 \u0d2a\u0d30\u0d26\u0d47\u0d35\u0d24\u0d47"}, {"M": "\u0d2e\u0d27\u0d4d\u0d2f\u0d2e\u0d15\u0d3e\u0d32 \u0d38\u0d3e\u0d39\u0d3f\u0d24\u0d4d\u0d2f\u0d2e\u0d4d", "T": "\u0d36\u0d4d\u0d30\u0d40\u0d2a\u0d24\u0d3f \u0d17\u0d4c\u0d30\u0d40\u0d2a\u0d24\u0d3f \u0d17\u0d41\u0d30\u0d41\u0d17\u0d41\u0d39 \u0d35\u0d3f\u0d28\u0d41\u0d24\u0d47 \u0d35\u0d3f\u0d27\u0d3f\u0d2f\u0d41\u0d35\u0d24\u0d47"}, {"M": "\u0d38\u0d2e\u0d38\u0d4d\u0d24\u0d3f \u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d35\u0d3e\u0d38\u0d28\u0d3e \u0d24\u0d4d\u0d30\u0d2f \u0d35\u0d3f\u0d35\u0d30\u0d4d\u0d1c\u0d3f\u0d24 <br/> \u0d35\u0d30\u0d2e\u0d41\u0d28\u0d3f \u0d2d\u0d3e\u0d35\u0d3f\u0d24 \u0d2e\u0d42\u0d30\u0d4d\u0d24\u0d4d\u0d24\u0d47 <br/> \u0d35\u0d3e\u0d38\u0d35\u0d3e\u0d26\u0d4d\u0d2f\u0d16\u0d3f\u0d32 \u0d28\u0d3f\u0d30\u0d4d\u0d1c\u0d30 <br/> \u0d35\u0d30 \u0d35\u0d3f\u0d24\u0d30\u0d23 \u0d2c\u0d39\u0d41\u0d15\u0d40\u0d30\u0d4d\u0d24\u0d4d\u0d24\u0d47 \u0d27\u0d30"}, {"M": "\u0d2e\u0d27\u0d4d\u0d2f\u0d2e\u0d15\u0d3e\u0d32 \u0d38\u0d3e\u0d39\u0d3f\u0d24\u0d4d\u0d2f\u0d2e\u0d4d", "T": "\u0d39\u0d3e\u0d38 \u0d2e\u0d41\u0d16\u0d3e\u0d2e\u0d4d\u0d2c\u0d41\u0d30\u0d41\u0d39\u0d47 <br/> \u0d05\u0d26\u0d4d\u0d2d\u0d41\u0d24 \u0d1a\u0d30\u0d23\u0d3e\u0d2e\u0d4d\u0d2c\u0d41\u0d30\u0d41\u0d39\u0d47 <br/> \u0d38\u0d2e\u0d4d\u0d38\u0d3e\u0d30 \u0d2d\u0d40\u0d24\u0d4d\u0d2f\u0d3e\u0d2a\u0d39\u0d47 <br/> \u0d38\u0d15\u0d32 \u0d2e\u0d28\u0d4d\u0d24\u0d4d\u0d30\u0d3e\u0d15\u0d4d\u0d37\u0d30 \u0d17\u0d41\u0d39\u0d47"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0936\u094d\u0930\u0940 \u0938\u0930\u0938\u094d\u0935\u0924\u093f \u0928\u092e\u094b\u0938\u094d\u0924\u0941\u0924\u0947 <br/> \u0935\u0930\u0926\u0947 \u092a\u0930\u0926\u0947\u0935\u0924\u0947"}, {"M": "\u092e\u0927\u094d\u092f\u092e\u0915\u093e\u0932 \u0938\u093e\u0939\u093f\u0924\u094d\u092f\u092e\u094d", "T": "\u0936\u094d\u0930\u0940\u092a\u0924\u093f \u0917\u094c\u0930\u0940\u092a\u0924\u093f \u0917\u0941\u0930\u0941\u0917\u0941\u0939 \u0935\u093f\u0928\u0941\u0924\u0947 \u0935\u093f\u0927\u093f\u092f\u0941\u0935\u0924\u0947"}, {"M": "\u0938\u092e\u0938\u094d\u0924\u093f \u091a\u0930\u0923\u092e\u094d", "T": "\u0935\u093e\u0938\u0928\u093e \u0924\u094d\u0930\u092f \u0935\u093f\u0935\u0930\u094d\u091c\u093f\u0924 <br/> \u0935\u0930\u092e\u0941\u0928\u093f \u092d\u093e\u0935\u093f\u0924 \u092e\u0942\u0930\u094d\u0924\u094d\u0924\u0947 <br/> \u0935\u093e\u0938\u0935\u093e\u0926\u094d\u092f\u0916\u093f\u0932 \u0928\u093f\u0930\u094d\u091c\u0930 <br/> \u0935\u0930 \u0935\u093f\u0924\u0930\u0923 \u092c\u0939\u0941\u0915\u0940\u0930\u094d\u0924\u094d\u0924\u0947 \u0927\u0930"}, {"M": "\u092e\u0927\u094d\u092f\u092e\u0915\u093e\u0932 \u0938\u093e\u0939\u093f\u0924\u094d\u092f\u092e\u094d", "T": "\u0939\u093e\u0938 \u092e\u0941\u0916\u093e\u092e\u094d\u092c\u0941\u0930\u0941\u0939\u0947 <br/> \u0905\u0926\u094d\u092d\u0941\u0924 \u091a\u0930\u0923\u093e\u092e\u094d\u092c\u0941\u0930\u0941\u0939\u0947 <br/> \u0938\u092e\u094d\u0938\u093e\u0930 \u092d\u0940\u0924\u094d\u092f\u093e\u092a\u0939\u0947 <br/> \u0938\u0915\u0932 \u092e\u0928\u094d\u0924\u094d\u0930\u093e\u0915\u094d\u0937\u0930 \u0917\u0941\u0939\u0947"}]}], "L": "l", "lyricsref": [{"links": [{"N": "www.medieval.org", "L": "http://www.medieval.org/music/world/carnatic/lyrics/TKG/shri_sarasvati_namostute.html"}, {"N": "guru-guha.blogspot.com", "L": "http://guru-guha.blogspot.com/2008/09/dikshitar-kriti-sri-sarasvati-namostute.html"}, {"N": "www.karnatik.com", "L": "http://www.karnatik.com/c1042.shtml"}, {"N": "www.shivkumar.org", "L": "http://www.shivkumar.org/music/srisaraswati-arabhi.htm"}]}]}