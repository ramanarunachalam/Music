0cbe\u0cb0-\u0ca6\u0ccb\u0cb2\u0cc1\u0c9a\u0cc1\u0ca8\u0ccd\u0ca8\u0ca6\u0cbf \u0ca8\u0cbe \u0cb2\u0ccb\u0ca8\u0cbf"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd 1", "T": "\u0cae\u0ca4\u0ccd\u0cb8\u0ccd\u0caf\u0cae\u0cc1\u0caf\u0cbe\u0c95\u0cb2\u0cbf \u0c95\u0cca\u0ca8\u0cbf \u0c95\u0cbe\u0cb2\u0cae\u0cc1\u0c9a\u0cc7 <br/> \u0cae\u0c97\u0ccd\u0ca8\u0cae\u0cc8\u0ca8 \u0cb0\u0cc0\u0ca4\u0cbf\u0ca8\u0cc1\u0ca8\u0ccd\u0ca8\u0ca6\u0cbf <br/> \u0c85\u0c9a\u0ccd\u0c9a\u0cae\u0cc8\u0ca8 \u0ca6\u0cc0\u0caa \u0cb8\u0ca8\u0ccd\u0ca8\u0cbf\u0ca7\u0cbf\u0ca8\u0cbf \u0cae\u0cb0\u0cc1\u0c97\u0ccd- <br/> \u0c85\u0ca1\u0ccd\u0ca1\u0cac\u0ca1\u0cbf \u0c9a\u0cc6\u0cb0\u0c9a\u0cbf\u0ca8\u0c9f\u0ccd\u0c9f\u0cc1\u0ca8\u0ccd\u0ca8\u0ca6\u0cbf \u0ca4\u0cc6\u0cb0"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd 2", "T": "\u0c87\u0cb0\u0cb5\u0cca\u0ca8\u0ccd\u0ca6\u0c97 \u0cad\u0cc1\u0c9c\u0cbf\u0caf\u0cbf\u0ca8\u0ccd\u0c9a\u0cc1 \u0cb8\u0cae\u0caf\u0cae\u0cc1\u0ca8 <br/> \u0c88\u0c97 \u0ca4\u0c97\u0cc1\u0cb2\u0cc1 \u0cb0\u0cc0\u0ca4\u0cbf\u0ca8\u0cc1\u0ca8\u0ccd\u0ca8\u0ca6\u0cbf <br/> \u0cb9\u0cb0\u0cbf \u0ca7\u0ccd\u0caf\u0cbe\u0ca8\u0cae\u0cc1 \u0cb8\u0cc7\u0caf\u0cc1 \u0cb5\u0cc7\u0cb3 \u0c9a\u0cbf\u0ca4\u0ccd\u0ca4\u0cae\u0cc1 <br/> \u0c85\u0ca8\u0ccd\u0ca4\u0ccd\u0caf\u0c9c\u0cc1 \u0cb5\u0cbe\u0ca1\u0c95\u0cc1 \u0caa\u0ccb\u0caf\u0cbf\u0ca8\u0c9f\u0ccd\u0c9f\u0cc1\u0ca8\u0ccd\u0ca8\u0ca6\u0cbf"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd 3", "T": "\u0cb5\u0cbe\u0c97\u0cc1\u0cb0\u0cae\u0ca8\u0cbf \u0ca4\u0cc6\u0cb2\u0cbf\u0caf\u0c95 \u0cae\u0cc3\u0c97 \u0c97\u0ca3\u0cae\u0cc1\u0cb2\u0cc1 <br/> \u0cb5\u0c9a\u0ccd\u0c9a\u0cbf \u0ca4\u0c97\u0cc1\u0cb2\u0cc1 \u0cb0\u0cc0\u0ca4\u0cbf\u0ca8\u0cc1\u0ca8\u0ccd\u0ca8\u0ca6\u0cbf <br/> \u0cb5\u0cc7\u0c97\u0cae\u0cc7 \u0ca8\u0cc0 \u0cae\u0ca4\u0cae\u0cc1\u0ca8\u0ca8\u0cc1\u0cb8\u0cb0\u0cbf\u0ca8\u0ccd\u0c9a\u0cbf\u0ca8 <br/> \u0ca4\u0ccd\u0caf\u0cbe\u0c97\u0cb0\u0cbe\u0c9c \u0ca8\u0cc1\u0ca4 \u0cae\u0ca6 \u0cae\u0ca4\u0ccd\u0cb8\u0cb0\u0cae\u0ca8\u0cc1"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d24\u0d46\u0d30 \u0d24\u0d40\u0d2f\u0d17 \u0d30\u0d3e\u0d26\u0d3e \u0d32\u0d4b\u0d28\u0d3f <br/> \u0d24\u0d3f\u0d30\u0d41\u0d2a\u0d24\u0d3f \u0d35\u0d47\u0d02\u0d15\u0d1f \u0d30\u0d2e\u0d23 \u0d2e\u0d24\u0d4d\u0d38\u0d30\u0d2e\u0d28\u0d41"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d2a\u0d30\u0d2e \u0d2a\u0d41\u0d30\u0d41\u0d37 \u0d27\u0d30\u0d4d\u0d2e\u0d3e\u0d26\u0d3f \u0d2e\u0d4b\u0d15\u0d4d\u0d37\u0d2e\u0d41\u0d32 <br/> \u0d2a\u0d3e\u0d30-\u0d26\u0d4b\u0d32\u0d41\u0d1a\u0d41\u0d28\u0d4d\u0d28\u0d26\u0d3f \u0d28\u0d3e \u0d32\u0d4b\u0d28\u0d3f"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 1", "T": "\u0d2e\u0d24\u0d4d\u0d38\u0d4d\u0d2f\u0d2e\u0d41\u0d2f\u0d3e\u0d15\u0d32\u0d3f \u0d15\u0d4a\u0d28\u0d3f \u0d15\u0d3e\u0d32\u0d2e\u0d41\u0d1a\u0d47 <br/> \u0d2e\u0d17\u0d4d\u0d28\u0d2e\u0d48\u0d28 \u0d30\u0d40\u0d24\u0d3f\u0d28\u0d41\u0d28\u0d4d\u0d28\u0d26\u0d3f <br/> \u0d05\u0d1a\u0d4d\u0d1a\u0d2e\u0d48\u0d28 \u0d26\u0d40\u0d2a \u0d38\u0d28\u0d4d\u0d28\u0d3f\u0d27\u0d3f\u0d28\u0d3f \u0d2e\u0d30\u0d41\u0d17\u0d4d- <br/> \u0d05\u0d21\u0d4d\u0d21\u0d2c\u0d21\u0d3f \u0d1a\u0d46\u0d30\u0d1a\u0d3f\u0d28\u0d1f\u0d4d\u0d1f\u0d41\u0d28\u0d4d\u0d28\u0d26\u0d3f \u0d24\u0d46\u0d30"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 2", "T": "\u0d07\u0d30\u0d35\u0d4a\u0d28\u0d4d\u0d26\u0d17 \u0d2d\u0d41\u0d1c\u0d3f\u0d2f\u0d3f\u0d28\u0d4d\u0d1a\u0d41 \u0d38\u0d2e\u0d2f\u0d2e\u0d41\u0d28 <br/> \u0d08\u0d17 \u0d24\u0d17\u0d41\u0d32\u0d41 \u0d30\u0d40\u0d24\u0d3f\u0d28\u0d41\u0d28\u0d4d\u0d28\u0d26\u0d3f <br/> \u0d39\u0d30\u0d3f \u0d27\u0d4d\u0d2f\u0d3e\u0d28\u0d2e\u0d41 \u0d38\u0d47\u0d2f\u0d41 \u0d35\u0d47\u0d33 \u0d1a\u0d3f\u0d24\u0d4d\u0d24\u0d2e\u0d41 <br/> \u0d05\u0d28\u0d4d\u0d24\u0d4d\u0d2f\u0d1c\u0d41 \u0d35\u0d3e\u0d21\u0d15\u0d41 \u0d2a\u0d4b\u0d2f\u0d3f\u0d28\u0d1f\u0d4d\u0d1f\u0d41\u0d28\u0d4d\u0d28\u0d26\u0d3f"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 3", "T": "\u0d35\u0d3e\u0d17\u0d41\u0d30\u0d2e\u0d28\u0d3f \u0d24\u0d46\u0d32\u0d3f\u0d2f\u0d15 \u0d2e\u0d43\u0d17 \u0d17\u0d23\u0d2e\u0d41\u0d32\u0d41 <br/> \u0d35\u0d1a\u0d4d\u0d1a\u0d3f \u0d24\u0d17\u0d41\u0d32\u0d41 \u0d30\u0d40\u0d24\u0d3f\u0d28\u0d41\u0d28\u0d4d\u0d28\u0d26\u0d3f <br/> \u0d35\u0d47\u0d17\u0d2e\u0d47 \u0d28\u0d40 \u0d2e\u0d24\u0d2e\u0d41\u0d28\u0d28\u0d41\u0d38\u0d30\u0d3f\u0d28\u0d4d\u0d1a\u0d3f\u0d28 <br/> \u0d24\u0d4d\u0d2f\u0d3e\u0d17\u0d30\u0d3e\u0d1c \u0d28\u0d41\u0d24 \u0d2e\u0d26 \u0d2e\u0d24\u0d4d\u0d38\u0d30\u0d2e\u0d28\u0d41"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0924\u0947\u0930 \u0924\u0940\u092f\u0917 \u0930\u093e\u0926\u093e \u0932\u094b\u0928\u093f <br/> \u0924\u093f\u0930\u0941\u092a\u0924\u093f \u0935\u0947\u0902\u0915\u091f \u0930\u092e\u0923 \u092e\u0924\u094d\u0938\u0930\u092e\u0928\u0941"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u092a\u0930\u092e \u092a\u0941\u0930\u0941\u0937 \u0927\u0930\u094d\u092e\u093e\u0926\u093f \u092e\u094b\u0915\u094d\u0937\u092e\u0941\u0932 <br/> \u092a\u093e\u0930-\u0926\u094b\u0932\u0941\u091a\u0941\u0928\u094d\u0928\u0926\u093f \u0928\u093e \u0932\u094b\u0928\u093f"}, {"M": "\u091a\u0930\u0923\u092e\u094d 1", "T": "\u092e\u0924\u094d\u0938\u094d\u092f\u092e\u0941\u092f\u093e\u0915\u0932\u093f \u0915\u094b\u0928\u093f \u0915\u093e\u0932\u092e\u0941\u091a\u0947 <br/> \u092e\u0917\u094d\u0928\u092e\u0948\u0928 \u0930\u0940\u0924\u093f\u0928\u0941\u0928\u094d\u0928\u0926\u093f <br/> \u0905\u091a\u094d\u091a\u092e\u0948\u0928 \u0926\u0940\u092a \u0938\u0928\u094d\u0928\u093f\u0927\u093f\u0928\u093f \u092e\u0930\u0941\u0917\u094d- <br/> \u0905\u0921\u094d\u0921\u092c\u0921\u093f \u091a\u0947\u0930\u091a\u093f\u0928\u091f\u094d\u091f\u0941\u0928\u094d\u0928\u0926\u093f \u0924\u0947\u0930"}, {"M": "\u091a\u0930\u0923\u092e\u094d 2", "T": "\u0907\u0930\u0935\u094b\u0928\u094d\u0926\u0917 \u092d\u0941\u091c\u093f\u092f\u093f\u0928\u094d\u091a\u0941 \u0938\u092e\u092f\u092e\u0941\u0928 <br/> \u0908\u0917 \u0924\u0917\u0941\u0932\u0941 \u0930\u0940\u0924\u093f\u0928\u0941\u0928\u094d\u0928\u0926\u093f <br/> \u0939\u0930\u093f \u0927\u094d\u092f\u093e\u0928\u092e\u0941 \u0938\u0947\u092f\u0941 \u0935\u0947\u0932 \u091a\u093f\u0924\u094d\u0924\u092e\u0941 <br/> \u0905\u0928\u094d\u0924\u094d\u092f\u091c\u0941 \u0935\u093e\u0921\u0915\u0941 \u092a\u094b\u092f\u093f\u0928\u091f\u094d\u091f\u0941\u0928\u094d\u0928\u0926\u093f"}, {"M": "\u091a\u0930\u0923\u092e\u094d 3", "T": "\u0935\u093e\u0917\u0941\u0930\u092e\u0928\u093f \u0924\u0947\u0932\u093f\u092f\u0915 \u092e\u0943\u0917 \u0917\u0923\u092e\u0941\u0932\u0941 <br/> \u0935\u091a\u094d\u091a\u093f \u0924\u0917\u0941\u0932\u0941 \u0930\u0940\u0924\u093f\u0928\u0941\u0928\u094d\u0928\u0926\u093f <br/> \u0935\u0947\u0917\u092e\u0947 \u0928\u0940 \u092e\u0924\u092e\u0941\u0928\u0928\u0941\u0938\u0930\u093f\u0928\u094d\u091a\u093f\u0928 <br/> \u0924\u094d\u092f\u093e\u0917\u0930\u093e\u091c \u0928\u0941\u0924 \u092e\u0926 \u092e\u0924\u094d\u0938\u0930\u092e\u0928\u0941"}]}], "L": "l", "lyricsref": [{"links": [{"N": "thyagaraja-vaibhavam.blogspot.com", "L": "http://thyagaraja-vaibhavam.blogspot.com/2007/03/thyagaraja-kriti-tera-teeyaga-raadaa.html"}, {"N": "www.karnatik.com", "L": "http://www.karnatik.com/c2896.shtml"}, {"N": "www.shivkumar.org", "L": "http://www.shivkumar.org/music/TeraTeeyagarada.htm"}, {"N": "www.sangeetasudha.org", "L": "http://www.sangeetasudha.org/thyagaraja/t.html#MARK_TERATEEYAGA"}]}]}