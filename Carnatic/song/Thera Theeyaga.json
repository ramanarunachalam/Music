baf\u0bbe\u0ba9\u0bae\u0bc1 \u0b9a\u0bc7\u0baf\u0bc1 \u0bb5\u0bc7\u0bb3 \u0b9a\u0bbf\u0ba4\u0bcd\u0ba4\u0bae\u0bc1 <br/> \u0b85\u0ba8\u0bcd\u0ba4\u0bcd\u0baf\u0b9c\u0bc1 \u0bb5\u0bbe\u0b9f\u0b95\u0bc1 \u0baa\u0bcb\u0baf\u0bbf\u0ba9\u0b9f\u0bcd\u0b9f\u0bc1\u0ba9\u0bcd\u0ba9\u0ba4\u0bbf"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd 3", "T": "\u0bb5\u0bbe\u0b95\u0bc1\u0bb0\u0bae\u0ba9\u0bbf \u0ba4\u0bc6\u0bb2\u0bbf\u0baf\u0b95 \u0bae\u0bcd\u0bb0\u0bc1\u0b95 \u0b95\u0ba3\u0bae\u0bc1\u0bb2\u0bc1 <br/> \u0bb5\u0b9a\u0bcd\u0b9a\u0bbf \u0ba4\u0b95\u0bc1\u0bb2\u0bc1 \u0bb0\u0bc0\u0ba4\u0bbf\u0ba9\u0bc1\u0ba9\u0bcd\u0ba9\u0ba4\u0bbf <br/> \u0bb5\u0bc7\u0b95\u0bae\u0bc7 \u0ba8\u0bc0 \u0bae\u0ba4\u0bae\u0bc1\u0ba9\u0ba9\u0bc1\u0b9a\u0bb0\u0bbf\u0ba9\u0bcd\u0b9a\u0bbf\u0ba9 <br/> \u0ba4\u0bcd\u0baf\u0bbe\u0b95\u0bb0\u0bbe\u0b9c \u0ba8\u0bc1\u0ba4 \u0bae\u0ba4 \u0bae\u0ba4\u0bcd\u0b9a\u0bb0\u0bae\u0ba9\u0bc1"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c24\u0c46\u0c30 \u0c24\u0c40\u0c2f\u0c17 \u0c30\u0c3e\u0c26\u0c3e \u0c32\u0c4b\u0c28\u0c3f <br/> \u0c24\u0c3f\u0c30\u0c41\u0c2a\u0c24\u0c3f \u0c35\u0c47\u0c02\u0c15\u0c1f \u0c30\u0c2e\u0c23 \u0c2e\u0c24\u0c4d\u0c38\u0c30\u0c2e\u0c28\u0c41"}, {"M": "\u0c05\u0c28\u0c41\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c2a\u0c30\u0c2e \u0c2a\u0c41\u0c30\u0c41\u0c37 \u0c27\u0c30\u0c4d\u0c2e\u0c3e\u0c26\u0c3f \u0c2e\u0c4b\u0c15\u0c4d\u0c37\u0c2e\u0c41\u0c32 <br/> \u0c2a\u0c3e\u0c30-\u0c26\u0c4b\u0c32\u0c41\u0c1a\u0c41\u0c28\u0c4d\u0c28\u0c26\u0c3f \u0c28\u0c3e \u0c32\u0c4b\u0c28\u0c3f"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d 1", "T": "\u0c2e\u0c24\u0c4d\u0c38\u0c4d\u0c2f\u0c2e\u0c41\u0c2f\u0c3e\u0c15\u0c32\u0c3f \u0c15\u0c4a\u0c28\u0c3f \u0c15\u0c3e\u0c32\u0c2e\u0c41\u0c1a\u0c47 <br/> \u0c2e\u0c17\u0c4d\u0c28\u0c2e\u0c48\u0c28 \u0c30\u0c40\u0c24\u0c3f\u0c28\u0c41\u0c28\u0c4d\u0c28\u0c26\u0c3f <br/> \u0c05\u0c1a\u0c4d\u0c1a\u0c2e\u0c48\u0c28 \u0c26\u0c40\u0c2a \u0c38\u0c28\u0c4d\u0c28\u0c3f\u0c27\u0c3f\u0c