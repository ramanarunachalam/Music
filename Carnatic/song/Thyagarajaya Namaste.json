, "T": "\u0baa\u0bcb\u0b95\u0bae\u0bcb\u0b95\u0bcd\u0bb7 \u0ba4\u0bbe\u0ba9 \u0bb5\u0bbe\u0bae \u0baa\u0bbe\u0b95 \u0bb8\u0bcd\u0ba4\u0bbf\u0ba4 \u0b9a\u0bc8\u0bb2\u0b9c\u0bbe\u0baf <br/> \u0baf\u0bcb\u0b95 \u0b95\u0bc1\u0bb0\u0bc1 \u0b95\u0bc1\u0bb9\u0bbe\u0ba4\u0bcd\u0bae\u0b9c\u0bbe\u0baf \u0ba4\u0bcd\u0baf\u0bbe\u0b95 \u0ba4\u0bcd\u0bb5\u0b9c\u0bbe\u0baf \u0b85\u0b9c\u0bbe\u0baf"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd", "T": "\u0bae\u0bc1\u0b95\u0bc1\u0ba8\u0bcd\u0ba4\u0bbe\u0ba4\u0bbf \u0baa\u0bc2\u0b9c\u0bbf\u0ba4 \u0b9a\u0bcb\u0bae\u0bbe\u0bb8\u0bcd\u0b95\u0ba8\u0bcd\u0ba4 \u0bae\u0bc2\u0bb0\u0bcd\u0ba4\u0bcd\u0ba4\u0baf\u0bc7 <br/> \u0bae\u0bc1\u0b9a\u0bc1\u0b95\u0bc1\u0ba8\u0bcd\u0ba4\u0bbe\u0ba4\u0bbf \u0baa\u0b95\u0bcd\u0ba4\u0b9c\u0ba9 \u0bae\u0ba9\u0bcb\u0bb0\u0ba4 \u0bb8\u0bcd\u0baa\u0bc2\u0bb0\u0bcd\u0ba4\u0bcd\u0ba4\u0baf\u0bc7 <br/> \u0bae\u0bc1\u0b95\u0bc1\u0bb0 \u0baa\u0bbf\u0bae\u0bcd\u0baa \u0baa\u0bcd\u0bb0\u0ba4\u0bbf\u0baa\u0bbf\u0bae\u0bcd\u0baa\u0bbf\u0ba4 \u0bae\u0bc1\u0b95 \u0bb8\u0bcd\u0baa\u0bc2\u0bb0\u0bcd\u0ba4\u0bcd\u0ba4\u0baf\u0bc7 <br/> \u0bae\u0bc1\u0ba9\u0bbf \u0baa\u0b95\u0bcd\u0bb7\u0bbf \u0bae\u0bcd\u0bb0\u0bc1\u0b95 \u0b95\u0bc0\u0b9f\u0bbe\u0ba4\u0bbf \u0bae\u0bc2\u0b95\u0bcd\u0ba4\u0bbf \u0baa\u0bcd\u0bb0\u0ba4 \u0b95\u0bc0\u0bb0\u0bcd\u0ba4\u0bcd\u0ba4\u0baf\u0bc7"}, {"M": "\u0bae\u0ba4\u0bcd\u0baf\u0bae\u0b95\u0bbe\u0bb2 \u0b9a\u0bbe\u0bb9\u0bbf\u0ba4\u0bcd\u0baf\u0bae\u0bcd", "T": "\u0b9a\u0b95\u0bb2\u0bbe\u0b95\u0bae \u0bae\u0ba8\u0bcd\u0ba4\u0bcd\u0bb0 \u0ba4\u0ba8\u0bcd\u0ba4\u0bcd\u0bb0 \u0b9a\u0bbe\u0bb0\u0b9e\u0bcd\u0b9e\u0bbe\u0ba9\u0bc1 \u0bb0\u0b95\u0bcd\u0ba4\u0baf\u0bc7 <br/> \u0b85\u0b95\u0ba4\u0bbe\u0ba4\u0bbf \u0ba4\u0bcd\u0bb0\u0bbf\u0bb0\u0bc7\u0b95\u0bbe\u0ba4\u0bcd\u0bae\u0b95\u0bbe\u0ba4\u0bbe\u0bb0 \u0baa\u0bcd\u0bb0\u0bb5\u0bcd\u0bb0\u0bc1\u0ba4\u0bcd\u0ba4\u0baf\u0bc7 <br/> \u0b9a\u0b95\u0bb3 \u0ba8\u0bbf\u0bb7\u0bcd\u0b95\u0bb3 \u0bb8\u0bcd\u0bb5\u0bb0\u0bc2\u0baa \u0b9a\u0b9a\u0bcd\u0b9a\u0bbf\u0ba4\u0bcd \u0b9a\u0bc1\u0b95 \u0bb5\u0bcd\u0baf\u0bbe\u0baa\u0bcd\u0ba4\u0baf\u0bc7 <br/> \u0bb5\u0bbf\u0b95\u0bb2\u0bcd\u0baa \u0baa\u0bc7\u0ba4\u0baf\u0bc1\u0b95\u0bcd\u0ba4\u0baf\u0bc7 \u0bb5\u0bbf\u0b9f\u0b99\u0bcd\u0b95 \u0bb0\u0bc2\u0baa \u0b9a\u0b95\u0bcd\u0ba4\u0baf\u0bc7"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c24\u0c4d\u0c2f\u0c3e\u0c17\u0c30\u0c3e\u0c1c\u0c3e\u0c2f \u0c28\u0c2e\u0c38\u0c4d\u0c24\u0c47 \u0c28\u0c2e\u0c38\u0c4d\u0c24\u0c47 <br/> \u0c15\u0c3e\u0c24\u0c4d\u0c2f\u0c3e\u0c2f\u0c28\u0c40\u0c2a\u0c24\u0c47 \u0c2a\u0c36\u0c41\u0c2a \u0c24\u0c47 \u0c38\u0c3f\u0c39\u0c4d\u0c2e\u0c3e\u0c38\u0c28\u0c2a\u0c24\u0c47"}, {"M": "\u0c05\u0c28\u0c41\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c35\u0c3e\u0c17\u0c40\u0c36\u0c3e\u0c26\u0c4d\u0c2f\u0c16\u0c3f\u0c32 \u0c26\u0c47\u0c35 \u0c35\u0c28\u0c4d\u0c26\u0c3f\u0c24 \u0c2a\u0c26 \u0c2a\u0c02\u0c15\u0c1c\u0c3e\u0c2f <br/> \u0c2f\u0c4b\u0c17\u0c40\u0c36\u0c4d\u0c35\u0c30 \u0c2e\u0c3e\u0c28\u0c38 \u0c38\u0c2e\u0c4d\u0c2f\u0c41\u0c15\u0c4d\u0c24 \u0c35\u0c26\u0c28 \u0c35\u0c3e\u0c30\u0c3f\u0c1c\u0c3e\u0c2f"}, {"M": "\u0c2e\u0c27\u0c4d\u0c2f\u0c2e\u0c15\u0c3e\u0c32 \u0c38\u0c3e\u0c39\u0c3f\u0c24\u0c4d\u0c2f\u0c2e\u0c4d", "T": "\u0c2d\u0c4b\u0c17\u0c2e\u0c4b\u0c15\u0c4d\u0c37 \u0c26\u0c3e\u0c28 \u0c35\u0c3e\u0c2e \u0c2d\u0c3e\u0c17 \u0c38\u0c4d\u0c25\u0c3f\u0c24 \u0c36\u0c48\u0c32\u0c1c\u0c3e\u0c2f <br/> \u0c2f\u0c4b\u0c17 \u0c17\u0c41\u0c30\u0c41 \u0c17\u0c41\u0c39\u0c3e\u0c24\u0c4d\u0c2e\u0c1c\u0c3e\u0c2f \u0c24\u0c4d\u0c2f\u0c3e\u0c17 \u0c27\u0c4d\u0c35\u0c1c\u0c3e\u0c2f \u0c05\u0c1c\u0c3e\u0c2f"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c2e\u0c41\u0c15\u0c41\u0c28\u0c4d\u0c26\u0c3e\u0c26\u0c3f \u0c2a\u0c42\u0c1c\u0c3f\u0c24 \u0c38\u0c4b\u0c2e\u0c3e\u0c38\u0c4d\u0c15\u0c28\u0c4d\u0c26 \u0c2e\u0c42\u0c30\u0c4d\u0c24\u0c4d\u0c24\u0c2f\u0c47 <br/> \u0c2e\u0c41\u0c1a\u0c41\u0c15\u0c41\u0c28\u0c4d\u0c26\u0c3e\u0c26\u0c3f \u0c2d\u0c15\u0c4d\u0c24\u0c1c\u0c28 \u0c2e\u0c28\u0c4b\u0c30\u0c25 \u0c38\u0c4d\u0c2b\u0c42\u0c30\u0c4d\u0c24\u0c4d\u0c24\u0c2f\u0c47 <br/> \u0c2e\u0c41\u0c15\u0c41\u0c30 \u0c2c\u0c3f\u0c2e\u0c4d\u0c2c \u0c2a\u0c4d\u0c30\u0c24\u0c3f\u0c2c\u0c3f\u0c2e\u0c4d\u0c2c\u0c3f\u0c24 \u0c2e\u0c41\u0c16 \u0c38\u0c4d\u0c2b\u0c42\u0c30\u0c4d\u0c24\u0c4d\u0c24\u0c2f\u0c47 <br/> \u0c2e\u0c41\u0c28\u0c3f \u0c2a\u0c15\u0c4d\u0c37\u0c3f \u0c2e\u0c43\u0c17 \u0c15\u0c40\u0c1f\u0c3e\u0c26\u0c3f \u0c2e\u0c42\u0c15\u0c4d\u0c24\u0c3f \u0c2a\u0c4d\u0c30\u0c26 \u0c15\u0c40\u0c30\u0c4d\u0c24\u0c4d\u0c24\u0c2f\u0c47"}, {"M": "\u0c2e\u0c27\u0c4d\u0c2f\u0c2e\u0c15\u0c3e\u0c32 \u0c38\u0c3e\u0c39\u0c3f\u0c24\u0c4d\u0c2f\u0c2e\u0c4d", "T": "\u0c38\u0c15\u0c32\u0c3e\u0c17\u0c2e \u0c2e\u0c28\u0c4d\u0c24\u0c4d\u0c30 \u0c24\u0c28\u0c4d\u0c24\u0c4d\u0c30 \u0c38\u0c3e\u0c30\u0c1c\u0c4d\u0c1e\u0c3e\u0c28\u0c41 \u0c30\u0c15\u0c4d\u0c24\u0c2f\u0c47 <br/> \u0c05\u0c15\u0c24\u0c3e\u0c26\u0c3f \u0c24\u0c4d\u0c30\u0c3f\u0c30\u0c47\u0c16\u0c3e\u0c24\u0c4d\u0c2e\u0c15\u0c3e\u0c27\u0c3e\u0c30 \u0c2a\u0c4d\u0c30\u0c35\u0c43\u0c24\u0c4d\u0c24\u0c2f\u0c47 <br/> \u0c38\u0c15\u0c33 \u0c28\u0c3f\u0c37\u0c4d\u0c15\u0c33 \u0c38\u0c4d\u0c35\u0c30\u0c42\u0c2a \u0c38\u0c1a\u0c4d\u0c1a\u0c3f\u0c24\u0c4d \u0c38\u0c41\u0c16 \u0c35\u0c4d\u0c2f\u0c3e\u0c2a\u0c4d\u0c24\u0c2f\u0c47 <br/> \u0c35\u0c3f\u0c15\u0c32\u0c4d\u0c2a \u0c2d\u0c47\u0c26\u0c2f\u0c41\u0c15\u0c4d\u0c24\u0c2f\u0c47 \u0c35\u0c3f\u0c1f\u0c02\u0c15 \u0c30\u0c42\u0c2a \u0c36\u0c15\u0c4d\u0c24\u0c2f\u0c47"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0ca4\u0ccd\u0caf\u0cbe\u0c97\u0cb0\u0cbe\u0c9c\u0cbe\u0caf \u0ca8\u0cae\u0cb8\u0ccd\u0ca4\u0cc7 \u0ca8\u0cae\u0cb8\u0ccd\u0ca4\u0cc7 <br/> \u0c95\u0cbe\u0ca4\u0ccd\u0caf\u0cbe\u0caf\u0ca8\u0cc0\u0caa\u0ca4\u0cc7 \u0caa\u0cb6\u0cc1\u0caa \u0ca4\u0cc7 \u0cb8\u0cbf\u0cb9\u0ccd\u0cae\u0cbe\u0cb8\u0ca8\u0caa\u0ca4\u0cc7"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cb5\u0cbe\u0c97\u0cc0\u0cb6\u0cbe\u0ca6\u0ccd\u0caf\u0c96\u0cbf\u0cb2 \u0ca6\u0cc7\u0cb5 \u0cb5\u0ca8\u0ccd\u0ca6\u0cbf\u0ca4 \u0caa\u0ca6 \u0caa\u0c82\u0c95\u0c9c\u0cbe\u0caf <br/> \u0caf\u0ccb\u0c97\u0cc0\u0cb6\u0ccd\u0cb5\u0cb0 \u0cae\u0cbe\u0ca8\u0cb8 \u0cb8\u0cae\u0ccd\u0caf\u0cc1\u0c95\u0ccd\u0ca4 \u0cb5\u0ca6\u0ca8 \u0cb5\u0cbe\u0cb0\u0cbf\u0c9c\u0cbe\u0caf"}, {"M": "\u0cae\u0ca7\u0ccd\u0caf\u0cae\u0c95\u0cbe\u0cb2 \u0cb8\u0cbe\u0cb9\u0cbf\u0ca4\u0ccd\u0caf\u0cae\u0ccd", "T": "\u0cad\u0ccb\u0c97\u0cae\u0ccb\u0c95\u0ccd\u0cb7 \u0ca6\u0cbe\u0ca8 \u0cb5\u0cbe\u0cae \u0cad\u0cbe\u0c97 \u0cb8\u0ccd\u0ca5\u0cbf\u0ca4 \u0cb6\u0cc8\u0cb2\u0c9c\u0cbe\u0caf <br/> \u0caf\u0ccb\u0c97 \u0c97\u0cc1\u0cb0\u0cc1 \u0c97\u0cc1\u0cb9\u0cbe\u0ca4\u0ccd\u0cae\u0c9c\u0cbe\u0caf \u0ca4\u0ccd\u0caf\u0cbe\u0c97 \u0ca7\u0ccd\u0cb5\u0c9c\u0cbe\u0caf \u0c85\u0c9c\u0cbe\u0caf"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0cae\u0cc1\u0c95\u0cc1\u0ca8\u0ccd\u0ca6\u0cbe\u0ca6\u0cbf \u0caa\u0cc2\u0c9c\u0cbf\u0ca4 \u0cb8\u0ccb\u0cae\u0cbe\u0cb8\u0ccd\u0c95\u0ca8\u0ccd\u0ca6 \u0cae\u0cc2\u0cb0\u0ccd\u0ca4\u0ccd\u0ca4\u0caf\u0cc7 <br/> \u0cae\u0cc1\u0c9a\u0cc1\u0c95\u0cc1\u0ca8\u0ccd\u0ca6\u0cbe\u0ca6\u0cbf \u0cad\u0c95\u0ccd\u0ca4\u0c9c\u0ca8 \u0cae\u0ca8\u0ccb\u0cb0\u0ca5 \u0cb8\u0ccd\u0cab\u0cc2\u0cb0\u0ccd\u0ca4\u0ccd\u0ca4\u0caf\u0cc7 <br/> \u0cae\u0cc1\u0c95\u0cc1\u0cb0 \u0cac\u0cbf\u0cae\u0ccd\u0cac \u0caa\u0ccd\u0cb0\u0ca4\u0cbf\u0cac\u0cbf\u0cae\u0ccd\u0cac\u0cbf\u0ca4 \u0cae\u0cc1\u0c96 \u0cb8\u0ccd\u0cab\u0cc2\u0cb0\u0ccd\u0ca4\u0ccd\u0ca4\u0caf\u0cc7 <br/> \u0cae\u0cc1\u0ca8\u0cbf \u0caa\u0c95\u0ccd\u0cb7\u0cbf \u0cae\u0cc3\u0c97 \u0c95\u0cc0\u0c9f\u0cbe\u0ca6\u0cbf \u0cae\u0cc2\u0c95\u0ccd\u0ca4\u0cbf \u0caa\u0ccd\u0cb0\u0ca6 \u0c95\u0cc0\u0cb0\u0ccd\u0ca4\u0ccd\u0ca4\u0caf\u0cc7"}, {"M": "\u0cae\u0ca7\u0ccd\u0caf\u0cae\u0c95\u0cbe\u0cb2 \u0cb8\u0cbe\u0cb9\u0cbf\u0ca4\u0ccd\u0caf\u0cae\u0ccd", "T": "\u0cb8\u0c95\u0cb2\u0cbe\u0c97\u0cae \u0cae\u0ca8\u0ccd\u0ca4\u0ccd\u0cb0 \u0ca4\u0ca8\u0ccd\u0ca4\u0ccd\u0cb0 \u0cb8\u0cbe\u0cb0\u0c9c\u0ccd\u0c9e\u0cbe\u0ca8\u0cc1 \u0cb0\u0c95\u0ccd\u0ca4\u0caf\u0cc7 <br/> \u0c85\u0c95\u0ca4\u0cbe\u0ca6\u0cbf \u0ca4\u0ccd\u0cb0\u0cbf\u0cb0\u0cc7\u0c96\u0cbe\u0ca4\u0ccd\u0cae\u0c95\u0cbe\u0ca7\u0cbe\u0cb0 \u0caa\u0ccd\u0cb0\u0cb5\u0cc3\u0ca4\u0ccd\u0ca4\u0caf\u0cc7 <br/> \u0cb8\u0c95\u0cb3 \u0ca8\u0cbf\u0cb7\u0ccd\u0c95\u0cb3 \u0cb8\u0ccd\u0cb5\u0cb0\u0cc2\u0caa \u0cb8\u0c9a\u0ccd\u0c9a\u0cbf\u0ca4\u0ccd \u0cb8\u0cc1\u0c96 \u0cb5\u0ccd\u0caf\u0cbe\u0caa\u0ccd\u0ca4\u0caf\u0cc7 <br/> \u0cb5\u0cbf\u0c95\u0cb2\u0ccd\u0caa \u0cad\u0cc7\u0ca6\u0caf\u0cc1\u0c95\u0ccd\u0ca4\u0caf\u0cc7 \u0cb5\u0cbf\u0c9f\u0c82\u0c95 \u0cb0\u0cc2\u0caa \u0cb6\u0c95\u0ccd\u0ca4\u0caf\u0cc7"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d24\u0d4d\u0d2f\u0d3e\u0d17\u0d30\u0d3e\u0d1c\u0d3e\u0d2f \u0d28\u0d2e\u0d38\u0d4d\u0d24\u0d47 \u0d28\u0d2e\u0d38\u0d4d\u0d24\u0d47 <br/> \u0d15\u0d3e\u0d24\u0d4d\u0d2f\u0d3e\u0d2f\u0d28\u0d40\u0d2a\u0d24\u0d47 \u0d2a\u0d36\u0d41\u0d2a \u0d24\u0d47 \u0d38\u0d3f\u0d39\u0d4d\u0d2e\u0d3e\u0d38\u0d28\u0d2a\u0d24\u0d47"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d35\u0d3e\u0d17\u0d40\u0d36\u0d3e\u0d26\u0d4d\u0d2f\u0d16\u0d3f\u0d32 \u0d26\u0d47\u0d35 \u0d35\u0d28\u0d4d\u0d26\u0d3f\u0d24 \u0d2a\u0d26 \u0d2a\u0d02\u0d15\u0d1c\u0d3e\u0d2f <br/> \u0d2f\u0d4b\u0d17\u0d40\u0d36\u0d4d\u0d35\u0d30 \u0d2e\u0d3e\u0d28\u0d38 \u0d38\u0d2e\u0d4d\u0d2f\u0d41\u0d15\u0d4d\u0d24 \u0d35\u0d26\u0d28 \u0d35\u0d3e\u0d30\u0d3f\u0d1c\u0d3e\u0d2f"}, {"M": "\u0d2e\u0d27\u0d4d\u0d2f\u0d2e\u0d15\u0d3e\u0d32 \u0d38\u0d3e\u0d39\u0d3f\u0d24\u0d4d\u0d2f\u0d2e\u0d4d", "T": "\u0d2d\u0d4b\u0d17\u0d2e\u0d4b\u0d15\u0d4d\u0d37 \u0d26\u0d3e\u0d28 \u0d35\u0d3e\u0d2e \u0d2d\u0d3e\u0d17 \u0d38\u0d4d\u0d25\u0d3f\u0d24 \u0d36\u0d48\u0d32\u0d1c\u0d3e\u0d2f <br/> \u0d2f\u0d4b\u0d17 \u0d17\u0d41\u0d30\u0d41 \u0d17\u0d41\u0d39\u0d3e\u0d24\u0d4d\u0d2e\u0d1c\u0d3e\u0d2f \u0d24\u0d4d\u0d2f\u0d3e\u0d17 \u0d27\u0d4d\u0d35\u0d1c\u0d3e\u0d2f \u0d05\u0d1c\u0d3e\u0d2f"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d2e\u0d41\u0d15\u0d41\u0d28\u0d4d\u0d26\u0d3e\u0d26\u0d3f \u0d2a\u0d42\u0d1c\u0d3f\u0d24 \u0d38\u0d4b\u0d2e\u0d3e\u0d38\u0d4d\u0d15\u0d28\u0d4d\u0d26 \u0d2e\u0d42\u0d30\u0d4d\u0d24\u0d4d\u0d24\u0d2f\u0d47 <br/> \u0d2e\u0d41\u0d1a\u0d41\u0d15\u0d41\u0d28\u0d4d\u0d26\u0d3e\u0d26\u0d3f \u0d2d\u0d15\u0d4d\u0d24\u0d1c\u0d28 \u0d2e\u0d28\u0d4b\u0d30\u0d25 \u0d38\u0d4d\u0d2b\u0d42\u0d30\u0d4d\u0d24\u0d4d\u0d24\u0d2f\u0d47 <br/> \u0d2e\u0d41\u0d15\u0d41\u0d30 \u0d2c\u0d3f\u0d2e\u0d4d\u0d2c \u0d2a\u0d4d\u0d30\u0d24\u0d3f\u0d2c\u0d3f\u0d2e\u0d4d\u0d2c\u0d3f\u0d24 \u0d2e\u0d41\u0d16 \u0d38\u0d4d\u0d2b\u0d42\u0d30\u0d4d\u0d24\u0d4d\u0d24\u0d2f\u0d47 <br/> \u0d2e\u0d41\u0d28\u0d3f \u0d2a\u0d15\u0d4d\u0d37\u0d3f \u0d2e\u0d43\u0d17 \u0d15\u0d40\u0d1f\u0d3e\u0d26\u0d3f \u0d2e\u0d42\u0d15\u0d4d\u0d24\u0d3f \u0d2a\u0d4d\u0d30\u0d26 \u0d15\u0d40\u0d30\u0d4d\u0d24\u0d4d\u0d24\u0d2f\u0d47"}, {"M": "\u0d2e\u0d27\u0d4d\u0d2f\u0d2e\u0d15\u0d3e\u0d32 \u0d38\u0d3e\u0d39\u0d3f\u0d24\u0d4d\u0d2f\u0d2e\u0d4d", "T": "\u0d38\u0d15\u0d32\u0d3e\u0d17\u0d2e \u0d2e\u0d28\u0d4d\u0d24\u0d4d\u0d30 \u0d24\u0d28\u0d4d\u0d24\u0d4d\u0d30 \u0d38\u0d3e\u0d30\u0d1c\u0d4d\u0d1e\u0d3e\u0d28\u0d41 \u0d30\u0d15\u0d4d\u0d24\u0d2f\u0d47 <br/> \u0d05\u0d15\u0d24\u0d3e\u0d26\u0d3f \u0d24\u0d4d\u0d30\u0d3f\u0d30\u0d47\u0d16\u0d3e\u0d24\u0d4d\u0d2e\u0d15\u0d3e\u0d27\u0d3e\u0d30 \u0d2a\u0d4d\u0d30\u0d35\u0d43\u0d24\u0d4d\u0d24\u0d2f\u0d47 <br/> \u0d38\u0d15\u0d33 \u0d28\u0d3f\u0d37\u0d4d\u0d15\u0d33 \u0d38\u0d4d\u0d35\u0d30\u0d42\u0d2a \u0d38\u0d1a\u0d4d\u0d1a\u0d3f\u0d24\u0d4d \u0d38\u0d41\u0d16 \u0d35\u0d4d\u0d2f\u0d3e\u0d2a\u0d4d\u0d24\u0d2f\u0d47 <br/> \u0d35\u0d3f\u0d15\u0d32\u0d4d\u0d2a \u0d2d\u0d47\u0d26\u0d2f\u0d41\u0d15\u0d4d\u0d24\u0d2f\u0d47 \u0d35\u0d3f\u0d1f\u0d02\u0d15 \u0d30\u0d42\u0d2a \u0d36\u0d15\u0d4d\u0d24\u0d2f\u0d47"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0924\u094d\u092f\u093e\u0917\u0930\u093e\u091c\u093e\u092f \u0928\u092e\u0938\u094d\u0924\u0947 \u0928\u092e\u0938\u094d\u0924\u0947 <br/> \u0915\u093e\u0924\u094d\u092f\u093e\u092f\u0928\u0940\u092a\u0924\u0947 \u092a\u0936\u0941\u092a \u0924\u0947 \u0938\u093f\u0939\u094d\u092e\u093e\u0938\u0928\u092a\u0924\u0947"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0935\u093e\u0917\u0940\u0936\u093e\u0926\u094d\u092f\u0916\u093f\u0932 \u0926\u0947\u0935 \u0935\u0928\u094d\u0926\u093f\u0924 \u092a\u0926 \u092a\u0902\u0915\u091c\u093e\u092f <br/> \u092f\u094b\u0917\u0940\u0936\u094d\u0935\u0930 \u092e\u093e\u0928\u0938 \u0938\u092e\u094d\u092f\u0941\u0915\u094d\u0924 \u0935\u0926\u0928 \u0935\u093e\u0930\u093f\u091c\u093e\u092f"}, {"M": "\u092e\u0927\u094d\u092f\u092e\u0915\u093e\u0932 \u0938\u093e\u0939\u093f\u0924\u094d\u092f\u092e\u094d", "T": "\u092d\u094b\u0917\u092e\u094b\u0915\u094d\u0937 \u0926\u093e\u0928 \u0935\u093e\u092e \u092d\u093e\u0917 \u0938\u094d\u0925\u093f\u0924 \u0936\u0948\u0932\u091c\u093e\u092f <br/> \u092f\u094b\u0917 \u0917\u0941\u0930\u0941 \u0917\u0941\u0939\u093e\u0924\u094d\u092e\u091c\u093e\u092f \u0924\u094d\u092f\u093e\u0917 \u0927\u094d\u0935\u091c\u093e\u092f \u0905\u091c\u093e\u092f"}, {"M": "\u091a\u0930\u0923\u092e\u094d", "T": "\u092e\u0941\u0915\u0941\u0928\u094d\u0926\u093e\u0926\u093f \u092a\u0942\u091c\u093f\u0924 \u0938\u094b\u092e\u093e\u0938\u094d\u0915\u0928\u094d\u0926 \u092e\u0942\u0930\u094d\u0924\u094d\u0924\u092f\u0947 <br/> \u092e\u0941\u091a\u0941\u0915\u0941\u0928\u094d\u0926\u093e\u0926\u093f \u092d\u0915\u094d\u0924\u091c\u0928 \u092e\u0928\u094b\u0930\u0925 \u0938\u094d\u092b\u0942\u0930\u094d\u0924\u094d\u0924\u092f\u0947 <br/> \u092e\u0941\u0915\u0941\u0930 \u092c\u093f\u092e\u094d\u092c \u092a\u094d\u0930\u0924\u093f\u092c\u093f\u092e\u094d\u092c\u093f\u0924 \u092e\u0941\u0916 \u0938\u094d\u092b\u0942\u0930\u094d\u0924\u094d\u0924\u092f\u0947 <br/> \u092e\u0941\u0928\u093f \u092a\u0915\u094d\u0937\u093f \u092e\u0943\u0917 \u0915\u0940\u091f\u093e\u0926\u093f \u092e\u0942\u0915\u094d\u0924\u093f \u092a\u094d\u0930\u0926 \u0915\u0940\u0930\u094d\u0924\u094d\u0924\u092f\u0947"}, {"M": "\u092e\u0927\u094d\u092f\u092e\u0915\u093e\u0932 \u0938\u093e\u0939\u093f\u0924\u094d\u092f\u092e\u094d", "T": "\u0938\u0915\u0932\u093e\u0917\u092e \u092e\u0928\u094d\u0924\u094d\u0930 \u0924\u0928\u094d\u0924\u094d\u0930 \u0938\u093e\u0930\u091c\u094d\u091e\u093e\u0928\u0941 \u0930\u0915\u094d\u0924\u092f\u0947 <br/> \u0905\u0915\u0924\u093e\u0926\u093f \u0924\u094d\u0930\u093f\u0930\u0947\u0916\u093e\u0924\u094d\u092e\u0915\u093e\u0927\u093e\u0930 \u092a\u094d\u0930\u0935\u0943\u0924\u094d\u0924\u092f\u0947 <br/> \u0938\u0915\u0932 \u0928\u093f\u0937\u094d\u0915\u0932 \u0938\u094d\u0935\u0930\u0942\u092a \u0938\u091a\u094d\u091a\u093f\u0924\u094d \u0938\u0941\u0916 \u0935\u094d\u092f\u093e\u092a\u094d\u0924\u092f\u0947 <br/> \u0935\u093f\u0915\u0932\u094d\u092a \u092d\u0947\u0926\u092f\u0941\u0915\u094d\u0924\u092f\u0947 \u0935\u093f\u091f\u0902\u0915 \u0930\u0942\u092a \u0936\u0915\u094d\u0924\u092f\u0947"}]}], "L": "l", "lyricsref": [{"links": [{"N": "www.medieval.org", "L": "http://www.medieval.org/music/world/carnatic/lyrics/TKG/tyagarajaya_namaste.html"}, {"N": "guru-guha.blogspot.com", "L": "http://guru-guha.blogspot.com/2007/11/dikshitar-kriti-thyagarajaaya-namastae.html"}, {"N": "www.shivkumar.org", "L": "http://www.shivkumar.org/music/thiagarajaya.htm"}]}]}