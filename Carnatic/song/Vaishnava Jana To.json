u0b95\u0bae\u0bbe\u0bae\u0bcd \u0b9a\u0bb9\u0bc1\u0ba9\u0bc7 \u0bb5\u0ba8\u0bcd\u0ba4\u0bc7, <br/> \u0ba8\u0bbf\u0ba8\u0bcd\u0ba4\u0bbe \u0ba8 \u0b95\u0bb0\u0bc7 \u0b95\u0bc7\u0ba9\u0bc0 \u0bb0\u0bc7 <br/> \u0bb5\u0bbe\u0b9a \u0b95\u0bbe\u0b9a \u0bae\u0ba9 \u0ba8\u0bbf\u0bb6\u0bcd\u0b9a\u0bb3 \u0bb0\u0bbe\u0b95\u0bc7, <br/> \u0ba4\u0ba9 \u0ba4\u0ba9 \u0b9c\u0ba9\u0ba9\u0bc0 \u0ba4\u0bc7\u0ba9\u0bc0 \u0bb0\u0bc7"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd 2", "T": "\u0b9a\u0bae\u0ba4\u0bcd\u0bb0\u0bc1\u0bb7\u0bcd\u0b9f\u0bbf \u0ba8\u0bc7 \u0ba4\u0bcd\u0bb0\u0bc1\u0bb7\u0bcd\u0ba3\u0bbe \u0ba4\u0bcd\u0baf\u0bbe\u0b95\u0bc0, <br/> \u0baa\u0bb0\u0bb8\u0bcd\u0ba4\u0bcd\u0bb0\u0bc0 \u0b9c\u0bc7\u0ba9\u0bc7 \u0bae\u0bbe\u0ba4 \u0bb0\u0bc7 <br/> \u0b9c\u0bbf\u0bb9\u0bcd\u0bb5\u0bbe \u0ba4\u0b95\u0bc0 \u0b85\u0b9a\u0ba4\u0bcd\u0baf \u0ba8 \u0baa\u0bcb\u0bb2\u0bc7, <br/> \u0baa\u0bb0\u0ba4\u0ba9 \u0ba8\u0bb5 \u0b9c\u0bbe\u0bb2\u0bc7 \u0bb9\u0bbe\u0ba4 \u0bb0\u0bc7"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd 3", "T": "\u0bae\u0bcb\u0bb9 \u0bae\u0bbe\u0baf\u0bbe \u0bb5\u0bcd\u0baf\u0bbe\u0baa\u0bc7 \u0ba8\u0bb9\u0bbf \u0b9c\u0bc7\u0ba9\u0bc7, <br/> \u0ba4\u0bcd\u0bb0\u0bc1\u0b9f\u093c \u0bb5\u0bc8\u0bb0\u0bbe\u0b95\u0bcd\u0baf \u0b9c\u0bc7\u0ba9\u0bbe \u0bae\u0ba9\u0bae\u0bbe\u0bae\u0bcd \u0bb0\u0bc7 <br/> \u0bb0\u0bbe\u0bae\u0ba9\u0bbe\u0bae \u0b9a\u0bc1\u0bae\u0bcd \u0ba4\u0bbe\u0bb2\u0bc0 \u0bb0\u0bc7 \u0bb2\u0bbe\u0b95\u0bc0, <br/> \u0b9a\u0b95\u0bb2 \u0ba4\u0bc0\u0bb0\u0ba4 \u0ba4\u0bc7\u0ba9\u0bbe \u0ba4\u0ba9\u0bae\u0bbe\u0bae\u0bcd \u0bb0\u0bc7"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd 4", "T": "\u0bb5\u0ba3\u0bb2\u0bcb\u0baa\u0bc0 \u0ba8\u0bc7 \u0b95\u0baa\u0b9f\u0bb0\u0bb9\u0bbf\u0ba4 \u0b9a\u0bc7, <br/> \u0b95\u0bbe\u0bae \u0b95\u0bcd\u0bb0\u0bcb\u0ba4 \u0ba8\u0bbf\u0bb5\u0bbe\u0bb0\u0bcd\u0baf\u0bbe \u0bb0\u0bc7 <br/> \u0baa\u0ba3\u0bc7 \u0ba8\u0bb0\u0b9a\u0bc8\u0baf\u0bca \u0ba4\u0bc7\u0ba9\u0bc1\u0bae\u0bcd \u0ba4\u0bb0\u0b9a\u0ba9 \u0b95\u0bb0\u0ba4\u0bbe\u0bae\u0bcd, <br/> \u0b95\u0bc1\u0bb2 \u0b8f\u0b95\u0bcb\u0ba4\u0bc7\u0bb0 \u0ba4\u0bbe\u0bb0\u0bcd\u0baf\u0bbe \u0bb0\u0bc7"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c35\u0c48\u0c37\u0c4d\u0c23\u0c35 \u0c1c\u0c28 \u0c24\u0c4b \u0c24\u0c47\u0c28\u0c47 \u0c15\u0c39\u0c3f\u0c2f\u0c47, <br/> \u0c1c\u0c47 \u0c2a\u0c40\u0c21 \u0c2a\u0c30\u0c3e\u0c2f\u0c40 \u0c1c\u0c3e\u0c23\u0c47 \u0c30\u0c47 <br/> \u0c2a\u0c30 \u0c26\u0c41\u0c03\u0c16\u0c47 \u0c09\u0c2a\u0c15\u0c3e\u0c30 \u0c15\u0c30\u0c47 \u0c24\u0c4b \u0c2f\u0c47, <br/> \u0c2e\u0c28 \u0c05\u0c2d\u0c3f\u0c2e\u0c3e\u0c28 \u0c28 \u0c06\u0c23\u0c47 \u0c30\u0c47 <br/> \u0c1c\u0c47 \u0c2a\u0c40\u0c21 \u0c2a\u0c30\u0c3e\u0c2f\u0c40 \u0c1c\u0c3e\u0c23\u0c47 \u0c30\u0c47"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d 1", "T": "\u0c38\u0c15\u0c32 \u0c32\u0c4b\u0c15\u0c2e\u0c3e\u0c02 \u0c38\u0c39\u0c41\u0c28\u0c47 \u0c35\u0c02\u0c26\u0c47, <br/> \u0c28\u0c3f\u0c02\u0c26\u0c3e \u0c28 \u0c15\u0c30\u0c47 \u0c15\u0c47\u0c28\u0c40 \u0c30\u0c47 <br/> \u0c35\u0c3e\u0c1a \u0c15\u0c3e\u0c1b \u0c2e\u0c28 \u0c28\u0c3f\u0c36\u0c4d\u0c1a\u0c33 \u0c30\u0c3e\u0c16\u0c47, <br/> \u0c27\u0c28 \u0c27\u0c28 \u0c1c\u0c28\u0c28\u0c40 \u0c24\u0c47\u0c28\u0c40 \u0c30\u0c47"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d 2", "T": "\u0c38\u0c2e\u0c26\u0c43\u0c37\u0c4d\u0c1f\u0c3f \u0c28\u0c47 \u0c24\u0c43\u0c37\u0c4d\u0c23\u0c3e \u0c24\u0c4d\u0c2f\u0c3e\u0c17\u0c40, <br/> \u0c2a\u0c30\u0c38\u0c4d\u0c24\u0c4d\u0c30\u0c40 \u0c1c\u0c47\u0c28\u0c47 \u0c2e\u0c3e\u0c24 \u0c30\u0c47 <br/> \u0c1c\u0c3f\u0c39\u0c4d\u0c35\u0c3e \u0c25\u0c15\u0c40 \u0c05\u0c38\u0c24\u0c4d\u0c2f \u0c28 \u0c2c\u0c4b\u0c32\u0c47, <br/> \u0c2a\u0c30\u0c27\u0c28 \u0c28\u0c35 \u0c1d\u0c3e\u0c32\u0c47 \u0c39\u0c3e\u0c25 \u0c30\u0c47"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d 3", "T": "\u0c2e\u0c4b\u0c39 \u0c2e\u0c3e\u0c2f\u0c3e \u0c35\u0c4d\u0c2f\u0c3e\u0c2a\u0c47 \u0c28\u0c39\u0c3f \u0c1c\u0c47\u0c28\u0c47, <br/> \u0c26\u0c43\u0c22\u093c \u0c35\u0c48\u0c30\u0c3e\u0c17\u0c4d\u0c2f \u0c1c\u0c47\u0c28\u0c3e \u0c2e\u0c28\u0c2e\u0c3e\u0c02 \u0c30\u0c47 <br/> \u0c30\u0c3e\u0c2e\u0c28\u0c3e\u0c2e \u0c36\u0c41\u0c02 \u0c24\u0c3e\u0c32\u0c40 \u0c30\u0c47 \u0c32\u0c3e\u0c17\u0c40, <br/> \u0c38\u0c15\u0c32 \u0c24\u0c40\u0c30\u0c25 \u0c24\u0c47\u0c28\u0c3e \u0c24\u0c28\u0c2e\u0c3e\u0c02 \u0c30\u0c47"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d 4", "T": "\u0c35\u0c23\u0c32\u0c4b\u0c2d\u0c40 \u0c28\u0c47 \u0c15\u0c2a\u0c1f\u0c30\u0c39\u0c3f\u0c24 \u0c1b\u0c47, <br/> \u0c15\u0c3e\u0c2e \u0c15\u0c4d\u0c30\u0c4b\u0c27 \u0c28\u0c3f\u0c35\u0c3e\u0c30\u0c4d\u0c2f\u0c3e \u0c30\u0c47 <br/> \u0c2d\u0c23\u0c47 \u0c28\u0c30\u0c38\u0c48\u0c2f\u0c4a \u0c24\u0c47\u0c28\u0c41\u0c02 \u0c26\u0c30\u0c38\u0c28 \u0c15\u0c30\u0c24\u0c3e\u0c02, <br/> \u0c15\u0c41\u0c32 \u0c0f\u0c15\u0c4b\u0c24\u0c47\u0c30 \u0c24\u0c3e\u0c30\u0c4d\u0c2f\u0c3e \u0c30\u0c47"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cb5\u0cc8\u0cb7\u0ccd\u0ca3\u0cb5 \u0c9c\u0ca8 \u0ca4\u0ccb \u0ca4\u0cc7\u0ca8\u0cc7 \u0c95\u0cb9\u0cbf\u0caf\u0cc7, <br/> \u0c9c\u0cc7 \u0caa\u0cc0\u0ca1 \u0caa\u0cb0\u0cbe\u0caf\u0cc0 \u0c9c\u0cbe\u0ca3\u0cc7 \u0cb0\u0cc7 <br/> \u0caa\u0cb0 \u0ca6\u0cc1\u0c83\u0c96\u0cc7 \u0c89\u0caa\u0c95\u0cbe\u0cb0 \u0c95\u0cb0\u0cc7 \u0ca4\u0ccb \u0caf\u0cc7, <br/> \u0cae\u0ca8 \u0c85\u0cad\u0cbf\u0cae\u0cbe\u0ca8 \u0ca8 \u0c86\u0ca3\u0cc7 \u0cb0\u0cc7 <br/> \u0c9c\u0cc7 \u0caa\u0cc0\u0ca1 \u0caa\u0cb0\u0cbe\u0caf\u0cc0 \u0c9c\u0cbe\u0ca3\u0cc7 \u0cb0\u0cc7"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd 1", "T": "\u0cb8\u0c95\u0cb2 \u0cb2\u0ccb\u0c95\u0cae\u0cbe\u0c82 \u0cb8\u0cb9\u0cc1\u0ca8\u0cc7 \u0cb5\u0c82\u0ca6\u0cc7, <br/> \u0ca8\u0cbf\u0c82\u0ca6\u0cbe \u0ca8 \u0c95\u0cb0\u0cc7 \u0c95\u0cc7\u0ca8\u0cc0 \u0cb0\u0cc7 <br/> \u0cb5\u0cbe\u0c9a \u0c95\u0cbe\u0c9b \u0cae\u0ca8 \u0ca8\u0cbf\u0cb6\u0ccd\u0c9a\u0cb3 \u0cb0\u0cbe\u0c96\u0cc7, <br/> \u0ca7\u0ca8 \u0ca7\u0ca8 \u0c9c\u0ca8\u0ca8\u0cc0 \u0ca4\u0cc7\u0ca8\u0cc0 \u0cb0\u0cc7"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd 2", "T": "\u0cb8\u0cae\u0ca6\u0cc3\u0cb7\u0ccd\u0c9f\u0cbf \u0ca8\u0cc7 \u0ca4\u0cc3\u0cb7\u0ccd\u0ca3\u0cbe \u0ca4\u0ccd\u0caf\u0cbe\u0c97\u0cc0, <br/> \u0caa\u0cb0\u0cb8\u0ccd\u0ca4\u0ccd\u0cb0\u0cc0 \u0c9c\u0cc7\u0ca8\u0cc7 \u0cae\u0cbe\u0ca4 \u0cb0\u0cc7 <br/> \u0c9c\u0cbf\u0cb9\u0ccd\u0cb5\u0cbe \u0ca5\u0c95\u0cc0 \u0c85\u0cb8\u0ca4\u0ccd\u0caf \u0ca8 \u0cac\u0ccb\u0cb2\u0cc7, <br/> \u0caa\u0cb0\u0ca7\u0ca8 \u0ca8\u0cb5 \u0c9d\u0cbe\u0cb2\u0cc7 \u0cb9\u0cbe\u0ca5 \u0cb0\u0cc7"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd 3", "T": "\u0cae\u0ccb\u0cb9 \u0cae\u0cbe\u0caf\u0cbe \u0cb5\u0ccd\u0caf\u0cbe\u0caa\u0cc7 \u0ca8\u0cb9\u0cbf \u0c9c\u0cc7\u0ca8\u0cc7, <br/> \u0ca6\u0cc3\u0ca2\u093c \u0cb5\u0cc8\u0cb0\u0cbe\u0c97\u0ccd\u0caf \u0c9c\u0cc7\u0ca8\u0cbe \u0cae\u0ca8\u0cae\u0cbe\u0c82 \u0cb0\u0cc7 <br/> \u0cb0\u0cbe\u0cae\u0ca8\u0cbe\u0cae \u0cb6\u0cc1\u0c82 \u0ca4\u0cbe\u0cb2\u0cc0 \u0cb0\u0cc7 \u0cb2\u0cbe\u0c97\u0cc0, <br/> \u0cb8\u0c95\u0cb2 \u0ca4\u0cc0\u0cb0\u0ca5 \u0ca4\u0cc7\u0ca8\u0cbe \u0ca4\u0ca8\u0cae\u0cbe\u0c82 \u0cb0\u0cc7"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd 4", "T": "\u0cb5\u0ca3\u0cb2\u0ccb\u0cad\u0cc0 \u0ca8\u0cc7 \u0c95\u0caa\u0c9f\u0cb0\u0cb9\u0cbf\u0ca4 \u0c9b\u0cc7, <br/> \u0c95\u0cbe\u0cae \u0c95\u0ccd\u0cb0\u0ccb\u0ca7 \u0ca8\u0cbf\u0cb5\u0cbe\u0cb0\u0ccd\u0caf\u0cbe \u0cb0\u0cc7 <br/> \u0cad\u0ca3\u0cc7 \u0ca8\u0cb0\u0cb8\u0cc8\u0caf\u0cca \u0ca4\u0cc7\u0ca8\u0cc1\u0c82 \u0ca6\u0cb0\u0cb8\u0ca8 \u0c95\u0cb0\u0ca4\u0cbe\u0c82, <br/> \u0c95\u0cc1\u0cb2 \u0c8f\u0c95\u0ccb\u0ca4\u0cc7\u0cb0 \u0ca4\u0cbe\u0cb0\u0ccd\u0caf\u0cbe \u0cb0\u0cc7"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d35\u0d48\u0d37\u0d4d\u0d23\u0d35 \u0d1c\u0d28 \u0d24\u0d4b \u0d24\u0d47\u0d28\u0d47 \u0d15\u0d39\u0d3f\u0d2f\u0d47, <br/> \u0d1c\u0d47 \u0d2a\u0d40\u0d21 \u0d2a\u0d30\u0d3e\u0d2f\u0d40 \u0d1c\u0d3e\u0d23\u0d47 \u0d30\u0d47 <br/> \u0d2a\u0d30 \u0d26\u0d41\u0d03\u0d16\u0d47 \u0d09\u0d2a\u0d15\u0d3e\u0d30 \u0d15\u0d30\u0d47 \u0d24\u0d4b \u0d2f\u0d47, <br/> \u0d2e\u0d28 \u0d05\u0d2d\u0d3f\u0d2e\u0d3e\u0d28 \u0d28 \u0d06\u0d23\u0d47 \u0d30\u0d47 <br/> \u0d1c\u0d47 \u0d2a\u0d40\u0d21 \u0d2a\u0d30\u0d3e\u0d2f\u0d40 \u0d1c\u0d3e\u0d23\u0d47 \u0d30\u0d47"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 1", "T": "\u0d38\u0d15\u0d32 \u0d32\u0d4b\u0d15\u0d2e\u0d3e\u0d02 \u0d38\u0d39\u0d41\u0d28\u0d47 \u0d35\u0d02\u0d26\u0d47, <br/> \u0d28\u0d3f\u0d02\u0d26\u0d3e \u0d28 \u0d15\u0d30\u0d47 \u0d15\u0d47\u0d28\u0d40 \u0d30\u0d47 <br/> \u0d35\u0d3e\u0d1a \u0d15\u0d3e\u0d1b \u0d2e\u0d28 \u0d28\u0d3f\u0d36\u0d4d\u0d1a\u0d33 \u0d30\u0d3e\u0d16\u0d47, <br/> \u0d27\u0d28 \u0d27\u0d28 \u0d1c\u0d28\u0d28\u0d40 \u0d24\u0d47\u0d28\u0d40 \u0d30\u0d47"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 2", "T": "\u0d38\u0d2e\u0d26\u0d43\u0d37\u0d4d\u0d1f\u0d3f \u0d28\u0d47 \u0d24\u0d43\u0d37\u0d4d\u0d23\u0d3e \u0d24\u0d4d\u0d2f\u0d3e\u0d17\u0d40, <br/> \u0d2a\u0d30\u0d38\u0d4d\u0d24\u0d4d\u0d30\u0d40 \u0d1c\u0d47\u0d28\u0d47 \u0d2e\u0d3e\u0d24 \u0d30\u0d47 <br/> \u0d1c\u0d3f\u0d39\u0d4d\u0d35\u0d3e \u0d25\u0d15\u0d40 \u0d05\u0d38\u0d24\u0d4d\u0d2f \u0d28 \u0d2c\u0d4b\u0d32\u0d47, <br/> \u0d2a\u0d30\u0d27\u0d28 \u0d28\u0d35 \u0d1d\u0d3e\u0d32\u0d47 \u0d39\u0d3e\u0d25 \u0d30\u0d47"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 3", "T": "\u0d2e\u0d4b\u0d39 \u0d2e\u0d3e\u0d2f\u0d3e \u0d35\u0d4d\u0d2f\u0d3e\u0d2a\u0d47 \u0d28\u0d39\u0d3f \u0d1c\u0d47\u0d28\u0d47, <br/> \u0d26\u0d43\u0d22\u093c \u0d35\u0d48\u0d30\u0d3e\u0d17\u0d4d\u0d2f \u0d1c\u0d47\u0d28\u0d3e \u0d2e\u0d28\u0d2e\u0d3e\u0d02 \u0d30\u0d47 <br/> \u0d30\u0d3e\u0d2e\u0d28\u0d3e\u0d2e \u0d36\u0d41\u0d02 \u0d24\u0d3e\u0d32\u0d40 \u0d30\u0d47 \u0d32\u0d3e\u0d17\u0d40, <br/> \u0d38\u0d15\u0d32 \u0d24\u0d40\u0d30\u0d25 \u0d24\u0d47\u0d28\u0d3e \u0d24\u0d28\u0d2e\u0d3e\u0d02 \u0d30\u0d47"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 4", "T": "\u0d35\u0d23\u0d32\u0d4b\u0d2d\u0d40 \u0d28\u0d47 \u0d15\u0d2a\u0d1f\u0d30\u0d39\u0d3f\u0d24 \u0d1b\u0d47, <br/> \u0d15\u0d3e\u0d2e \u0d15\u0d4d\u0d30\u0d4b\u0d27 \u0d28\u0d3f\u0d35\u0d3e\u0d30\u0d4d\u0d2f\u0d3e \u0d30\u0d47 <br/> \u0d2d\u0d23\u0d47 \u0d28\u0d30\u0d38\u0d48\u0d2f\u0d4a \u0d24\u0d47\u0d28\u0d41\u0d02 \u0d26\u0d30\u0d38\u0d28 \u0d15\u0d30\u0d24\u0d3e\u0d02, <br/> \u0d15\u0d41\u0d32 \u0d0f\u0d15\u0d4b\u0d24\u0d47\u0d30 \u0d24\u0d3e\u0d30\u0d4d\u0d2f\u0d3e \u0d30\u0d47"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0935\u0948\u0937\u094d\u0923\u0935 \u091c\u0928 \u0924\u094b \u0924\u0947\u0928\u0947 \u0915\u0939\u093f\u092f\u0947, <br/> \u091c\u0947 \u092a\u0940\u0921 \u092a\u0930\u093e\u092f\u0940 \u091c\u093e\u0923\u0947 \u0930\u0947 <br/> \u092a\u0930 \u0926\u0941\u0903\u0916\u0947 \u0909\u092a\u0915\u093e\u0930 \u0915\u0930\u0947 \u0924\u094b \u092f\u0947, <br/> \u092e\u0928 \u0905\u092d\u093f\u092e\u093e\u0928 \u0928 \u0906\u0923\u0947 \u0930\u0947 <br/> \u091c\u0947 \u092a\u0940\u0921 \u092a\u0930\u093e\u092f\u0940 \u091c\u093e\u0923\u0947 \u0930\u0947"}, {"M": "\u091a\u0930\u0923\u092e\u094d 1", "T": "\u0938\u0915\u0932 \u0932\u094b\u0915\u092e\u093e\u0902 \u0938\u0939\u0941\u0928\u0947 \u0935\u0902\u0926\u0947, <br/> \u0928\u093f\u0902\u0926\u093e \u0928 \u0915\u0930\u0947 \u0915\u0947\u0928\u0940 \u0930\u0947 <br/> \u0935\u093e\u091a \u0915\u093e\u091b \u092e\u0928 \u0928\u093f\u0936\u094d\u091a\u0932 \u0930\u093e\u0916\u0947, <br/> \u0927\u0928 \u0927\u0928 \u091c\u0928\u0928\u0940 \u0924\u0947\u0928\u0940 \u0930\u0947"}, {"M": "\u091a\u0930\u0923\u092e\u094d 2", "T": "\u0938\u092e\u0926\u0943\u0937\u094d\u091f\u093f \u0928\u0947 \u0924\u0943\u0937\u094d\u0923\u093e \u0924\u094d\u092f\u093e\u0917\u0940, <br/> \u092a\u0930\u0938\u094d\u0924\u094d\u0930\u0940 \u091c\u0947\u0928\u0947 \u092e\u093e\u0924 \u0930\u0947 <br/> \u091c\u093f\u0939\u094d\u0935\u093e \u0925\u0915\u0940 \u0905\u0938\u0924\u094d\u092f \u0928 \u092c\u094b\u0932\u0947, <br/> \u092a\u0930\u0927\u0928 \u0928\u0935 \u091d\u093e\u0932\u0947 \u0939\u093e\u0925 \u0930\u0947"}, {"M": "\u091a\u0930\u0923\u092e\u094d 3", "T": "\u092e\u094b\u0939 \u092e\u093e\u092f\u093e \u0935\u094d\u092f\u093e\u092a\u0947 \u0928\u0939\u093f \u091c\u0947\u0928\u0947, <br/> \u0926\u0943\u0922\u093c \u0935\u0948\u0930\u093e\u0917\u094d\u092f \u091c\u0947\u0928\u093e \u092e\u0928\u092e\u093e\u0902 \u0930\u0947 <br/> \u0930\u093e\u092e\u0928\u093e\u092e \u0936\u0941\u0902 \u0924\u093e\u0932\u0940 \u0930\u0947 \u0932\u093e\u0917\u0940, <br/> \u0938\u0915\u0932 \u0924\u0940\u0930\u0925 \u0924\u0947\u0928\u093e \u0924\u0928\u092e\u093e\u0902 \u0930\u0947"}, {"M": "\u091a\u0930\u0923\u092e\u094d 4", "T": "\u0935\u0923\u0932\u094b\u092d\u0940 \u0928\u0947 \u0915\u092a\u091f\u0930\u0939\u093f\u0924 \u091b\u0947, <br/> \u0915\u093e\u092e \u0915\u094d\u0930\u094b\u0927 \u0928\u093f\u0935\u093e\u0930\u094d\u092f\u093e \u0930\u0947 <br/> \u092d\u0923\u0947 \u0928\u0930\u0938\u0948\u092f\u094b \u0924\u0947\u0928\u0941\u0902 \u0926\u0930\u0938\u0928 \u0915\u0930\u0924\u093e\u0902, <br/> \u0915\u0941\u0932 \u090f\u0915\u094b\u0924\u0947\u0930 \u0924\u093e\u0930\u094d\u092f\u093e \u0930\u0947"}]}], "L": "l", "lyricsref": [{"links": [{"N": "www.bhaktibharat.com", "L": "https://www.bhaktibharat.com/bhajan/vaishnav-jan-to-tene-kahiye-je"}]}]}