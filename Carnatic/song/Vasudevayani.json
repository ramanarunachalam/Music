a gatulanu pADucunu <br/> tyAgarAja san-nutuni pogaDucunu"}]}, {"L": "Tamil", "text": [{"M": "\u0baa\u0bb2\u0bcd\u0bb2\u0bb5\u0bbf", "T": "\u0bb5\u0bbe\u0b9a\u0bc1\u0ba4\u0bc7\u0bb5\u0baf\u0ba9\u0bbf \u0bb5\u0bc6\u0b9f\u0bb2\u0bbf\u0ba9\u0baf\u0bc0 <br/> \u0ba4\u0bcc\u0bb5\u0bbe\u0bb0\u0bbf\u0b95\u0bc1\u0ba9\u0bbf \u0b95\u0ba9\u0bb0\u0bc7"}, {"M": "\u0b85\u0ba9\u0bc1\u0baa\u0bb2\u0bcd\u0bb2\u0bb5\u0bbf", "T": "\u0bb5\u0bbe\u0b9a\u0bb5\u0bbe\u0ba4\u0bbf \u0b9a\u0bc1\u0bb0 \u0baa\u0bc2\u0b9c\u0bbf\u0ba4\u0bc1\u0b9f\u0bc8 <br/> \u0bb5\u0bbe\u0bb0\u0bbf\u0b9c \u0ba8\u0baf\u0ba9\u0bc1\u0ba9\u0bbf \u0bae\u0ba4\u0bbf\u0ba9\u0bbf \u0ba4\u0bb2\u0b9a\u0bc1\u0b9a\u0bc1\u0ba9\u0bc1"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd 1", "T": "\u0ba8\u0bc0\u0bb0\u0bc1 \u0b95\u0bbe\u0bb5\u0bbf \u0ba4\u0bcb\u0bb5\u0ba4\u0bc1\u0bb2\u0ba9\u0bc1 \u0b95\u0b9f\u0bcd\u0b9f\u0bbf <br/> \u0ba8\u0bbf\u0b9f\u0bb2\u0bae\u0bc1\u0ba9\u0ba9\u0bc1 \u0bb6\u0bcd\u0bb0\u0bc0 \u0b9a\u0bc2\u0bb0\u0bcd\u0ba3\u0bae\u0bc1 \u0baa\u0bc6\u0b9f\u0bcd\u0b9f\u0bbf <br/> \u0b9a\u0bbe\u0bb0\u0bbf \u0bb5\u0bc6\u0b9f\u0bb2\u0bbf\u0baf\u0bc0 \u0b9a\u0baa\u0bb2\u0bcb \u0b9c\u0bc1\u0b9f\u0bcd\u0b9f\u0bbf <br/> \u0b9a\u0bbe\u0bb0\u0bc6\u0b95\u0bc1 \u0baa\u0b99\u0bcd\u0b95\u0bb0\u0bc1 \u0b95\u0bcb\u0bb2\u0ba9\u0bc1 \u0baa\u0b9f\u0bcd\u0b9f\u0bbf"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd 2", "T": "\u0bae\u0bbe\u0b9f\u0bbf \u0bae\u0bbe\u0b9f\u0bbf\u0b95\u0bbf\u0ba9\u0bbf \u0bae\u0bc0\u0b9a\u0bae\u0bc1 \u0ba4\u0bc1\u0bb5\u0bcd\u0bb5\u0bbf <br/> \u0bae\u0ba9\u0bcd\u0bae\u0ba4 \u0bb0\u0bc2\u0baa\u0bc1\u0b9f\u0bc1 \u0ba4\u0bbe\u0ba9\u0ba9\u0bbf \u0b95\u0bcd\u0bb0\u0bca\u0bb5\u0bcd\u0bb5\u0bbf <br/> \u0ba4\u0bbe\u0b9f\u0bbf \u0ba4\u0bbe\u0b9f\u0bbf \u0baa\u0b9f\u0bc1\u0b9a\u0bc1\u0ba9\u0bc1 <br/> \u0ba4\u0bbe\u0ba9\u0bbf\u0bb5\u0bcd\u0bb5\u0bbf\u0ba4\u0bae\u0bcd\u0baa\u0bc1\u0ba9 \u0baa\u0bb2\u0bc1\u0b95\u0bc1\u0b9a\u0bc1 \u0baa\u0b95 \u0baa\u0b95 \u0ba8\u0bb5\u0bcd\u0bb5\u0bbf"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd 3", "T": "\u0baa\u0bbe\u0b95\u0bc1 \u0bae\u0bc0\u0bb0 \u0ba8\u0b9f\u0ba9\u0bae\u0bc1 \u0b9a\u0bc7\u0baf\u0bc1\u0b9a\u0bc1\u0ba9\u0bc1 <br/> \u0baa\u0ba4\u0bbf\u0ba4 \u0baa\u0bbe\u0bb5\u0ba9\u0bc1\u0ba9\u0bbf \u0ba4\u0bbe \u0bb5\u0bc7\u0b9f\u0bc1\u0b9a\u0bc1\u0ba9\u0bc1 <br/> \u0bb0\u0bbe\u0b95 \u0ba4\u0bbe\u0bb3 \u0b95\u0ba4\u0bc1\u0bb2\u0ba9\u0bc1 \u0baa\u0bbe\u0b9f\u0bc1\u0b9a\u0bc1\u0ba9\u0bc1 <br/> \u0ba4\u0bcd\u0baf\u0bbe\u0b95\u0bb0\u0bbe\u0b9c \u0b9a\u0ba9\u0bcd-\u0ba8\u0bc1\u0ba4\u0bc1\u0ba9\u0bbf \u0baa\u0bca\u0b95\u0b9f\u0bc1\u0b9a\u0bc1\u0ba9\u0bc1"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c35\u0c3e\u0c38\u0c41\u0c26\u0c47\u0c35\u0c2f\u0c28\u0c3f \u0c35\u0c46\u0c21\u0c32\u0c3f\u0c28\u0c2f\u0c40 <br/> \u0c26\u0c4c\u0c35\u0c3e\u0c30\u0c3f\u0c15\u0c41\u0c28\u0c3f \u0c15\u0c28\u0c30\u0c47"}, {"M": "\u0c05\u0c28\u0c41\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c35\u0c3e\u0c38\u0c35\u0c3e\u0c26\u0c3f \u0c38\u0c41\u0c30 \u0c2a\u0c42\u0c1c\u0c3f\u0c24\u0c41\u0c21\u0c48 <br/> \u0c35\u0c3e\u0c30\u0c3f\u0c1c \u0c28\u0c2f\u0c28\u0c41\u0c28\u0c3f \u0c2e\u0c26\u0c3f\u0c28\u0c3f \u0c24\u0c32\u0c1a\u0c41\u0c1a\u0c41\u0c28\u0c41"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d 1", "T": "\u0c28\u0c40\u0c30\u0c41 \u0c15\u0c3e\u0c35\u0c3f \u0c26\u0c4b\u0c35\u0c24\u0c41\u0c32\u0c28\u0c41 \u0c15\u0c1f\u0c4d\u0c1f\u0c3f <br/> \u0c28\u0c3f\u0c1f\u0c32\u0c2e\u0c41\u0c28\u0c28\u0c41 \u0c36\u0c4d\u0c30\u0c40 \u0c1a\u0c42\u0c30\u0c4d\u0c23\u0c2e\u0c41 \u0c2a\u0c46\u0c1f\u0c4d\u0c1f\u0c3f <br/> \u0c38\u0c3e\u0c30\u0c3f \u0c35\u0c46\u0c21\u0c32\u0c3f\u0c2f\u0c40 \u0c38\u0c2d\u0c32\u0c4b \u0c1c\u0c41\u0c1f\u0c4d\u0c1f\u0c3f <br/> \u0c38\u0c3e\u0c30\u0c46\u0c15\u0c41 \u0c2c\u0c02\u0c17\u0c30\u0c41 \u0c15\u0c4b\u0c32\u0c28\u0c41 \u0c2a\u0c1f\u0c4d\u0c1f\u0c3f"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d 2", "T": "\u0c2e\u0c3e\u0c1f\u0c3f \u0c2e\u0c3e\u0c1f\u0c3f\u0c15\u0c3f\u0c28\u0c3f \u0c2e\u0c40\u0c38\u0c2e\u0c41 \u0c26\u0c41\u0c35\u0c4d\u0c35\u0c3f <br/> \u0c2e\u0c28\u0c4d\u0c2e\u0c25 \u0c30\u0c42\u0c2a\u0c41\u0c21\u0c41 \u0c24\u0c3e\u0c28\u0c28\u0c3f \u0c15\u0c4d\u0c30\u0c4a\u0c35\u0c4d\u0c35\u0c3f <br/> \u0c26\u0c3e\u0c1f\u0c3f \u0c26\u0c3e\u0c1f\u0c3f \u0c2a\u0c21\u0c41\u0c1a\u0c41\u0c28\u0c41 <br/> \u0c24\u0c3e\u0c28\u0c3f\u0c35\u0c4d\u0c35\u0c3f\u0c27\u0c2e\u0c4d\u0c2c\u0c41\u0c28 \u0c2a\u0c32\u0c41\u0c15\u0c41\u0c1a\u0c41 \u0c2a\u0c15 \u0c2a\u0c15 \u0c28\u0c35\u0c4d\u0c35\u0c3f"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d 3", "T": "\u0c2c\u0c3e\u0c17\u0c41 \u0c2e\u0c40\u0c30 \u0c28\u0c1f\u0c28\u0c2e\u0c41 \u0c38\u0c47\u0c2f\u0c41\u0c1a\u0c41\u0c28\u0c41 <br/> \u0c2a\u0c24\u0c3f\u0c24 \u0c2a\u0c3e\u0c35\u0c28\u0c41\u0c28\u0c3f \u0c24\u0c3e \u0c35\u0c47\u0c21\u0c41\u0c1a\u0c41\u0c28\u0c41 <br/> \u0c30\u0c3e\u0c17 \u0c24\u0c3e\u0c33 \u0c17\u0c24\u0c41\u0c32\u0c28\u0c41 \u0c2a\u0c3e\u0c21\u0c41\u0c1a\u0c41\u0c28\u0c41 <br/> \u0c24\u0c4d\u0c2f\u0c3e\u0c17\u0c30\u0c3e\u0c1c \u0c38\u0c28\u0c4d-\u0c28\u0c41\u0c24\u0c41\u0c28\u0c3f \u0c2a\u0c4a\u0c17\u0c21\u0c41\u0c1a\u0c41\u0c28\u0c41"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cb5\u0cbe\u0cb8\u0cc1\u0ca6\u0cc7\u0cb5\u0caf\u0ca8\u0cbf \u0cb5\u0cc6\u0ca1\u0cb2\u0cbf\u0ca8\u0caf\u0cc0 <br/> \u0ca6\u0ccc\u0cb5\u0cbe\u0cb0\u0cbf\u0c95\u0cc1\u0ca8\u0cbf \u0c95\u0ca8\u0cb0\u0cc7"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cb5\u0cbe\u0cb8\u0cb5\u0cbe\u0ca6\u0cbf \u0cb8\u0cc1\u0cb0 \u0caa\u0cc2\u0c9c\u0cbf\u0ca4\u0cc1\u0ca1\u0cc8 <br/> \u0cb5\u0cbe\u0cb0\u0cbf\u0c9c \u0ca8\u0caf\u0ca8\u0cc1\u0ca8\u0cbf \u0cae\u0ca6\u0cbf\u0ca8\u0cbf \u0ca4\u0cb2\u0c9a\u0cc1\u0c9a\u0cc1\u0ca8\u0cc1"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd 1", "T": "\u0ca8\u0cc0\u0cb0\u0cc1 \u0c95\u0cbe\u0cb5\u0cbf \u0ca6\u0ccb\u0cb5\u0ca4\u0cc1\u0cb2\u0ca8\u0cc1 \u0c95\u0c9f\u0ccd\u0c9f\u0cbf <br/> \u0ca8\u0cbf\u0c9f\u0cb2\u0cae\u0cc1\u0ca8\u0ca8\u0cc1 \u0cb6\u0ccd\u0cb0\u0cc0 \u0c9a\u0cc2\u0cb0\u0ccd\u0ca3\u0cae\u0cc1 \u0caa\u0cc6\u0c9f\u0ccd\u0c9f\u0c