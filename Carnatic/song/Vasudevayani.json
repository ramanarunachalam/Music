35\u0d3e\u0d30\u0d3f\u0d1c \u0d28\u0d2f\u0d28\u0d41\u0d28\u0d3f \u0d2e\u0d26\u0d3f\u0d28\u0d3f \u0d24\u0d32\u0d1a\u0d41\u0d1a\u0d41\u0d28\u0d41"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 1", "T": "\u0d28\u0d40\u0d30\u0d41 \u0d15\u0d3e\u0d35\u0d3f \u0d26\u0d4b\u0d35\u0d24\u0d41\u0d32\u0d28\u0d41 \u0d15\u0d1f\u0d4d\u0d1f\u0d3f <br/> \u0d28\u0d3f\u0d1f\u0d32\u0d2e\u0d41\u0d28\u0d28\u0d41 \u0d36\u0d4d\u0d30\u0d40 \u0d1a\u0d42\u0d30\u0d4d\u0d23\u0d2e\u0d41 \u0d2a\u0d46\u0d1f\u0d4d\u0d1f\u0d3f <br/> \u0d38\u0d3e\u0d30\u0d3f \u0d35\u0d46\u0d21\u0d32\u0d3f\u0d2f\u0d40 \u0d38\u0d2d\u0d32\u0d4b \u0d1c\u0d41\u0d1f\u0d4d\u0d1f\u0d3f <br/> \u0d38\u0d3e\u0d30\u0d46\u0d15\u0d41 \u0d2c\u0d02\u0d17\u0d30\u0d41 \u0d15\u0d4b\u0d32\u0d28\u0d41 \u0d2a\u0d1f\u0d4d\u0d1f\u0d3f"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 2", "T": "\u0d2e\u0d3e\u0d1f\u0d3f \u0d2e\u0d3e\u0d1f\u0d3f\u0d15\u0d3f\u0d28\u0d3f \u0d2e\u0d40\u0d38\u0d2e\u0d41 \u0d26\u0d41\u0d35\u0d4d\u0d35\u0d3f <br/> \u0d2e\u0d28\u0d4d\u0d2e\u0d25 \u0d30\u0d42\u0d2a\u0d41\u0d21\u0d41 \u0d24\u0d3e\u0d28\u0d28\u0d3f \u0d15\u0d4d\u0d30\u0d4a\u0d35\u0d4d\u0d35\u0d3f <br/> \u0d26\u0d3e\u0d1f\u0d3f \u0d26\u0d3e\u0d1f\u0d3f \u0d2a\u0d21\u0d41\u0d1a\u0d41\u0d28\u0d41 <br/> \u0d24\u0d3e\u0d28\u0d3f\u0d35\u0d4d\u0d35\u0d3f\u0d27\u0d2e\u0d4d\u0d2c\u0d41\u0d28 \u0d2a\u0d32\u0d41\u0d15\u0d41\u0d1a\u0d41 \u0d2a\u0d15 \u0d2a\u0d15 \u0d28\u0d35\u0d4d\u0d35\u0d3f"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 3", "T": "\u0d2c\u0d3e\u0d17\u0d41 \u0d2e\u0d40\u0d30 \u0d28\u0d1f\u0d28\u0d2e\u0d41 \u0d38\u0d47\u0d2f\u0d41\u0d1a\u0d41\u0d28\u0d41 <br/> \u0d2a\u0d24\u0d3f\u0d24 \u0d2a\u0d3e\u0d35\u0d28\u0d41\u0d28\u0d3f \u0d24\u0d3e \u0d35\u0d47\u0d21\u0d41\u0d1a\u0d41\u0d28\u0d41 <br/> \u0d30\u0d3e\u0d17 \u0d24\u0d3e\u0d33 \u0d17\u0d24\u0d41\u0d32\u0d28\u0d41 \u0d2a\u0d3e\u0d21\u0d41\u0d1a\u0d41\u0d28\u0d41 <br/> \u0d24\u0d4d\u0d2f\u0d3e\u0d17\u0d30\u0d3e\u0d1c \u0d38\u0d28\u0d4d-\u0d28\u0d41\u0d24\u0d41\u0d28\u0d3f \u0d2a\u0d4a\u0d17\u0d21\u0d41\u0d1a\u0d41\u0d28\u0d41"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0935\u093e\u0938\u0941\u0926\u0947\u0935\u092f\u0928\u093f \u0935\u0947\u0921\u0932\u093f\u0928\u092f\u0940 <br/> \u0926\u094c\u0935\u093e\u0930\u093f\u0915\u0941\u0928\u093f \u0915\u0928\u0930\u0947"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0935\u093e\u0938\u0935\u093e\u0926\u093f \u0938\u0941\u0930 \u092a\u0942\u091c\u093f\u0924\u0941\u0921\u0948 <br/> \u0935\u093e\u0930\u093f\u091c \u0928\u092f\u0928\u0941\u0928\u093f \u092e\u0926\u093f\u0928\u093f \u0924\u0932\u091a\u0941\u091a\u0941\u0928\u0941"}, {"M": "\u091a\u0930\u0923\u092e\u094d 1", "T": "\u0928\u0940\u0930\u0941 \u0915\u093e\u0935\u093f \u0926\u094b\u0935\u0924\u0941\u0932\u0928\u0941 \u0915\u091f\u094d\u091f\u093f <br/> \u0928\u093f\u091f\u0932\u092e\u0941\u0928\u0928\u0941 \u0936\u094d\u0930\u0940 \u091a\u0942\u0930\u094d\u0923\u092e\u0941 \u092a\u0947\u091f\u094d\u091f\u093f <br/> \u0938\u093e\u0930\u093f \u0935\u0947\u0921\u0932\u093f\u092f\u0940 \u0938\u092d\u0932\u094b \u091c\u0941\u091f\u094d\u091f\u093f <br/> \u0938\u093e\u0930\u0947\u0915\u0941 \u092c\u0902\u0917\u0930\u0941 \u0915\u094b\u0932\u0928\u0941 \u092a\u091f\u094d\u091f\u093f"}, {"M": "\u091a\u0930\u0923\u092e\u094d 2", "T": "\u092e\u093e\u091f\u093f \u092e\u093e\u091f\u093f\u0915\u093f\u0928\u093f \u092e\u0940\u0938\u092e\u0941 \u0926\u0941\u0935\u094d\u0935\u093f <br/> \u092e\u0928\u094d\u092e\u0925 \u0930\u0942\u092a\u0941\u0921\u0941 \u0924\u093e\u0928\u0928\u093f \u0915\u094d\u0930\u094b\u0935\u094d\u0935\u093f <br/> \u0926\u093e\u091f\u093f \u0926\u093e\u091f\u093f \u092a\u0921\u0941\u091a\u0941\u0928\u0941 <br/> \u0924\u093e\u0928\u093f\u0935\u094d\u0935\u093f\u0927\u092e\u094d\u092c\u0941\u0928 \u092a\u0932\u0941\u0915\u0941\u091a\u0941 \u092a\u0915 \u092a\u0915 \u0928\u0935\u094d\u0935\u093f"}, {"M": "\u091a\u0930\u0923\u092e\u094d 3", "T": "\u092c\u093e\u0917\u0941 \u092e\u0940\u0930 \u0928\u091f\u0928\u092e\u0941 \u0938\u0947\u092f\u0941\u091a\u0941\u0928\u0941 <br/> \u092a\u0924\u093f\u0924 \u092a\u093e\u0935\u0928\u0941\u0928\u093f \u0924\u093e \u0935\u0947\u0921\u0941\u091a\u0941\u0928\u0941 <br/> \u0930\u093e\u0917 \u0924\u093e\u0932 \u0917\u0924\u0941\u0932\u0928\u0941 \u092a\u093e\u0921\u0941\u091a\u0941\u0928\u0941 <br/> \u0924\u094d\u092f\u093e\u0917\u0930\u093e\u091c \u0938\u0928\u094d-\u0928\u0941\u0924\u0941\u0928\u093f \u092a\u094b\u0917\u0921\u0941\u091a\u0941\u0928\u0941"}]}], "L": "l", "lyricsref": [{"links": [{"N": "thyagaraja-vaibhavam.blogspot.com", "L": "http://thyagaraja-vaibhavam.blogspot.com/2008/10/thyagaraja-kriti-vasudevayani-raga.html"}, {"N": "www.sangeetasudha.org", "L": "http://www.sangeetasudha.org/thyagaraja/v.html#MARK_VASUDEVA"}, {"N": "www.karnatik.com", "L": "http://www.karnatik.com/c1287.shtml"}]}]}