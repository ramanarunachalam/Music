bae\u0bcb\u0b9a\u0ba9\u0bbf <br/> \u0b87\u0ba8\u0bcd\u0ba4\u0bbf\u0bb0\u0bc7\u0b9a \u0b9a\u0bb9\u0bcb\u0ba4\u0bb0\u0bbf \u0ba4\u0bb2\u0bcb\u0ba4\u0bb0\u0bbf"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c35\u0c40\u0c23\u0c3e \u0c2d\u0c47\u0c30\u0c3f \u0c35\u0c47\u0c23\u0c41 \u0c35\u0c3e\u0c26\u0c4d\u0c2f\u0c3e\u0c26\u0c3f \u0c35\u0c3f\u0c28\u0c4b\u0c26\u0c3f\u0c28\u0c40 <br/> \u0c2e\u0c4b\u0c26\u0c3f\u0c28\u0c40 \u0c30\u0c15\u0c4d\u0c37 \u0c2e\u0c3e\u0c2e\u0c4d"}, {"M": "\u0c38\u0c2e\u0c38\u0c4d\u0c24\u0c3f \u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c18\u0c4b\u0c23\u0c40 \u0c35\u0c26\u0c28\u0c3e\u0c26\u0c3f \u0c35\u0c3f\u0c28\u0c41\u0c24 \u0c1a\u0c30\u0c3f\u0c24\u0c47 <br/> \u0c17\u0c41\u0c23 \u0c30\u0c39\u0c3f\u0c24\u0c47 \u0c35\u0c3f\u0c27\u0c3f \u0c17\u0c41\u0c30\u0c41\u0c17\u0c41\u0c39 \u0c2e\u0c39\u0c3f\u0c24\u0c47 <br/> \u0c0f\u0c23\u0c40 \u0c32\u0c4b\u0c1a\u0c28\u0c3f \u0c2a\u0c3e\u0c2a \u0c35\u0c3f\u0c2e\u0c4b\u0c1a\u0c28\u0c3f <br/> \u0c07\u0c28\u0c4d\u0c26\u0c3f\u0c30\u0c47\u0c36 \u0c38\u0c39\u0c4b\u0c26\u0c30\u0c3f \u0c24\u0c32\u0c4b\u0c26\u0c30\u0c3f"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cb5\u0cc0\u0ca3\u0cbe \u0cad\u0cc7\u0cb0\u0cbf \u0cb5\u0cc7\u0ca3\u0cc1 \u0cb5\u0cbe\u0ca6\u0ccd\u0caf\u0cbe\u0ca6\u0cbf \u0cb5\u0cbf\u0ca8\u0ccb\u0ca6\u0cbf\u0ca8\u0cc0 <br/> \u0cae\u0ccb\u0ca6\u0cbf\u0ca8\u0cc0 \u0cb0\u0c95\u0ccd\u0cb7 \u0cae\u0cbe\u0cae\u0ccd"}, {"M": "\u0cb8\u0cae\u0cb8\u0ccd\u0ca4\u0cbf \u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0c98\u0ccb\u0ca3\u0cc0 \u0cb5\u0ca6\u0ca8\u0cbe\u0ca6\u0cbf \u0cb5\u0cbf\u0ca8\u0cc1\u0ca4 \u0c9a\u0cb0\u0cbf\u0ca4\u0cc7 <br/> \u0c97\u0cc1\u0ca3 \u0cb0\u0cb9\u0cbf\u0ca4\u0cc7 \u0cb5\u0cbf\u0ca7\u0cbf \u0c97\u0cc1\u0cb0\u0cc1\u0c97\u0cc1\u0cb9 \u0cae\u0cb9\u0cbf\u0ca4\u0cc7 <br/> \u0c8f\u0ca3\u0cc0 \u0cb2\u0ccb\u0c9a\u0ca8\u0cbf \u0caa\u0cbe\u0caa \u0cb5\u0cbf\u0cae\u0ccb\u0c9a\u0ca8\u0cbf <br/> \u0c87\u0ca8\u0ccd\u0ca6\u0cbf\u0cb0\u0cc7\u0cb6 \u0cb8\u0cb9\u0ccb\u0ca6\u0cb0\u0cbf \u0ca4\u0cb2\u0ccb\u0ca6\u0cb0\u0cbf"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d35\u0d40\u0d23\u0d3e \u0d2d\u0d47\u0d30\u0d3f \u0d35\u0d47\u0d23\u0d41 \u0d35\u0d3e\u0d26\u0d4d\u0d2f\u0d3e\u0d26\u0d3f \u0d35\u0d3f\u0d28\u0d4b\u0d26\u0d3f\u0d28\u0d40 <br/> \u0d2e\u0d4b\u0d26\u0d3f\u0d28\u0d40 \u0d30\u0d15\u0d4d\u0d37 \u0d2e\u0d3e\u0d2e\u0d4d"}, {"M": "\u0d38\u0d2e\u0d38\u0d4d\u0d24\u0d3f \u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d18\u0d4b\u0d23\u0d40 \u0d35\u0d26\u0d28\u0d3e\u0d26\u0d3f \u0d35\u0d3f\u0d28\u0d41\u0d24 \u0d1a\u0d30\u0d3f\u0d24\u0d47 <br/> \u0d17\u0d41\u0d23 \u0d30\u0d39\u0d3f\u0d24\u0d47 \u0d35\u0d3f\u0d27\u0d3f \u0d17\u0d41\u0d30\u0d41\u0d17\u0d41\u0d39 \u0d2e\u0d39\u0d3f\u0d24\u0d47 <br/> \u0d0f\u0d23\u0d40 \u0d32\u0d4b\u0d1a\u0d28\u0d3f \u0d2a\u0d3e\u0d2a \u0d35\u0d3f\u0d2e\u0d4b\u0d1a\u0d28\u0d3f <br/> \u0d07\u0d28\u0d4d\u0d26\u0d3f\u0d30\u0d47\u0d36 \u0d38\u0d39\u0d4b\u0d26\u0d30\u0d3f \u0d24\u0d32\u0d4b\u0d26\u0d30\u0d3f"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0935\u0940\u0923\u093e \u092d\u0947\u0930\u093f \u0935\u0947\u0923\u0941 \u0935\u093e\u0926\u094d\u092f\u093e\u0926\u093f \u0935\u093f\u0928\u094b\u0926\u093f\u0928\u0940 <br/> \u092e\u094b\u0926\u093f\u0928\u0940 \u0930\u0915\u094d\u0937 \u092e\u093e\u092e\u094d"}, {"M": "\u0938\u092e\u0938\u094d\u0924\u093f \u091a\u0930\u0923\u092e\u094d", "T": "\u0918\u094b\u0923\u0940 \u0935\u0926\u0928\u093e\u0926\u093f \u0935\u093f\u0928\u0941\u0924 \u091a\u0930\u093f\u0924\u0947 <br/> \u0917\u0941\u0923 \u0930\u0939\u093f\u0924\u0947 \u0935\u093f\u0927\u093f \u0917\u0941\u0930\u0941\u0917\u0941\u0939 \u092e\u0939\u093f\u0924\u0947 <br/> \u090f\u0923\u0940 \u0932\u094b\u091a\u0928\u093f \u092a\u093e\u092a \u0935\u093f\u092e\u094b\u091a\u0928\u093f <br/> \u0907\u0928\u094d\u0926\u093f\u0930\u0947\u0936 \u0938\u0939\u094b\u0926\u0930\u093f \u0924\u0932\u094b\u0926\u0930\u093f"}]}], "L": "l", "lyricsref": [{"links": [{"N": "www.medieval.org", "L": "http://www.medieval.org/music/world/carnatic/lyrics/L.Ramakrishnan/vINAbhErI.txt"}, {"N": "guru-guha.blogspot.com", "L": "http://guru-guha.blogspot.com/2008/06/dikshitar-kriti-veena-bheri-raga-abheri.html"}, {"N": "www.karnatik.com", "L": "http://www.karnatik.com/c1726.shtml"}]}]}