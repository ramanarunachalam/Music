baa\u0bcb\u0bb2\u0bcd \u0b87\u0bb0\u0bc1  \u0bb8\u0bcd\u0ba4\u0ba9\u0bae\u0bc1\u0bae\u0bcd-\u0b95\u0bc2\u0b9f <br/> \u0baa\u0bbe\u0b99\u0bcd\u0b95\u0bbf\u0baf\u0bb0\u0bcd\u0b95\u0bb3\u0bcd \u0b87\u0ba9 \u0bae\u0bc1\u0ba8\u0bcd\u0ba4\u0bc1\u0bb0\u0bc8\u0ba4\u0bcd  \u0ba4\u0ba9\u0bae\u0bc1\u0bae\u0bcd <br/> \u0b8e\u0ba3\u0bcd\u0ba3\u0ba4\u0bcd\u0ba4\u0bbe\u0bb2\u0bc1\u0bae\u0bcd \u0bb5\u0ba3\u0bcd\u0ba3\u0ba4\u0bcd\u0ba4\u0bbe\u0bb2\u0bc1\u0bae\u0bcd  \u0baa\u0b99\u0bcd\u0b95\u0baf\u0baa\u0bcd <br/> \u0baa\u0bc6\u0ba3\u0bcd\u0ba3\u0bc8\u0baa\u0bcd \u0baa\u0bcb\u0bb2\u0bcd \u0b95\u0ba3\u0bcd\u0ba3\u0bbf\u0bb1\u0bcd \u0b95\u0bbe\u0ba3\u0bc1\u0bae\u0bcd \u0bae\u0b99\u0bcd\u0b95\u0bc8\u0baf\u0bb0\u0bcd"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd 2", "T": "\u0baa\u0bbe\u0b95\u0bcd\u0b95\u0bbf\u0baf\u0bae\u0bcd \u0b8e\u0ba9\u0bcd\u0baa \u0ba4\u0bbf\u0bb5\u0bb0\u0bcd\u0ba4\u0bc6\u0bb0\u0bbf \u0b9a\u0ba9\u0bae\u0bc7-\u0b85\u0ba4\u0bbf\u0b99\u0bcd\u0b95\u0bc7 <br/> \u0baa\u0bb2\u0bbf\u0ba4\u0bcd\u0ba4\u0ba4\u0bc6\u0ba9\u0bcd\u0ba9 \u0baa\u0bc1\u0ba3\u0bcd\u0ba3\u0bbf\u0baf\u0bae\u0bcb \u0bae\u0ba9\u0bae\u0bc7 <br/> \u0bae\u0bc2\u0b95\u0bcd\u0b95\u0bc1\u0bae\u0bcd \u0bae\u0bc1\u0bb4\u0bbf\u0baf\u0bc1\u0bae\u0bcd \u0ba4\u0bc0\u0bb0\u0bcd\u0b95\u0bcd\u0b95\u0bae\u0bbe\u0baf\u0bcd \u0b87\u0ba9\u0bcd\u0ba9\u0bae\u0bc1\u0bae\u0bcd \u0baa\u0bc6\u0ba3\u0bcd\u0b95\u0bb3\u0bcd <br/> \u0baa\u0bbe\u0bb0\u0bcd\u0b95\u0bcd\u0b95\u0baa\u0bcd \u0baa\u0bbe\u0bb0\u0bcd\u0b95\u0bcd\u0b95 \u0ba8\u0bcb\u0b95\u0bcd\u0b95\u0bae\u0bcd \u0b95\u0bca\u0bb3\u0bcd\u0bb3\u0bc1\u0bae\u0bcb \u0b95\u0ba3\u0bcd\u0b95\u0bb3\u0bcd"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd 3", "T": "\u0b9a\u0ba8\u0bcd\u0ba4\u0bbf\u0bb0 \u0bb5\u0bbf\u0bae\u0bcd\u0baa\u0bae\u0bc1\u0b95   \u0bae\u0bb2\u0bb0\u0bbe\u0bb2\u0bc7-\u0b8e\u0ba9\u0bcd\u0ba9\u0bc8\u0ba4\u0bcd \u0ba4\u0bbe\u0ba9\u0bc7 \u0baa\u0bbe\u0bb0\u0bcd\u0b95\u0bcd\u0b95\u0bbf\u0bb1\u0bbe\u0bb0\u0bcd   \u0b92\u0bb0\u0bc1\u0b95\u0bbe\u0bb2\u0bc7 <br/> \u0b85\u0ba8\u0bcd\u0ba