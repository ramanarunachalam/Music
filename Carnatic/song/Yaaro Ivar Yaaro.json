\u0cb0\u0ccd  \u0c89\u0cb2\u0cbe\u0cb5\u0cc1\u0cae\u0ccd  \u0cae\u0cbf\u0ca4\u0cbf\u0cb2\u0cc8\u0caf\u0cbf\u0cb2\u0ccd <br/> \u0c95\u0ca8\u0ccd\u0ca8\u0cbf \u0cae\u0cbe\u0c9f\u0ca8\u0ccd\u0ca4\u0ca8\u0cbf\u0cb2\u0ccd \u0cae\u0cc1\u0ca8\u0ccd\u0ca8\u0cc7 \u0ca8\u0cbf\u0ca8\u0ccd\u0cb1\u0cb5\u0cb0\u0ccd"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd 1", "T": "\u0caa\u0ca3\u0ccd\u0ca3\u0cbf\u0caa\u0ccd \u0caa\u0ca4\u0cbf\u0ca4\u0ccd\u0ca4\u0cbe\u0cb1\u0ccd \u0caa\u0ccb\u0cb2\u0ccd \u0c87\u0cb0\u0cc1  \u0cb8\u0ccd\u0ca4\u0ca8\u0cae\u0cc1\u0cae\u0ccd-\u0c95\u0cc2\u0c9f <br/> \u0caa\u0cbe\u0c99\u0ccd\u0c95\u0cbf\u0caf\u0cb0\u0ccd\u0c95\u0cb3\u0ccd \u0c87\u0ca8 \u0cae\u0cc1\u0ca8\u0ccd\u0ca4\u0cc1\u0cb0\u0cc8\u0ca4\u0ccd  \u0ca4\u0ca8\u0cae\u0cc1\u0cae\u0ccd <br/> \u0c8e\u0ca3\u0ccd\u0ca3\u0ca4\u0ccd\u0ca4\u0cbe\u0cb2\u0cc1\u0cae\u0ccd \u0cb5\u0ca3\u0ccd\u0ca3\u0ca4\u0ccd\u0ca4\u0cbe\u0cb2\u0cc1\u0cae\u0ccd  \u0caa\u0c99\u0ccd\u0c95\u0caf\u0caa\u0ccd <br/> \u0caa\u0cc6\u0ca3\u0ccd\u0ca3\u0cc8\u0caa\u0ccd \u0caa\u0ccb\u0cb2\u0ccd \u0c95\u0ca3\u0ccd\u0ca3\u0cbf\u0cb1\u0ccd \u0c95\u0cbe\u0ca3\u0cc1\u0cae\u0ccd \u0cae\u0c99\u0ccd\u0c95\u0cc8\u0caf\u0cb0\u0ccd"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd 2", "T": "\u0caa\u0cbe\u0c95\u0ccd\u0c95\u0cbf\u0caf\u0cae\u0ccd \u0c8e\u0ca8\u0ccd\u0caa \u0ca4\u0cbf\u0cb5\u0cb0\u0ccd\u0ca4\u0cc6\u0cb0\u0cbf \u0c9a\u0ca8\u0cae\u0cc7-\u0c85\u0ca4\u0cbf\u0c99\u0ccd\u0c95\u0cc7 <br/> \u0caa\u0cb2\u0cbf\u0ca4\u0ccd\u0ca4\u0ca4\u0cc6\u0ca8\u0ccd\u0ca8 \u0caa\u0cc1\u0ca3\u0ccd\u0ca3\u0cbf\u0caf\u0cae\u0ccb \u0cae\u0ca8\u0cae\u0cc7 <br/> \u0cae\u0cc2\u0c95\u0ccd\u0c95\u0cc1\u0cae\u0ccd \u0cae\u0cc1\u0cb3\u0cbf\u0caf\u0cc1\u0cae\u0ccd \u0ca4\u0cc0\u0cb0\u0ccd\u0c95\u0ccd\u0c95\u0cae\u0cbe\u0caf\u0ccd \u0c87\u0ca8\u0ccd\u0ca8\u0cae\u0cc1\u0cae\u0ccd \u0caa\u0cc6\u0ca3\u0ccd\u0c95\u0cb3\u0ccd <br/> \u0caa\u0cbe\u0cb0\u0ccd\u0c95\u0ccd\u0c95\u0caa\u0ccd \u0caa\u0cbe\u0cb0\u0ccd\u0c95\u0ccd\u0c95 \u0ca8\u0ccb\u0c95\u0ccd\u0c95\u0cae\u0ccd \u0c95\u0cca\u0cb3\u0c