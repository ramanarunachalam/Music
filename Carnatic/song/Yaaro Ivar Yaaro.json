0d23\u0d4d\u0d23\u0d24\u0d4d\u0d24\u0d3e\u0d32\u0d41\u0d2e\u0d4d \u0d35\u0d23\u0d4d\u0d23\u0d24\u0d4d\u0d24\u0d3e\u0d32\u0d41\u0d2e\u0d4d  \u0d2a\u0d19\u0d4d\u0d15\u0d2f\u0d2a\u0d4d <br/> \u0d2a\u0d46\u0d23\u0d4d\u0d23\u0d48\u0d2a\u0d4d \u0d2a\u0d4b\u0d32\u0d4d \u0d15\u0d23\u0d4d\u0d23\u0d3f\u0d31\u0d4d \u0d15\u0d3e\u0d23\u0d41\u0d2e\u0d4d \u0d2e\u0d19\u0d4d\u0d15\u0d48\u0d2f\u0d30\u0d4d"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 2", "T": "\u0d2a\u0d3e\u0d15\u0d4d\u0d15\u0d3f\u0d2f\u0d2e\u0d4d \u0d0e\u0d28\u0d4d\u0d2a \u0d24\u0d3f\u0d35\u0d30\u0d4d\u0d24\u0d46\u0d30\u0d3f \u0d1a\u0d28\u0d2e\u0d47-\u0d05\u0d24\u0d3f\u0d19\u0d4d\u0d15\u0d47 <br/> \u0d2a\u0d32\u0d3f\u0d24\u0d4d\u0d24\u0d24\u0d46\u0d28\u0d4d\u0d28 \u0d2a\u0d41\u0d23\u0d4d\u0d23\u0d3f\u0d2f\u0d2e\u0d4b \u0d2e\u0d28\u0d2e\u0d47 <br/> \u0d2e\u0d42\u0d15\u0d4d\u0d15\u0d41\u0d2e\u0d4d \u0d2e\u0d41\u0d34\u0d3f\u0d2f\u0d41\u0d2e\u0d4d \u0d24\u0d40\u0d30\u0d4d\u0d15\u0d4d\u0d15\u0d2e\u0d3e\u0d2f\u0d4d \u0d07\u0d28\u0d4d\u0d28\u0d2e\u0d41\u0d2e\u0d4d \u0d2a\u0d46\u0d23\u0d4d\u0d15\u0d33\u0d4d <br/> \u0d2a\u0d3e\u0d30\u0d4d\u0d15\u0d4d\u0d15\u0d2a\u0d4d \u0d2a\u0d3e\u0d30\u0d4d\u0d15\u0d4d\u0d15 \u0d28\u0d4b\u0d15\u0d4d\u0d15\u0d2e\u0d4d \u0d15\u0d4a\u0d33\u0d4d\u0d33\u0d41\u0d2e\u0d4b \u0d15\u0d23\u0d4d\u0d15\u0d33\u0d4d"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d 3", "T": "\u0d1a\u0d28\u0d4d\u0d24\u0d3f\u0d30 \u0d35\u0d3f\u0d2e\u0d4d\u0d2a\u0d2e\u0d41\u0d15   \u0d2e\u0d32\u0d30\u0d3e\u0d32\u0d47-\u0d0e\u0d28\u0d4d\u0d28\u0d48\u0d24\u0d4d \u0d24\u0d3e\u0d28\u0d47 \u0d2a\u0d3e\u0d30\u0d4d\u0d15\u0d4d\u0d15\u0d3f\u0d31\u0d3e\u0d30\u0d4d   \u0d12\u0d30\u0d41\u0d15\u0d3e\u0d32\u0d47 <br/> \u0d05\u0d28\u0d4d\u0d24 \u0d28\u0d3e\u0d33\u0d3f\u0d32\u0d4d \u0d24\u0d4a\u0d28\u0d4d\u0d24\u0d2e\u0d4d \u0d2a\u0d4b\u0d32\u0d47 \u0d09\u0d30\u0d41\u0d15\u0d3f\u0d31\u0d3e\u0d30\u0d4d <br/> \u0d07\u0d28\u0d4d\u0d24  \u0d28\u0d3e\u0d33\u0d3f\u0d32\u0d4d  \u0d35\u0d28\u0d4d\u0d24\u0d41  \u0d1a\u0d47\u0d35\u0d48  \u0d24\u0d30\u0d41\u0d15\u0d3f\u0d31\u0d3e\u0d30\u0d4d"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0906\u0930\u094b \u0907\u0935\u0930\u094d \u092f\u093e\u0930\u094b-\u090f\u0928\u094d\u0928  \u092a\u0947\u0930\u094b \u0905\u0930\u093f\u092f\u0947\u0928\u094d          \u0906\u0930\u094b"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0915\u093e\u0930\u094d \u0909\u0932\u093e\u0935\u0941\u092e\u094d  \u091a\u0940\u0930\u094d  \u0909\u0932\u093e\u0935\u0941\u092e\u094d  \u092e\u093f\u0924\u093f\u0932\u0948\u092f\u093f\u0932\u094d <br/> \u0915\u0928\u094d\u0928\u093f \u092e\u093e\u091f\u0928\u094d\u0924\u0928\u093f\u0932\u094d \u092e\u0941\u0928\u094d\u0928\u0947 \u0928\u093f\u0928\u094d\u0930\u0935\u0930\u094d"}, {"M": "\u091a\u0930\u0923\u092e\u094d 1", "T": "\u092a\u0923\u094d\u0923\u093f\u092a\u094d \u092a\u0924\u093f\u0924\u094d\u0924\u093e\u0930\u094d \u092a\u094b\u0932\u094d \u0907\u0930\u0941  \u0938\u094d\u0924\u0928\u092e\u0941\u092e\u094d-\u0915\u0942\u091f <br/> \u092a\u093e\u0919\u094d\u0915\u093f\u092f\u0930\u094d\u0915\u0932\u094d \u0907\u0928 \u092e\u0941\u0928\u094d\u0924\u0941\u0930\u0948\u0924\u094d  \u0924\u0928\u092e\u0941\u092e\u094d <br/> \u090f\u0923\u094d\u0923\u0924\u094d\u0924\u093e\u0932\u0941\u092e\u094d \u0935\u0923\u094d\u0923\u0924\u094d\u0924\u093e\u0932\u0941\u092e\u094d  \u092a\u0919\u094d\u0915\u092f\u092a\u094d <br/> \u092a\u0947\u0923\u094d\u0923\u0948\u092a\u094d \u092a\u094b\u0932\u094d \u0915\u0923\u094d\u0923\u093f\u0930\u094d \u0915\u093e\u0923\u0941\u092e\u094d \u092e\u0919\u094d\u0915\u0948\u092f\u0930\u094d"}, {"M": "\u091a\u0930\u0923\u092e\u094d 2", "T": "\u092a\u093e\u0915\u094d\u0915\u093f\u092f\u092e\u094d \u090f\u0928\u094d\u092a \u0924\u093f\u0935\u0930\u094d\u0924\u0947\u0930\u093f \u091a\u0928\u092e\u0947-\u0905\u0924\u093f\u0919\u094d\u0915\u0947 <br/> \u092a\u0932\u093f\u0924\u094d\u0924\u0924\u0947\u0928\u094d\u0928 \u092a\u0941\u0923\u094d\u0923\u093f\u092f\u092e\u094b \u092e\u0928\u092e\u0947 <br/> \u092e\u0942\u0915\u094d\u0915\u0941\u092e\u094d \u092e\u0941\u0932\u093f\u092f\u0941\u092e\u094d \u0924\u0940\u0930\u094d\u0915\u094d\u0915\u092e\u093e\u092f\u094d \u0907\u0928\u094d\u0928\u092e\u0941\u092e\u094d \u092a\u0947\u0923\u094d\u0915\u0932\u094d <br/> \u092a\u093e\u0930\u094d\u0915\u094d\u0915\u092a\u094d \u092a\u093e\u0930\u094d\u0915\u094d\u0915 \u0928\u094b\u0915\u094d\u0915\u092e\u094d \u0915\u094b\u0932\u094d\u0932\u0941\u092e\u094b \u0915\u0923\u094d\u0915\u0932\u094d"}, {"M": "\u091a\u0930\u0923\u092e\u094d 3", "T": "\u091a\u0928\u094d\u0924\u093f\u0930 \u0935\u093f\u092e\u094d\u092a\u092e\u0941\u0915   \u092e\u0932\u0930\u093e\u0932\u0947-\u090f\u0928\u094d\u0928\u0948\u0924\u094d \u0924\u093e\u0928\u0947 \u092a\u093e\u0930\u094d\u0915\u094d\u0915\u093f\u0930\u093e\u0930\u094d   \u0913\u0930\u0941\u0915\u093e\u0932\u0947 <br/> \u0905\u0928\u094d\u0924 \u0928\u093e\u0932\u093f\u0932\u094d \u0924\u094b\u0928\u094d\u0924\u092e\u094d \u092a\u094b\u0932\u0947 \u0909\u0930\u0941\u0915\u093f\u0930\u093e\u0930\u094d <br/> \u0907\u0928\u094d\u0924  \u0928\u093e\u0932\u093f\u0932\u094d  \u0935\u0928\u094d\u0924\u0941  \u091a\u0947\u0935\u0948  \u0924\u0930\u0941\u0915\u093f\u0930\u093e\u0930\u094d"}]}], "L": "l", "lyricsref": [{"links": [{"N": "periscope-narada.blogspot.com", "L": "http://periscope-narada.blogspot.com/2014/07/yaro-ivar-yaro-critical-review-of.html"}]}]}