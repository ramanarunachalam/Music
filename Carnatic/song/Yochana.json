L": "English", "text": [{"M": "pallavi", "T": "yOcanA kamala lOcana nanu brOva"}, {"M": "anupallavi", "T": "sUcana teliyakanorula <br/> yAcana sEtunanucu nIku <br/> tOcenA dyuti vijitAyuta <br/> virOcana nannu brOvaninka"}, {"M": "caraNam", "T": "kEcana nija bhakta nicaya pApa <br/> vimOcana kala birudulella koni <br/> nannEcanA kruta vipina cara <br/> varAbhishEcana tyAgarAja pUjita"}]}, {"L": "Tamil", "text": [{"M": "\u0baa\u0bb2\u0bcd\u0bb2\u0bb5\u0bbf", "T": "\u0baf\u0bcb\u0b9a\u0ba9\u0bbe \u0b95\u0bae\u0bb2 \u0bb2\u0bcb\u0b9a\u0ba9 \u0ba8\u0ba9\u0bc1 \u0baa\u0bcd\u0bb0\u0bcb\u0bb5"}, {"M": "\u0b85\u0ba9\u0bc1\u0baa\u0bb2\u0bcd\u0bb2\u0bb5\u0bbf", "T": "\u0b9a\u0bc2\u0b9a\u0ba9 \u0ba4\u0bc6\u0bb2\u0bbf\u0baf\u0b95\u0ba9\u0bca\u0bb0\u0bc1\u0bb2 <br/> \u0baf\u0bbe\u0b9a\u0ba9 \u0b9a\u0bc7\u0ba4\u0bc1\u0ba9\u0ba9\u0bc1\u0b9a\u0bc1 \u0ba8\u0bc0\u0b95\u0bc1 <br/> \u0ba4\u0bcb\u0b9a\u0bc6\u0ba9\u0bbe \u0ba4\u0bcd\u0baf\u0bc1\u0ba4\u0bbf \u0bb5\u0bbf\u0b9c\u0bbf\u0ba4\u0bbe\u0baf\u0bc1\u0ba4 <br/> \u0bb5\u0bbf\u0bb0\u0bcb\u0b9a\u0ba9 \u0ba8\u0ba9\u0bcd\u0ba9\u0bc1 \u0baa\u0bcd\u0bb0\u0bcb\u0bb5\u0ba9\u0bbf\u0ba9\u0bcd\u0b95"}, {"M": "\u0b9a\u0bb0\u0ba3\u0bae\u0bcd", "T": "\u0b95\u0bc7\u0b9a\u0ba9 \u0ba8\u0bbf\u0b9c \u0baa\u0b95\u0bcd\u0ba4 \u0ba8\u0bbf\u0b9a\u0baf \u0baa\u0bbe\u0baa <br/> \u0bb5\u0bbf\u0bae\u0bcb\u0b9a\u0ba9 \u0b95\u0bb2 \u0baa\u0bbf\u0bb0\u0bc1\u0ba4\u0bc1\u0bb2\u0bc6\u0bb2\u0bcd\u0bb2 \u0b95\u0bca\u0ba9\u0bbf <br/> \u0ba8\u0ba9\u0bcd\u0ba9\u0bc7\u0b9a\u0ba9\u0bbe \u0b95\u0bcd\u0bb0\u0bc1\u0ba4 \u0bb5\u0bbf\u0baa\u0bbf\u0ba9 \u0b9a\u0bb0 <br/> \u0bb5\u0bb0\u0bbe\u0baa\u0bbf\u0bb7\u0bc7\u0b9a\u0ba9 \u0ba4\u0bcd\u0baf\u0bbe\u0b95\u0bb0\u0bbe\u0b9c \u0baa\u0bc2\u0b9c\u0bbf\u0ba4"}]}, {"L": "Telugu", "text": [{"M": "\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c2f\u0c4b\u0c1a\u0c28\u0c3e \u0c15\u0c2e\u0c32 \u0c32\u0c4b\u0c1a\u0c28 \u0c28\u0c28\u0c41 \u0c2c\u0c4d\u0c30\u0c4b\u0c35"}, {"M": "\u0c05\u0c28\u0c41\u0c2a\u0c32\u0c4d\u0c32\u0c35\u0c3f", "T": "\u0c38\u0c42\u0c1a\u0c28 \u0c24\u0c46\u0c32\u0c3f\u0c2f\u0c15\u0c28\u0c4a\u0c30\u0c41\u0c32 <br/> \u0c2f\u0c3e\u0c1a\u0c28 \u0c38\u0c47\u0c24\u0c41\u0c28\u0c28\u0c41\u0c1a\u0c41 \u0c28\u0c40\u0c15\u0c41 <br/> \u0c24\u0c4b\u0c1a\u0c46\u0c28\u0c3e \u0c26\u0c4d\u0c2f\u0c41\u0c24\u0c3f \u0c35\u0c3f\u0c1c\u0c3f\u0c24\u0c3e\u0c2f\u0c41\u0c24 <br/> \u0c35\u0c3f\u0c30\u0c4b\u0c1a\u0c28 \u0c28\u0c28\u0c4d\u0c28\u0c41 \u0c2c\u0c4d\u0c30\u0c4b\u0c35\u0c28\u0c3f\u0c28\u0c4d\u0c15"}, {"M": "\u0c1a\u0c30\u0c23\u0c2e\u0c4d", "T": "\u0c15\u0c47\u0c1a\u0c28 \u0c28\u0c3f\u0c1c \u0c2d\u0c15\u0c4d\u0c24 \u0c28\u0c3f\u0c1a\u0c2f \u0c2a\u0c3e\u0c2a <br/> \u0c35\u0c3f\u0c2e\u0c4b\u0c1a\u0c28 \u0c15\u0c32 \u0c2c\u0c3f\u0c30\u0c41\u0c26\u0c41\u0c32\u0c46\u0c32\u0c4d\u0c32 \u0c15\u0c4a\u0c28\u0c3f <br/> \u0c28\u0c28\u0c4d\u0c28\u0c47\u0c1a\u0c28\u0c3e \u0c15\u0c43\u0c24 \u0c35\u0c3f\u0c2a\u0c3f\u0c28 \u0c1a\u0c30 <br/> \u0c35\u0c30\u0c3e\u0c2d\u0c3f\u0c37\u0c47\u0c1a\u0c28 \u0c24\u0c4d\u0c2f\u0c3e\u0c17\u0c30\u0c3e\u0c1c \u0c2a\u0c42\u0c1c\u0c3f\u0c24"}]}, {"L": "Kannada", "text": [{"M": "\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0caf\u0ccb\u0c9a\u0ca8\u0cbe \u0c95\u0cae\u0cb2 \u0cb2\u0ccb\u0c9a\u0ca8 \u0ca8\u0ca8\u0cc1 \u0cac\u0ccd\u0cb0\u0ccb\u0cb5"}, {"M": "\u0c85\u0ca8\u0cc1\u0caa\u0cb2\u0ccd\u0cb2\u0cb5\u0cbf", "T": "\u0cb8\u0cc2\u0c9a\u0ca8 \u0ca4\u0cc6\u0cb2\u0cbf\u0caf\u0c95\u0ca8\u0cca\u0cb0\u0cc1\u0cb2 <br/> \u0caf\u0cbe\u0c9a\u0ca8 \u0cb8\u0cc7\u0ca4\u0cc1\u0ca8\u0ca8\u0cc1\u0c9a\u0cc1 \u0ca8\u0cc0\u0c95\u0cc1 <br/> \u0ca4\u0ccb\u0c9a\u0cc6\u0ca8\u0cbe \u0ca6\u0ccd\u0caf\u0cc1\u0ca4\u0cbf \u0cb5\u0cbf\u0c9c\u0cbf\u0ca4\u0cbe\u0caf\u0cc1\u0ca4 <br/> \u0cb5\u0cbf\u0cb0\u0ccb\u0c9a\u0ca8 \u0ca8\u0ca8\u0ccd\u0ca8\u0cc1 \u0cac\u0ccd\u0cb0\u0ccb\u0cb5\u0ca8\u0cbf\u0ca8\u0ccd\u0c95"}, {"M": "\u0c9a\u0cb0\u0ca3\u0cae\u0ccd", "T": "\u0c95\u0cc7\u0c9a\u0ca8 \u0ca8\u0cbf\u0c9c \u0cad\u0c95\u0ccd\u0ca4 \u0ca8\u0cbf\u0c9a\u0caf \u0caa\u0cbe\u0caa <br/> \u0cb5\u0cbf\u0cae\u0ccb\u0c9a\u0ca8 \u0c95\u0cb2 \u0cac\u0cbf\u0cb0\u0cc1\u0ca6\u0cc1\u0cb2\u0cc6\u0cb2\u0ccd\u0cb2 \u0c95\u0cca\u0ca8\u0cbf <br/> \u0ca8\u0ca8\u0ccd\u0ca8\u0cc7\u0c9a\u0ca8\u0cbe \u0c95\u0cc3\u0ca4 \u0cb5\u0cbf\u0caa\u0cbf\u0ca8 \u0c9a\u0cb0 <br/> \u0cb5\u0cb0\u0cbe\u0cad\u0cbf\u0cb7\u0cc7\u0c9a\u0ca8 \u0ca4\u0ccd\u0caf\u0cbe\u0c97\u0cb0\u0cbe\u0c9c \u0caa\u0cc2\u0c9c\u0cbf\u0ca4"}]}, {"L": "Malayalam", "text": [{"M": "\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d2f\u0d4b\u0d1a\u0d28\u0d3e \u0d15\u0d2e\u0d32 \u0d32\u0d4b\u0d1a\u0d28 \u0d28\u0d28\u0d41 \u0d2c\u0d4d\u0d30\u0d4b\u0d35"}, {"M": "\u0d05\u0d28\u0d41\u0d2a\u0d32\u0d4d\u0d32\u0d35\u0d3f", "T": "\u0d38\u0d42\u0d1a\u0d28 \u0d24\u0d46\u0d32\u0d3f\u0d2f\u0d15\u0d28\u0d4a\u0d30\u0d41\u0d32 <br/> \u0d2f\u0d3e\u0d1a\u0d28 \u0d38\u0d47\u0d24\u0d41\u0d28\u0d28\u0d41\u0d1a\u0d41 \u0d28\u0d40\u0d15\u0d41 <br/> \u0d24\u0d4b\u0d1a\u0d46\u0d28\u0d3e \u0d26\u0d4d\u0d2f\u0d41\u0d24\u0d3f \u0d35\u0d3f\u0d1c\u0d3f\u0d24\u0d3e\u0d2f\u0d41\u0d24 <br/> \u0d35\u0d3f\u0d30\u0d4b\u0d1a\u0d28 \u0d28\u0d28\u0d4d\u0d28\u0d41 \u0d2c\u0d4d\u0d30\u0d4b\u0d35\u0d28\u0d3f\u0d28\u0d4d\u0d15"}, {"M": "\u0d1a\u0d30\u0d23\u0d2e\u0d4d", "T": "\u0d15\u0d47\u0d1a\u0d28 \u0d28\u0d3f\u0d1c \u0d2d\u0d15\u0d4d\u0d24 \u0d28\u0d3f\u0d1a\u0d2f \u0d2a\u0d3e\u0d2a <br/> \u0d35\u0d3f\u0d2e\u0d4b\u0d1a\u0d28 \u0d15\u0d32 \u0d2c\u0d3f\u0d30\u0d41\u0d26\u0d41\u0d32\u0d46\u0d32\u0d4d\u0d32 \u0d15\u0d4a\u0d28\u0d3f <br/> \u0d28\u0d28\u0d4d\u0d28\u0d47\u0d1a\u0d28\u0d3e \u0d15\u0d43\u0d24 \u0d35\u0d3f\u0d2a\u0d3f\u0d28 \u0d1a\u0d30 <br/> \u0d35\u0d30\u0d3e\u0d2d\u0d3f\u0d37\u0d47\u0d1a\u0d28 \u0d24\u0d4d\u0d2f\u0d3e\u0d17\u0d30\u0d3e\u0d1c \u0d2a\u0d42\u0d1c\u0d3f\u0d24"}]}, {"L": "Sanskrit", "text": [{"M": "\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u092f\u094b\u091a\u0928\u093e \u0915\u092e\u0932 \u0932\u094b\u091a\u0928 \u0928\u0928\u0941 \u092c\u094d\u0930\u094b\u0935"}, {"M": "\u0905\u0928\u0941\u092a\u0932\u094d\u0932\u0935\u093f", "T": "\u0938\u0942\u091a\u0928 \u0924\u0947\u0932\u093f\u092f\u0915\u0928\u094b\u0930\u0941\u0932 <br/> \u092f\u093e\u091a\u0928 \u0938\u0947\u0924\u0941\u0928\u0928\u0941\u091a\u0941 \u0928\u0940\u0915\u0941 <br/> \u0924\u094b\u091a\u0947\u0928\u093e \u0926\u094d\u092f\u0941\u0924\u093f \u0935\u093f\u091c\u093f\u0924\u093e\u092f\u0941\u0924 <br/> \u0935\u093f\u0930\u094b\u091a\u0928 \u0928\u0928\u094d\u0928\u0941 \u092c\u094d\u0930\u094b\u0935\u0928\u093f\u0928\u094d\u0915"}, {"M": "\u091a\u0930\u0923\u092e\u094d", "T": "\u0915\u0947\u091a\u0928 \u0928\u093f\u091c \u092d\u0915\u094d\u0924 \u0928\u093f\u091a\u092f \u092a\u093e\u092a <br/> \u0935\u093f\u092e\u094b\u091a\u0928 \u0915\u0932 \u092c\u093f\u0930\u0941\u0926\u0941\u0932\u0947\u0932\u094d\u0932 \u0915\u094b\u0928\u093f <br/> \u0928\u0928\u094d\u0928\u0947\u091a\u0928\u093e \u0915\u0943\u0924 \u0935\u093f\u092a\u093f\u0928 \u091a\u0930 <br/> \u0935\u0930\u093e\u092d\u093f\u0937\u0947\u091a\u0928 \u0924\u094d\u092f\u093e\u0917\u0930\u093e\u091c \u092a\u0942\u091c\u093f\u0924"}]}], "L": "l", "lyricsref": [{"links": [{"N": "thyagaraja-vaibhavam.blogspot.com", "L": "http://thyagaraja-vaibhavam.blogspot.com/2007/08/thyagaraja-kriti-yochanaa-kamala-raga.html"}, {"N": "www.karnatik.com", "L": "http://www.karnatik.com/c1064.shtml"}, {"N": "www.sangeetasudha.org", "L": "http://www.sangeetasudha.org/thyagaraja/y.html#MARK_YOCHANA"}]}]}